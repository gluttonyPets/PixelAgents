                                                                                <i class="bi bi-x-lg"></i>
                                                                            </button>
                                                                        </div>
                                                                    }
                                                                }
                                                                <div style="display: flex; align-items: flex-end; gap: 0.3rem; margin-top: 0.3rem; padding-left: 0.5rem;">
                                                                    <input type="text" @bind="_editJ2vNewFieldName" placeholder="nombre del campo"
