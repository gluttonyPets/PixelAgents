@code {
    // ── Module group display ──
    private record ModuleGroup(string Type, string Label, string Icon, List<AiModuleResponse> Modules);

    private static readonly (string Type, string Label, string Icon)[] ModuleTypeOrder =
    [
        ("Text",        "Generacion de texto",   "T"),
        ("Image",       "Generacion de imagen",  "I"),
        ("Audio",       "Generacion de audio",   "A"),
        ("Interaction", "Interaccion",           "C"),
        ("Publish",     "Publicacion",           "P"),
        ("Design",      "Diseno",                "D"),
        ("FileUpload",  "Archivos",              "F"),
        ("StaticText",  "Texto plano",           "T"),
        ("Checkpoint",  "Checkpoint",            "C"),
        ("Orchestrator","Orquestador",           "O"),
        ("Coordinator", "Coordinador",           "K"),
    ];

    private List<ModuleGroup> GetModuleGroups()
    {
        // System modules (Start, StaticText, FileUpload, Checkpoint, Scene, Interaction,
        // Publish) are built-in and managed internally — they do not appear in this page.
        var userModules = _modules
            .Where(m => !m.ProviderType.Equals("System", StringComparison.OrdinalIgnoreCase))
            .ToList();

        // Filtro del buscador: coincide por nombre, proveedor, modelo o tipo (case-insensitive).
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var term = _search.Trim();
            userModules = userModules
                .Where(m =>
                    m.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || m.ProviderType.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || m.ModelName.Contains(term, StringComparison.OrdinalIgnoreCase)
                    || m.ModuleType.Contains(term, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }

        var groups = new List<ModuleGroup>();
        foreach (var (type, label, icon) in ModuleTypeOrder)
        {
            var mods = userModules.Where(m => m.ModuleType == type).ToList();
            if (mods.Count > 0)
                groups.Add(new ModuleGroup(type, label, icon, mods));
        }
        // Any unknown types not in ModuleTypeOrder
        var knownTypes = ModuleTypeOrder.Select(t => t.Type).ToHashSet();
        var others = userModules.Where(m => !knownTypes.Contains(m.ModuleType)).ToList();
        if (others.Count > 0)
            groups.Add(new ModuleGroup("other", "Otros", "?", others));
        return groups;
    }

