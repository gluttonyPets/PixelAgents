                                        <input type="number" min="1" max="30" step="0.5" @bind="_editJ2vImageDuration" />
                                    </div>
                                }
                                else if (m.ModuleType == "Design" && m.ProviderType == "Canva")
                                {
                                    <div class="form-group">
                                        <label>Access Token</label>
