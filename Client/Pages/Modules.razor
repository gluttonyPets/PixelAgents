@page "/modules"
@using Microsoft.AspNetCore.Components.Forms
@inject ApiClient Api

<h2>Modulos IA</h2>

<div class="card">
    <h3>Nuevo Modulo</h3>
    @if (_error is not null)
    {
        <div class="alert alert-error">@_error</div>
    }

    <!-- Step 1: Provider -->
    <div class="form-group">
        <label>Proveedor</label>
        <select value="@_provider" @onchange="OnProviderChanged">
            <option value="">-- Seleccionar proveedor --</option>
            <option value="OpenAI">OpenAI</option>
            <option value="Anthropic">Anthropic</option>
            <option value="Google">Google (Gemini)</option>
            <option value="xAI">xAI (Grok)</option>
            <option value="LeonardoAI">Leonardo AI</option>
            <option value="Canva">Canva</option>
            <option value="Pexels">Pexels (Video gratuito)</option>
            <option value="Json2Video">Json2Video (Edicion de video)</option>
            <option value="System">Sistema (Utilidades)</option>
        </select>
    </div>

    @if (!string.IsNullOrEmpty(_provider))
    {
        <!-- Step 2: Module Type (filtered by provider) -->
        <div class="form-group">
            <label>Tipo de modulo</label>
            <select value="@_moduleType" @onchange="OnModuleTypeChanged">
                <option value="">-- Seleccionar tipo --</option>
                @foreach (var t in GetAvailableTypes())
                {
                    <option value="@t.Value">@t.Label</option>
                }
            </select>
        </div>
    }

    @if (!string.IsNullOrEmpty(_moduleType))
    {
        <!-- Step 3: Model (filtered by provider + type) -->
        <div class="form-group">
            <label>Modelo</label>
            <select value="@_model" @onchange="OnModelChanged">
                <option value="">-- Seleccionar modelo --</option>
                @foreach (var m in GetAvailableModels())
                {
                    <option value="@m.Id">@m.DisplayName</option>
                }
            </select>
            @{ var selectedModel = GetSelectedModel(); }
            @if (selectedModel is not null)
            {
                <div class="model-info">
                    <span class="text-sm text-muted">@selectedModel.Description</span>
                    @if (selectedModel.MaxContext is not null)
                    {
                        <span class="badge badge-info">@selectedModel.MaxContext tokens</span>
                    }
                    @foreach (var cap in selectedModel.Capabilities)
                    {
                        <span class="badge badge-success">@cap</span>
                    }
                </div>
            }
        </div>

        <!-- Name & Description -->
        <div class="form-row">
            <div class="form-group">
                <label>Nombre del modulo</label>
                <input type="text" @bind="_name" placeholder="Ej: GPT-4o para textos" />
            </div>
            <div class="form-group">
                <label>Descripcion</label>
                <input type="text" @bind="_desc" placeholder="Descripcion opcional" />
            </div>
        </div>

        <!-- API Key (filtered by provider) — hidden for System provider -->
        @if (_provider != "System")
        {
            <div class="form-group">
                <label>API Key (@_provider)</label>
                <select @bind="_apiKeyId">
                    <option value="">-- Seleccionar --</option>
                    @foreach (var k in _keys.Where(k => k.ProviderType.Equals(_provider, StringComparison.OrdinalIgnoreCase)))
                    {
                        <option value="@k.Id">@k.Name</option>
                    }
                </select>
                @if (!_keys.Any(k => k.ProviderType.Equals(_provider, StringComparison.OrdinalIgnoreCase)))
                {
                    <span class="text-sm text-muted">No tienes API keys de @_provider. <a href="/apikeys">Crear una</a></span>
                }
            </div>
        }

        <!-- Dynamic Configuration (provider + type specific) -->
        <fieldset class="config-fieldset">
            <legend>Configuracion</legend>

            @if (_moduleType is "Text" or "Orchestrator" or "Coordinator")
            {
                <div class="form-group">
                    <label>System Prompt @(_moduleType == "Orchestrator" ? "(se combina con instrucciones del orquestador)" : _moduleType == "Coordinator" ? "(instrucciones para coordinar las entradas)" : "")</label>
                    <textarea @bind="_systemPrompt" rows="3" placeholder="@(_moduleType == "Coordinator" ? "Ej: Recibiras datos de varias entradas (imagenes, textos). Genera un JSON array de recursos para Json2Video..." : _moduleType == "Orchestrator" ? "Ej: Prioriza videos de stock sobre generacion. Maximo 5 tareas por plan." : "Ej: Eres un asistente experto en...")"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Temperatura <span class="text-sm text-muted">(0.0 - 2.0)</span></label>
                        <input type="number" step="0.1" min="0" max="2" @bind="_temperature" />
                    </div>
                    <div class="form-group">
                        <label>Max Tokens</label>
                        <input type="number" min="1" max="200000" @bind="_maxTokens" />
                    </div>
                </div>
            }
            else if (_moduleType == "Image" && _provider == "OpenAI")
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>Tamano</label>
                        <select @bind="_imageSize">
                            @foreach (var s in GetImageSizes())
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Calidad</label>
                        <select @bind="_imageQuality">
                            <option value="standard">Standard</option>
                            <option value="hd">HD</option>
                        </select>
                    </div>
                </div>
                @if (IsGptImage())
                {
                    <div class="form-group">
                        <label>Numero de imagenes <span class="text-sm text-muted">(1-4)</span></label>
                        <input type="number" min="1" max="4" @bind="_imageCount" />
                    </div>
                }
            }
            else if (_moduleType == "Image" && _provider == "LeonardoAI")
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>Ancho</label>
                        <select @bind="_leoWidth">
                            <option value="512">512</option>
                            <option value="768">768</option>
                            <option value="1024">1024</option>
                            <option value="1360">1360</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Alto</label>
                        <select @bind="_leoHeight">
                            <option value="512">512</option>
                            <option value="768">768</option>
                            <option value="1024">1024</option>
                            <option value="1360">1360</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Estilo</label>
                    <select @bind="_leoPresetStyle">
                        <option value="DYNAMIC">Dynamic</option>
                        <option value="NONE">Ninguno</option>
                        <option value="ANIME">Anime</option>
                        <option value="CINEMATIC">Cinematico</option>
                        <option value="PHOTOGRAPHY">Fotografia</option>
                        <option value="ILLUSTRATION">Ilustracion</option>
                        <option value="RAYTRACED">Raytraced</option>
                    </select>
                </div>
            }
            else if (_moduleType == "Image" && _provider == "Google")
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>Relacion de aspecto</label>
                        <select @bind="_geminiAspectRatio">
                            <option value="1:1">1:1 (Cuadrado)</option>
                            <option value="16:9">16:9 (Paisaje)</option>
                            <option value="9:16">9:16 (Retrato)</option>
                            <option value="4:3">4:3 (Clasico)</option>
                            <option value="3:4">3:4 (Retrato clasico)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Numero de imagenes <span class="text-sm text-muted">(1-4)</span></label>
                        <input type="number" min="1" max="4" @bind="_geminiImageCount" />
                    </div>
                </div>
            }
            else if (_moduleType == "Image" && _provider == "xAI")
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>Numero de imagenes <span class="text-sm text-muted">(1-4)</span></label>
                        <input type="number" min="1" max="4" @bind="_grokImageCount" />
                    </div>
                </div>
            }
            else if (_moduleType == "Video" && _provider == "Google")
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>Relacion de aspecto</label>
                        <select @bind="_videoAspectRatio">
                            <option value="16:9">16:9 (Paisaje)</option>
                            <option value="9:16">9:16 (Retrato)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Duracion (segundos)</label>
                        <select @bind="_videoDuration">
                            @if (_model.Contains("veo-2"))
                            {
                                <option value="5">5s</option>
                                <option value="6">6s</option>
                                <option value="8">8s</option>
                            }
                            else
                            {
                                <option value="4">4s</option>
                                <option value="6">6s</option>
                                <option value="8">8s</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Resolucion</label>
                        <select @bind="_videoResolution">
                            <option value="720p">720p</option>
                            @if (!_model.Contains("veo-2"))
                            {
                                <option value="1080p">1080p</option>
                                <option value="4k">4K</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Generacion de personas</label>
                        <select @bind="_videoPersonGeneration">
                            <option value="allow_adult">Permitir adultos</option>
                            <option value="allow_all">Permitir todos</option>
                            <option value="dont_allow">No permitir</option>
                        </select>
                    </div>
                </div>
            }
            else if (_moduleType == "Video" && _provider == "OpenAI")
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>Resolucion</label>
                        <select @bind="_soraSize">
                            <option value="1280x720">1280x720 (Paisaje 720p)</option>
                            <option value="720x1280">720x1280 (Retrato 720p)</option>
                            @if (_model.Contains("pro"))
                            {
                                <option value="1920x1080">1920x1080 (Paisaje 1080p)</option>
                                <option value="1080x1920">1080x1920 (Retrato 1080p)</option>
                            }
                            <option value="480x480">480x480 (Cuadrado)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Duracion (segundos)</label>
                        <select @bind="_soraDuration">
                            <option value="5">5s</option>
                            <option value="8">8s</option>
                            <option value="10">10s</option>
                            <option value="16">16s</option>
                            <option value="20">20s</option>
                        </select>
                    </div>
                </div>
            }
            else if (_moduleType == "Design" && _provider == "Canva")
            {
                <div class="form-group">
                    <label>Access Token <span class="text-sm text-muted">(OAuth token de Canva Connect API)</span></label>
                    <input type="password" @bind="_canvaAccessToken" placeholder="Token OAuth de Canva" />
                </div>
                <div class="form-group">
                    <label>Formato de exportacion</label>
                    <select @bind="_canvaExportFormat">
                        <option value="png">PNG (imagen)</option>
                        <option value="jpg">JPG (imagen)</option>
                        <option value="pdf">PDF (documento)</option>
                        <option value="pptx">PPTX (presentacion)</option>
                    </select>
                </div>
                @if (_model == "canva-autofill")
                {
                    <div class="form-group">
                        <label>Brand Template ID <span class="text-sm text-muted">(opcional, se puede sobreescribir desde el paso del pipeline)</span></label>
                        <input type="text" @bind="_canvaBrandTemplate" placeholder="Ej: DAVZr1z5464..." />
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label>Tipo de diseno</label>
                        <select @bind="_canvaDesignType">
                            <option value="doc">Documento</option>
                            <option value="presentation">Presentacion</option>
                            <option value="whiteboard">Pizarra</option>
                        </select>
                    </div>
                }
            }
            else if (_moduleType == "VideoSearch" && _provider == "Pexels")
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>Orientacion</label>
                        <select @bind="_pexelsOrientation">
                            <option value="landscape">Paisaje</option>
                            <option value="portrait">Retrato</option>
                            <option value="square">Cuadrado</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Tamano minimo</label>
                        <select @bind="_pexelsSize">
                            <option value="large">Grande (4K)</option>
                            <option value="medium">Medio (Full HD)</option>
                            <option value="small">Pequeno (HD)</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Calidad preferida</label>
                        <select @bind="_pexelsQuality">
                            <option value="hd">HD</option>
                            <option value="sd">SD</option>
                            <option value="uhd">UHD (4K)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Idioma de busqueda</label>
                        <select @bind="_pexelsLocale">
                            <option value="es-ES">Espanol</option>
                            <option value="en-US">Ingles</option>
                            <option value="fr-FR">Frances</option>
                            <option value="de-DE">Aleman</option>
                            <option value="pt-BR">Portugues</option>
                            <option value="it-IT">Italiano</option>
                            <option value="ja-JP">Japones</option>
                            <option value="zh-CN">Chino</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Duracion minima <span class="text-sm text-muted">(segundos, 0 = sin limite)</span></label>
                        <input type="number" min="0" @bind="_pexelsMinDuration" />
                    </div>
                    <div class="form-group">
                        <label>Duracion maxima <span class="text-sm text-muted">(segundos, 0 = sin limite)</span></label>
                        <input type="number" min="0" @bind="_pexelsMaxDuration" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Resultados por pagina <span class="text-sm text-muted">(1-80)</span></label>
                    <input type="number" min="1" max="80" @bind="_pexelsPerPage" />
                </div>
            }
            else if (_moduleType == "VideoEdit" && _provider == "Json2Video")
            {
                <div class="form-group">
                    <label style="display: flex; align-items: center; gap: 0.4rem; cursor: pointer;">
                        <input type="checkbox" @bind="_j2vUseTemplate" /> Usar plantilla
                    </label>
                    <p class="text-sm text-muted" style="margin-top: 0.15rem;">Activa el modo plantilla para enviar variables a un template de Json2Video.</p>
                </div>

                @if (_j2vUseTemplate)
                {
                    <div class="form-group" style="border: 1px solid var(--border); border-radius: 0.5rem; padding: 0.75rem; background: var(--bg-secondary, rgba(255,255,255,0.03));">
                        <label style="font-weight: 600; margin-bottom: 0.25rem;">Variables de plantilla</label>
                        <p class="text-sm text-muted" style="margin-bottom: 0.5rem;">
                            <i class="bi bi-exclamation-triangle" style="color: #ffc107;"></i>
                            El nombre debe coincidir exactamente con la variable del template en Json2Video.
                        </p>

                        @if (_j2vTemplateVars.Count > 0)
                        {
                            @foreach (var tv in _j2vTemplateVars)
                            {
                                var capturedTv = tv;
                                <div style="border: 1px solid var(--border); border-radius: 0.35rem; padding: 0.4rem 0.5rem; margin-bottom: 0.35rem;">
                                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                                        <span style="font-family: monospace; font-size: 0.85rem; flex: 1;">@tv.Name</span>
                                        <span class="badge" style="background: @(tv.Type == "scene" ? "#ff7043" : tv.Type == "file" ? "#607d8b" : "#6c63ff"); color: #fff; padding: 0.1rem 0.4rem; border-radius: 0.25rem; font-size: 0.75rem;">
                                            @(tv.Type == "scene" ? "Escena" : tv.Type == "file" ? "Archivo" : "Texto")
                                        </span>
                                        <button type="button" class="btn-icon" title="Eliminar"
                                                @onclick="() => _j2vTemplateVars.Remove(capturedTv)"
                                                style="color: #f44336; background: none; border: none; cursor: pointer; font-size: 0.9rem;">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                    @if (tv.Type == "scene")
                                    {
                                        <div style="margin-top: 0.35rem; padding-top: 0.35rem; border-top: 1px dashed var(--border);">
                                            <label style="font-size: 0.78rem; font-weight: 600;">Campos de cada escena:</label>
                                            @if (tv.Fields is { Count: > 0 })
                                            {
                                                @foreach (var f in tv.Fields)
                                                {
                                                    var capturedField = f;
                                                    <div style="display: flex; align-items: center; gap: 0.4rem; margin-top: 0.2rem; padding-left: 0.5rem;">
                                                        <span style="font-family: monospace; font-size: 0.8rem; flex: 1;">@f.Name</span>
                                                        <span style="background: @(f.Type == "file" ? "#607d8b" : "#6c63ff"); color: #fff; padding: 0.05rem 0.3rem; border-radius: 0.2rem; font-size: 0.7rem;">
                                                            @(f.Type == "file" ? "Archivo" : "Texto")
                                                        </span>
                                                        <button type="button" title="Eliminar campo"
                                                                @onclick="() => capturedTv.Fields?.Remove(capturedField)"
                                                                style="color: #f44336; background: none; border: none; cursor: pointer; font-size: 0.8rem; padding: 0;">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </div>
                                                }
                                            }
                                            <div style="display: flex; align-items: flex-end; gap: 0.3rem; margin-top: 0.3rem; padding-left: 0.5rem;">
                                                <input type="text" @bind="_j2vNewFieldName" placeholder="nombre del campo"
                                                       style="flex: 2; font-size: 0.8rem; padding: 0.15rem 0.3rem;" />
                                                <select @bind="_j2vNewFieldType" style="flex: 1; font-size: 0.8rem; padding: 0.15rem 0.3rem;">
                                                    <option value="text">Texto</option>
                                                    <option value="file">Archivo</option>
                                                </select>
                                                <button type="button" class="btn btn-sm"
                                                        style="font-size: 0.75rem; padding: 0.15rem 0.4rem;"
                                                        disabled="@string.IsNullOrWhiteSpace(_j2vNewFieldName)"
                                                        @onclick="() => AddJ2vSceneField(capturedTv)">
                                                    <i class="bi bi-plus"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }

                        <div class="form-row" style="align-items: flex-end; gap: 0.5rem;">
                            <div class="form-group" style="flex: 2;">
                                <label>Nombre</label>
                                <input type="text" @bind="_j2vNewVarName" placeholder="ej: titulo, slides..." />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label>Tipo</label>
                                <select @bind="_j2vNewVarType">
                                    <option value="text">Texto</option>
                                    <option value="file">Archivo</option>
                                    <option value="scene">Escena</option>
                                </select>
                            </div>
                            <button type="button" class="btn btn-sm"
                                    style="margin-bottom: 0.25rem; white-space: nowrap;"
                                    disabled="@string.IsNullOrWhiteSpace(_j2vNewVarName)"
                                    @onclick="AddJ2vTemplateVar">
                                <i class="bi bi-plus-lg"></i> Anadir
                            </button>
                        </div>
                    </div>
                }

                <div class="form-row">
                    <div class="form-group">
                        <label>Resolucion</label>
                        <select @bind="_j2vResolution">
                            <option value="full-hd">Full HD (1080p)</option>
                            <option value="hd">HD (720p)</option>
                            <option value="4k">4K</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Modelo de voz</label>
                        <select @bind="_j2vVoiceModel">
                            <option value="azure">Azure (gratis)</option>
                            <option value="elevenlabs">ElevenLabs (premium)</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Nombre de voz <span class="text-sm text-muted">(ej: es-ES-AlvaroNeural, en-US-EmmaMultilingualNeural)</span></label>
                    <input type="text" @bind="_j2vVoiceName" placeholder="es-ES-AlvaroNeural" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Idioma subtitulos</label>
                        <select @bind="_j2vSubtitleLanguage">
                            <option value="es">Espanol</option>
                            <option value="en">Ingles</option>
                            <option value="fr">Frances</option>
                            <option value="de">Aleman</option>
                            <option value="pt">Portugues</option>
                            <option value="it">Italiano</option>
                            <option value="ja">Japones</option>
                            <option value="zh">Chino</option>
                            <option value="auto">Auto-detectar</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Estilo subtitulos</label>
                        <select @bind="_j2vSubtitleStyle">
                            <option value="boxed">Con fondo</option>
                            <option value="classic">Solo texto</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Tamano fuente <span class="text-sm text-muted">(90-150)</span></label>
                        <input type="number" min="90" max="150" @bind="_j2vSubtitleFontSize" />
                    </div>
                    <div class="form-group">
                        <label>Color palabra activa <span class="text-sm text-muted">(hex)</span></label>
                        <input type="text" @bind="_j2vSubtitleWordColor" placeholder="#FFFF00" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label><input type="checkbox" @bind="_j2vEnableVoice" /> Habilitar voz (TTS)</label>
                    </div>
                    <div class="form-group">
                        <label><input type="checkbox" @bind="_j2vEnableSubtitles" /> Habilitar subtitulos</label>
                    </div>
                </div>
                <div class="form-group">
                    <label>Duracion de escenas con imagen (seg)</label>
                    <input type="number" min="1" max="30" step="0.5" @bind="_j2vImageDuration" />
                </div>
            }
            else if (_moduleType == "StaticText")
            {
                <div class="form-group">
                    <label>Contenido de texto</label>
                    <textarea @bind="_staticTextContent" rows="5" placeholder="Escribe aqui el texto que este modulo emitira como salida..."></textarea>
                    <p class="text-sm text-muted" style="margin-top: 0.15rem;">Este texto se usara tal cual como salida del modulo en cada ejecucion.</p>
                </div>
            }
            else if (_moduleType == "Embeddings")
            {
                <div class="form-group">
                    <label>Dimensiones <span class="text-sm text-muted">(opcional, por defecto la maxima del modelo)</span></label>
                    <input type="number" min="1" @bind="_embeddingDimensions" />
                </div>
            }
            else if (_moduleType == "Audio" && _provider == "OpenAI")
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>Voz</label>
                        <select @bind="_ttsVoice">
                            <option value="alloy">Alloy</option>
                            <option value="echo">Echo</option>
                            <option value="fable">Fable</option>
                            <option value="onyx">Onyx</option>
                            <option value="nova">Nova</option>
                            <option value="shimmer">Shimmer</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Velocidad <span class="text-sm text-muted">(0.25 - 4.0)</span></label>
                        <input type="number" step="0.25" min="0.25" max="4.0" @bind="_ttsSpeed" />
                    </div>
                </div>
            }
            else if (_moduleType == "Transcription" && _provider == "OpenAI")
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>Idioma <span class="text-sm text-muted">(codigo ISO 639-1, opcional)</span></label>
                        <input type="text" @bind="_transcriptionLang" placeholder="es, en, fr..." />
                    </div>
                    <div class="form-group">
                        <label>Formato de respuesta</label>
                        <select @bind="_transcriptionFormat">
                            <option value="json">JSON</option>
                            <option value="text">Texto plano</option>
                            <option value="srt">SRT</option>
                            <option value="vtt">VTT</option>
                            <option value="verbose_json">JSON detallado</option>
                        </select>
                    </div>
                </div>
            }
        </fieldset>

        @if (_moduleType is "Text" or "Image" or "Orchestrator" or "FileUpload")
        {
            <div class="form-group">
                <label>Archivos adjuntos <span class="text-sm text-muted">(@(_moduleType == "Image" ? "imagenes de referencia para edicion" : _moduleType == "FileUpload" ? "archivos que se proporcionaran como recurso al pipeline" : "imagenes, documentos, etc."))</span></label>

                @if (_createPendingFiles.Count > 0)
                {
                    <div class="file-list">
                        @foreach (var f in _createPendingFiles)
                        {
                            <div class="file-item">
                                <span class="file-name" title="@f.Name">@f.Name</span>
                                <span class="text-sm text-muted">@FormatFileSize(f.Size)</span>
                                <button class="btn btn-danger btn-sm" style="padding: 0.1rem 0.4rem; font-size: 0.7rem;"
                                        @onclick="() => _createPendingFiles.Remove(f)">x</button>
                            </div>
                        }
                    </div>
                }

                <InputFile OnChange="OnCreateFilesSelected" multiple
                           accept="@(_moduleType == "Image" ? "image/*" : _moduleType == "FileUpload" ? "*/*" : "image/*,.pdf,.txt,.csv,.json,.md,.docx,.xlsx")" />
            </div>
        }

        <button class="btn btn-primary mt-1" @onclick="Create" disabled="@_loading">Crear Modulo</button>
    }
</div>

@if (_modules.Count > 0)
{
    @foreach (var group in GetModuleGroups())
    {
        <div class="module-group" data-type="@group.Type">
            <div class="module-group-header">
                <span class="module-group-icon">@group.Icon</span>
                <h3 class="module-group-title">@group.Label</h3>
                <span class="badge badge-@(group.Type.ToLower()) module-group-count">@group.Modules.Count</span>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Proveedor</th>
                        <th>Modelo</th>
                        <th>API Key</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in group.Modules)
                    {
                <tr>
                    <td>@m.Name</td>
                    <td><span class="badge badge-info">@m.ProviderType</span></td>
                    <td>
                        <select class="select-inline"
                                value="@m.ModelName"
                                @onchange="(e) => ChangeModel(m, e)">
                            @foreach (var model in AllModels.Where(x => x.Provider == m.ProviderType && x.Types.Contains(m.ModuleType)))
                            {
                                <option value="@model.Id">@model.DisplayName</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="select-inline"
                                value="@(m.ApiKeyId?.ToString() ?? "")"
                                @onchange="(e) => ChangeApiKey(m, e)">
                            <option value="">-- Sin API Key --</option>
                            @foreach (var k in _keys.Where(k => k.ProviderType.Equals(m.ProviderType, StringComparison.OrdinalIgnoreCase)))
                            {
                                <option value="@k.Id">@k.Name</option>
                            }
                        </select>
                    </td>
                    <td style="display: flex; gap: 0.25rem;">
                        <button class="btn btn-sm" @onclick="() => ToggleEditConfig(m)">Configurar</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => Delete(m.Id)">Eliminar</button>
                    </td>
                </tr>
                @if (_editingModuleId == m.Id)
                {
                    <tr>
                        <td colspan="5">
                            <div class="card" style="margin: 0.5rem 0;">
                                @if (_editConfigError is not null)
                                {
                                    <div class="alert alert-error">@_editConfigError</div>
                                }
