                                                                        <i class="bi bi-plus"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            }

                                            <div class="form-row" style="align-items: flex-end; gap: 0.5rem;">
                                                <div class="form-group" style="flex: 2;">
                                                    <label>Nombre</label>
                                                    <input type="text" @bind="_editJ2vNewVarName" placeholder="ej: titulo, slides..." />
                                                </div>
                                                <div class="form-group" style="flex: 1;">
                                                    <label>Tipo</label>
                                                    <select @bind="_editJ2vNewVarType">
                                                        <option value="text">Texto</option>
                                                        <option value="file">Archivo</option>
                                                        <option value="scene">Escena</option>
                                                    </select>
                                                </div>
                                                <button type="button" class="btn btn-sm"
                                                        style="margin-bottom: 0.25rem; white-space: nowrap;"
                                                        disabled="@string.IsNullOrWhiteSpace(_editJ2vNewVarName)"
                                                        @onclick="AddEditJ2vTemplateVar">
                                                    <i class="bi bi-plus-lg"></i> Anadir
                                                </button>
                                            </div>
                                        </div>
                                    }

                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Resolucion</label>
                                            <select @bind="_editJ2vResolution">
                                                <option value="full-hd">Full HD (1080p)</option>
                                                <option value="hd">HD (720p)</option>
                                                <option value="4k">4K</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
