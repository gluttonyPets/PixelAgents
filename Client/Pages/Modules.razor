                                                    <div style="border: 1px solid var(--border); border-radius: 0.35rem; padding: 0.4rem 0.5rem; margin-bottom: 0.35rem;">
                                                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                                                            <span style="font-family: monospace; font-size: 0.85rem; flex: 1;">@tv.Name</span>
                                                            <span class="badge" style="background: @(tv.Type == "scene" ? "#ff7043" : tv.Type == "file" ? "#607d8b" : "#6c63ff"); color: #fff; padding: 0.1rem 0.4rem; border-radius: 0.25rem; font-size: 0.75rem;">
                                                                @(tv.Type == "scene" ? "Escena" : tv.Type == "file" ? "Archivo" : "Texto")
                                                            </span>
                                                            <button type="button" class="btn-icon" title="Eliminar"
                                                                    @onclick="() => _editJ2vTemplateVars.Remove(capturedTv)"
