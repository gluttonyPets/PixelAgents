                                                <option value="16:9">16:9 (Paisaje)</option>
                                                <option value="9:16">9:16 (Retrato)</option>
                                                <option value="4:3">4:3 (Clasico)</option>
                                                <option value="3:4">3:4 (Retrato clasico)</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
