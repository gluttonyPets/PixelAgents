                                {
                                    <div class="alert alert-success">Configuracion guardada</div>
                                }

                                @if (m.ModuleType is "Text" or "Coordinator")
                                {
                                    <div class="form-group">
                                        <label>System Prompt</label>
                                        <textarea @bind="_editSystemPrompt" rows="4" placeholder="@(m.ModuleType == "Coordinator" ? "Ej: Recibiras datos de varias entradas. Genera un JSON array de recursos..." : "Ej: Eres un asistente experto en...")"></textarea>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Temperatura <span class="text-sm text-muted">(0.0 - 2.0)</span></label>
                                            <input type="number" step="0.1" min="0" max="2" @bind="_editTemperature" />
                                        </div>
                                        <div class="form-group">
                                            <label>Max Tokens</label>
                                            <input type="number" min="1" max="200000" @bind="_editMaxTokens" />
                                        </div>
                                    </div>
                                }
                                else if (m.ModuleType == "Image" && m.ProviderType == "OpenAI")
                                {
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Tamano</label>
                                            <select @bind="_editImageSize">
                                                @foreach (var s in GetImageSizesForModel(m.ModelName))
                                                {
                                                    <option value="@s">@s</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Calidad</label>
                                            <select @bind="_editImageQuality">
                                                <option value="standard">Standard</option>
                                                <option value="hd">HD</option>
                                            </select>
                                        </div>
                                    </div>
                                }
                                else if (m.ModuleType == "Image" && m.ProviderType == "Google")
