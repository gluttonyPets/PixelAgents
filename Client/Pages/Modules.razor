@page "/modules"
@using Microsoft.AspNetCore.Components.Forms
@inject ApiClient Api

@* Cabecera de página: muestra el título y el botón que abre el modal de creación.
   El formulario de creación ya no ocupa espacio permanente en la página; se abre bajo demanda. *@
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
    <h2 style="margin:0;">Módulos IA</h2>
    @* Al hacer clic se activa el flag _showCreateModal, lo que renderiza el modal overlay *@
    <button class="btn btn-primary" @onclick="() => _showCreateModal = true">
        <i class="bi bi-plus-lg"></i> Nuevo módulo
    </button>
</div>

@* Buscador de módulos: filtra por nombre, proveedor, modelo o tipo en tiempo real.
   Solo se muestra cuando el usuario tiene al menos un módulo creado. *@
@if (_modules.Any(m => !m.ProviderType.Equals("System", StringComparison.OrdinalIgnoreCase)))
{
    <div class="modules-search-wrap">
        <input class="modules-search" type="text" @bind="_search" @bind:event="oninput"
               placeholder="🔍 Buscar por nombre, proveedor o modelo…" />
        @if (!string.IsNullOrEmpty(_search))
        {
            <button class="modules-search-clear" @onclick="ClearSearch" title="Limpiar">&#x2715;</button>
        }
    </div>
}

@* Modal de creación: se renderiza solo cuando _showCreateModal es true.
   El overlay cubre toda la pantalla; hacer clic sobre él cierra el modal (CloseCreateModal).
   @onclick:stopPropagation evita que el clic dentro del contenido propague al overlay y lo cierre. *@
@if (_showCreateModal)
{
    <div class="modal-overlay" @onclick="CloseCreateModal">
        <div class="modal-content" style="max-width:760px; width:95vw;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 style="margin:0; font-size:1.05rem; flex:1;">Nuevo módulo</h3>
                @* Botón X en la cabecera del modal: cierre explícito sin guardar *@
                <button class="btn-icon" @onclick="CloseCreateModal">&#x2715;</button>
            </div>
            @* modal-body admite scroll interno para formularios largos (ver CSS global .modal-body) *@
            <div class="modal-body">
    @if (_error is not null)
    {
        <div class="alert alert-error">@_error</div>
    }

    <!-- Step 1: Provider -->
    <div class="form-group">
        <label>Proveedor</label>
        <select value="@_provider" @onchange="OnProviderChanged">
            <option value="">-- Seleccionar proveedor --</option>
            <option value="OpenAI">OpenAI</option>
            <option value="Anthropic">Anthropic</option>
            <option value="Google">Google (Gemini)</option>
            <option value="xAI">xAI (Grok)</option>
            <option value="LeonardoAI">Leonardo AI</option>
            <option value="Canva">Canva</option>
        </select>
    </div>

    @if (!string.IsNullOrEmpty(_provider))
    {
        <!-- Step 2: Module Type (filtered by provider) -->
        <div class="form-group">
            <label>Tipo de modulo</label>
            <select value="@_moduleType" @onchange="OnModuleTypeChanged">
                <option value="">-- Seleccionar tipo --</option>
                @foreach (var t in GetAvailableTypes())
                {
                    <option value="@t.Value">@t.Label</option>
                }
            </select>
        </div>
    }

    @if (!string.IsNullOrEmpty(_moduleType))
    {
        <!-- Step 3: Model (filtered by provider + type) -->
        <div class="form-group">
            <label>Modelo</label>
            <select value="@_model" @onchange="OnModelChanged">
                <option value="">-- Seleccionar modelo --</option>
                @foreach (var m in GetAvailableModels())
                {
                    <option value="@m.Id">@m.DisplayName</option>
                }
            </select>
            @{ var selectedModel = GetSelectedModel(); }
            @if (selectedModel is not null)
            {
                <div class="model-info">
                    <span class="text-sm text-muted">@selectedModel.Description</span>
                    @if (selectedModel.MaxContext is not null)
                    {
                        <span class="badge badge-info">@selectedModel.MaxContext tokens</span>
                    }
                    @foreach (var cap in selectedModel.Capabilities)
                    {
                        <span class="badge badge-success">@cap</span>
                    }
                </div>
            }
        </div>

        <!-- Name & Description -->
        <div class="form-row">
            <div class="form-group">
                <label>Nombre del modulo</label>
                <input type="text" @bind="_name" placeholder="Ej: GPT-4o para textos" />
            </div>
            <div class="form-group">
                <label>Descripcion</label>
                <input type="text" @bind="_desc" placeholder="Descripcion opcional" />
            </div>
        </div>

        <!-- API Key (filtered by provider) — hidden for System provider -->
        @if (_provider != "System")
        {
            <div class="form-group">
                <label>API Key (@_provider)</label>
                <select @bind="_apiKeyId">
                    <option value="">-- Seleccionar --</option>
                    @foreach (var k in _keys.Where(k => k.ProviderType.Equals(_provider, StringComparison.OrdinalIgnoreCase)))
                    {
                        <option value="@k.Id">@k.Name</option>
                    }
                </select>
                @if (!_keys.Any(k => k.ProviderType.Equals(_provider, StringComparison.OrdinalIgnoreCase)))
                {
                    <span class="text-sm text-muted">No tienes API keys de @_provider. <a href="/apikeys">Crear una</a></span>
                }
            </div>
        }

        <!-- Dynamic Configuration (provider + type specific) -->
        <fieldset class="config-fieldset">
            <legend>Configuracion</legend>

            @if (_moduleType is "Text" or "Orchestrator" or "Coordinator")
            {
                <div class="form-group">
                    <label>System Prompt @(_moduleType == "Orchestrator" ? "(se combina con instrucciones del orquestador)" : _moduleType == "Coordinator" ? "(instrucciones para coordinar las entradas)" : "")</label>
                    <textarea @bind="_systemPrompt" rows="3" placeholder="@(_moduleType == "Coordinator" ? "Ej: Recibiras datos de varias entradas (imagenes, textos). Genera un JSON array de recursos..." : _moduleType == "Orchestrator" ? "Ej: Prioriza videos de stock sobre generacion. Maximo 5 tareas por plan." : "Ej: Eres un asistente experto en...")"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Temperatura <span class="text-sm text-muted">(0.0 - 2.0)</span></label>
                        <input type="number" step="0.1" min="0" max="2" @bind="_temperature" />
                    </div>
                    <div class="form-group">
                        <label>Max Tokens</label>
                        <input type="number" min="1" max="200000" @bind="_maxTokens" />
                    </div>
                </div>
            }
            else if (_moduleType == "Image" && _provider == "OpenAI")
            {
                <div class="form-group">
                    <label>Instrucciones <span class="text-sm text-muted">(se añaden al inicio del prompt)</span></label>
                    <textarea @bind="_systemPrompt" rows="3" placeholder="Ej: Siempre usa un estilo fotorrealista, colores vibrantes y fondo neutro..."></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Tamano</label>
                        <select @bind="_imageSize">
                            @foreach (var s in GetImageSizes())
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Calidad</label>
                        <select @bind="_imageQuality">
                            <option value="standard">Standard</option>
                            <option value="hd">HD</option>
                        </select>
                    </div>
                </div>
                @if (IsGptImage())
                {
                    <div class="form-group">
                        <label>Numero de imagenes <span class="text-sm text-muted">(1-4)</span></label>
                        <input type="number" min="1" max="4" @bind="_imageCount" />
                    </div>
                }
            }
            else if (_moduleType == "Image" && _provider == "LeonardoAI")
            {
                <div class="form-group">
                    <label>Instrucciones <span class="text-sm text-muted">(se añaden al inicio del prompt)</span></label>
                    <textarea @bind="_systemPrompt" rows="3" placeholder="Ej: Siempre usa un estilo fotorrealista, colores vibrantes y fondo neutro..."></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Ancho</label>
                        <select @bind="_leoWidth">
                            <option value="512">512</option>
                            <option value="768">768</option>
                            <option value="1024">1024</option>
                            <option value="1360">1360</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Alto</label>
                        <select @bind="_leoHeight">
                            <option value="512">512</option>
                            <option value="768">768</option>
                            <option value="1024">1024</option>
                            <option value="1360">1360</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Estilo</label>
                    <select @bind="_leoPresetStyle">
                        <option value="DYNAMIC">Dynamic</option>
                        <option value="NONE">Ninguno</option>
                        <option value="ANIME">Anime</option>
                        <option value="CINEMATIC">Cinematico</option>
                        <option value="PHOTOGRAPHY">Fotografia</option>
                        <option value="ILLUSTRATION">Ilustracion</option>
                        <option value="RAYTRACED">Raytraced</option>
                    </select>
                </div>
            }
            else if (_moduleType == "Image" && _provider == "Google")
            {
                <div class="form-group">
                    <label>Instrucciones <span class="text-sm text-muted">(se añaden al inicio del prompt)</span></label>
                    <textarea @bind="_systemPrompt" rows="3" placeholder="Ej: Siempre usa un estilo fotorrealista, colores vibrantes y fondo neutro..."></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Relacion de aspecto</label>
                        <select @bind="_geminiAspectRatio">
                            <option value="1:1">1:1 (Cuadrado)</option>
                            <option value="16:9">16:9 (Paisaje)</option>
                            <option value="9:16">9:16 (Retrato)</option>
                            <option value="4:3">4:3 (Clasico)</option>
                            <option value="3:4">3:4 (Retrato clasico)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Numero de imagenes <span class="text-sm text-muted">(1-4)</span></label>
                        <input type="number" min="1" max="4" @bind="_geminiImageCount" />
                    </div>
                </div>
            }
            else if (_moduleType == "Image" && _provider == "xAI")
            {
                <div class="form-group">
                    <label>Instrucciones <span class="text-sm text-muted">(se añaden al inicio del prompt)</span></label>
                    <textarea @bind="_systemPrompt" rows="3" placeholder="Ej: Siempre usa un estilo fotorrealista, colores vibrantes y fondo neutro..."></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Numero de imagenes <span class="text-sm text-muted">(1-4)</span></label>
                        <input type="number" min="1" max="4" @bind="_grokImageCount" />
                    </div>
                </div>
            }
            else if (_moduleType == "Design" && _provider == "Canva")
            {
                <div class="form-group">
                    <label>Access Token <span class="text-sm text-muted">(OAuth token de Canva Connect API)</span></label>
                    <input type="password" @bind="_canvaAccessToken" placeholder="Token OAuth de Canva" />
                </div>
                <div class="form-group">
                    <label>Formato de exportacion</label>
                    <select @bind="_canvaExportFormat">
                        <option value="png">PNG (imagen)</option>
                        <option value="jpg">JPG (imagen)</option>
                        <option value="pdf">PDF (documento)</option>
                        <option value="pptx">PPTX (presentacion)</option>
                    </select>
                </div>
                @if (_model == "canva-autofill")
                {
                    <div class="form-group">
                        <label>Brand Template ID <span class="text-sm text-muted">(opcional, se puede sobreescribir desde el paso del pipeline)</span></label>
                        <input type="text" @bind="_canvaBrandTemplate" placeholder="Ej: DAVZr1z5464..." />
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label>Tipo de diseno</label>
                        <select @bind="_canvaDesignType">
                            <option value="doc">Documento</option>
                            <option value="presentation">Presentacion</option>
                            <option value="whiteboard">Pizarra</option>
                        </select>
                    </div>
                }
            }
            else if (_moduleType == "StaticText")
            {
                <div class="form-group">
                    <label>Contenido de texto</label>
                    <textarea @bind="_staticTextContent" rows="5" placeholder="Escribe aqui el texto que este modulo emitira como salida..."></textarea>
                    <p class="text-sm text-muted" style="margin-top: 0.15rem;">Este texto se usara tal cual como salida del modulo en cada ejecucion.</p>
                </div>
            }
            else if (_moduleType == "Embeddings")
            {
                <div class="form-group">
                    <label>Dimensiones <span class="text-sm text-muted">(opcional, por defecto la maxima del modelo)</span></label>
                    <input type="number" min="1" @bind="_embeddingDimensions" />
                </div>
            }
            else if (_moduleType == "Audio" && _provider == "OpenAI")
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>Voz</label>
                        <select @bind="_ttsVoice">
                            <option value="alloy">Alloy</option>
                            <option value="echo">Echo</option>
                            <option value="fable">Fable</option>
                            <option value="onyx">Onyx</option>
                            <option value="nova">Nova</option>
                            <option value="shimmer">Shimmer</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Velocidad <span class="text-sm text-muted">(0.25 - 4.0)</span></label>
                        <input type="number" step="0.25" min="0.25" max="4.0" @bind="_ttsSpeed" />
                    </div>
                </div>
            }
            else if (_moduleType == "Transcription" && _provider == "OpenAI")
            {
                <div class="form-row">
                    <div class="form-group">
                        <label>Idioma <span class="text-sm text-muted">(codigo ISO 639-1, opcional)</span></label>
                        <input type="text" @bind="_transcriptionLang" placeholder="es, en, fr..." />
                    </div>
                    <div class="form-group">
                        <label>Formato de respuesta</label>
                        <select @bind="_transcriptionFormat">
                            <option value="json">JSON</option>
                            <option value="text">Texto plano</option>
                            <option value="srt">SRT</option>
                            <option value="vtt">VTT</option>
                            <option value="verbose_json">JSON detallado</option>
                        </select>
                    </div>
                </div>
            }
        </fieldset>

        @if (_moduleType == "FileUpload")
        {
            <div class="form-group">
                <p class="text-sm text-muted">
                    Los archivos no se cargan en el catalogo. Cada instancia del modulo
                    dentro de un proyecto guarda sus propios archivos: subelos desde el
                    editor del proyecto.
                </p>
            </div>
        }

        <button class="btn btn-primary mt-1" @onclick="Create" disabled="@_loading">Crear Modulo</button>
    }
            </div>
        </div>
    </div>
}

@if (_modules.Count > 0)
{
    var _groups = GetModuleGroups();
    if (_groups.Count == 0 && !string.IsNullOrWhiteSpace(_search))
    {
        @* Sin coincidencias para el término de búsqueda actual *@
        <div style="text-align:center; padding:2.5rem 1rem; color:var(--text-muted, #888);">
            <div style="font-size:2rem; margin-bottom:0.5rem;"><i class="bi bi-search"></i></div>
            <p style="font-size:0.95rem; margin-bottom:0.75rem;">No hay módulos que coincidan con «@_search».</p>
            <button class="btn btn-sm" @onclick="ClearSearch">Limpiar búsqueda</button>
        </div>
    }
    @foreach (var group in _groups)
    {
        <div class="module-group" data-type="@group.Type">
            <div class="module-group-header">
                <span class="module-group-icon">@group.Icon</span>
                <h3 class="module-group-title">@group.Label</h3>
                <span class="badge badge-@(group.Type.ToLower()) module-group-count">@group.Modules.Count</span>
            </div>
            <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Proveedor</th>
                        <th>Modelo</th>
                        <th>API Key</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in group.Modules)
                    {
                <tr>
                    <td>@m.Name</td>
                    <td>
                        <span class="badge @GetModuleProviderBadgeClass(m.ProviderType)">
                            <ProviderIcon Provider="@m.ProviderType" Size="13" />&nbsp;@m.ProviderType
                        </span>
                    </td>
                    <td>
                        @if (m.ProviderType == "System")
                        {
                            <span class="text-muted">@m.ModelName</span>
                        }
                        else
                        {
                            <select class="select-inline"
                                    value="@m.ModelName"
                                    @onchange="(e) => ChangeModel(m, e)">
                                @foreach (var model in AllModels.Where(x => x.Provider == m.ProviderType && x.Types.Contains(m.ModuleType)))
                                {
                                    <option value="@model.Id">@model.DisplayName</option>
                                }
                            </select>
                        }
                    </td>
                    <td>
                        @if (m.ProviderType == "System")
                        {
                            <span class="text-muted">No aplica</span>
                        }
                        else
                        {
                            <select class="select-inline"
                                    value="@(m.ApiKeyId?.ToString() ?? "")"
                                    @onchange="(e) => ChangeApiKey(m, e)">
                                <option value="">-- Sin API Key --</option>
                                @foreach (var k in _keys.Where(k => k.ProviderType.Equals(m.ProviderType, StringComparison.OrdinalIgnoreCase)))
                                {
                                    <option value="@k.Id">@k.Name</option>
                                }
                            </select>
                        }
                    </td>
                    <td class="cell-actions">
                        <button class="btn btn-sm" @onclick="() => ToggleEditConfig(m)">Configurar</button>
                        @if (IsBuiltInSystemModule(m))
                        {
                            <span class="text-muted" style="align-self: center; font-size: 0.8rem;">Integrado</span>
                        }
                        else
                        {
                            <button class="btn btn-danger btn-sm" @onclick="() => Delete(m.Id)">Eliminar</button>
                        }
                    </td>
                </tr>
                @if (_editingModuleId == m.Id)
                {
                    <tr>
                        <td colspan="5">
                            <div class="card" style="margin: 0.5rem 0;">
                                @if (_editConfigError is not null)
                                {
                                    <div class="alert alert-error">@_editConfigError</div>
                                }
                                @if (_editConfigSuccess)
                                {
                                    <div class="alert alert-success">Configuracion guardada</div>
                                }

                                @if (m.ModuleType is "Text" or "Coordinator" or "Orchestrator")
                                {
                                    <div class="form-group">
                                        <label>System Prompt</label>
                                        <textarea @bind="_editSystemPrompt" rows="4" placeholder="@(m.ModuleType == "Coordinator" ? "Ej: Recibiras datos de varias entradas. Genera un JSON array de recursos..." : m.ModuleType == "Orchestrator" ? "Ej: Prioriza videos de stock sobre generacion. Maximo 5 tareas por plan." : "Ej: Eres un asistente experto en...")"></textarea>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Temperatura <span class="text-sm text-muted">(0.0 - 2.0)</span></label>
                                            <input type="number" step="0.1" min="0" max="2" @bind="_editTemperature" />
                                        </div>
                                        <div class="form-group">
                                            <label>Max Tokens</label>
                                            <input type="number" min="1" max="200000" @bind="_editMaxTokens" />
                                        </div>
                                    </div>
                                }
                                else if (m.ModuleType == "Image" && m.ProviderType == "OpenAI")
                                {
                                    <div class="form-group">
                                        <label>Instrucciones <span class="text-sm text-muted">(se añaden al inicio del prompt)</span></label>
                                        <textarea @bind="_editSystemPrompt" rows="3" placeholder="Ej: Siempre usa un estilo fotorrealista, colores vibrantes y fondo neutro..."></textarea>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Tamano</label>
                                            <select @bind="_editImageSize">
                                                @foreach (var s in GetImageSizesForModel(m.ModelName))
                                                {
                                                    <option value="@s">@s</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Calidad</label>
                                            <select @bind="_editImageQuality">
                                                <option value="standard">Standard</option>
                                                <option value="hd">HD</option>
                                            </select>
                                        </div>
                                    </div>
                                }
                                else if (m.ModuleType == "Image" && m.ProviderType == "Google")
                                {
                                    <div class="form-group">
                                        <label>Instrucciones <span class="text-sm text-muted">(se añaden al inicio del prompt)</span></label>
                                        <textarea @bind="_editSystemPrompt" rows="3" placeholder="Ej: Siempre usa un estilo fotorrealista, colores vibrantes y fondo neutro..."></textarea>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Relacion de aspecto</label>
                                            <select @bind="_editGeminiAspectRatio">
                                                <option value="1:1">1:1 (Cuadrado)</option>
                                                <option value="16:9">16:9 (Paisaje)</option>
                                                <option value="9:16">9:16 (Retrato)</option>
                                                <option value="4:3">4:3 (Clasico)</option>
                                                <option value="3:4">3:4 (Retrato clasico)</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Numero de imagenes <span class="text-sm text-muted">(1-4)</span></label>
                                            <input type="number" min="1" max="4" @bind="_editGeminiImageCount" />
                                        </div>
                                    </div>
                                }
                                else if (m.ModuleType == "Image" && m.ProviderType == "xAI")
                                {
                                    <div class="form-group">
                                        <label>Instrucciones <span class="text-sm text-muted">(se añaden al inicio del prompt)</span></label>
                                        <textarea @bind="_editSystemPrompt" rows="3" placeholder="Ej: Siempre usa un estilo fotorrealista, colores vibrantes y fondo neutro..."></textarea>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Numero de imagenes <span class="text-sm text-muted">(1-4)</span></label>
                                            <input type="number" min="1" max="4" @bind="_editGrokImageCount" />
                                        </div>
                                    </div>
                                }
                                else if (m.ModuleType == "Image" && m.ProviderType == "LeonardoAI")
                                {
                                    <div class="form-group">
                                        <label>Instrucciones <span class="text-sm text-muted">(se añaden al inicio del prompt)</span></label>
                                        <textarea @bind="_editSystemPrompt" rows="3" placeholder="Ej: Siempre usa un estilo fotorrealista, colores vibrantes y fondo neutro..."></textarea>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Ancho</label>
                                            <select @bind="_editLeoWidth">
                                                <option value="512">512</option>
                                                <option value="768">768</option>
                                                <option value="1024">1024</option>
                                                <option value="1360">1360</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Alto</label>
                                            <select @bind="_editLeoHeight">
                                                <option value="512">512</option>
                                                <option value="768">768</option>
                                                <option value="1024">1024</option>
                                                <option value="1360">1360</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label>Estilo</label>
                                        <select @bind="_editLeoPresetStyle">
                                            <option value="DYNAMIC">Dynamic</option>
                                            <option value="NONE">Ninguno</option>
                                            <option value="ANIME">Anime</option>
                                            <option value="CINEMATIC">Cinematico</option>
                                            <option value="PHOTOGRAPHY">Fotografia</option>
                                            <option value="ILLUSTRATION">Ilustracion</option>
                                            <option value="RAYTRACED">Raytraced</option>
                                        </select>
                                    </div>
                                }
                                else if (m.ModuleType == "Audio" && m.ProviderType == "OpenAI")
                                {
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Voz</label>
                                            <select @bind="_editTtsVoice">
                                                <option value="alloy">Alloy</option>
                                                <option value="echo">Echo</option>
                                                <option value="fable">Fable</option>
                                                <option value="onyx">Onyx</option>
                                                <option value="nova">Nova</option>
                                                <option value="shimmer">Shimmer</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Velocidad <span class="text-sm text-muted">(0.25 - 4.0)</span></label>
                                            <input type="number" step="0.25" min="0.25" max="4.0" @bind="_editTtsSpeed" />
                                        </div>
                                    </div>
                                }
                                else if (m.ModuleType == "Design" && m.ProviderType == "Canva")
                                {
                                    <div class="form-group">
                                        <label>Access Token</label>
                                        <input type="password" @bind="_editCanvaAccessToken" placeholder="Token OAuth de Canva" />
                                    </div>
                                    <div class="form-group">
                                        <label>Formato de exportacion</label>
                                        <select @bind="_editCanvaExportFormat">
                                            <option value="png">PNG (imagen)</option>
                                            <option value="jpg">JPG (imagen)</option>
                                            <option value="pdf">PDF (documento)</option>
                                            <option value="pptx">PPTX (presentacion)</option>
                                        </select>
                                    </div>
                                    @if (m.ModelName == "canva-autofill")
                                    {
                                        <div class="form-group">
                                            <label>Brand Template ID</label>
                                            <input type="text" @bind="_editCanvaBrandTemplate" placeholder="Ej: DAVZr1z5464..." />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="form-group">
                                            <label>Tipo de diseno</label>
                                            <select @bind="_editCanvaDesignType">
                                                <option value="doc">Documento</option>
                                                <option value="presentation">Presentacion</option>
                                                <option value="whiteboard">Pizarra</option>
                                            </select>
                                        </div>
                                    }
                                }
                                else if (m.ModuleType == "StaticText")
                                {
                                    <div class="form-group">
                                        <label>Contenido de texto</label>
                                        <textarea @bind="_editStaticTextContent" rows="5" placeholder="Texto que este modulo emitira como salida..."></textarea>
                                        <p class="text-sm text-muted" style="margin-top: 0.15rem;">Este texto se usara tal cual como salida del modulo.</p>
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">Este tipo de modulo no tiene configuracion editable.</p>
                                }

                                @* Los archivos viven en cada instancia ProjectModule del proyecto,
                                   no en el catalogo. Se gestionan desde el editor de cada proyecto. *@

                                @if (m.ModuleType is "Text" or "Image" or "Audio" or "Design")
                                {
                                    <button class="btn btn-primary btn-sm" @onclick="() => SaveConfig(m)" disabled="@_editConfigSaving">
                                        @(_editConfigSaving ? "Guardando..." : "Guardar")
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                    }
                </tbody>
            </table>
            </div>
        </div>
    }
}
else
