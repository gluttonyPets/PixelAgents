                                    </div>
                                    @if (m.ModelName == "canva-autofill")
                                    {
                                        <div class="form-group">
                                            <label>Brand Template ID</label>
                                            <input type="text" @bind="_editCanvaBrandTemplate" placeholder="Ej: DAVZr1z5464..." />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="form-group">
                                            <label>Tipo de diseno</label>
                                            <select @bind="_editCanvaDesignType">
                                                <option value="doc">Documento</option>
                                                <option value="presentation">Presentacion</option>
                                                <option value="whiteboard">Pizarra</option>
                                            </select>
                                        </div>
                                    }
                                }
                                else if (m.ModuleType == "StaticText")
                                {
                                    <div class="form-group">
                                        <label>Contenido de texto</label>
                                        <textarea @bind="_editStaticTextContent" rows="5" placeholder="Texto que este modulo emitira como salida..."></textarea>
                                        <p class="text-sm text-muted" style="margin-top: 0.15rem;">Este texto se usara tal cual como salida del modulo.</p>
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">Este tipo de modulo no tiene configuracion editable.</p>
                                }

                                @* ── File attachments ── *@
                                @if (m.ModuleType is "Text" or "Image" or "FileUpload")
                                {
                                    <hr style="margin: 0.75rem 0; border-color: var(--border);" />
                                    <div class="form-group">
                                        <label>Archivos adjuntos <span class="text-sm text-muted">(@(m.ModuleType == "Image" ? "imagenes de referencia para edicion" : m.ModuleType == "FileUpload" ? "archivos recurso del modulo" : "imagenes, documentos, etc."))</span></label>

                                        @if (_editModuleFiles.Count > 0)
                                        {
                                            <div class="file-list">
                                                @foreach (var f in _editModuleFiles)
                                                {
                                                    <div class="file-item">
                                                        <span class="file-name" title="@f.FileName">@f.FileName</span>
                                                        <span class="text-sm text-muted">@FormatFileSize(f.FileSize)</span>
                                                        <button class="btn btn-danger btn-sm" style="padding: 0.1rem 0.4rem; font-size: 0.7rem;"
                                                                @onclick="() => DeleteModuleFile(f.Id, m.Id)">x</button>
                                                    </div>
                                                }
                                            </div>
                                        }

                                        <InputFile OnChange="OnModuleFilesSelected" multiple
                                                   accept="@(m.ModuleType == "Image" ? "image/*" : m.ModuleType == "FileUpload" ? "*/*" : "image/*,.pdf,.txt,.csv,.json,.md,.docx,.xlsx")" />

                                        @if (_fileUploadError is not null)
                                        {
                                            <div class="alert alert-error" style="margin-top: 0.3rem;">@_fileUploadError</div>
                                        }

                                        @if (_uploadingFiles)
                                        {
                                            <p class="text-muted" style="margin-top: 0.3rem;">Subiendo archivos...</p>
                                        }
                                    </div>
                                }

                                @if (m.ModuleType is "Text" or "Image" or "Audio" or "Video" or "Design" or "VideoSearch")
                                {
                                    <button class="btn btn-primary btn-sm" @onclick="() => SaveConfig(m)" disabled="@_editConfigSaving">
                                        @(_editConfigSaving ? "Guardando..." : "Guardar")
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                    }
                </tbody>
            </table>
        </div>
    }
}
else if (!_loading)
{
    <p class="text-muted">No hay modulos creados.</p>
}

