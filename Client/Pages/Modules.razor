    {
        _systemPrompt = "";
        _temperature = 0.7;
        _maxTokens = 4096;
        _imageSize = "1024x1024";
        _imageQuality = "standard";
        _imageCount = 1;
        _embeddingDimensions = null;
        _leoWidth = 1024;
        _leoHeight = 1024;
        _leoPresetStyle = "DYNAMIC";
        _geminiAspectRatio = "1:1";
        _geminiImageCount = 1;
        _grokImageCount = 1;
        _ttsVoice = "alloy";
        _ttsSpeed = 1.0;
        _transcriptionLang = "";
        _transcriptionFormat = "json";
        _canvaAccessToken = "";
        _canvaExportFormat = "png";
        _canvaBrandTemplate = "";
        _canvaDesignType = "doc";
        _staticTextContent = "";
