    // ── Build config JSON ──
    private string? BuildConfigJson()
    {
        var parts = new List<string>();

        if (_moduleType is "Text" or "Orchestrator" or "Coordinator")
        {
            if (!string.IsNullOrWhiteSpace(_systemPrompt))
                parts.Add($"\"systemPrompt\":{System.Text.Json.JsonSerializer.Serialize(_systemPrompt)}");
            if (_temperature != 0.7)
                parts.Add($"\"temperature\":{_temperature}");
            if (_maxTokens != 4096)
                parts.Add($"\"maxTokens\":{_maxTokens}");
        }
        else if (_moduleType == "Image" && _provider == "Google")
        {
            if (_geminiAspectRatio != "1:1")
                parts.Add($"\"aspectRatio\":\"{_geminiAspectRatio}\"");
            if (_geminiImageCount != 1)
                parts.Add($"\"numberOfImages\":{_geminiImageCount}");
        }
        else if (_moduleType == "Image" && _provider == "xAI")
        {
            if (_grokImageCount != 1)
                parts.Add($"\"n\":{_grokImageCount}");
        }
        else if (_moduleType == "Image" && _provider == "LeonardoAI")
        {
            if (_leoWidth != 1024)
                parts.Add($"\"width\":{_leoWidth}");
            if (_leoHeight != 1024)
                parts.Add($"\"height\":{_leoHeight}");
            if (_leoPresetStyle != "DYNAMIC")
                parts.Add($"\"presetStyle\":\"{_leoPresetStyle}\"");
        }
        else if (_moduleType == "Image")
        {
            if (_imageSize != "1024x1024")
                parts.Add($"\"size\":\"{_imageSize}\"");
            if (_imageQuality != "standard")
                parts.Add($"\"quality\":\"{_imageQuality}\"");
            if (IsGptImage() && _imageCount != 1)
                parts.Add($"\"n\":{_imageCount}");
        }
        else if (_moduleType == "Video" && _provider == "Google")
        {
            if (_videoAspectRatio != "16:9")
                parts.Add($"\"aspectRatio\":\"{_videoAspectRatio}\"");
            if (_videoDuration != "8")
                parts.Add($"\"duration\":\"{_videoDuration}\"");
            if (_videoResolution != "720p")
                parts.Add($"\"resolution\":\"{_videoResolution}\"");
            if (_videoPersonGeneration != "allow_adult")
                parts.Add($"\"personGeneration\":\"{_videoPersonGeneration}\"");
        }
        else if (_moduleType == "Video" && _provider == "OpenAI")
        {
            if (_soraSize != "1280x720")
                parts.Add($"\"size\":\"{_soraSize}\"");
            if (_soraDuration != "8")
                parts.Add($"\"duration\":\"{_soraDuration}\"");
        }
        else if (_moduleType == "StaticText")
        {
            if (!string.IsNullOrWhiteSpace(_staticTextContent))
                parts.Add($"\"content\":{System.Text.Json.JsonSerializer.Serialize(_staticTextContent)}");
        }
        else if (_moduleType == "Embeddings")
        {
            if (_embeddingDimensions.HasValue)
                parts.Add($"\"dimensions\":{_embeddingDimensions.Value}");
        }
        else if (_moduleType == "Audio")
        {
            parts.Add($"\"voice\":\"{_ttsVoice}\"");
            if (_ttsSpeed != 1.0)
                parts.Add($"\"speed\":{_ttsSpeed}");
        }
        else if (_moduleType == "Transcription")
        {
            if (!string.IsNullOrWhiteSpace(_transcriptionLang))
                parts.Add($"\"language\":\"{_transcriptionLang}\"");
            if (_transcriptionFormat != "json")
                parts.Add($"\"response_format\":\"{_transcriptionFormat}\"");
        }
        else if (_moduleType == "Design" && _provider == "Canva")
        {
            if (!string.IsNullOrWhiteSpace(_canvaAccessToken))
                parts.Add($"\"accessToken\":{System.Text.Json.JsonSerializer.Serialize(_canvaAccessToken)}");
            if (_canvaExportFormat != "png")
                parts.Add($"\"exportFormat\":\"{_canvaExportFormat}\"");
            if (!string.IsNullOrWhiteSpace(_canvaBrandTemplate))
                parts.Add($"\"brandTemplateId\":{System.Text.Json.JsonSerializer.Serialize(_canvaBrandTemplate)}");
            if (_canvaDesignType != "doc")
                parts.Add($"\"designType\":\"{_canvaDesignType}\"");
        }
        else if (_moduleType == "VideoSearch" && _provider == "Pexels")
        {
            if (_pexelsOrientation != "landscape")
                parts.Add($"\"orientation\":\"{_pexelsOrientation}\"");
            if (_pexelsSize != "medium")
                parts.Add($"\"size\":\"{_pexelsSize}\"");
            if (_pexelsQuality != "hd")
                parts.Add($"\"preferredQuality\":\"{_pexelsQuality}\"");
            if (_pexelsLocale != "es-ES")
                parts.Add($"\"locale\":\"{_pexelsLocale}\"");
            if (_pexelsMinDuration > 0)
                parts.Add($"\"minDuration\":{_pexelsMinDuration}");
            if (_pexelsMaxDuration > 0)
                parts.Add($"\"maxDuration\":{_pexelsMaxDuration}");
            if (_pexelsPerPage != 15)
                parts.Add($"\"perPage\":{_pexelsPerPage}");
        }
        else if (_moduleType == "VideoEdit" && _provider == "Json2Video")
        {
            if (_j2vUseTemplate)
            {
                parts.Add("\"useTemplate\":true");
                if (_j2vTemplateVars.Count > 0)
                    parts.Add($"\"templateVars\":{System.Text.Json.JsonSerializer.Serialize(_j2vTemplateVars)}");
            }
            if (_j2vResolution != "full-hd")
                parts.Add($"\"resolution\":\"{_j2vResolution}\"");
            if (!_j2vEnableVoice)
                parts.Add("\"enableVoice\":false");
            if (!_j2vEnableSubtitles)
                parts.Add("\"enableSubtitles\":false");
            if (_j2vVoiceModel != "azure")
                parts.Add($"\"voiceModel\":\"{_j2vVoiceModel}\"");
            if (_j2vVoiceName != "es-ES-AlvaroNeural")
                parts.Add($"\"voiceName\":\"{_j2vVoiceName}\"");
            if (_j2vSubtitleLanguage != "es")
                parts.Add($"\"subtitleLanguage\":\"{_j2vSubtitleLanguage}\"");
            if (_j2vSubtitleStyle != "boxed")
                parts.Add($"\"subtitleStyle\":\"{_j2vSubtitleStyle}\"");
            if (_j2vSubtitleFontSize != 120)
                parts.Add($"\"subtitleFontSize\":{_j2vSubtitleFontSize}");
            if (_j2vSubtitleWordColor != "#FFFF00")
                parts.Add($"\"subtitleWordColor\":\"{_j2vSubtitleWordColor}\"");
            if (Math.Abs(_j2vImageDuration - 5.0) > 0.01)
                parts.Add($"\"imageDuration\":{_j2vImageDuration.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
        }

        return parts.Count > 0 ? "{" + string.Join(",", parts) + "}" : null;
    }

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _modules = await Api.GetModulesAsync();
            _keys = await Api.GetApiKeysAsync();
        }
        catch { }
        _loading = false;
    }

    private async Task Create()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_provider)) { _error = "Selecciona un proveedor"; return; }
        if (string.IsNullOrWhiteSpace(_moduleType)) { _error = "Selecciona un tipo de modulo"; return; }
        if (string.IsNullOrWhiteSpace(_model)) { _error = "Selecciona un modelo"; return; }
        if (string.IsNullOrWhiteSpace(_name)) { _error = "Indica un nombre para el modulo"; return; }

        _loading = true;
        try
        {
            Guid? keyId = Guid.TryParse(_apiKeyId, out var id) ? id : null;
            var config = BuildConfigJson();
            var req = new CreateAiModuleRequest(_name, _desc, _provider, _moduleType, _model, keyId, config);
            var (ok, error, moduleId) = await Api.CreateModuleAsync(req);
            if (ok)
            {
                if (moduleId.HasValue && _createPendingFiles.Count > 0)
                {
                    using var content = new MultipartFormDataContent();
                    foreach (var file in _createPendingFiles)
                    {
                        var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
                        content.Add(new StreamContent(stream), "files", file.Name);
                    }
                    await Api.UploadModuleFilesAsync(moduleId.Value, content);
                }
                _createPendingFiles.Clear();
                _name = ""; _desc = ""; _model = ""; _apiKeyId = "";
                ResetConfig();
                _modules = await Api.GetModulesAsync();
            }
            else _error = error;
        }
        catch (Exception ex) { _error = $"Error de conexion: {ex.Message}"; }
        _loading = false;
    }

    private async Task ChangeModel(AiModuleResponse module, ChangeEventArgs e)
    {
        var newModel = e.Value?.ToString() ?? "";
        if (string.IsNullOrEmpty(newModel) || newModel == module.ModelName) return;

        try
        {
            var (ok, error) = await Api.UpdateModuleModelAsync(module.Id, module, newModel);
            if (ok)
                _modules = await Api.GetModulesAsync();
            else
                _error = error;
        }
        catch (Exception ex) { _error = $"Error al cambiar modelo: {ex.Message}"; }
    }

    private async Task ChangeApiKey(AiModuleResponse module, ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        Guid? newKeyId = Guid.TryParse(val, out var parsed) ? parsed : null;
        if (newKeyId == module.ApiKeyId) return;

        try
        {
            var (ok, error) = await Api.UpdateModuleApiKeyAsync(module.Id, module, newKeyId);
            if (ok)
                _modules = await Api.GetModulesAsync();
            else
                _error = error;
        }
        catch (Exception ex) { _error = $"Error al cambiar API Key: {ex.Message}"; }
    }

    private async Task ToggleEditConfig(AiModuleResponse module)
    {
        if (_editingModuleId == module.Id)
        {
            _editingModuleId = null;
            return;
        }

        _editingModuleId = module.Id;
        _editConfigError = null;
        _editConfigSuccess = false;

        // Parse existing configuration
        _editSystemPrompt = "";
        _editTemperature = 0.7;
        _editMaxTokens = 4096;
        _editImageSize = "1024x1024";
        _editImageQuality = "standard";
        _editTtsVoice = "alloy";
        _editTtsSpeed = 1.0;
        _editLeoWidth = 1024;
        _editLeoHeight = 1024;
        _editLeoPresetStyle = "DYNAMIC";
        _editCanvaAccessToken = "";
        _editCanvaExportFormat = "png";
        _editCanvaBrandTemplate = "";
        _editCanvaDesignType = "doc";
        _editGrokImageCount = 1;

        if (!string.IsNullOrWhiteSpace(module.Configuration))
        {
            try
            {
                var doc = System.Text.Json.JsonDocument.Parse(module.Configuration);
                var root = doc.RootElement;

                if (root.TryGetProperty("systemPrompt", out var sp)) _editSystemPrompt = sp.GetString() ?? "";
                if (root.TryGetProperty("temperature", out var t)) _editTemperature = t.GetDouble();
                if (root.TryGetProperty("maxTokens", out var mt)) _editMaxTokens = mt.GetInt32();
                if (root.TryGetProperty("size", out var sz)) _editImageSize = sz.GetString() ?? "1024x1024";
                if (root.TryGetProperty("quality", out var q)) _editImageQuality = q.GetString() ?? "standard";
                if (root.TryGetProperty("voice", out var v)) _editTtsVoice = v.GetString() ?? "alloy";
                if (root.TryGetProperty("speed", out var spd)) _editTtsSpeed = spd.GetDouble();
                if (root.TryGetProperty("width", out var lw)) _editLeoWidth = lw.GetInt32();
                if (root.TryGetProperty("height", out var lh)) _editLeoHeight = lh.GetInt32();
                if (root.TryGetProperty("presetStyle", out var lps)) _editLeoPresetStyle = lps.GetString() ?? "DYNAMIC";
                if (root.TryGetProperty("aspectRatio", out var ar))
                {
                    _editGeminiAspectRatio = ar.GetString() ?? "1:1";
                    _editVideoAspectRatio = ar.GetString() ?? "16:9";
                }
                if (root.TryGetProperty("numberOfImages", out var ni)) _editGeminiImageCount = ni.GetInt32();
                if (root.TryGetProperty("n", out var grokN)) _editGrokImageCount = grokN.GetInt32();
                if (root.TryGetProperty("duration", out var vdur))
                {
                    _editVideoDuration = vdur.GetString() ?? "8";
                    _editSoraDuration = vdur.GetString() ?? "8";
                }
                if (root.TryGetProperty("resolution", out var vres)) _editVideoResolution = vres.GetString() ?? "720p";
                if (root.TryGetProperty("personGeneration", out var vpg)) _editVideoPersonGeneration = vpg.GetString() ?? "allow_adult";
                if (root.TryGetProperty("size", out var soraSize) && soraSize.GetString()?.Contains("x") == true)
                    _editSoraSize = soraSize.GetString() ?? "1280x720";
                if (root.TryGetProperty("accessToken", out var cat)) _editCanvaAccessToken = cat.GetString() ?? "";
                if (root.TryGetProperty("exportFormat", out var cef)) _editCanvaExportFormat = cef.GetString() ?? "png";
                if (root.TryGetProperty("brandTemplateId", out var cbt)) _editCanvaBrandTemplate = cbt.GetString() ?? "";
                if (root.TryGetProperty("designType", out var cdt)) _editCanvaDesignType = cdt.GetString() ?? "doc";
                if (root.TryGetProperty("orientation", out var por)) _editPexelsOrientation = por.GetString() ?? "landscape";
                if (root.TryGetProperty("size", out var psz2) && psz2.GetString() is "large" or "medium" or "small") _editPexelsSize = psz2.GetString()!;
                if (root.TryGetProperty("preferredQuality", out var ppq)) _editPexelsQuality = ppq.GetString() ?? "hd";
                if (root.TryGetProperty("locale", out var ploc)) _editPexelsLocale = ploc.GetString() ?? "es-ES";
                if (root.TryGetProperty("minDuration", out var pmd)) _editPexelsMinDuration = pmd.GetInt32();
                if (root.TryGetProperty("maxDuration", out var pmxd)) _editPexelsMaxDuration = pmxd.GetInt32();
                if (root.TryGetProperty("perPage", out var ppp)) _editPexelsPerPage = ppp.GetInt32();
                // Json2Video VideoEdit
                if (root.TryGetProperty("useTemplate", out var j2vUt)) _editJ2vUseTemplate = j2vUt.ValueKind == System.Text.Json.JsonValueKind.True;
                if (root.TryGetProperty("templateVars", out var j2vTv) && j2vTv.ValueKind == System.Text.Json.JsonValueKind.Array)
                {
                    _editJ2vTemplateVars = System.Text.Json.JsonSerializer.Deserialize<List<TemplateVariable>>(j2vTv.GetRawText()) ?? [];
                }
                if (root.TryGetProperty("resolution", out var j2vRes) && j2vRes.GetString() is "full-hd" or "hd" or "4k") _editJ2vResolution = j2vRes.GetString()!;
                if (root.TryGetProperty("enableVoice", out var j2vEv)) _editJ2vEnableVoice = j2vEv.ValueKind != System.Text.Json.JsonValueKind.False;
                if (root.TryGetProperty("enableSubtitles", out var j2vEs)) _editJ2vEnableSubtitles = j2vEs.ValueKind != System.Text.Json.JsonValueKind.False;
                if (root.TryGetProperty("voiceModel", out var j2vVm)) _editJ2vVoiceModel = j2vVm.GetString() ?? "azure";
                if (root.TryGetProperty("voiceName", out var j2vVn)) _editJ2vVoiceName = j2vVn.GetString() ?? "es-ES-AlvaroNeural";
                if (root.TryGetProperty("subtitleLanguage", out var j2vSl)) _editJ2vSubtitleLanguage = j2vSl.GetString() ?? "es";
                if (root.TryGetProperty("subtitleStyle", out var j2vSs)) _editJ2vSubtitleStyle = j2vSs.GetString() ?? "boxed";
                if (root.TryGetProperty("subtitleFontSize", out var j2vSf)) _editJ2vSubtitleFontSize = j2vSf.GetInt32();
                if (root.TryGetProperty("subtitleWordColor", out var j2vSw)) _editJ2vSubtitleWordColor = j2vSw.GetString() ?? "#FFFF00";
                if (root.TryGetProperty("imageDuration", out var j2vId)) _editJ2vImageDuration = j2vId.GetDouble();
                // StaticText
                if (root.TryGetProperty("content", out var stContent)) _editStaticTextContent = stContent.GetString() ?? "";
            }
            catch { }
        }

        // Load module files
        _editModuleFiles = [];
        _fileUploadError = null;
        try { _editModuleFiles = await Api.GetModuleFilesAsync(module.Id); } catch { }
    }

    private async Task OnModuleFilesSelected(InputFileChangeEventArgs e)
    {
        if (_editingModuleId is null) return;
        _fileUploadError = null;
        _uploadingFiles = true;
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            foreach (var file in e.GetMultipleFiles(10))
            {
                var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024); // 50MB
                content.Add(new StreamContent(stream), "files", file.Name);
            }

            var uploaded = await Api.UploadModuleFilesAsync(_editingModuleId.Value, content);
            _editModuleFiles.InsertRange(0, uploaded);
        }
        catch (Exception ex) { _fileUploadError = $"Error al subir: {ex.Message}"; }
        _uploadingFiles = false;
    }

    private void OnCreateFilesSelected(InputFileChangeEventArgs e)
    {
        _createPendingFiles.AddRange(e.GetMultipleFiles(10));
    }

    private async Task DeleteModuleFile(Guid fileId, Guid moduleId)
    {
        try
        {
            await Api.DeleteModuleFileAsync(fileId);
            _editModuleFiles.RemoveAll(f => f.Id == fileId);
        }
        catch { }
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private async Task SaveConfig(AiModuleResponse module)
    {
        _editConfigError = null;
        _editConfigSuccess = false;
        _editConfigSaving = true;

        try
        {
            var config = BuildEditConfigJson(module.ModuleType, module.ProviderType);
            var (ok, error) = await Api.UpdateModuleConfigAsync(module.Id, module, config);
            if (ok)
            {
                _editConfigSuccess = true;
                _modules = await Api.GetModulesAsync();
            }
            else
            {
                _editConfigError = error;
            }
        }
        catch (Exception ex) { _editConfigError = $"Error: {ex.Message}"; }
        _editConfigSaving = false;
    }

    private string? BuildEditConfigJson(string moduleType, string providerType)
    {
        var parts = new List<string>();

        if (moduleType is "Text" or "Orchestrator" or "Coordinator")
        {
            if (!string.IsNullOrWhiteSpace(_editSystemPrompt))
                parts.Add($"\"systemPrompt\":{System.Text.Json.JsonSerializer.Serialize(_editSystemPrompt)}");
            if (_editTemperature != 0.7)
                parts.Add($"\"temperature\":{_editTemperature}");
            if (_editMaxTokens != 4096)
                parts.Add($"\"maxTokens\":{_editMaxTokens}");
        }
        else if (moduleType == "Image" && providerType == "Google")
        {
            if (_editGeminiAspectRatio != "1:1")
                parts.Add($"\"aspectRatio\":\"{_editGeminiAspectRatio}\"");
            if (_editGeminiImageCount != 1)
                parts.Add($"\"numberOfImages\":{_editGeminiImageCount}");
        }
        else if (moduleType == "Image" && providerType == "xAI")
        {
            if (_editGrokImageCount != 1)
                parts.Add($"\"n\":{_editGrokImageCount}");
        }
        else if (moduleType == "Image" && providerType == "LeonardoAI")
        {
            if (_editLeoWidth != 1024)
                parts.Add($"\"width\":{_editLeoWidth}");
            if (_editLeoHeight != 1024)
                parts.Add($"\"height\":{_editLeoHeight}");
            if (_editLeoPresetStyle != "DYNAMIC")
                parts.Add($"\"presetStyle\":\"{_editLeoPresetStyle}\"");
        }
        else if (moduleType == "Image")
        {
            if (_editImageSize != "1024x1024")
                parts.Add($"\"size\":\"{_editImageSize}\"");
            if (_editImageQuality != "standard")
                parts.Add($"\"quality\":\"{_editImageQuality}\"");
        }
        else if (moduleType == "Video" && providerType == "Google")
        {
            if (_editVideoAspectRatio != "16:9")
                parts.Add($"\"aspectRatio\":\"{_editVideoAspectRatio}\"");
            if (_editVideoDuration != "8")
                parts.Add($"\"duration\":\"{_editVideoDuration}\"");
            if (_editVideoResolution != "720p")
                parts.Add($"\"resolution\":\"{_editVideoResolution}\"");
            if (_editVideoPersonGeneration != "allow_adult")
                parts.Add($"\"personGeneration\":\"{_editVideoPersonGeneration}\"");
        }
        else if (moduleType == "Video" && providerType == "OpenAI")
        {
            if (_editSoraSize != "1280x720")
                parts.Add($"\"size\":\"{_editSoraSize}\"");
            if (_editSoraDuration != "8")
                parts.Add($"\"duration\":\"{_editSoraDuration}\"");
        }
        else if (moduleType == "Audio")
        {
            parts.Add($"\"voice\":\"{_editTtsVoice}\"");
            if (_editTtsSpeed != 1.0)
                parts.Add($"\"speed\":{_editTtsSpeed}");
        }
        else if (moduleType == "Design" && providerType == "Canva")
        {
            if (!string.IsNullOrWhiteSpace(_editCanvaAccessToken))
                parts.Add($"\"accessToken\":{System.Text.Json.JsonSerializer.Serialize(_editCanvaAccessToken)}");
            if (_editCanvaExportFormat != "png")
                parts.Add($"\"exportFormat\":\"{_editCanvaExportFormat}\"");
            if (!string.IsNullOrWhiteSpace(_editCanvaBrandTemplate))
                parts.Add($"\"brandTemplateId\":{System.Text.Json.JsonSerializer.Serialize(_editCanvaBrandTemplate)}");
            if (_editCanvaDesignType != "doc")
                parts.Add($"\"designType\":\"{_editCanvaDesignType}\"");
        }
        else if (moduleType == "VideoSearch" && providerType == "Pexels")
        {
            if (_editPexelsOrientation != "landscape")
                parts.Add($"\"orientation\":\"{_editPexelsOrientation}\"");
            if (_editPexelsSize != "medium")
                parts.Add($"\"size\":\"{_editPexelsSize}\"");
            if (_editPexelsQuality != "hd")
                parts.Add($"\"preferredQuality\":\"{_editPexelsQuality}\"");
            if (_editPexelsLocale != "es-ES")
                parts.Add($"\"locale\":\"{_editPexelsLocale}\"");
            if (_editPexelsMinDuration > 0)
                parts.Add($"\"minDuration\":{_editPexelsMinDuration}");
            if (_editPexelsMaxDuration > 0)
                parts.Add($"\"maxDuration\":{_editPexelsMaxDuration}");
            if (_editPexelsPerPage != 15)
                parts.Add($"\"perPage\":{_editPexelsPerPage}");
        }
        else if (moduleType == "VideoEdit" && providerType == "Json2Video")
        {
            if (_editJ2vUseTemplate)
            {
                parts.Add("\"useTemplate\":true");
                if (_editJ2vTemplateVars.Count > 0)
                    parts.Add($"\"templateVars\":{System.Text.Json.JsonSerializer.Serialize(_editJ2vTemplateVars)}");
            }
            if (_editJ2vResolution != "full-hd")
                parts.Add($"\"resolution\":\"{_editJ2vResolution}\"");
            if (!_editJ2vEnableVoice)
                parts.Add("\"enableVoice\":false");
            if (!_editJ2vEnableSubtitles)
                parts.Add("\"enableSubtitles\":false");
            if (_editJ2vVoiceModel != "azure")
                parts.Add($"\"voiceModel\":\"{_editJ2vVoiceModel}\"");
            if (_editJ2vVoiceName != "es-ES-AlvaroNeural")
                parts.Add($"\"voiceName\":\"{_editJ2vVoiceName}\"");
            if (_editJ2vSubtitleLanguage != "es")
                parts.Add($"\"subtitleLanguage\":\"{_editJ2vSubtitleLanguage}\"");
            if (_editJ2vSubtitleStyle != "boxed")
                parts.Add($"\"subtitleStyle\":\"{_editJ2vSubtitleStyle}\"");
            if (_editJ2vSubtitleFontSize != 120)
                parts.Add($"\"subtitleFontSize\":{_editJ2vSubtitleFontSize}");
            if (_editJ2vSubtitleWordColor != "#FFFF00")
                parts.Add($"\"subtitleWordColor\":\"{_editJ2vSubtitleWordColor}\"");
            if (Math.Abs(_editJ2vImageDuration - 5.0) > 0.01)
                parts.Add($"\"imageDuration\":{_editJ2vImageDuration.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
        }

        if (moduleType == "StaticText")
        {
            if (!string.IsNullOrWhiteSpace(_editStaticTextContent))
                parts.Add($"\"content\":{System.Text.Json.JsonSerializer.Serialize(_editStaticTextContent)}");
        }

        return parts.Count > 0 ? "{" + string.Join(",", parts) + "}" : null;
    }

    private async Task Delete(Guid moduleId)
    {
        try { await Api.DeleteModuleAsync(moduleId); _modules = await Api.GetModulesAsync(); }
        catch { }
    }
}
