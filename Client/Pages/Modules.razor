    // ── Build config JSON ──
    private string? BuildConfigJson()
    {
        var parts = new List<string>();

        if (_moduleType is "Text" or "Orchestrator" or "Coordinator")
        {
            if (!string.IsNullOrWhiteSpace(_systemPrompt))
                parts.Add($"\"systemPrompt\":{System.Text.Json.JsonSerializer.Serialize(_systemPrompt)}");
            if (_temperature != 0.7)
                parts.Add($"\"temperature\":{_temperature}");
            if (_maxTokens != 4096)
                parts.Add($"\"maxTokens\":{_maxTokens}");
        }
        else if (_moduleType == "Image" && _provider == "Google")
        {
            if (!string.IsNullOrWhiteSpace(_systemPrompt))
                parts.Add($"\"systemPrompt\":{System.Text.Json.JsonSerializer.Serialize(_systemPrompt)}");
            if (_geminiAspectRatio != "1:1")
                parts.Add($"\"aspectRatio\":\"{_geminiAspectRatio}\"");
            if (_geminiImageCount != 1)
                parts.Add($"\"numberOfImages\":{_geminiImageCount}");
        }
        else if (_moduleType == "Image" && _provider == "xAI")
        {
            if (!string.IsNullOrWhiteSpace(_systemPrompt))
                parts.Add($"\"systemPrompt\":{System.Text.Json.JsonSerializer.Serialize(_systemPrompt)}");
            if (_grokImageCount != 1)
                parts.Add($"\"n\":{_grokImageCount}");
        }
        else if (_moduleType == "Image" && _provider == "LeonardoAI")
        {
            if (!string.IsNullOrWhiteSpace(_systemPrompt))
                parts.Add($"\"systemPrompt\":{System.Text.Json.JsonSerializer.Serialize(_systemPrompt)}");
            if (_leoWidth != 1024)
                parts.Add($"\"width\":{_leoWidth}");
            if (_leoHeight != 1024)
                parts.Add($"\"height\":{_leoHeight}");
            if (_leoPresetStyle != "DYNAMIC")
                parts.Add($"\"presetStyle\":\"{_leoPresetStyle}\"");
        }
        else if (_moduleType == "Image")
        {
            if (!string.IsNullOrWhiteSpace(_systemPrompt))
                parts.Add($"\"systemPrompt\":{System.Text.Json.JsonSerializer.Serialize(_systemPrompt)}");
            if (_imageSize != "1024x1024")
                parts.Add($"\"size\":\"{_imageSize}\"");
            if (_imageQuality != "standard")
                parts.Add($"\"quality\":\"{_imageQuality}\"");
            if (IsGptImage() && _imageCount != 1)
                parts.Add($"\"n\":{_imageCount}");
        }
        else if (_moduleType == "StaticText")
        {
            if (!string.IsNullOrWhiteSpace(_staticTextContent))
                parts.Add($"\"content\":{System.Text.Json.JsonSerializer.Serialize(_staticTextContent)}");
        }
        else if (_moduleType == "Embeddings")
        {
            if (_embeddingDimensions.HasValue)
                parts.Add($"\"dimensions\":{_embeddingDimensions.Value}");
        }
        else if (_moduleType == "Audio")
        {
            parts.Add($"\"voice\":\"{_ttsVoice}\"");
            if (_ttsSpeed != 1.0)
                parts.Add($"\"speed\":{_ttsSpeed}");
        }
        else if (_moduleType == "Transcription")
        {
            if (!string.IsNullOrWhiteSpace(_transcriptionLang))
                parts.Add($"\"language\":\"{_transcriptionLang}\"");
            if (_transcriptionFormat != "json")
                parts.Add($"\"response_format\":\"{_transcriptionFormat}\"");
        }
        else if (_moduleType == "Design" && _provider == "Canva")
        {
            if (!string.IsNullOrWhiteSpace(_canvaAccessToken))
                parts.Add($"\"accessToken\":{System.Text.Json.JsonSerializer.Serialize(_canvaAccessToken)}");
            if (_canvaExportFormat != "png")
                parts.Add($"\"exportFormat\":\"{_canvaExportFormat}\"");
            if (!string.IsNullOrWhiteSpace(_canvaBrandTemplate))
                parts.Add($"\"brandTemplateId\":{System.Text.Json.JsonSerializer.Serialize(_canvaBrandTemplate)}");
            if (_canvaDesignType != "doc")
                parts.Add($"\"designType\":\"{_canvaDesignType}\"");
        }
        return parts.Count > 0 ? "{" + string.Join(",", parts) + "}" : null;
    }

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _modules = await Api.GetModulesAsync();
            _keys = await Api.GetApiKeysAsync();
        }
        catch { }
        _loading = false;
    }

    private async Task Create()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_provider)) { _error = "Selecciona un proveedor"; return; }
        if (string.IsNullOrWhiteSpace(_moduleType)) { _error = "Selecciona un tipo de modulo"; return; }
        if (string.IsNullOrWhiteSpace(_model)) { _error = "Selecciona un modelo"; return; }
        if (string.IsNullOrWhiteSpace(_name)) { _error = "Indica un nombre para el modulo"; return; }

        _loading = true;
        try
        {
            Guid? keyId = Guid.TryParse(_apiKeyId, out var id) ? id : null;
            var config = BuildConfigJson();
            var req = new CreateAiModuleRequest(_name, _desc, _provider, _moduleType, _model, keyId, config);
            var (ok, error, moduleId) = await Api.CreateModuleAsync(req);
            if (ok)
            {
                // Los archivos del modulo se cargan en cada ProjectModule del proyecto,
                // no aqui en el catalogo. Si el usuario marca archivos en la pantalla
                // de creacion (caso legacy) los descartamos en silencio.
                _createPendingFiles.Clear();
                _name = ""; _desc = ""; _model = ""; _apiKeyId = "";
                ResetConfig();
                _modules = await Api.GetModulesAsync();
                // Cierre automático del modal tras creación exitosa: la lista se refresca antes de cerrar
                // para que el nuevo módulo aparezca inmediatamente al volver a la vista principal.
                _showCreateModal = false;
            }
            else _error = error;
        }
        catch (Exception ex) { _error = $"Error de conexion: {ex.Message}"; }
        _loading = false;
    }

    private async Task ChangeModel(AiModuleResponse module, ChangeEventArgs e)
    {
        var newModel = e.Value?.ToString() ?? "";
        if (string.IsNullOrEmpty(newModel) || newModel == module.ModelName) return;

        try
        {
            var (ok, error) = await Api.UpdateModuleModelAsync(module.Id, module, newModel);
            if (ok)
                _modules = await Api.GetModulesAsync();
            else
                _error = error;
        }
        catch (Exception ex) { _error = $"Error al cambiar modelo: {ex.Message}"; }
    }

    private async Task ChangeApiKey(AiModuleResponse module, ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        Guid? newKeyId = Guid.TryParse(val, out var parsed) ? parsed : null;
        if (newKeyId == module.ApiKeyId) return;

        try
        {
            var (ok, error) = await Api.UpdateModuleApiKeyAsync(module.Id, module, newKeyId);
            if (ok)
                _modules = await Api.GetModulesAsync();
            else
                _error = error;
        }
        catch (Exception ex) { _error = $"Error al cambiar API Key: {ex.Message}"; }
    }

    private async Task ToggleEditConfig(AiModuleResponse module)
    {
        if (_editingModuleId == module.Id)
        {
            _editingModuleId = null;
            return;
        }

        _editingModuleId = module.Id;
        _editConfigError = null;
        _editConfigSuccess = false;

        // Parse existing configuration
        _editSystemPrompt = "";
        _editTemperature = 0.7;
        _editMaxTokens = 4096;
        _editImageSize = "1024x1024";
        _editImageQuality = "standard";
        _editTtsVoice = "alloy";
        _editTtsSpeed = 1.0;
        _editLeoWidth = 1024;
        _editLeoHeight = 1024;
        _editLeoPresetStyle = "DYNAMIC";
        _editCanvaAccessToken = "";
        _editCanvaExportFormat = "png";
        _editCanvaBrandTemplate = "";
        _editCanvaDesignType = "doc";
        _editGrokImageCount = 1;

        if (!string.IsNullOrWhiteSpace(module.Configuration))
        {
            try
            {
                var doc = System.Text.Json.JsonDocument.Parse(module.Configuration);
                var root = doc.RootElement;

                if (root.TryGetProperty("systemPrompt", out var sp)) _editSystemPrompt = sp.GetString() ?? "";
                if (root.TryGetProperty("temperature", out var t)) _editTemperature = t.GetDouble();
                if (root.TryGetProperty("maxTokens", out var mt)) _editMaxTokens = mt.GetInt32();
                if (root.TryGetProperty("size", out var sz)) _editImageSize = sz.GetString() ?? "1024x1024";
                if (root.TryGetProperty("quality", out var q)) _editImageQuality = q.GetString() ?? "standard";
                if (root.TryGetProperty("voice", out var v)) _editTtsVoice = v.GetString() ?? "alloy";
                if (root.TryGetProperty("speed", out var spd)) _editTtsSpeed = spd.GetDouble();
                if (root.TryGetProperty("width", out var lw)) _editLeoWidth = lw.GetInt32();
                if (root.TryGetProperty("height", out var lh)) _editLeoHeight = lh.GetInt32();
                if (root.TryGetProperty("presetStyle", out var lps)) _editLeoPresetStyle = lps.GetString() ?? "DYNAMIC";
                if (root.TryGetProperty("aspectRatio", out var ar)) _editGeminiAspectRatio = ar.GetString() ?? "1:1";
                if (root.TryGetProperty("numberOfImages", out var ni)) _editGeminiImageCount = ni.GetInt32();
                if (root.TryGetProperty("n", out var grokN)) _editGrokImageCount = grokN.GetInt32();
                if (root.TryGetProperty("accessToken", out var cat)) _editCanvaAccessToken = cat.GetString() ?? "";
                if (root.TryGetProperty("exportFormat", out var cef)) _editCanvaExportFormat = cef.GetString() ?? "png";
                if (root.TryGetProperty("brandTemplateId", out var cbt)) _editCanvaBrandTemplate = cbt.GetString() ?? "";
                if (root.TryGetProperty("designType", out var cdt)) _editCanvaDesignType = cdt.GetString() ?? "doc";
                // StaticText
                if (root.TryGetProperty("content", out var stContent)) _editStaticTextContent = stContent.GetString() ?? "";
            }
            catch { }
        }

        // Ya no se cargan archivos en el catalogo: viven en cada ProjectModule.
        _editModuleFiles = [];
        _fileUploadError = null;
        await Task.CompletedTask;
    }

    private async Task OnModuleFilesSelected(InputFileChangeEventArgs e)
    {
        if (_editingModuleId is null) return;
        _fileUploadError = null;
        _uploadingFiles = true;
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            foreach (var file in e.GetMultipleFiles(10))
            {
                content.Add(CreateBrowserFileContent(file), "files", file.Name);
            }

            var uploaded = await Api.UploadModuleFilesAsync(_editingModuleId.Value, content);
            _editModuleFiles.InsertRange(0, uploaded);
        }
        catch (Exception ex) { _fileUploadError = $"Error al subir: {ex.Message}"; }
        _uploadingFiles = false;
    }

    private void OnCreateFilesSelected(InputFileChangeEventArgs e)
    {
        _createPendingFiles.AddRange(e.GetMultipleFiles(10));
    }

    private static StreamContent CreateBrowserFileContent(IBrowserFile file)
    {
        var stream = file.OpenReadStream(maxAllowedSize: MaxUploadFileSize);
        var content = new StreamContent(stream);
        var contentType = string.IsNullOrWhiteSpace(file.ContentType)
            ? "application/octet-stream"
            : file.ContentType;
        content.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(contentType);
        return content;
    }

    private async Task DeleteModuleFile(Guid fileId, Guid moduleId)
    {
        try
        {
            await Api.DeleteModuleFileAsync(fileId);
            _editModuleFiles.RemoveAll(f => f.Id == fileId);
        }
        catch { }
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private async Task SaveConfig(AiModuleResponse module)
    {
        _editConfigError = null;
        _editConfigSuccess = false;
        _editConfigSaving = true;

        try
        {
            var config = BuildEditConfigJson(module.ModuleType, module.ProviderType);
            var (ok, error) = await Api.UpdateModuleConfigAsync(module.Id, module, config);
            if (ok)
            {
                _editConfigSuccess = true;
                _modules = await Api.GetModulesAsync();
            }
            else
            {
                _editConfigError = error;
            }
        }
        catch (Exception ex) { _editConfigError = $"Error: {ex.Message}"; }
        _editConfigSaving = false;
    }

