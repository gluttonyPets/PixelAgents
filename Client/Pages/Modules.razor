    private void OnModelChanged(ChangeEventArgs e)
    {
        _model = e.Value?.ToString() ?? "";
        // Set size default based on model: gpt-image defaults to "auto" (preserves input dimensions)
        var sizes = GetImageSizesForModel(_model);
        _imageSize = sizes[0];
    }

    private void AddJ2vTemplateVar()
    {
        var name = _j2vNewVarName?.Trim();
        if (!string.IsNullOrWhiteSpace(name) && !_j2vTemplateVars.Any(v => v.Name == name))
        {
            var tv = new TemplateVariable { Name = name, Type = _j2vNewVarType };
            if (_j2vNewVarType == "scene") tv.Fields = new List<SceneField>();
            _j2vTemplateVars.Add(tv);
            _j2vNewVarName = "";
        }
    }

    private void AddEditJ2vTemplateVar()
    {
        var name = _editJ2vNewVarName?.Trim();
        if (!string.IsNullOrWhiteSpace(name) && !_editJ2vTemplateVars.Any(v => v.Name == name))
        {
            var tv = new TemplateVariable { Name = name, Type = _editJ2vNewVarType };
            if (_editJ2vNewVarType == "scene") tv.Fields = new List<SceneField>();
            _editJ2vTemplateVars.Add(tv);
            _editJ2vNewVarName = "";
        }
    }

    private void AddJ2vSceneField(TemplateVariable tv)
    {
        var name = _j2vNewFieldName?.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        tv.Fields ??= new List<SceneField>();
        if (tv.Fields.Any(f => f.Name == name)) return;
        tv.Fields.Add(new SceneField { Name = name, Type = _j2vNewFieldType });
        _j2vNewFieldName = "";
    }

    private void AddEditJ2vSceneField(TemplateVariable tv)
    {
        var name = _editJ2vNewFieldName?.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        tv.Fields ??= new List<SceneField>();
        if (tv.Fields.Any(f => f.Name == name)) return;
        tv.Fields.Add(new SceneField { Name = name, Type = _editJ2vNewFieldType });
        _editJ2vNewFieldName = "";
    }

