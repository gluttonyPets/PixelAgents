    // ── Available types per provider ──
    private record TypeOption(string Value, string Label);

    private List<TypeOption> GetAvailableTypes()
    {
        var types = AllModels
            .Where(m => m.Provider == _provider)
            .SelectMany(m => m.Types)
            .Where(t => t != "Publish")
            .Distinct()
            .Select(t => new TypeOption(t, t switch
            {
                "Text"          => "Texto / Chat",
                "Image"         => "Generacion de imagen",
                "Embeddings"    => "Embeddings",
                "Audio"         => "Audio (TTS)",
                "Transcription" => "Transcripcion (STT)",
                "Design"        => "Diseno (Canva)",
                "Orchestrator"  => "Orquestador de pipeline",
                "Coordinator"   => "Coordinador (multi-entrada)",
                "FileUpload"    => "Archivos",
                "Scene"         => "Constructor de escena",
                "StaticText"    => "Texto plano",
                _               => t
            }))
            .ToList();
        return types;
    }

    private List<ModelInfo> GetAvailableModels()
    {
        return AllModels
            .Where(m => m.Provider == _provider && m.Types.Contains(_moduleType))
            .ToList();
    }

    private ModelInfo? GetSelectedModel()
    {
        if (string.IsNullOrEmpty(_model)) return null;
        return AllModels.FirstOrDefault(m => m.Id == _model);
    }

    private bool IsGptImage() => _model.StartsWith("gpt-image", StringComparison.OrdinalIgnoreCase);

    private string[] GetImageSizes()
    {
        return GetImageSizesForModel(_model);
    }

    private static string[] GetImageSizesForModel(string model)
    {
        return model switch
        {
            _ when model.StartsWith("gpt-image", StringComparison.OrdinalIgnoreCase)
                => ["auto", "1024x1024", "1536x1024", "1024x1536"],
            "dall-e-3" => ["1024x1024", "1024x1792", "1792x1024"],
            "dall-e-2" => ["256x256", "512x512", "1024x1024"],
            _ => ["1024x1024"]
        };
    }

    // ── Events ──

    private void OnProviderChanged(ChangeEventArgs e)
    {
        _provider = e.Value?.ToString() ?? "";
        _moduleType = "";
        _model = "";
        ResetConfig();
    }

    private void OnModuleTypeChanged(ChangeEventArgs e)
    {
        _moduleType = e.Value?.ToString() ?? "";
        _model = "";
        ResetConfig();
    }

    private void OnModelChanged(ChangeEventArgs e)
    {
        _model = e.Value?.ToString() ?? "";
        // Set size default based on model: gpt-image defaults to "auto" (preserves input dimensions)
        var sizes = GetImageSizesForModel(_model);
        _imageSize = sizes[0];
    }

