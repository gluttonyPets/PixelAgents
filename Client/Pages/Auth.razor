@page "/"
@inject ApiClient Api
@inject AuthStateService AuthState
@inject NavigationManager Nav

<h2>Autenticacion</h2>

@if (AuthState.IsAuthenticated)
{
    <div class="card">
        <p>Conectado como <strong>@AuthState.User!.Email</strong></p>
        <p class="text-sm text-muted">Account ID: @AuthState.User.AccountId</p>
        <p class="text-sm text-muted">DB: @AuthState.User.DbName</p>
        <button class="btn btn-danger mt-1" @onclick="Logout">Cerrar sesion</button>
    </div>
}
else
{
    <div class="form-row">
        <!-- Register -->
        <div class="card">
            <h3>Registro</h3>
            @if (_regError is not null)
            {
                <div class="alert alert-error">@_regError</div>
            }
            @if (_regSuccess)
            {
                <div class="alert alert-success">Usuario registrado. Ahora inicia sesion.</div>
            }
            <div class="form-group">
                <label>Email</label>
                <input type="email" @bind="_regEmail" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" @bind="_regPassword" />
            </div>
            <button class="btn btn-primary" @onclick="Register" disabled="@_loading">Registrar</button>
        </div>

        <!-- Login -->
        <div class="card">
            <h3>Login</h3>
            @if (_loginError is not null)
            {
                <div class="alert alert-error">@_loginError</div>
            }
            <div class="form-group">
                <label>Email</label>
                <input type="email" @bind="_loginEmail" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" @bind="_loginPassword" />
            </div>
            <button class="btn btn-primary" @onclick="Login" disabled="@_loading">Entrar</button>
        </div>
    </div>
}

@code {
    private bool _loading;

    // Register
    private string _regEmail = "";
    private string _regPassword = "";
    private string? _regError;
    private bool _regSuccess;

    // Login
    private string _loginEmail = "";
    private string _loginPassword = "";
    private string? _loginError;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            try
            {
                var user = await Api.GetMeAsync();
                if (user is not null) AuthState.SetUser(user);
            }
            catch { }
        }
    }

    private async Task Register()
    {
        _regError = null; _regSuccess = false; _loading = true;
        try
        {
            var (ok, error) = await Api.RegisterAsync(_regEmail, _regPassword);
            if (ok) { _regSuccess = true; _loginEmail = _regEmail; }
            else _regError = error;
        }
        catch (Exception ex) { _regError = $"Error de conexion: {ex.Message}"; }
        _loading = false;
    }

    private async Task Login()
    {
        _loginError = null; _loading = true;
        try
        {
            var (ok, user, error) = await Api.LoginAsync(_loginEmail, _loginPassword);
            if (ok)
            {
                AuthState.SetUser(user);
                Nav.NavigateTo("/apikeys");
            }
            else _loginError = error;
        }
        catch (Exception ex) { _loginError = $"Error de conexion: {ex.Message}"; }
        _loading = false;
    }

    private async Task Logout()
    {
        await Api.LogoutAsync();
        AuthState.SetUser(null);
    }
}
