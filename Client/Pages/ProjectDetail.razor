    private async Task SaveGraph(SaveGraphRequest req)
    {
        Console.WriteLine($"[ProjectDetail] SaveGraph: saving {req.Connections.Count} connections");
        var (ok, error) = await Api.SaveGraphAsync(ProjectId, req);
        if (!ok)
        {
            Console.WriteLine($"[ProjectDetail] SaveGraph FAILED: {error}");
