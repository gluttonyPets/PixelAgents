    private void StartAddBranch(int fromStepOrder)
    {
        _addBranchFromStep = fromStepOrder;
        _newBranchName = "";
        _showAddBranch = true;
    }

    private void ConfirmAddBranch()
    {
        if (string.IsNullOrWhiteSpace(_newBranchName)) return;
        var branchId = _newBranchName.Trim().ToLowerInvariant().Replace(" ", "-");
        if (!_pendingBranches.Any(pb => pb.BranchId == branchId))
            _pendingBranches.Add((branchId, _addBranchFromStep));
        _stepBranchId = branchId;
        _stepBranchFromStep = _addBranchFromStep;
        _stepOrder = 1;
        _inputMapping = $"{{\"source\":\"step\",\"stepOrder\":{_addBranchFromStep}}}";
        _showAddBranch = false;
    }

    private void CleanPendingBranches()
    {
        var existing = (_project?.Modules ?? new())
            .Where(m => m.BranchId != "main")
            .Select(m => m.BranchId)
            .Distinct()
            .ToHashSet();
        _pendingBranches.RemoveAll(pb => existing.Contains(pb.BranchId));
    }

    private void OnBranchSelectChanged(ChangeEventArgs e)
    {
        var selected = e.Value?.ToString() ?? "main";
        _stepBranchId = selected;

        if (selected == "main")
        {
            _stepBranchFromStep = null;
            var mainSteps = GetMainSteps();
            _stepOrder = mainSteps.Count + 1;
            _inputMapping = mainSteps.Count > 0
                ? "{\"source\":\"previous\",\"field\":\"text\"}"
                : "{\"source\":\"user\"}";
        }
        else
        {
            var branchModules = (_project?.Modules ?? new())
                .Where(m => m.BranchId == selected)
                .OrderBy(m => m.StepOrder)
                .ToList();

            if (branchModules.Count > 0)
            {
                _stepBranchFromStep = branchModules.First().BranchFromStep;
                _stepOrder = branchModules.Count + 1;
            }
            else
            {
                var pending = _pendingBranches.FirstOrDefault(pb => pb.BranchId == selected);
                _stepBranchFromStep = pending.FromStep;
                _stepOrder = 1;
            }
            _inputMapping = _stepOrder == 1
                ? $"{{\"source\":\"step\",\"stepOrder\":{_stepBranchFromStep}}}"
                : "{\"source\":\"previous\",\"field\":\"text\"}";
        }
    }

