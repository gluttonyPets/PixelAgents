    private List<ProjectModuleResponse> GetMainSteps()
        => _project?.Modules.Where(m => m.BranchId == "main").OrderBy(m => m.StepOrder).ToList() ?? new();

    private List<KeyValuePair<string, List<ProjectModuleResponse>>> GetBranchesFromStep(int stepOrder)
        => (_project?.Modules.Where(m => m.BranchId != "main")
            .GroupBy(m => m.BranchId)
            .ToDictionary(g => g.Key, g => g.OrderBy(m => m.StepOrder).ToList())
            ?? new())
            .Where(b => b.Value.FirstOrDefault()?.BranchFromStep == stepOrder)
            .ToList();

    private static string FormatInputMapping(string? mapping)
    {
        if (string.IsNullOrEmpty(mapping)) return "usuario";
        if (mapping.Contains("\"user\"")) return "usuario";
        if (mapping.Contains("\"previous\"") && mapping.Contains("\"file\"")) return "paso anterior (archivo)";
        if (mapping.Contains("\"previous\"")) return "paso anterior (texto)";
        if (mapping.Contains("\"step\"")) return "paso especifico";
        return mapping;
    }

    private static int GetMaxPromptLength(string modelName) => modelName.ToLowerInvariant() switch
    {
        "dall-e-2" => 1000,
        "dall-e-3" => 4000,
        var m when m.StartsWith("gpt-image") => 4000,
        var m when m.StartsWith("leonardo-") => 1500,
        var m when m.StartsWith("imagen-") => 4000,
        _ => 4000
    };

    private async Task AddStep()
    {
        _stepError = null;
        if (!Guid.TryParse(_stepModuleId, out var moduleId))
        {
            _stepError = "Selecciona un modulo";
            return;
        }
        _loading = true;
        try
        {
            // Build config for interaction steps
            string? stepConfig = null;
            var mod = _modules.FirstOrDefault(m => m.Id == moduleId);
            if (mod?.ModuleType == "Interaction")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    messageTemplate = string.IsNullOrWhiteSpace(_interactionTemplate) ? "{previous_output}" : _interactionTemplate,
                    messageType = _interactionMessageType,
                    waitForResponse = _interactionWaitForResponse == "true"
                });
            }
            if (mod?.ModuleType == "Text" && _isImagePrompt)
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    isImagePrompt = true,
                    imageCount = _imageCount
                });
            }
            if (mod?.ModuleType == "Design")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    exportFormat = _canvaExportFormat,
                    designTitle = string.IsNullOrWhiteSpace(_canvaDesignTitle) ? "PixelAgents Design" : _canvaDesignTitle,
                    brandTemplateId = string.IsNullOrWhiteSpace(_canvaStepBrandTemplateId) ? (string?)null : _canvaStepBrandTemplateId,
                    designType = _canvaDesignType
                });
            }
            if (mod?.ModuleType == "Publish")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    caption = string.IsNullOrWhiteSpace(_publishCaption) ? "{previous_output}" : _publishCaption,
                    publishType = _publishType
                });
            }
            if (mod?.ModuleType == "Image" && !string.IsNullOrWhiteSpace(_imagePrompt))
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    imagePrompt = _imagePrompt.Trim()
                });
            }
            if (mod?.ModuleType == "Video")
            {
                if (string.IsNullOrWhiteSpace(_videoPrompt))
                {
                    _stepError = "El prompt del video es obligatorio.";
                    _loading = false;
                    return;
                }
                stepConfig = JsonSerializer.Serialize(new
                {
                    videoSource = _videoSource,
                    videoPrompt = _videoPrompt.Trim()
                });
            }
            var req = new AddProjectModuleRequest(moduleId, _stepOrder, _stepName, _inputMapping, stepConfig, _stepBranchId, _stepBranchFromStep);
            var (ok, error) = await Api.AddProjectModuleAsync(ProjectId, req);
            if (ok) { _stepName = ""; _stepModuleId = ""; _interactionTemplate = ""; _interactionMessageType = "combined"; _interactionWaitForResponse = "true"; _isImagePrompt = false; _imageCount = 1; _imagePrompt = ""; _publishCaption = ""; _publishType = "post"; _canvaExportFormat = "png"; _canvaDesignTitle = ""; _canvaStepBrandTemplateId = ""; _canvaDesignType = "doc"; _videoSource = "prompt"; _videoPrompt = ""; _stepBranchId = "main"; _stepBranchFromStep = null; await LoadAll(); CleanPendingBranches(); }
            else _stepError = error;
        }
        catch (Exception ex) { _stepError = $"Error de conexion: {ex.Message}"; }
        _loading = false;
    }

    private void StartEdit(ProjectModuleResponse pm)
    {
        _editingPmId = pm.Id;
        _editStepName = pm.StepName ?? "";
        _editInputMapping = pm.InputMapping ?? "{\"source\":\"user\"}";
        _editError = null;

        // Reset all type-specific fields
        _imagePrompt = "";
        _videoPrompt = "";
        _videoSource = "prompt";
        _publishCaption = "";
        _publishType = "post";
        _interactionTemplate = "";
        _interactionMessageType = "combined";
        _interactionWaitForResponse = "true";
        _canvaExportFormat = "png";
        _canvaDesignTitle = "";
        _canvaStepBrandTemplateId = "";
        _canvaDesignType = "doc";

        if (!string.IsNullOrWhiteSpace(pm.Configuration))
        {
            try
            {
                var cfg = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(pm.Configuration);
                if (cfg is not null)
                {
                    if (cfg.TryGetValue("imagePrompt", out var ipEl))
                        _imagePrompt = ipEl.GetString() ?? "";
                    if (cfg.TryGetValue("videoPrompt", out var vpEl))
                        _videoPrompt = vpEl.GetString() ?? "";
                    if (cfg.TryGetValue("videoSource", out var vsEl))
                        _videoSource = vsEl.GetString() ?? "prompt";
                    if (cfg.TryGetValue("caption", out var capEl))
                        _publishCaption = capEl.GetString() ?? "";
                    if (cfg.TryGetValue("publishType", out var ptEl))
                        _publishType = ptEl.GetString() ?? "post";
                    if (cfg.TryGetValue("messageTemplate", out var mtEl))
                        _interactionTemplate = mtEl.GetString() ?? "";
                    if (cfg.TryGetValue("messageType", out var mtyEl))
                        _interactionMessageType = mtyEl.GetString() ?? "combined";
                    if (cfg.TryGetValue("waitForResponse", out var wfrEl))
                        _interactionWaitForResponse = wfrEl.ValueKind == JsonValueKind.True ? "true" : "false";
                    if (cfg.TryGetValue("exportFormat", out var efEl))
                        _canvaExportFormat = efEl.GetString() ?? "png";
                    if (cfg.TryGetValue("designTitle", out var dtEl))
                        _canvaDesignTitle = dtEl.GetString() ?? "";
                    if (cfg.TryGetValue("brandTemplateId", out var btEl))
                        _canvaStepBrandTemplateId = btEl.GetString() ?? "";
                    if (cfg.TryGetValue("designType", out var dtyEl))
                        _canvaDesignType = dtyEl.GetString() ?? "doc";
                }
            }
            catch { /* ignore parse errors */ }
        }
    }

    private void CancelEdit()
    {
        _editingPmId = null;
        _editError = null;
    }

    private async Task SaveEdit()
    {
        if (_editingPmId is null || _project is null) return;
        _editError = null;

        var pm = _project.Modules.FirstOrDefault(m => m.Id == _editingPmId);
        if (pm is null) return;

        try
        {
            // Rebuild step config based on module type
            string? stepConfig = null;
            if (pm.ModuleType == "Image")
            {
                if (!string.IsNullOrWhiteSpace(_imagePrompt))
                    stepConfig = JsonSerializer.Serialize(new { imagePrompt = _imagePrompt.Trim() });
            }
            else if (pm.ModuleType == "Video")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    videoSource = _videoSource,
                    videoPrompt = _videoPrompt.Trim()
                });
            }
            else if (pm.ModuleType == "Publish")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    caption = string.IsNullOrWhiteSpace(_publishCaption) ? "{previous_output}" : _publishCaption,
                    publishType = _publishType
                });
            }
            else if (pm.ModuleType == "Interaction")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    messageTemplate = string.IsNullOrWhiteSpace(_interactionTemplate) ? "{previous_output}" : _interactionTemplate,
                    messageType = _interactionMessageType,
                    waitForResponse = _interactionWaitForResponse == "true"
                });
            }
            else if (pm.ModuleType == "Design")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    exportFormat = _canvaExportFormat,
                    designTitle = _canvaDesignTitle,
                    brandTemplateId = string.IsNullOrWhiteSpace(_canvaStepBrandTemplateId) ? (string?)null : _canvaStepBrandTemplateId,
                    designType = _canvaDesignType
                });
            }
            else
            {
                stepConfig = pm.Configuration; // preserve existing for unknown types
            }

            var req = new UpdateProjectModuleRequest(
                pm.StepOrder,
                string.IsNullOrWhiteSpace(_editStepName) ? null : _editStepName,
                _editInputMapping,
                stepConfig,
                pm.IsActive);
            var (ok, error) = await Api.UpdateProjectModuleAsync(ProjectId, pm.Id, req);
            if (ok) { _editingPmId = null; await LoadAll(); }
            else _editError = error;
        }
        catch (Exception ex) { _editError = $"Error: {ex.Message}"; }
    }

    private async Task MoveStep(ProjectModuleResponse target, int direction)
    {
        if (_project is null) return;
        _editError = null;

        // Only swap within the same branch
        var sameBranch = _project.Modules.Where(m => m.BranchId == target.BranchId).OrderBy(m => m.StepOrder).ToList();
        var idx = sameBranch.FindIndex(m => m.Id == target.Id);
        var swapIdx = idx + direction;
        if (swapIdx < 0 || swapIdx >= sameBranch.Count) return;

        var other = sameBranch[swapIdx];

        try
        {
            var (ok, error) = await Api.SwapStepOrderAsync(ProjectId, target.Id, other.Id);
            if (!ok) _editError = error;
            await LoadAll();
        }
        catch (Exception ex) { _editError = $"Error: {ex.Message}"; }
    }

