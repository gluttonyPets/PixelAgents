    // TikTok config (Buffer)
    private string _tkApiKey = "";
    private string _tkChannelId = "";
    private string? _tkError;
    private bool _tkSuccess;
    private bool _tkSaving;

    // Buffer API debug modal
    private bool _showBufferDebug;
    private string? _bufferDebugRequest;
    private string? _bufferDebugResponse;
    private int? _bufferDebugStatus;

    // WhatsApp config
    private string _waPhoneNumberId = "";
    private string _waAccessToken = "";
    private string _waRecipientNumber = "";
    private string _waVerifyToken = "";
    private string? _waError;
    private bool _waSuccess;
    private bool _waSaving;

    // Schedule
    private ScheduleResponse? _schedule;
    private string _schedPreset = "daily";
    private int _schedHour1 = 9;
    private int _schedMinute1 = 0;
    private int _schedHour2 = 18;
    private int _schedMinute2 = 0;
    private string _schedDayOfWeek = "1";
    private string _schedCron = "";
    private string _schedTimeZone = "Europe/Madrid";
    private string _schedUserInput = "";
    private string? _schedError;
    private bool _schedSuccess;
    private bool _schedSaving;

    // Execution log
    private List<LogEntry> _logEntries = [];
    private Dictionary<Guid, string> _realtimeStepStatuses = new();
    private HubConnection? _hubConnection;
    private ElementReference _logContainer;
    private System.Threading.Timer? _pollTimer;

    // API base URL for file downloads (images, etc.)
    private string _apiBase = "";

    private record LogEntry(string Level, string Message, int? StepOrder, string? StepName, DateTime Timestamp);

    protected override async Task OnInitializedAsync()
    {
        var cfgUrl = Config["ApiBaseUrl"];
        _apiBase = !string.IsNullOrWhiteSpace(cfgUrl) ? cfgUrl.TrimEnd('/') : Nav.BaseUri.TrimEnd('/');

        await LoadAll();
        await InitializeSignalR();
    }

    private async Task InitializeSignalR()
    {
        var hubUrl = _apiBase + "/hubs/execution";

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        // Re-join the project group after automatic reconnection (new ConnectionId)
        _hubConnection.Reconnected += async _ =>
        {
            try { await _hubConnection.InvokeAsync("JoinProject", ProjectId.ToString()); } catch { }
        };

        _hubConnection.On<LogEntry>("ExecutionLog", entry =>
        {
            _logEntries.Add(entry);
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<StepExecutionStatus>("StepProgress", entry =>
        {
            _realtimeStepStatuses[entry.ProjectModuleId] = entry.Status;
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<ExecutionDetailResponse>("ExecutionCompleted", result =>
        {
            _result = result;
            _executing = false;
            _realtimeStepStatuses.Clear();
            _orchestratorActiveTasks = null;
            _orchestratorTaskStatus.Clear();
            StopPolling();
            InvokeAsync(async () =>
            {
                _executions = await Api.GetExecutionsAsync(ProjectId);
                StateHasChanged();
            });
        });

        _hubConnection.On<ExecutionDetailResponse>("OrchestratorWaitingForReview", result =>
        {
            InvokeAsync(() =>
            {
                OpenOrchestratorModal(result);
                StateHasChanged();
            });
        });

        _hubConnection.On<ExecutionDetailResponse>("CheckpointWaitingForReview", result =>
        {
            InvokeAsync(() =>
            {
                _checkpointExecutionId = result.Id;
                var pausedStep = result.Steps?.FirstOrDefault(s => s.Status == "WaitingForCheckpoint");
                _checkpointPreviewJson = pausedStep?.InputData;
                _showCheckpointModal = true;
                _executing = false;
                StopPolling();
                StateHasChanged();
            });
        });

        _hubConnection.On<OrchestratorTaskProgressEntry>("OrchestratorTaskProgress", progress =>
        {
            InvokeAsync(() =>
            {
                _orchestratorTaskStatus[progress.TaskId] = new OrchestratorTaskProgressState
                {
                    Status = progress.Status,
                    FileUrl = progress.FileUrl,
                    ContentType = progress.ContentType,
                    ErrorMessage = progress.ErrorMessage,
                };
                StateHasChanged();
            });
        });

        _hubConnection.On<string>("ExecutionFailed", error =>
        {
            _execError = error;
            _executing = false;
            _realtimeStepStatuses.Clear();
            StopPolling();
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinProject", ProjectId.ToString());
        }
        catch
        {
            // SignalR connection failed — polling fallback will handle completion detection
        }
    }

    /// <summary>
    /// Starts a periodic poll that checks the latest execution status every 5 seconds.
    /// Acts as a safety net in case SignalR misses the completion event.
    /// </summary>
    private void StartPolling()
    {
        StopPolling();
        _pollTimer = new System.Threading.Timer(async _ =>
        {
            if (!_executing) { StopPolling(); return; }
            try
            {
                var execs = await Api.GetExecutionsAsync(ProjectId);
                var latest = execs.FirstOrDefault();
                if (latest is null) return;

                // Still running — nothing to do
                if (latest.Status == "Running") return;

                // Checkpoint waiting for review — open modal
                if (latest.Status == "WaitingForCheckpoint")
                {
                    var cpDetail = await Api.GetExecutionDetailAsync(latest.Id);
                    if (cpDetail is not null)
                    {
                        _executions = execs;
                        await InvokeAsync(() =>
                        {
                            _checkpointExecutionId = cpDetail.Id;
                            var pausedStep = cpDetail.Steps?.FirstOrDefault(s => s.Status == "WaitingForCheckpoint");
                            _checkpointPreviewJson = pausedStep?.InputData;
                            _showCheckpointModal = true;
                            _executing = false;
                            StopPolling();
                            StateHasChanged();
                        });
                    }
                    return;
                }

                // Orchestrator waiting for review — open modal
                if (latest.Status == "WaitingForReview")
                {
                    var detail = await Api.GetExecutionDetailAsync(latest.Id);
                    if (detail is not null)
                    {
                        _executions = execs;
                        await InvokeAsync(() =>
                        {
                            OpenOrchestratorModal(detail);
                            StateHasChanged();
                        });
                    }
                    return;
                }

                // Execution finished — load full detail
                {
                    var detail = await Api.GetExecutionDetailAsync(latest.Id);
                    if (detail is not null)
                    {
                        _result = detail;
                        _executing = false;
                        _orchestratorActiveTasks = null;
                        _orchestratorTaskStatus.Clear();
                        _executions = execs;
                        StopPolling();
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch { /* poll failed, will retry next interval */ }
        }, null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(5));
    }

    private void StopPolling()
    {
        _pollTimer?.Dispose();
        _pollTimer = null;
    }

    private async Task LoadAll()
    {
        _loading = true;
        try
        {
            _project = await Api.GetProjectDetailAsync(ProjectId);
            // Immediately grab connections so they're available on first render
            _projectConnections = _project?.Connections ?? new();
            _modules = await Api.GetModulesAsync();
            _executions = await Api.GetExecutionsAsync(ProjectId);
            if (_project is not null)
                _stepOrder = _project.Modules.Count + 1;

            // Check if latest execution is waiting for checkpoint or orchestrator review
            var latestExec = _executions.FirstOrDefault();
            if (latestExec is not null && (latestExec.Status == "WaitingForCheckpoint" || latestExec.Status == "WaitingForReview"))
            {
                var detail = await Api.GetExecutionDetailAsync(latestExec.Id);
                if (detail is not null)
                {
                    _result = detail;
                    if (latestExec.Status == "WaitingForCheckpoint")
                    {
                        _checkpointExecutionId = detail.Id;
                        var pausedStep = detail.Steps?.FirstOrDefault(s => s.Status == "WaitingForCheckpoint");
                        _checkpointPreviewJson = pausedStep?.InputData;
                        _showCheckpointModal = false; // banner visible, modal on demand
                    }
                    else if (latestExec.Status == "WaitingForReview")
                    {
                        OpenOrchestratorModal(detail);
                    }
                }
            }

            // Load Telegram config
            var tgConfig = await Api.GetTelegramConfigAsync(ProjectId);
            if (tgConfig is not null)
            {
                _tgBotToken = tgConfig.BotToken;
                _tgChatId = tgConfig.ChatId;
            }

            // Load Buffer config (Instagram)
            var igConfig = await Api.GetInstagramConfigAsync(ProjectId);
            if (igConfig is not null)
            {
                _igApiKey = igConfig.ApiKey;
                _igChannelId = igConfig.ChannelId;
            }

            // Load TikTok config (Buffer)
            var tkConfig = await Api.GetTikTokConfigAsync(ProjectId);
            if (tkConfig is not null)
            {
                _tkApiKey = tkConfig.ApiKey;
                _tkChannelId = tkConfig.ChannelId;
            }

            // Load Schedule
            _schedule = await Api.GetScheduleAsync(ProjectId);
            if (_schedule is not null)
            {
                _schedCron = _schedule.CronExpression;
                _schedTimeZone = _schedule.TimeZone;
                _schedUserInput = _schedule.UserInput ?? "";
                // Try to detect preset from cron
                DetectPresetFromCron(_schedule.CronExpression);
            }

            // Load WhatsApp config
            var waConfig = await Api.GetWhatsAppConfigAsync(ProjectId);
            if (waConfig is not null)
            {
                _waPhoneNumberId = waConfig.PhoneNumberId;
                _waAccessToken = waConfig.AccessToken;
                _waRecipientNumber = waConfig.RecipientNumber;
                _waVerifyToken = waConfig.WebhookVerifyToken;
            }

