        }
        _loading = true;
        try
        {
            // Build config for interaction steps
            string? stepConfig = null;
            var mod = _modules.FirstOrDefault(m => m.Id == moduleId);
            if (mod?.ModuleType == "Interaction")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    messageTemplate = string.IsNullOrWhiteSpace(_interactionTemplate) ? "{previous_output}" : _interactionTemplate,
                    messageType = _interactionMessageType,
                    waitForResponse = _interactionWaitForResponse == "true"
                });
            }
            if (mod?.ModuleType == "Text" && _isImagePrompt)
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    isImagePrompt = true,
                    imageCount = _imageCount
                });
            }
            if (mod?.ModuleType == "Design")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    exportFormat = _canvaExportFormat,
                    designTitle = string.IsNullOrWhiteSpace(_canvaDesignTitle) ? "PixelAgents Design" : _canvaDesignTitle,
                    brandTemplateId = string.IsNullOrWhiteSpace(_canvaStepBrandTemplateId) ? (string?)null : _canvaStepBrandTemplateId,
                    designType = _canvaDesignType
                });
            }
            if (mod?.ModuleType == "Publish")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    caption = string.IsNullOrWhiteSpace(_publishCaption) ? "{previous_output}" : _publishCaption,
                    publishType = _publishType
                });
            }
            if (mod?.ModuleType == "Image" && !string.IsNullOrWhiteSpace(_imagePrompt))
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    imagePrompt = _imagePrompt.Trim()
                });
            }
            if (mod?.ModuleType == "Video")
            {
                if (string.IsNullOrWhiteSpace(_videoPrompt))
                {
                    _stepError = "El prompt del video es obligatorio.";
                    _loading = false;
                    return;
                }
                stepConfig = JsonSerializer.Serialize(new
                {
                    videoSource = _videoSource,
                    videoPrompt = _videoPrompt.Trim()
                });
            }
            if (mod?.ModuleType == "VideoEdit")
            {
                if (string.IsNullOrWhiteSpace(_videoPrompt))
                {
                    _stepError = "El guion del video es obligatorio.";
                    _loading = false;
                    return;
                }
                stepConfig = JsonSerializer.Serialize(new
                {
                    videoPrompt = _videoPrompt.Trim(),
                    subtitleLanguage = _j2vSubtitleLanguage
                });
            }
            var req = new AddProjectModuleRequest(moduleId, _stepOrder, _stepName, _inputMapping, stepConfig, _stepBranchId, _stepBranchFromStep);
            var (ok, error) = await Api.AddProjectModuleAsync(ProjectId, req);
            if (ok)
            {
                // Create orchestrator outputs if any were defined
                if (mod?.ModuleType == "Orchestrator" && _pendingOrchestratorOutputs.Count > 0)
                {
                    await LoadAll();
                    var newPm = _project.Modules.OrderByDescending(m => m.StepOrder).FirstOrDefault();
                    if (newPm is not null)
                    {
                        foreach (var po in _pendingOrchestratorOutputs)
                            await Api.CreateOrchestratorOutputAsync(ProjectId, newPm.Id, po);
                    }
                    _pendingOrchestratorOutputs.Clear();
                }
                _stepName = ""; _stepModuleId = ""; _interactionTemplate = ""; _interactionMessageType = "combined"; _interactionWaitForResponse = "true"; _isImagePrompt = false; _imageCount = 1; _imagePrompt = ""; _publishCaption = ""; _publishType = "post"; _canvaExportFormat = "png"; _canvaDesignTitle = ""; _canvaStepBrandTemplateId = ""; _canvaDesignType = "doc"; _videoSource = "prompt"; _videoPrompt = ""; _j2vSubtitleLanguage = "es"; _stepBranchId = "main"; _stepBranchFromStep = null;
                await LoadAll(); CleanPendingBranches();
            }
            else _stepError = error;
        }
        catch (Exception ex) { _stepError = $"Error de conexion: {ex.Message}"; }
