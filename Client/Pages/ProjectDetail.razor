    // Orchestrator task progress (real-time cards after approval)
    private List<OrchestratorTaskDto>? _orchestratorActiveTasks;
    private Dictionary<string, OrchestratorTaskProgressState> _orchestratorTaskStatus = new();

    // Telegram config
    private string _tgBotToken = "";
    private string _tgChatId = "";
    private string? _tgError;
