@page "/projects/{ProjectId:guid}"
@using System.Text.Json
@using System.Text.Encodings.Web
@using Client.Models
@using Client.Components.Pipeline
@using Microsoft.AspNetCore.SignalR.Client
@inject ApiClient Api
@inject IConfiguration Config
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

@if (_project is null)
{
    <p class="text-muted">Cargando...</p>
}
else
{
<div class="project-page-layout">
    <!-- ═══════════ PROJECT HEADER ═══════════ -->
    <div class="project-header">
        <div class="project-header-info">
            <h2 class="project-title">@_project.Name</h2>
            <p class="project-meta">@(_project.Description ?? "") &middot; Creado @_project.CreatedAt.ToString("dd MMM yyyy")</p>
        </div>
        <div class="project-header-actions">
            <!-- Integration status pills -->
            <div class="integration-pills">
                <span class="pill @(string.IsNullOrWhiteSpace(_telegramConnSel) ? "pill-off" : "pill-on")" title="Telegram">TG</span>
                <span class="pill @(string.IsNullOrWhiteSpace(_instagramConnSel) && string.IsNullOrWhiteSpace(_tiktokConnSel) && string.IsNullOrWhiteSpace(_pinterestConnSel) ? "pill-off" : "pill-on")" title="Buffer">BF</span>
                @if (_schedule is not null && _schedule.IsEnabled)
                {
                    <span class="pill pill-on" title="Programacion activa">&#x23f0;</span>
                }
                else
                {
                    <span class="pill pill-off" title="Sin programacion">&#x23f0;</span>
                }
            </div>
            <button class="btn-icon" @onclick="() => _showSettings = true" title="Configuracion">
                &#x2699;
            </button>
        </div>
    </div>

    <!-- Project Context (editable) -->
    @if (_editingContext)
    {
        <div class="context-bar context-bar-editing">
            <span class="context-label">Contexto</span>
            @if (_contextError is not null)
            {
                <div class="alert alert-error" style="margin:0 0 4px 0;font-size:.85rem;">@_contextError</div>
            }
            <textarea class="context-edit-input" @bind="_contextDraft" rows="3" placeholder="Escribe el contexto del proyecto..."></textarea>
            <div class="context-edit-actions">
                <button class="btn btn-primary btn-sm" @onclick="SaveContext" disabled="@_contextSaving">
                    @(_contextSaving ? "Guardando..." : "Guardar")
                </button>
                <button class="btn btn-sm" @onclick="CancelContextEdit">Cancelar</button>
            </div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_project.Context))
    {
        <div class="context-bar" @onclick="StartContextEdit" style="cursor:pointer;" title="Clic para editar">
            <span class="context-label">Contexto</span>
            <span class="context-text">@_project.Context</span>
            <span class="context-edit-icon">&#x270E;</span>
        </div>
    }
    else
    {
        <button class="btn btn-sm" style="margin-bottom:8px;" @onclick="StartContextEdit">+ Agregar contexto</button>
    }

    <!-- ═══════════ TABS ═══════════ -->
    <div class="tab-bar">
        <button class="tab @(_activeTab == "pipeline" ? "tab-active" : "")" @onclick='() => _activeTab = "pipeline"'>
            Pipeline
            @if (_project.Modules.Count > 0)
            {
                <span class="tab-count">@_project.Modules.Count</span>
            }
        </button>
        <button class="tab @(_activeTab == "history" ? "tab-active" : "")" @onclick="SwitchToHistoryTab">
            Historial
            @if (_executions.Count > 0)
            {
                <span class="tab-count">@_executions.Count</span>
            }
        </button>
    </div>

    <!-- ═══════════ TAB: PIPELINE ═══════════ -->
    @if (_activeTab == "pipeline")
    {
        <div class="tab-content">
            @if (_editError is not null)
            {
                <div class="alert alert-error" style="flex-shrink: 0;">@_editError</div>
            }

            <PipelineCanvas @ref="_pipelineCanvasRef"
                            ProjectId="_project.Id"
                            Modules="_project.Modules.ToList()"
                            AvailableModules="_modules"
                            Connections="_projectConnections"
                            TenantRules="_tenantRules"
                            OnAddModule="AddModuleFromCanvas"
                            OnRemoveModule="RemoveModuleFromCanvas"
                            OnModulesChanged="LoadAll"
                            OnSaveGraph="SaveGraph"
                            Executing="_executing"
                            StepStatuses="GetStepStatuses()"
                            ExecutionLogs="GetExecutionLogs()">
                <TopPanel>
                    <div class="execute-inline">
                        @if (_execError is not null)
                        {
                            <div class="alert alert-error" style="font-size: 0.75rem; padding: 0.3rem 0.5rem; margin-bottom: 0.3rem;">@_execError</div>
                        }
                        <div class="execution-mode-toggle">
                            <button class="execution-mode-btn @(_executionMode == "simple" ? "is-active" : "")"
                                    @onclick='() => SetExecutionMode("simple")'>Sencilla</button>
                            <button class="execution-mode-btn @(_executionMode == "planner" ? "is-active" : "")"
                                    @onclick='() => SetExecutionMode("planner")'>Planificador</button>
                        </div>
                        @if (_executionMode == "simple")
                        {
                            <textarea @bind="_userInput" rows="2" placeholder="Escribe tu prompt..." class="execute-inline-input"></textarea>
                            <label class="execute-history-toggle" title="Incluir resumen de ejecuciones anteriores para evitar repetir tematicas">
                                <input type="checkbox" @bind="_useHistory" />
                                <span>No repetir tematicas anteriores</span>
                            </label>
                            <div style="display: flex; gap: 0.3rem; margin-top: 0.3rem;">
                                <button class="btn btn-success btn-sm" style="flex: 1; font-size: 0.75rem; padding: 0.3rem;" @onclick="Execute" disabled="@_executing">
                                    @if (_executing)
                                    {
                                        <span class="spinner" style="width: 0.7rem; height: 0.7rem;"></span>
                                        <span>Ejecutando...</span>
                                    }
                                    else
                                    {
                                        <span>Ejecutar</span>
                                    }
                                </button>
                                @if (_executing)
                                {
                                    <button class="btn btn-danger btn-sm" style="font-size: 0.75rem; padding: 0.3rem;" @onclick="CancelExecution">Cancelar</button>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="planner-panel">
                                @if (_plannerError is not null)
                                {
                                    <div class="alert alert-error planner-alert">@_plannerError</div>
                                }
                                <label class="planner-field">
                                    <span class="planner-field-label">Modelo generador</span>
                                    <select @bind="_plannerModelName" class="planner-input">
                                        <option value="">-- elige modelo --</option>
                                        @foreach (var m in _plannerModels)
                                        {
                                            <option value="@m.ModelName">@m.DisplayName (@m.Provider)</option>
                                        }
                                    </select>
                                </label>
                                <label class="planner-field">
                                    <span class="planner-field-label">Cantidad</span>
                                    <input type="number" min="1" max="50" @bind="_plannerCount" class="planner-input" />
                                </label>
                                <label class="planner-field">
                                    <span class="planner-field-label">Instrucciones / necesidades</span>
                                    <textarea @bind="_plannerInstructions" rows="3" class="planner-input planner-textarea" placeholder="Describe que debe generar el planificador..."></textarea>
                                </label>
                                <label class="planner-checkbox">
                                    <input type="checkbox" @bind="_plannerReplace" />
                                    <span>Reemplazar pendientes existentes</span>
                                </label>
                                <button class="btn btn-primary btn-sm planner-generate-btn" @onclick="GeneratePlannedPrompts" disabled="@_plannerBusy">
                                    @if (_plannerBusy)
                                    {
                                        <span class="spinner" style="width: 0.7rem; height: 0.7rem;"></span>
                                        <span>Generando...</span>
                                    }
                                    else
                                    {
                                        <span>Generar prompts</span>
                                    }
                                </button>

                                <div class="planner-queue">
                                    <div class="planner-queue-header">
                                        <strong class="planner-queue-title">Cola de prompts (@_plannedPrompts.Count)</strong>
                                        <button class="btn btn-ghost btn-xs" @onclick="AddManualPrompt">+ Añadir</button>
                                    </div>
                                    @if (_plannedPrompts.Count == 0)
                                    {
                                        <div class="planner-queue-empty">No hay prompts en cola.</div>
                                    }
                                    else
                                    {
                                        <div class="planner-queue-list">
                                            @for (int i = 0; i < _plannedPrompts.Count; i++)
                                            {
                                                var idx = i;
                                                var p = _plannedPrompts[idx];
                                                var statusClass = p.Status == "Used" ? "is-used" : p.Status == "Skipped" ? "is-skipped" : "is-pending";
                                                <div class="planner-prompt-card @statusClass">
                                                    <div class="planner-prompt-toolbar">
                                                        <span class="planner-prompt-index">#@(idx + 1)</span>
                                                        <span class="planner-prompt-status">@p.Status</span>
                                                        @if (p.Status == "Pending")
                                                        {
                                                            <button class="btn btn-success btn-xs planner-prompt-run"
                                                                    title="Ejecutar este prompt ahora"
                                                                    disabled="@(_executingPromptId == p.Id || _executing)"
                                                                    @onclick="() => ExecutePlannedPrompt(p.Id)">
                                                                @if (_executingPromptId == p.Id)
                                                                {
                                                                    <span class="spinner" style="width: 0.55rem; height: 0.55rem;"></span>
                                                                }
                                                                else
                                                                {
                                                                    <span>&#9654; Ejecutar</span>
                                                                }
                                                            </button>
                                                        }
                                                        <div class="planner-prompt-actions @(p.Status == "Pending" ? "" : "is-pushed")">
                                                            <button class="btn btn-ghost btn-xs" disabled="@(idx == 0)" @onclick="() => MovePrompt(idx, -1)" title="Subir">&uarr;</button>
                                                            <button class="btn btn-ghost btn-xs" disabled="@(idx == _plannedPrompts.Count - 1)" @onclick="() => MovePrompt(idx, 1)" title="Bajar">&darr;</button>
                                                            <button class="btn btn-ghost btn-xs btn-danger-ghost" @onclick="() => DeletePrompt(p.Id)" title="Eliminar">&#x2715;</button>
                                                        </div>
                                                    </div>
                                                    @if (p.Status == "Pending")
                                                    {
                                                        <textarea rows="2" class="planner-prompt-editor"
                                                                  value="@p.Content"
                                                                  @onchange="@(e => OnPromptContentChanged(p.Id, e.Value?.ToString() ?? string.Empty))"></textarea>
                                                    }
                                                    else
                                                    {
                                                        <div class="planner-prompt-content">@p.Content</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="planner-history">
                                    <div class="planner-queue-header">
                                        <strong class="planner-queue-title">Historial de ejecuciones (@_executions.Count)</strong>
                                    </div>
                                    @if (_executions.Count == 0)
                                    {
                                        <div class="planner-queue-empty">No hay ejecuciones previas.</div>
                                    }
                                    else
                                    {
                                        <div class="planner-history-list">
                                            @foreach (var exec in _executions.Take(20))
                                            {
                                                var histStatusClass = exec.Status == "Completed" ? "is-used" : exec.Status == "Failed" ? "is-skipped" : "is-pending";
                                                <div class="planner-prompt-card @histStatusClass planner-history-card">
                                                    <div class="planner-prompt-toolbar">
                                                        <span class="planner-prompt-status">@exec.Status</span>
                                                        <span class="planner-history-date">@exec.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                                        <button class="btn btn-ghost btn-xs" title="Repetir esta ejecución"
                                                                disabled="@_executing"
                                                                @onclick="() => RepeatExecution(exec.UserInput)">
                                                            &#x27F3; Repetir
                                                        </button>
                                                    </div>
                                                    <div class="planner-prompt-content">
                                                        @(string.IsNullOrWhiteSpace(exec.UserInput) ? "(sin input)" : exec.UserInput)
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        @if (_executing || _result is not null)
                        {
                            <div class="execute-inline-status">
                                @if (_executing)
                                {
                                    <span class="spinner" style="width: 0.6rem; height: 0.6rem;"></span>
                                    <span>Pipeline en ejecucion...</span>
                                }
                                else if (_result is not null)
                                {
                                    <span class="badge @StatusBadge(_result.Status)" style="font-size: 0.65rem;">@_result.Status</span>
                                    @if (_result.TotalEstimatedCost > 0)
                                    {
                                        <span class="text-muted" style="font-size: 0.65rem;">~$@_result.TotalEstimatedCost.ToString("F4")</span>
                                    }
                                    <button class="btn btn-sm" style="font-size: 0.65rem; padding: 0.1rem 0.3rem; margin-left: auto;"
                                            @onclick='() => { _activeTab = "history"; }'>Ver detalles</button>
                                }
                            </div>
                        }
                        @if (_showCheckpointModal || _result?.Status == "WaitingForCheckpoint")
                        {
                            <div style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 6px; padding: 0.4rem 0.6rem; margin-top: 0.3rem; display: flex; align-items: center; gap: 0.4rem;">
                                <span style="font-size: 0.75rem; color: #856404; flex: 1;">Checkpoint esperando revision</span>
                                <button class="btn btn-success btn-sm" style="font-size: 0.7rem; padding: 0.2rem 0.5rem;" @onclick="@(() => ReviewCheckpoint(true))">Continuar</button>
                                <button class="btn btn-danger btn-sm" style="font-size: 0.7rem; padding: 0.2rem 0.5rem;" @onclick="@(() => ReviewCheckpoint(false))">Abortar</button>
                                <button class="btn btn-sm" style="font-size: 0.7rem; padding: 0.2rem 0.5rem; border: 1px solid var(--border-color);" @onclick="@(() => { _showCheckpointModal = true; StateHasChanged(); })">Ver datos</button>
                            </div>
                        }
                        @if (_showOrchestratorModal || _result?.Status == "WaitingForReview")
                        {
                            <div style="background: #e3f2fd; border: 1px solid #2196f3; border-radius: 6px; padding: 0.4rem 0.6rem; margin-top: 0.3rem; display: flex; align-items: center; gap: 0.4rem;">
                                <span style="font-size: 0.75rem; color: #1565c0; flex: 1;">Orquestador esperando revision</span>
                                <button class="btn btn-sm" style="font-size: 0.7rem; padding: 0.2rem 0.5rem; background: #2196f3; color: #fff; border: none;" @onclick="@(() => { _showOrchestratorModal = true; StateHasChanged(); })">Revisar plan</button>
                            </div>
                        }
                    </div>
                </TopPanel>
            </PipelineCanvas>
        </div> @* end tab-content *@

        @* ── Edit step modal ── *@
        @if (_editingPmId.HasValue)
        {
            var editPm = _project.Modules.FirstOrDefault(m => m.Id == _editingPmId);
            if (editPm is not null)
            {
                var catalogModule = _modules.FirstOrDefault(m => m.Id == editPm.AiModuleId);
                var catalogSystemPrompt = GetSystemPromptFromConfig(catalogModule?.Configuration);
                <div class="modal-overlay" @onclick="CancelEdit">
                    <div class="modal-content" @onclick:stopPropagation="true">
                        <div class="modal-header">
                            <span class="badge badge-@(editPm.ModuleType.ToLower())">@editPm.ModuleType</span>
                            <strong style="flex:1">Editar modulo &mdash; @(editPm.StepName ?? editPm.AiModuleName)</strong>
                            <button class="btn btn-xs" @onclick="CancelEdit">&#x2715;</button>
                        </div>
                        <div class="modal-body">
                            @if (_editError is not null)
                            {
                                <div class="alert alert-error" style="margin-bottom:0.8rem;">@_editError</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(catalogSystemPrompt) && editPm.ModuleType is "Text" or "Orchestrator" or "Coordinator" or "Image")
                            {
                                <div class="form-group">
                                    <label style="display:flex;align-items:center;gap:0.4rem;">
                                        Instrucciones del modulo
                                        <span class="text-sm text-muted">(definidas en el catalogo &mdash; solo lectura)</span>
                                    </label>
                                    <textarea rows="3" readonly style="background:var(--bg-secondary,#f5f5f5);color:var(--text-muted,#666);cursor:default;">@catalogSystemPrompt</textarea>
                                </div>
                            }
                            <div class="form-group">
                                <label>Nombre del paso</label>
                                <input type="text" @bind="_editStepName" placeholder="Nombre personalizado" />
                            </div>
                            @if (editPm.ModuleType == "Image")
                            {
                                <div class="form-group">
                                    <label>Prompt de imagen</label>
                                    <textarea @bind="_imagePrompt" rows="3" placeholder="Prompt de imagen (opcional)"></textarea>
                                </div>
                            }
                            @if (editPm.ModuleType == "Publish")
                            {
                                <div class="form-group">
                                    <label>Caption</label>
                                    <textarea @bind="_publishCaption" rows="3" placeholder="Caption ({previous_output})"></textarea>
                                </div>
                                <div class="form-group">
                                    <label>Tipo de publicacion</label>
                                    <select @bind="_publishType">
                                        <option value="post">Post</option>
                                        <option value="reel">Reel</option>
                                        <option value="story">Story</option>
                                    </select>
                                </div>
                            }
                            @if (editPm.ModuleType == "Interaction")
                            {
                                <div class="form-group">
                                    <label>Plantilla de mensaje</label>
                                    <textarea @bind="_interactionTemplate" rows="3" placeholder="Mensaje ({previous_output})"></textarea>
                                </div>
                                <div class="form-group">
                                    <label>Tipo de mensaje</label>
                                    <select @bind="_interactionMessageType">
                                        <option value="combined">Texto + Imagenes</option>
                                        <option value="text">Solo texto</option>
                                        <option value="image">Solo imagenes</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Respuesta</label>
                                    <select @bind="_interactionWaitForResponse">
                                        <option value="true">Esperar respuesta</option>
                                        <option value="false">Enviar y continuar</option>
                                    </select>
                                </div>
                            }
                            @if (editPm.ModuleType == "Design")
                            {
                                <div class="form-group">
                                    <label>Titulo del diseno</label>
                                    <input type="text" @bind="_canvaDesignTitle" placeholder="Titulo del diseno" />
                                </div>
                                <div class="form-group">
                                    <label>Formato de exportacion</label>
                                    <select @bind="_canvaExportFormat">
                                        <option value="png">PNG</option>
                                        <option value="jpg">JPG</option>
                                        <option value="pdf">PDF</option>
                                        <option value="pptx">PPTX</option>
                                    </select>
                                </div>
                            }
                            <div style="display:flex; gap:0.5rem; justify-content:flex-end; margin-top:1rem; padding-top:0.8rem; border-top:1px solid var(--border);">
                                <button class="btn" @onclick="CancelEdit">Cancelar</button>
                                <button class="btn btn-primary" @onclick="SaveEdit">Guardar</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    }

    <!-- Execute tab removed — UI is now in the pipeline inspector panel -->
    <!-- ═══════════ TAB: HISTORIAL ═══════════ -->
    @if (_activeTab == "history")
    {
        <div class="tab-content tab-content-scroll">
            @if (_executions.Count > 0)
            {
                var doneCount    = _executions.Count(e => e.Status == "Completed");
                var failedCount  = _executions.Count(e => e.Status == "Failed");
                var runningCount = _executions.Count(e => e.Status is "Running" or "WaitingForCheckpoint" or "WaitingForReview" or "WaitingForInput" or "Pending");
                var totalCost    = _executions.Sum(e => e.TotalEstimatedCost);
                var successRate  = _executions.Count > 0 ? (int)Math.Round(100.0 * doneCount / _executions.Count) : 0;

                @* ── Summary stats ── *@
                <div class="history-stats">
                    <div class="hstat">
                        <span class="hstat-value">@_executions.Count</span>
                        <span class="hstat-label">Ejecuciones</span>
                    </div>
                    <div class="hstat">
                        <span class="hstat-value hstat-ok">@successRate%</span>
                        <span class="hstat-label">Éxito</span>
                    </div>
                    <div class="hstat">
                        <span class="hstat-value">~$@totalCost.ToString("F2")</span>
                        <span class="hstat-label">Coste total</span>
                    </div>
                </div>

                @* ── Toolbar: search + status filters ── *@
                <div class="history-toolbar">
                    <div class="history-search">
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6">
                            <circle cx="7" cy="7" r="5"/><path d="M11 11l3.5 3.5" stroke-linecap="round"/>
                        </svg>
                        <input type="text" placeholder="Buscar por prompt…" value="@_historySearch"
                               @oninput="OnHistorySearchInput" />
                        @if (!string.IsNullOrEmpty(_historySearch))
                        {
                            <button class="history-search-clear" @onclick="@(() => SetHistoryStatus(_historyStatusFilter, clearSearch: true))" title="Limpiar">&#x2715;</button>
                        }
                    </div>
                    <div class="history-filters">
                        <button class="hf-chip @(_historyStatusFilter == "all" ? "hf-chip-active" : "")"
                                @onclick="@(() => SetHistoryStatus("all"))">
                            Todas <span class="hf-count">@_executions.Count</span>
                        </button>
                        <button class="hf-chip hf-ok @(_historyStatusFilter == "completed" ? "hf-chip-active" : "")"
                                @onclick="@(() => SetHistoryStatus("completed"))">
                            Completadas <span class="hf-count">@doneCount</span>
                        </button>
                        <button class="hf-chip hf-fail @(_historyStatusFilter == "failed" ? "hf-chip-active" : "")"
                                @onclick="@(() => SetHistoryStatus("failed"))">
                            Fallidas <span class="hf-count">@failedCount</span>
                        </button>
                        <button class="hf-chip hf-run @(_historyStatusFilter == "running" ? "hf-chip-active" : "")"
                                @onclick="@(() => SetHistoryStatus("running"))">
                            En curso <span class="hf-count">@runningCount</span>
                        </button>
                    </div>
                </div>

                var filtered  = FilteredHistory().ToList();
                var pageItems = filtered.Take(_historyPageSize).ToList();
                var dayGroups = pageItems
                    .GroupBy(e => e.CreatedAt.ToLocalTime().Date)
                    .OrderByDescending(g => g.Key)
                    .ToList();

                @if (filtered.Count == 0)
                {
                    <div class="empty-state" style="padding: 2.5rem 1rem;">
                        <span class="empty-state-icon">&#x1F50D;</span>
                        <p class="text-sm text-muted">Ninguna ejecución coincide con los filtros</p>
                        <button class="btn btn-sm" @onclick="@(() => SetHistoryStatus("all", clearSearch: true))">Limpiar filtros</button>
                    </div>
                }
                else
                {
                @foreach (var group in dayGroups)
                {
                    <div class="history-day">
                        <div class="history-day-header">
                            <span class="hd-day-label">@DayLabel(group.Key)</span>
                            <span class="hd-day-line"></span>
                            <span class="hd-day-count">@group.Count() @(group.Count() == 1 ? "ejecución" : "ejecuciones")</span>
                        </div>
                    @foreach (var e in group.OrderByDescending(x => x.CreatedAt))
                    {
                        var isExpanded = _expandedExecId == e.Id;
                        var hcClass = e.Status switch {
                            "Completed" => "hc-completed",
                            "Failed"    => "hc-failed",
                            "Running"   => "hc-running",
                            _           => "hc-pending"
                        };
                        <div class="history-card @hcClass" @key="e.Id">
                            <div class="history-card-header" @onclick="() => ToggleHistoryCard(e.Id)">
                                <span class="hc-time">@e.CreatedAt.ToLocalTime().ToString("HH:mm")</span>
                                <div class="history-card-main">
                                    <div class="history-card-meta">
                                        <span class="hc-status-pill hc-pill-@(e.Status.ToLower())">
                                            <span class="hc-dot hc-dot-@(e.Status.ToLower())"></span>
                                            @StatusLabelEs(e.Status)
                                        </span>
                                        @if (e.TotalEstimatedCost > 0)
                                        {
                                            <span class="hc-cost">~$@e.TotalEstimatedCost.ToString("F4")</span>
                                        }
                                    </div>
                                    <div class="history-card-prompt">
                                        @if (!string.IsNullOrWhiteSpace(e.UserInput))
                                        {
                                            <span class="hc-prompt-text">@(e.UserInput.Length > 140 ? e.UserInput[..140] + "…" : e.UserInput)</span>
                                        }
                                        else
                                        {
                                            <span class="hc-prompt-empty">Sin prompt</span>
                                        }
                                    </div>
                                </div>
                                <div class="history-card-actions">
                                    <button class="btn btn-sm hc-open-btn" @onclick="() => ViewExecution(e.Id)" @onclick:stopPropagation="true" title="Ver detalle completo">
                                        Ver detalle
                                    </button>
                                    <span class="history-expand-icon @(isExpanded ? "hc-chevron-up" : "")">&#x25BC;</span>
                                </div>
                            </div>

                            @if (isExpanded && _expandedExecDetail is not null && _expandedExecDetail.Id == e.Id)
                            {
                                var outputSteps = _expandedExecDetail.Steps
                                    .Where(s => s.Status != "Skipped")
                                    .OrderBy(s => s.CreatedAt)
                                    .ToList();
                                <div class="history-card-body">
                                    @if (outputSteps.Count == 0)
                                    {
                                        <p class="text-sm text-muted" style="margin:0;">Sin pasos registrados.</p>
                                    }
                                    @foreach (var step in outputSteps)
                                    {
                                        @if (step.Status == "WaitingForCheckpoint")
                                        {
                                            <div class="hc-step-block hc-step-checkpoint">
                                                <div class="hc-step-label">
                                                    <span class="hc-step-icon">⏸</span>
                                                    <span class="hc-step-name">@step.ModuleName</span>
                                                    <span class="hc-step-tag hc-tag-warning">Checkpoint</span>
                                                    @if (e.Status == "WaitingForCheckpoint")
                                                    {
                                                        <button class="btn btn-success btn-xs" style="font-size:0.65rem;"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="@(() => { _checkpointExecutionId = e.Id; _checkpointPreviewJson = step.InputData; _showCheckpointModal = true; StateHasChanged(); })">
                                                            Revisar
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        else if (step.OutputData is not null)
                                        {
                                            var parsed = TryParseOutput(step.OutputData);
                                            @if (parsed?.Type == "image" && parsed.Files is { Count: > 0 })
                                            {
                                                <div class="hc-step-block">
                                                    <div class="hc-step-label">
                                                        <span class="hc-step-icon">🖼</span>
                                                        <span class="hc-step-name">@step.ModuleName</span>
                                                        <span class="hc-step-tag">@parsed.Files.Count imagen(es)</span>
                                                    </div>
                                                    <div class="history-image-grid">
                                                        @foreach (var f in parsed.Files)
                                                        {
                                                            var fileUrl = $"{_apiBase}/api/executions/{_expandedExecDetail.Id}/files/{f.FileId}";
                                                            <div class="history-image-item">
                                                                <img src="@fileUrl" alt="@f.FileName" class="history-image-thumb" crossorigin="use-credentials" />
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            else if (parsed?.Type == "video" && parsed.Files is { Count: > 0 })
                                            {
                                                <div class="hc-step-block">
                                                    <div class="hc-step-label">
                                                        <span class="hc-step-icon">🎬</span>
                                                        <span class="hc-step-name">@step.ModuleName</span>
                                                    </div>
                                                    @foreach (var f in parsed.Files)
                                                    {
                                                        var fileUrl = $"{_apiBase}/api/executions/{_expandedExecDetail.Id}/files/{f.FileId}";
                                                        <video controls class="hc-video-preview" crossorigin="use-credentials">
                                                            <source src="@fileUrl" type="@f.ContentType" />
                                                        </video>
                                                    }
                                                </div>
                                            }
                                            else if (parsed?.Type == "text" && parsed.Content is not null)
                                            {
                                                <div class="hc-step-block">
                                                    <div class="hc-step-label">
                                                        <span class="hc-step-icon">✍</span>
                                                        <span class="hc-step-name">@step.ModuleName</span>
                                                    </div>
                                                    <div class="hc-text-preview">
                                                        @(parsed.Content.Length > 280 ? parsed.Content[..280] + "…" : parsed.Content)
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else if (step.ErrorMessage is not null)
                                        {
                                            <div class="hc-step-block hc-step-error">
                                                <div class="hc-step-label">
                                                    <span class="hc-step-icon">✗</span>
                                                    <span class="hc-step-name">@step.ModuleName</span>
                                                </div>
                                                <div class="hc-error-msg">@step.ErrorMessage</div>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                            else if (isExpanded && _expandedExecDetail is null)
                            {
                                <div class="history-card-body">
                                    <div class="hc-loading">
                                        <span class="spinner" style="width:1rem;height:1rem;"></span>
                                        <span class="text-sm text-muted">Cargando...</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    </div>
                }
                @if (filtered.Count > _historyPageSize)
                {
                    <div class="hc-load-more">
                        <span class="text-sm text-muted">Mostrando @pageItems.Count de @filtered.Count</span>
                        <button class="btn btn-sm" @onclick="() => _historyPageSize += 20">Ver 20 más</button>
                    </div>
                }
                }
            }
            else
            {
                <div class="empty-state">
                    <span class="empty-state-icon">&#x1F4CB;</span>
                    <p>Sin ejecuciones aun</p>
                    <p class="text-sm text-muted">Ejecuta el pipeline para ver resultados aqui</p>
                </div>
            }
        </div>
    }

</div> @* end project-page-layout *@

    <!-- ═══════════ EXECUTION DETAIL MODAL ═══════════ -->
    @if (_showExecDetailModal)
    {
        <div class="modal-overlay" @onclick="() => _showExecDetailModal = false">
            <div class="settings-modal" @onclick:stopPropagation="true" style="max-width: 1100px; width: 95vw;">
                <div class="settings-modal-header">
                    <h3 style="margin: 0;">Detalle de ejecucion</h3>
                    @if (_execDetailModal is not null && (_execDetailModal.Status == "Running" || _execDetailModal.Status == "WaitingForInput"))
                    {
                        <button class="btn btn-sm" style="margin-left: 0.5rem; font-size: 0.7rem;" @onclick="() => RefreshExecDetail(_execDetailModal.Id)">
                            &#x21BB; Actualizar
                        </button>
                    }
                    <button class="btn-icon" @onclick="() => { _showExecDetailModal = false; _execDetailRefreshTimer?.Dispose(); }">&#x2715;</button>
                </div>
                <div class="settings-modal-body" style="max-height: 75vh; overflow: hidden; padding: 0;">
                    @if (_execDetailModal is null)
                    {
                        <p class="text-muted" style="padding: 1rem;">Cargando...</p>
                    }
                    else
                    {
                        <div style="padding: 0.5rem 0.8rem;">
                            <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem; flex-wrap: wrap;">
                                <span class="badge @StatusBadge(_execDetailModal.Status)">@_execDetailModal.Status</span>
                                <span class="text-sm text-muted">@_execDetailModal.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                                @if (_execDetailModal.CompletedAt.HasValue)
                                {
                                    <span class="text-sm text-muted">- @_execDetailModal.CompletedAt.Value.ToString("HH:mm")</span>
                                }
                                @if (_execDetailModal.TotalEstimatedCost > 0)
                                {
                                    <span class="text-sm text-muted">~$@_execDetailModal.TotalEstimatedCost.ToString("F4")</span>
                                }
                            </div>
                            @if (_execDetailModal.UserInput is not null)
                            {
                                <div class="output-block" style="font-size: 0.8rem; margin-bottom: 0.5rem; max-height: 60px; overflow-y: auto;">
                                    <strong>Prompt:</strong> @_execDetailModal.UserInput
                                </div>
                            }
                        </div>

                        <div style="display: flex; gap: 0; height: calc(75vh - 130px); overflow: hidden;">
                            <!-- Left: Steps -->
                            <div style="flex: 1; overflow-y: auto; padding: 0 0.8rem 0.8rem; border-right: 1px solid var(--border);">
                                @{ var visibleSteps = _execDetailModal.Steps
                                    .Where(s => !PassThroughModuleTypes.Contains(s.ModuleType))
                                    .OrderBy(s => s.CreatedAt).ToList();
                                   var stepIdx = 0; }
                                @foreach (var step in visibleSteps)
                                {
                                    stepIdx++;
                                    var isExpanded = _expandedSteps.Contains(step.ProjectModuleId);
                                    var capturedModuleId = step.ProjectModuleId;
                                    var duration = step.CompletedAt.HasValue ? (step.CompletedAt.Value - step.CreatedAt).TotalSeconds : 0;

                                    <div class="exec-step-card @(step.Status == "Failed" ? "exec-step-failed" : step.Status == "Running" ? "exec-step-running" : "")">
                                        @* ── Compact header (always visible) ── *@
                                        <div class="exec-step-header" @onclick="() => ToggleStepExpanded(capturedModuleId)">
                                            <span class="exec-step-badge">@stepIdx</span>
                                            <span class="exec-step-name">@step.ModuleName</span>
                                            <span class="badge @StatusBadge(step.Status)" style="font-size: 0.58rem;">@step.Status</span>
                                            @if (step.EstimatedCost > 0)
                                            {
                                                <span class="text-sm text-muted">$@step.EstimatedCost.ToString("F4")</span>
                                            }
                                            @if (duration > 0)
                                            {
                                                <span class="text-sm text-muted">@(duration < 1 ? "<1s" : $"{duration:F0}s")</span>
                                            }
                                            @if (step.Status == "WaitingForCheckpoint" && _execDetailModal.Status == "WaitingForCheckpoint")
                                            {
                                                <button class="btn btn-success btn-xs" style="font-size: 0.6rem; margin-left: auto; padding: 0.1rem 0.35rem;"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="@(() => { _checkpointExecutionId = _execDetailModal.Id; _checkpointPreviewJson = step.InputData; _showCheckpointModal = true; StateHasChanged(); })">
                                                    Revisar
                                                </button>
                                            }
                                            <span class="exec-step-chevron @(isExpanded ? "expanded" : "")">&#x25B6;</span>
                                        </div>

                                        @if (step.ErrorMessage is not null)
                                        {
                                            <div class="alert alert-error" style="font-size: 0.72rem; padding: 0.25rem 0.5rem; margin: 0.3rem 0 0;">@step.ErrorMessage</div>
                                        }

                                        @* ── Summary line (compact view): show a brief output preview ── *@
                                        @if (!isExpanded && step.OutputData is not null)
                                        {
                                            var preview = TryParseOutput(step.OutputData);
                                            @if (preview?.Type == "text" && preview.Content is not null)
                                            {
                                                <div class="exec-step-preview">@(preview.Content.Length > 120 ? preview.Content[..120] + "..." : preview.Content)</div>
                                            }
                                            else if (preview?.Type == "scene" && preview.Content is not null)
                                            {
                                                var scenePreview = FormatJson(preview.Content) ?? preview.Content;
                                                <div class="exec-step-preview">@(scenePreview.Length > 120 ? scenePreview[..120] + "..." : scenePreview)</div>
                                            }
                                            else if (preview?.Files is { Count: > 0 })
                                            {
                                                <div class="exec-step-preview">@preview.Files.Count archivo(s): @string.Join(", ", preview.Files.Select(f => f.FileName))</div>
                                            }
                                        }

                                        @* ── Expanded detail ── *@
                                        @if (isExpanded)
                                        {
                                            <div class="exec-step-detail">
                                                @* ── INPUTS ── *@
                                                @if (step.InputData is not null)
                                                {
                                                    @if (step.Status == "WaitingForCheckpoint" || step.ModuleName?.Contains("Checkpoint", StringComparison.OrdinalIgnoreCase) == true)
                                                    {
                                                        <div class="exec-io-section">
                                                            <div class="exec-io-title exec-io-in">Datos del Checkpoint</div>
                                                            <pre class="exec-io-block">@step.InputData</pre>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        var inputParsed = ParseInputData(step.InputData);
                                                        @if (inputParsed is not null)
                                                        {
                                                            @if (!string.IsNullOrWhiteSpace(inputParsed.MandatoryRules))
                                                            {
                                                                <div class="exec-io-section">
                                                                    <div class="exec-io-title exec-io-in">Reglas obligatorias</div>
                                                                    <div class="exec-io-block">@inputParsed.MandatoryRules</div>
                                                                </div>
                                                            }
                                                            @if (inputParsed.SystemPrompt is not null)
                                                            {
                                                                <div class="exec-io-section">
                                                                    <div class="exec-io-title exec-io-in">System Prompt</div>
                                                                    <div class="exec-io-block">@inputParsed.SystemPrompt</div>
                                                                </div>
                                                            }
                                                            @if (inputParsed.Prompts.Count > 0)
                                                            {
                                                                @foreach (var (prompt, pi) in inputParsed.Prompts.Select((p, i) => (p, i)))
                                                                {
                                                                    <div class="exec-io-section">
                                                                        <div class="exec-io-title exec-io-in">@(inputParsed.Prompts.Count > 1 ? $"Input {pi + 1}" : "Input")</div>
                                                                        <div class="exec-io-block">@prompt</div>
                                                                    </div>
                                                                }
                                                            }
                                                            @if (inputParsed.SystemPrompt is null && inputParsed.Prompts.Count == 0)
                                                            {
                                                                <div class="exec-io-section">
                                                                    <div class="exec-io-title exec-io-in">Input</div>
                                                                    <pre class="exec-io-block">@inputParsed.RawJson</pre>
                                                                </div>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <div class="exec-io-section">
                                                                <div class="exec-io-title exec-io-in">Input</div>
                                                                <pre class="exec-io-block">@step.InputData</pre>
                                                            </div>
                                                        }

                                                        @* ── Raw payload (exact data sent to the provider API) ── *@
                                                        var rawExpanded = _expandedRawPayloadSteps.Contains(step.ProjectModuleId);
                                                        <div class="exec-io-section">
                                                            <button type="button"
                                                                    class="btn btn-sm"
                                                                    @onclick="() => ToggleRawPayload(step.ProjectModuleId)">
                                                                @(rawExpanded ? "Ocultar payload enviado" : "Ver payload enviado a la API")
                                                            </button>
                                                            @if (rawExpanded)
                                                            {
                                                                <pre class="exec-io-block" style="margin-top:8px;">@(inputParsed?.RawJson ?? step.InputData)</pre>
                                                            }
                                                        </div>
                                                    }
                                                }

                                                @* ── OUTPUTS ── *@
                                                @if (step.OutputData is not null)
                                                {
                                                    var parsed = TryParseOutput(step.OutputData);
                                                    @if (parsed?.Type == "text")
                                                    {
                                                        @if (parsed.Items is { Count: > 0 })
                                                        {
                                                            @foreach (var (item, oi) in parsed.Items.Select((it, i) => (it, i)))
                                                            {
                                                                <div class="exec-io-section">
                                                                    <div class="exec-io-title exec-io-out">@(parsed.Items.Count > 1 ? $"Output {oi + 1}" : "Output") @(item.Label is not null ? $"({item.Label})" : "")</div>
                                                                    <div class="exec-io-block">@item.Content</div>
                                                                </div>
                                                            }
                                                        }
                                                        @if (parsed.Content is not null)
                                                        {
                                                            <div class="exec-io-section">
                                                                <div class="exec-io-title exec-io-out">@(parsed.Items is { Count: > 0 } ? "Content" : "Output")</div>
                                                                <div class="exec-io-block">@parsed.Content</div>
                                                            </div>
                                                        }
                                                    }
                                                    else if (parsed?.Files is { Count: > 0 })
                                                    {
                                                        <div class="exec-io-section">
                                                            <div class="exec-io-title exec-io-out">Output (@parsed.Files.Count archivo/s)</div>
                                                            @if (parsed.Type == "image")
                                                            {
                                                                <div class="history-image-grid" style="margin-top: 0.2rem;">
                                                                    @foreach (var f in parsed.Files)
                                                                    {
                                                                        var fileUrl = $"{_apiBase}/api/executions/{_execDetailModal.Id}/files/{f.FileId}";
                                                                        <div class="history-image-item">
                                                                            <img src="@fileUrl" alt="@f.FileName" class="history-image-thumb" crossorigin="use-credentials" style="max-width: 200px;" />
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                @foreach (var f in parsed.Files)
                                                                {
                                                                    var fileUrl = $"{_apiBase}/api/executions/{_execDetailModal.Id}/files/{f.FileId}";
                                                                    @if (parsed.Type == "video")
                                                                    {
                                                                        <video controls style="max-width: 300px; border-radius: 6px; margin-top: 0.3rem;" crossorigin="use-credentials">
                                                                            <source src="@fileUrl" type="@f.ContentType" />
                                                                        </video>
                                                                    }
                                                                }
                                                            }
                                                        </div>
                                                    }
                                                    else if (parsed?.Type == "scene" && parsed.Content is not null)
                                                    {
                                                        <div class="exec-io-section">
                                                            <div class="exec-io-title exec-io-out">Output escena</div>
                                                            <pre class="exec-io-block">@(FormatJson(parsed.Content) ?? parsed.Content)</pre>
                                                        </div>
                                                    }
                                                    else if (parsed?.Content is not null)
                                                    {
                                                        <div class="exec-io-section">
                                                            <div class="exec-io-title exec-io-out">Output</div>
                                                            <div class="exec-io-block">@parsed.Content</div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="exec-io-section">
                                                            <div class="exec-io-title exec-io-out">Output</div>
                                                            <pre class="exec-io-block">@(FormatJson(step.OutputData) ?? step.OutputData)</pre>
                                                        </div>
                                                    }
                                                }

                                                @* ── FILES ── *@
                                                @if (step.Files is { Count: > 0 })
                                                {
                                                    <div class="exec-io-section">
                                                        <div class="exec-io-title" style="color: var(--text-muted);">Archivos</div>
                                                        <div style="display: flex; flex-wrap: wrap; gap: 0.3rem;">
                                                            @foreach (var file in step.Files.Where(f => f.Direction == "Output"))
                                                            {
                                                                var capturedFile = file;
                                                                var capturedExecId = _execDetailModal.Id;
                                                                <button class="btn btn-sm" style="font-size: 0.7rem; padding: 0.12rem 0.35rem;"
                                                                        @onclick="() => DownloadFile(capturedExecId, capturedFile.Id, capturedFile.FileName)">
                                                                    &#x2B73; @file.FileName <span class="text-muted">(@FormatFileSize(file.FileSize))</span>
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                }

                                                @* ── RETRY ── *@
                                                @if ((step.Status == "Completed" || step.Status == "Failed") && !_executing)
                                                {
                                                    var capturedModuleIdForRetry = step.ProjectModuleId;
                                                    <div style="margin-top: 0.4rem; display: flex; align-items: center; gap: 0.3rem; flex-wrap: wrap;">
                                                        <button class="btn btn-sm btn-outline" style="font-size: 0.68rem; padding: 0.12rem 0.4rem;"
                                                                @onclick="() => ToggleRetryPanel(capturedModuleIdForRetry)">
                                                            &#x21BB; Reiniciar desde aqui
                                                        </button>
                                                        @if (_retryModuleId == capturedModuleIdForRetry)
                                                        {
                                                            <input type="text" @bind="_retryComment" placeholder="Comentario..."
                                                                   style="font-size: 0.72rem; padding: 0.15rem 0.35rem; flex: 1; min-width: 100px;" />
                                                            <button class="btn btn-sm btn-primary" style="font-size: 0.68rem; padding: 0.12rem 0.4rem;"
                                                                    @onclick="() => RetryFromModule(capturedModuleIdForRetry)">
                                                                Ejecutar
                                                            </button>
                                                        }
                                                    </div>
                                                    @if (_retryError is not null && _retryModuleId == capturedModuleIdForRetry)
                                                    {
                                                        <div class="alert alert-error" style="font-size: 0.68rem; padding: 0.2rem 0.4rem; margin-top: 0.2rem;">@_retryError</div>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- Right: Logs -->
                            <div style="width: 360px; min-width: 280px; overflow-y: auto; padding: 0 0.8rem 0.8rem; display: flex; flex-direction: column;">
                                <div style="font-weight: 600; font-size: 0.85rem; padding: 0.3rem 0; position: sticky; top: 0; background: var(--bg-secondary); z-index: 1;">
                                    Logs @(_execDetailLogs is { Count: > 0 } ? $"({_execDetailLogs.Count})" : "")
                                </div>
                                @if (_execDetailLogs is { Count: > 0 })
                                {
                                    <div class="inspector-log-entries" style="flex: 1;">
                                        @foreach (var log in _execDetailLogs)
                                        {
                                            @if (log.Level == "step-start")
                                            {
                                                <div class="inspector-log-step-header">
                                                    <span class="inspector-log-time">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                                    @if (log.ProjectModuleId.HasValue)
                                                    {
                                                        var logModule = _project?.Modules.FirstOrDefault(m => m.Id == log.ProjectModuleId.Value);
                                                        <span class="inspector-log-step-badge">@(logModule?.StepName ?? logModule?.AiModuleName ?? log.ModuleName)</span>
                                                    }
                                                    <span class="inspector-log-step-name">@log.Message</span>
                                                </div>
                                            }
                                            else if (log.Level == "input")
                                            {
                                                <div class="inspector-log-io inspector-log-io-in">
                                                    <span class="inspector-log-io-label">IN</span>
                                                    <span class="inspector-log-io-text">@log.Message</span>
                                                </div>
                                            }
                                            else if (log.Level == "output")
                                            {
                                                <div class="inspector-log-io inspector-log-io-out">
                                                    <span class="inspector-log-io-label">OUT</span>
                                                    <span class="inspector-log-io-text">@log.Message</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="inspector-log-entry inspector-log-@log.Level">
                                                    <span class="inspector-log-time">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                                    @if (log.ProjectModuleId.HasValue)
                                                    {
                                                        var logModule = _project?.Modules.FirstOrDefault(m => m.Id == log.ProjectModuleId.Value);
                                                        <span class="inspector-log-step">@(logModule?.StepName ?? logModule?.AiModuleName ?? log.ModuleName)</span>
                                                    }
                                                    <span>@log.Message</span>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-sm text-muted">Sin logs</p>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- ═══════════ SETTINGS MODAL ═══════════ -->
    @if (_showSettings)
    {
        <div class="modal-overlay" @onclick="() => _showSettings = false">
            <div class="settings-modal" @onclick:stopPropagation="true">
                <div class="settings-modal-header">
                    <h3 style="margin: 0;">Configuracion</h3>
                    <button class="btn-icon" @onclick="() => _showSettings = false">&#x2715;</button>
                </div>

