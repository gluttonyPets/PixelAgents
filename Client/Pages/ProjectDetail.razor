            <div class="modal-body">
                <h4>Request</h4>
                <pre class="debug-pre">@_bufferDebugRequest</pre>
                <h4>Response</h4>
                <pre class="debug-pre">@_bufferDebugResponse</pre>
            </div>
        </div>
    </div>
}

