                                    <textarea @bind="_interactionTemplate" rows="3" placeholder="Mensaje ({previous_output})"></textarea>
                                </div>
                                <div class="form-group">
                                    <label>Tipo de mensaje</label>
                                    <select @bind="_interactionMessageType">
                                        <option value="combined">Texto + Imagenes</option>
                                        <option value="text">Solo texto</option>
                                        <option value="image">Solo imagenes</option>
