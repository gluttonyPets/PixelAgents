    private string BuildCronFromPreset()
    {
        return _schedPreset switch
        {
            "daily" => $"{_schedMinute1} {_schedHour1} * * *",
            "twice" => $"{_schedMinute1} {_schedHour1},{_schedHour2} * * *",
            "weekly" => $"{_schedMinute1} {_schedHour1} * * {_schedDayOfWeek}",
            _ => _schedCron
        };
    }

    private void DetectPresetFromCron(string cron)
    {
        var parts = cron.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length != 5) { _schedPreset = ""; return; }

        // daily: M H * * *
        if (parts[2] == "*" && parts[3] == "*" && parts[4] == "*"
            && int.TryParse(parts[0], out var m1) && int.TryParse(parts[1], out var h1)
            && !parts[1].Contains(','))
        {
            _schedPreset = "daily";
            _schedHour1 = h1;
            _schedMinute1 = m1;
            return;
        }

        // twice: M H1,H2 * * *
        if (parts[2] == "*" && parts[3] == "*" && parts[4] == "*"
            && int.TryParse(parts[0], out var m2) && parts[1].Contains(','))
        {
            var hours = parts[1].Split(',');
            if (hours.Length == 2 && int.TryParse(hours[0], out var ha) && int.TryParse(hours[1], out var hb))
            {
                _schedPreset = "twice";
                _schedMinute1 = m2;
                _schedHour1 = ha;
                _schedHour2 = hb;
                return;
            }
        }

        // weekly: M H * * DOW
        if (parts[2] == "*" && parts[3] == "*" && parts[4] != "*"
            && int.TryParse(parts[0], out var m3) && int.TryParse(parts[1], out var h3))
        {
            _schedPreset = "weekly";
            _schedMinute1 = m3;
            _schedHour1 = h3;
            _schedDayOfWeek = parts[4];
            return;
        }

        _schedPreset = "";
    }

    private async Task SaveSchedule()
    {
        _schedError = null;
        _schedSuccess = false;
        _schedSaving = true;
        try
        {
            var cron = BuildCronFromPreset();
            if (string.IsNullOrWhiteSpace(cron))
            {
                _schedError = "Debes configurar una expresion cron o seleccionar una frecuencia.";
                _schedSaving = false;
                return;
            }

            var input = string.IsNullOrWhiteSpace(_schedUserInput) ? null : _schedUserInput;

            if (_schedule is null)
            {
                var (ok, result, error) = await Api.CreateScheduleAsync(ProjectId,
                    new CreateScheduleRequest(cron, _schedTimeZone, input));
                if (ok)
                {
                    _schedule = result;
                    _schedSuccess = true;
                }
                else
                    _schedError = error;
            }
            else
            {
                var (ok, result, error) = await Api.UpdateScheduleAsync(ProjectId,
                    new UpdateScheduleRequest(cron, _schedTimeZone, input, _schedule.IsEnabled));
                if (ok)
                {
                    _schedule = result;
                    _schedSuccess = true;
                }
                else
                    _schedError = error;
            }
        }
        catch (Exception ex) { _schedError = ex.Message; }
        _schedSaving = false;
    }

    private async Task ToggleSchedule()
    {
        if (_schedule is null) return;
        _schedError = null;
        _schedSuccess = false;
        _schedSaving = true;
        try
        {
            var cron = _schedule.CronExpression;
            var tz = _schedule.TimeZone;
            var input = _schedule.UserInput;
            var newEnabled = !_schedule.IsEnabled;

            var (ok, result, error) = await Api.UpdateScheduleAsync(ProjectId,
                new UpdateScheduleRequest(cron, tz, input, newEnabled));
            if (ok)
            {
                _schedule = result;
                _schedSuccess = true;
            }
            else
                _schedError = error;
        }
        catch (Exception ex) { _schedError = ex.Message; }
        _schedSaving = false;
    }

    private async Task DeleteSchedule()
