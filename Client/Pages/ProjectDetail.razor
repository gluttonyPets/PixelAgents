    private async Task ReviewOrchestrator(bool approved)
    {
        if (_result is null) return;
        _orchestratorError = null;
        _orchestratorReviewing = true;

        try
        {
            var comment = string.IsNullOrWhiteSpace(_orchestratorComment) ? null : _orchestratorComment;
            var (ok, error) = await Api.OrchestratorReviewAsync(_result.Id, approved, comment);
            if (ok)
            {
                _orchestratorComment = "";
                if (approved)
                {
                    _executing = true;
                    _logEntries.Clear();
                    StartPolling();
                }
                else
                {
                    // Rejected: reload to show updated status
                    _result = await Api.GetExecutionDetailAsync(_result.Id);
                    await InvokeAsync(StateHasChanged);
                }
            }
            else
            {
                _orchestratorError = error;
            }
        }
        catch (Exception ex) { _orchestratorError = $"Error de conexion: {ex.Message}"; }
        _orchestratorReviewing = false;
    }

    private List<OrchestratorTaskDto>? TryParseOrchestratorPlan(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return null;
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(json);
            if (!doc.RootElement.TryGetProperty("tasks", out var tasksEl)) return null;

            var tasks = new List<OrchestratorTaskDto>();
            foreach (var t in tasksEl.EnumerateArray())
            {
                tasks.Add(new OrchestratorTaskDto
                {
                    TaskId = t.TryGetProperty("taskId", out var tid) ? tid.GetString() ?? "" : "",
                    Description = t.TryGetProperty("description", out var desc) ? desc.GetString() ?? "" : "",
                    ModuleId = t.TryGetProperty("moduleId", out var mid) ? mid.GetString() ?? "" : "",
                    ModuleName = t.TryGetProperty("moduleName", out var mn) ? mn.GetString() ?? "" : "",
                    ModuleType = t.TryGetProperty("moduleType", out var mt) ? mt.GetString() ?? "" : "",
                    Input = t.TryGetProperty("input", out var inp) ? inp.GetString() ?? "" : "",
                    Order = t.TryGetProperty("order", out var ord) ? ord.GetInt32() : 0,
                    Reason = t.TryGetProperty("reason", out var r) ? r.GetString() ?? "" : "",
                });
            }
            return tasks;
        }
        catch { return null; }
    }

    private class OrchestratorTaskDto
    {
        public string TaskId { get; set; } = "";
        public string Description { get; set; } = "";
        public string ModuleId { get; set; } = "";
        public string ModuleName { get; set; } = "";
        public string ModuleType { get; set; } = "";
        public string Input { get; set; } = "";
        public int Order { get; set; }
        public string Reason { get; set; } = "";
    }

    private class OrchestratorChatMessage
    {
        public string Text { get; set; } = "";
        public DateTime Time { get; set; }
        public bool IsSystem { get; set; }
    }

    private void OpenOrchestratorModal(ExecutionDetailResponse detail)
    {
        _result = detail;
        _executing = false;
        StopPolling();

        // Find the WaitingForReview step and parse its plan
        var reviewStep = detail.Steps.FirstOrDefault(s => s.Status == "WaitingForReview");
        if (reviewStep is null) return;

        _orchestratorModalTasks = TryParseOrchestratorPlan(reviewStep.OutputData);
        _orchestratorModalSummary = TryParseOrchestratorSummary(reviewStep.OutputData);
        _orchestratorComment = "";
        _orchestratorError = null;
        _orchestratorChat.Clear();
        _orchestratorChat.Add(new OrchestratorChatMessage
        {
            Text = $"Plan generado con {_orchestratorModalTasks?.Count ?? 0} tarea(s). Revisa el detalle arriba.",
            Time = DateTime.Now,
            IsSystem = true,
        });
        _showOrchestratorModal = true;
        _activeTab = "execute";
    }

    private string? TryParseOrchestratorSummary(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return null;
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(json);
            return doc.RootElement.TryGetProperty("summary", out var s) ? s.GetString() : null;
        }
        catch { return null; }
    }

    private void CloseOrchestratorModal()
    {
        _showOrchestratorModal = false;
    }

    private async Task ReviewOrchestratorModal(bool approved)
    {
        if (_result is null) return;
        _orchestratorError = null;
        _orchestratorReviewing = true;

        try
        {
            var comment = string.IsNullOrWhiteSpace(_orchestratorComment) ? null : _orchestratorComment;

            // Add user message to chat
            if (!string.IsNullOrWhiteSpace(comment))
            {
                _orchestratorChat.Add(new OrchestratorChatMessage
                {
                    Text = comment,
                    Time = DateTime.Now,
                    IsSystem = false,
                });
            }

            var (ok, error) = await Api.OrchestratorReviewAsync(_result.Id, approved, comment);
            if (ok)
            {
                _orchestratorComment = "";
                if (approved)
                {
                    _orchestratorChat.Add(new OrchestratorChatMessage
                    {
                        Text = "Plan aprobado. Ejecutando tareas...",
                        Time = DateTime.Now,
                        IsSystem = true,
                    });
                    _showOrchestratorModal = false;
                    _executing = true;
                    _logEntries.Clear();
                    StartPolling();
                }
                else
                {
                    _orchestratorChat.Add(new OrchestratorChatMessage
                    {
                        Text = "Plan rechazado. Tu comentario se guardara para la proxima ejecucion.",
                        Time = DateTime.Now,
                        IsSystem = true,
                    });
                    // Reload to show updated status
                    _result = await Api.GetExecutionDetailAsync(_result.Id);
                    _executions = await Api.GetExecutionsAsync(ProjectId);
                    // Keep modal open briefly so user sees the chat, then close
                    await Task.Delay(1500);
                    _showOrchestratorModal = false;
                    await InvokeAsync(StateHasChanged);
                }
            }
            else
            {
                _orchestratorError = error;
            }
        }
        catch (Exception ex) { _orchestratorError = $"Error de conexion: {ex.Message}"; }
        _orchestratorReviewing = false;
    }

