@if (_showCheckpointModal)
{
    <div class="modal-overlay" @onclick="@(() => { _showCheckpointModal = false; })">
        <div class="modal-content" style="max-width: 750px;" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: var(--bg-input); border-bottom: 1px solid var(--border);">
                <span style="color: var(--warning); font-size: 1rem; margin-right: 0.2rem;">&#9632;</span>
                <strong style="font-size: 0.9rem;">Checkpoint - Revision de datos</strong>
                <div style="margin-left: auto; display: flex; gap: 0.3rem; align-items: center;">
                    <button class="btn btn-sm @(_checkpointRawView ? "" : "btn-primary")" style="font-size: 0.65rem; padding: 0.15rem 0.4rem;"
                            @onclick="@(() => { _checkpointRawView = false; })">Formal</button>
                    <button class="btn btn-sm @(_checkpointRawView ? "btn-primary" : "")" style="font-size: 0.65rem; padding: 0.15rem 0.4rem;"
                            @onclick="@(() => { _checkpointRawView = true; })">Raw</button>
                    <button class="btn btn-sm" style="padding: 0.1rem 0.4rem; font-size: 0.8rem;"
                            @onclick="@(() => { _showCheckpointModal = false; })">X</button>
                </div>
            </div>
            <div class="modal-body" style="padding: 0.8rem 1rem;">
                <div style="background: #332b00; color: #ffc107; border: 1px solid #665500; font-size: 0.78rem; padding: 0.45rem 0.65rem; margin-bottom: 0.7rem; border-radius: 0.35rem;">
                    El pipeline se ha pausado en un punto de control. Revisa los datos recibidos antes de continuar.
                </div>

                @if (!string.IsNullOrEmpty(_checkpointPreviewJson))
                {
                    @if (_checkpointRawView)
                    {
                        <pre style="background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 0.6rem; font-size: 0.7rem; max-height: 400px; overflow: auto; white-space: pre-wrap; word-break: break-word;">@_checkpointPreviewJson</pre>
                    }
                    else
                    {
                        @foreach (var entry in ParseCheckpointEntries(_checkpointPreviewJson))
                        {
                            <div style="margin-bottom: 0.6rem;">
                                <div style="font-size: 0.72rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.03em; margin-bottom: 0.25rem;">
                                    @entry.Label
                                </div>
                                <div style="background: var(--bg); border: 1px solid var(--border); border-radius: 5px; padding: 0.45rem 0.6rem; font-size: 0.78rem; max-height: 180px; overflow-y: auto; white-space: pre-wrap; word-break: break-word; line-height: 1.45;">@entry.Value</div>
                            </div>
                        }
                    }
                }

                <div style="display: flex; gap: 0.5rem; margin-top: 0.8rem; padding-top: 0.6rem; border-top: 1px solid var(--border);">
                    <button class="btn btn-success" style="flex: 1; font-size: 0.85rem; padding: 0.45rem;" @onclick="@(() => ReviewCheckpoint(true))">Continuar</button>
                    <button class="btn btn-danger" style="flex: 1; font-size: 0.85rem; padding: 0.45rem;" @onclick="@(() => ReviewCheckpoint(false))">Abortar</button>
                </div>
            </div>
        </div>
    </div>
}

