    private void HistoryDateNav(int direction)
    {
        var days = _executions.Select(e => e.CreatedAt.Date).Distinct().OrderByDescending(d => d).ToList();
        if (days.Count == 0) return;

        if (_historyShowAll)
        {
            _historyShowAll = false;
            _historyDateFilter = direction < 0 ? days.First() : days.Last();
            return;
        }

        var idx = days.IndexOf(_historyDateFilter.Date);
        if (idx < 0) { _historyDateFilter = days.First(); return; }

        // In descending list: "previous day" = next index, "next day" = previous index
        var newIdx = idx - direction;
        if (newIdx < 0 || newIdx >= days.Count)
        {
            _historyShowAll = true;
        }
        else
        {
            _historyDateFilter = days[newIdx];
        }
    }

