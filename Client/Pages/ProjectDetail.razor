    /// <summary>
    /// Compute a branch-prefixed step label. Pre-fork trunk steps show plain numbers (1, 2, 3).
    /// Post-fork: main continuation = A + seq, other branches = B, C, D... + seq.
    /// </summary>
    private bool IsStepSkipped(ProjectModuleResponse pm)
    {
        if (string.IsNullOrWhiteSpace(pm.Configuration)) return false;
        try
        {
            var cfg = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(pm.Configuration);
            if (cfg is not null && cfg.TryGetValue("skipped", out var el))
                return el.ValueKind == JsonValueKind.True;
        }
        catch { }
        return false;
    }

    private async Task ToggleStepSkipped(ProjectModuleResponse pm)
    {
        var currentlySkipped = IsStepSkipped(pm);
        var newSkipped = !currentlySkipped;

        // Parse existing config, update skipped flag, save
        var cfg = new Dictionary<string, object>();
        if (!string.IsNullOrWhiteSpace(pm.Configuration))
        {
            try
            {
                var parsed = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(pm.Configuration);
                if (parsed is not null)
                    foreach (var kv in parsed)
                        cfg[kv.Key] = kv.Value;
            }
            catch { }
        }
        cfg["skipped"] = newSkipped;
        var stepConfig = JsonSerializer.Serialize(cfg);

        var req = new UpdateProjectModuleRequest(pm.StepOrder, pm.StepName, pm.InputMapping, stepConfig, pm.IsActive);
        var (ok, _) = await Api.UpdateProjectModuleAsync(ProjectId, pm.Id, req);
        if (ok) await LoadAll();
    }

    private string GetStepLabel(ProjectModuleResponse pm)
    {
        if (_project is null) return pm.StepOrder.ToString();

        var modules = _project.Modules;
        var branches = modules.Where(m => m.BranchId != "main")
            .Select(m => m.BranchFromStep).Where(f => f.HasValue).Select(f => f!.Value).Distinct().ToList();

        // If no branches exist, just return the number
        if (branches.Count == 0) return pm.StepOrder.ToString();

        var maxFork = branches.Max();

        // Trunk step before any fork
        if (pm.BranchId == "main" && pm.StepOrder <= maxFork)
            return pm.StepOrder.ToString();

        // Post-fork: determine branch letter and position
        if (pm.BranchId == "main")
        {
            // Main continuation after fork
            var mainPostFork = modules.Where(m => m.BranchId == "main" && m.StepOrder > maxFork)
                .OrderBy(m => m.StepOrder).ToList();
            var idx = mainPostFork.FindIndex(m => m.StepOrder == pm.StepOrder);
            return $"A{maxFork + 1 + idx}";
        }
        else
        {
            // Non-main branch: assign letter B, C, D... based on branch order
            var branchIds = modules.Where(m => m.BranchId != "main")
                .GroupBy(m => m.BranchId).Select(g => g.Key).OrderBy(b => b).ToList();
            var branchIdx = branchIds.IndexOf(pm.BranchId);
            var letter = (char)('B' + branchIdx);

            var forkStep = pm.BranchFromStep ?? maxFork;
            var branchSteps = modules.Where(m => m.BranchId == pm.BranchId)
                .OrderBy(m => m.StepOrder).ToList();
            var idx = branchSteps.FindIndex(m => m.StepOrder == pm.StepOrder);
            return $"{letter}{forkStep + 1 + idx}";
        }
    }

    /// <summary>
    /// Compute step label from a StepOrder int (for log entries that only have the order number).
    /// </summary>
    private string GetStepLabelFromOrder(int stepOrder)
    {
        var pm = _project?.Modules.FirstOrDefault(m => m.StepOrder == stepOrder);
        if (pm is null) return stepOrder.ToString();
        return GetStepLabel(pm);
    }

