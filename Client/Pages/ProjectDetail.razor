@if (_showCheckpointModal)
{
    <div class="modal-overlay" @onclick="@(() => { _showCheckpointModal = false; })">
        <div class="modal-content" style="max-width: 750px;" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: var(--bg-input); border-bottom: 1px solid var(--border);">
                <span style="color: var(--warning); font-size: 1rem; margin-right: 0.2rem;">&#9632;</span>
                <strong style="font-size: 0.9rem;">Checkpoint - Revision de datos</strong>
                <div style="margin-left: auto; display: flex; gap: 0.3rem; align-items: center;">
                    <button class="btn btn-sm @(_checkpointRawView ? "" : "btn-primary")" style="font-size: 0.65rem; padding: 0.15rem 0.4rem;"
                            @onclick="@(() => { _checkpointRawView = false; })">Formal</button>
                    <button class="btn btn-sm @(_checkpointRawView ? "btn-primary" : "")" style="font-size: 0.65rem; padding: 0.15rem 0.4rem;"
                            @onclick="@(() => { _checkpointRawView = true; })">Raw</button>
                    <button class="btn btn-sm" style="padding: 0.1rem 0.4rem; font-size: 0.8rem;"
                            @onclick="@(() => { _showCheckpointModal = false; })">X</button>
                </div>
            </div>
            <div class="modal-body" style="padding: 0.8rem 1rem;">
                <div style="background: #332b00; color: #ffc107; border: 1px solid #665500; font-size: 0.78rem; padding: 0.45rem 0.65rem; margin-bottom: 0.7rem; border-radius: 0.35rem;">
                    El pipeline se ha pausado en un punto de control. Revisa los datos recibidos antes de continuar.
                </div>

                @if (!string.IsNullOrEmpty(_checkpointPreviewJson))
                {
                    @if (_checkpointRawView)
                    {
                        <pre style="background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 0.6rem; font-size: 0.7rem; max-height: 400px; overflow: auto; white-space: pre-wrap; word-break: break-word;">@_checkpointPreviewJson</pre>
                    }
                    else
                    {
                        @foreach (var entry in ParseCheckpointEntries(_checkpointPreviewJson))
                        {
                            <div style="margin-bottom: 0.6rem;">
                                <div style="font-size: 0.72rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.03em; margin-bottom: 0.25rem;">
                                    @entry.Label
                                </div>
                                <div style="background: var(--bg); border: 1px solid var(--border); border-radius: 5px; padding: 0.45rem 0.6rem; font-size: 0.78rem; max-height: 180px; overflow-y: auto; white-space: pre-wrap; word-break: break-word; line-height: 1.45;">@entry.Value</div>
                            </div>
                        }
                    }
                }

                <div style="display: flex; gap: 0.5rem; margin-top: 0.8rem; padding-top: 0.6rem; border-top: 1px solid var(--border);">
                    <button class="btn btn-success" style="flex: 1; font-size: 0.85rem; padding: 0.45rem;" @onclick="@(() => ReviewCheckpoint(true))">Continuar</button>
                    <button class="btn btn-danger" style="flex: 1; font-size: 0.85rem; padding: 0.45rem;" @onclick="@(() => ReviewCheckpoint(false))">Abortar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ProjectId { get; set; }

    private static readonly JsonSerializerOptions PrettyJsonOptions = new()
    {
        WriteIndented = true,
        Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping
    };

    private ProjectDetailResponse? _project;
    private List<AiModuleResponse> _modules = [];
    private List<ExecutionResponse> _executions = [];
    private List<RuleResponse> _tenantRules = [];
    private ExecutionDetailResponse? _result;

    private bool _loading;
    private bool _executing;
    private PipelineCanvas? _pipelineCanvasRef;

    // Checkpoint state
    private bool _showCheckpointModal;
    private Guid? _checkpointExecutionId;
    private string? _checkpointPreviewJson;
    private bool _checkpointRawView;

    // UI state
    private string _activeTab = "pipeline";
    private bool _showSettings;
    private string _settingsTab = "messaging";

    // Pipeline visual editor
    private List<ModuleConnectionResponse> _projectConnections = new();

    // Add module
    private string _stepModuleId = "";
    private string _stepName = "";
    private string? _stepError;

    // Interaction step
    private string _interactionTemplate = "";
    private string _interactionMessageType = "combined";
    private string _interactionWaitForResponse = "true";

    // Publish step (Buffer)
    private bool _isImagePrompt = false;
    private int _imageCount = 1;

    private string _publishCaption = "";
    private string _publishType = "post";

    // Orchestrator outputs (pending, before module is created)
    private List<OrchestratorOutputRequest> _pendingOrchestratorOutputs = new();
    private string _poLabel = "", _poPrompt = "", _poDataType = "text";

    // Publish step (Canva)
    private string _canvaExportFormat = "png";
    private string _canvaDesignTitle = "";
    private string _canvaStepBrandTemplateId = "";
    private string _canvaDesignType = "doc";

    // Image step
    private string _imagePrompt = "";

    // History expansion
    private Guid? _expandedExecId;
    private ExecutionDetailResponse? _expandedExecDetail;

    // History filters (search by prompt + status), timeline grouped by day
    private string _historySearch = "";
    private string _historyStatusFilter = "all"; // all | completed | failed | running
    private int _historyPageSize = 20;

    private void OnHistorySearchInput(ChangeEventArgs e)
    {
        _historySearch = e.Value?.ToString() ?? "";
        _historyPageSize = 20;
    }

    private void SetHistoryStatus(string status, bool clearSearch = false)
    {
        _historyStatusFilter = status;
        if (clearSearch) _historySearch = "";
        _historyPageSize = 20;
    }

    private IEnumerable<ExecutionResponse> FilteredHistory()
    {
        IEnumerable<ExecutionResponse> query = _executions;

        query = _historyStatusFilter switch
        {
            "completed" => query.Where(e => e.Status == "Completed"),
            "failed"    => query.Where(e => e.Status == "Failed"),
            "running"   => query.Where(e => e.Status is "Running" or "WaitingForCheckpoint" or "WaitingForReview" or "WaitingForInput" or "Pending"),
            _           => query
        };

        if (!string.IsNullOrWhiteSpace(_historySearch))
        {
            var term = _historySearch.Trim();
            query = query.Where(e => e.UserInput is not null &&
                e.UserInput.Contains(term, StringComparison.OrdinalIgnoreCase));
        }

        return query.OrderByDescending(e => e.CreatedAt);
    }

    private static string DayLabel(DateTime day)
    {
        if (day == DateTime.Today) return "Hoy";
        if (day == DateTime.Today.AddDays(-1)) return "Ayer";
        var label = day.Year == DateTime.Today.Year
            ? day.ToString("dddd, dd MMM")
            : day.ToString("dddd, dd MMM yyyy");
        return char.ToUpper(label[0]) + label[1..];
    }

