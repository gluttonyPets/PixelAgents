@page "/projects/{ProjectId:guid}"
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR.Client
@inject ApiClient Api
@inject IConfiguration Config
@implements IAsyncDisposable

<h2>@(_project?.Name ?? "Proyecto")</h2>

@if (_project is null)
{
    <p class="text-muted">Cargando...</p>
}
else
{
    <p class="text-muted text-sm mb-1">@(_project.Description ?? "") | Creado: @_project.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>

    <!-- Project Context -->
    @if (!string.IsNullOrWhiteSpace(_project.Context))
    {
        <div class="card">
            <div class="form-group">
                <label>Contexto del proyecto <span class="text-sm text-muted">(se aplica a todos los modulos)</span></label>
                <div class="output-block">@_project.Context</div>
            </div>
        </div>
    }

    <!-- Telegram Config -->
    <details class="card" style="margin-bottom: 1rem;">
        <summary style="cursor: pointer; font-weight: bold;">Configuracion Telegram (Interaccion)</summary>
        <div style="padding-top: 0.5rem;">
            @if (_tgError is not null)
            {
                <div class="alert alert-error">@_tgError</div>
            }
            @if (_tgSuccess)
            {
                <div class="alert alert-success">Configuracion Telegram guardada correctamente</div>
            }
            <div class="form-row">
                <div class="form-group">
                    <label>Bot Token</label>
                    <input type="password" @bind="_tgBotToken" placeholder="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11" />
                </div>
                <div class="form-group">
                    <label>Chat ID</label>
                    <input type="text" @bind="_tgChatId" placeholder="Ej: 123456789" />
                </div>
            </div>
            <p class="text-sm text-muted">
                1. Habla con <strong>@@BotFather</strong> en Telegram → <code>/newbot</code> → copia el token.<br/>
                2. Envia un mensaje al bot y visita <code>https://api.telegram.org/bot&lt;TOKEN&gt;/getUpdates</code> para obtener tu Chat ID.<br/>
                3. Webhook URL: <code>https://tu-servidor/api/webhooks/telegram</code> — se configura automaticamente al guardar.
            </p>
            <button class="btn btn-primary" @onclick="SaveTelegramConfig" disabled="@_tgSaving">
                @(_tgSaving ? "Guardando..." : "Guardar configuracion")
            </button>
        </div>
    </details>

    <!-- Buffer Config (Publish) -->
    <details class="card" style="margin-bottom: 1rem;">
        <summary style="cursor: pointer; font-weight: bold;">Configuracion Buffer (Publicacion)</summary>
        <div style="padding-top: 0.5rem;">
            @if (_igError is not null)
            {
                <div class="alert alert-error">@_igError</div>
            }
            @if (_igSuccess)
            {
                <div class="alert alert-success">Configuracion Buffer guardada correctamente</div>
            }
            <div class="form-row">
                <div class="form-group">
                    <label>API Key</label>
                    <input type="password" @bind="_igApiKey" placeholder="Token de Buffer API" />
                </div>
                <div class="form-group">
                    <label>Channel ID</label>
                    <input type="text" @bind="_igChannelId" placeholder="Ej: 65a1b2c3d4e5f6..." />
                </div>
            </div>
            <p class="text-sm text-muted">
                1. Ve a <strong>buffer.com</strong> → Cuenta → API Settings → genera tu API Key.<br/>
                2. El <strong>Channel ID</strong> se obtiene consultando tus canales conectados via la API.<br/>
                3. Plan gratuito: 3 canales, 10 posts programados por canal. Soporta Instagram, Twitter, LinkedIn, etc.
            </p>
            <button class="btn btn-primary" @onclick="SaveInstagramConfig" disabled="@_igSaving">
                @(_igSaving ? "Guardando..." : "Guardar configuracion")
            </button>
        </div>
    </details>

    <!-- Canva Config (Publish) -->
    <details class="card" style="margin-bottom: 1rem;">
        <summary style="cursor: pointer; font-weight: bold;">Configuracion Canva (Disenos)</summary>
        <div style="padding-top: 0.5rem;">
            @if (_canvaError is not null)
            {
                <div class="alert alert-error">@_canvaError</div>
            }
            @if (_canvaSuccess)
            {
                <div class="alert alert-success">Configuracion Canva guardada correctamente</div>
            }
            <div class="form-row">
                <div class="form-group">
                    <label>Access Token</label>
                    <input type="password" @bind="_canvaAccessToken" placeholder="Token OAuth de Canva Connect API" />
                </div>
                <div class="form-group">
                    <label>Brand Template ID (opcional)</label>
                    <input type="text" @bind="_canvaBrandTemplateId" placeholder="Ej: DAVZr1z5464..." />
                </div>
            </div>
            <p class="text-sm text-muted">
                1. Registra tu app en <strong>canva.dev</strong> → obtiene un Access Token via OAuth 2.0.<br/>
                2. El <strong>Brand Template ID</strong> es opcional. Si se proporciona, se usara autofill con el template.<br/>
                3. Formatos de exportacion soportados: PNG, JPG, PDF, PPTX, MP4, GIF.
            </p>
            <button class="btn btn-primary" @onclick="SaveCanvaConfig" disabled="@_canvaSaving">
                @(_canvaSaving ? "Guardando..." : "Guardar configuracion")
            </button>
        </div>
    </details>

    <!-- WhatsApp Config (legacy) -->
    <details class="card" style="margin-bottom: 1rem;">
        <summary style="cursor: pointer; font-weight: bold;">Configuracion WhatsApp (alternativa)</summary>
        <div style="padding-top: 0.5rem;">
            @if (_waError is not null)
            {
                <div class="alert alert-error">@_waError</div>
            }
            @if (_waSuccess)
            {
                <div class="alert alert-success">Configuracion guardada correctamente</div>
            }
            <div class="form-row">
                <div class="form-group">
                    <label>Phone Number ID</label>
                    <input type="text" @bind="_waPhoneNumberId" placeholder="Ej: 123456789012345" />
                </div>
                <div class="form-group">
                    <label>Numero destinatario</label>
                    <input type="text" @bind="_waRecipientNumber" placeholder="Ej: 34612345678" />
                </div>
            </div>
            <div class="form-group">
                <label>Access Token</label>
                <input type="password" @bind="_waAccessToken" placeholder="EAABx..." />
            </div>
            <div class="form-group">
                <label>Webhook Verify Token</label>
                <input type="text" @bind="_waVerifyToken" placeholder="Token de verificacion para el webhook" />
            </div>
            <p class="text-sm text-muted">
                Webhook URL: <code>https://tu-servidor/api/webhooks/whatsapp</code> — Configuralo en Meta for Developers.
            </p>
            <button class="btn btn-primary" @onclick="SaveWhatsAppConfig" disabled="@_waSaving">
                @(_waSaving ? "Guardando..." : "Guardar configuracion")
            </button>
        </div>
    </details>

    <!-- Pipeline Steps -->
    <h3>Pipeline</h3>

    @if (_editError is not null)
    {
        <div class="alert alert-error">@_editError</div>
    }

    @if (_project.Modules.Count > 0)
    {
        <div class="pipeline-format-rule">
            Regla global: Sin emojis, sin markdown (**, *, #), sin saltos de linea, sin caracteres decorativos. Solo texto plano ASCII.
        </div>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Paso</th>
                    <th>Modulo</th>
                    <th>Tipo</th>
                    <th>Coste</th>
                    <th>Input</th>
                    <th>Orden</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{ var sorted = _project.Modules.OrderBy(m => m.StepOrder).ToList(); }
                @for (var si = 0; si < sorted.Count; si++)
                {
                    var pm = sorted[si];
                    var nextPm = si + 1 < sorted.Count ? sorted[si + 1] : null;
                    var isEditing = _editingPmId == pm.Id;
                    <tr>
                        <td>@pm.StepOrder</td>
                        <td>
                            @if (isEditing)
                            {
                                <input type="text" class="input-inline" @bind="_editStepName" placeholder="Nombre del paso" />
                            }
                            else
                            {
                                @(pm.StepName ?? "-")
                            }
                        </td>
                        <td>@pm.AiModuleName</td>
                        <td><span class="badge badge-warning">@pm.ModuleType</span></td>
                        <td>
                            @{
                                var stepCost = _result?.Steps?.FirstOrDefault(s => s.ProjectModuleId == pm.Id)?.EstimatedCost;
                            }
                            @if (stepCost.HasValue && stepCost.Value > 0)
                            {
                                <span class="text-sm text-muted">~$@stepCost.Value.ToString("F4")</span>
                            }
                            else
                            {
                                <span class="text-sm text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (isEditing)
                            {
                                <select class="select-inline" @bind="_editInputMapping">
                                    <option value='{"source":"user"}'>Entrada del usuario</option>
                                    <option value='{"source":"previous","field":"text"}'>Paso anterior (texto)</option>
                                    <option value='{"source":"previous","field":"file"}'>Paso anterior (archivo)</option>
                                </select>
                            }
                            else
                            {
                                <span class="text-sm">@FormatInputMapping(pm.InputMapping)</span>
                            }
                        </td>
                        <td>
                            <div style="display:flex; gap:0.2rem;">
                                <button class="btn btn-sm" @onclick="() => MoveStep(pm, -1)"
                                        disabled="@(pm.StepOrder <= 1)" title="Subir">▲</button>
                                <button class="btn btn-sm" @onclick="() => MoveStep(pm, 1)"
                                        disabled="@(pm.StepOrder >= sorted.Count)" title="Bajar">▼</button>
                            </div>
                        </td>
                        <td>
                            <div style="display:flex; gap:0.3rem;">
                                @if (isEditing)
                                {
                                    <button class="btn btn-sm btn-success" @onclick="SaveEdit">Guardar</button>
                                    <button class="btn btn-sm" @onclick="CancelEdit">Cancelar</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-primary" @onclick="() => StartEdit(pm)">Editar</button>
                                }
                                <button class="btn btn-sm btn-danger" @onclick="() => RemoveStep(pm.Id)">Quitar</button>
                            </div>
                        </td>
                    </tr>
                    @if (pm.ModuleType == "Text" && nextPm is not null)
                    {
                        var maxLen = GetMaxPromptLength(nextPm.ModelName);
                        <tr class="step-rule-row">
                            <td colspan="7">
                                <span class="step-rule-hint">Los items generados en este paso se limitaran a <strong>@maxLen caracteres</strong> (modelo siguiente: @nextPm.ModelName)</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">Pipeline vacio. Agrega pasos abajo.</p>
    }

    <!-- Add Step -->
    <div class="card">
        <h3>Agregar Paso</h3>
        @if (_stepError is not null)
        {
            <div class="alert alert-error">@_stepError</div>
        }
        <div class="form-row">
            <div class="form-group">
                <label>Modulo</label>
                <select @bind="_stepModuleId">
                    <option value="">-- Seleccionar --</option>
                    @foreach (var m in _modules)
                    {
                        <option value="@m.Id">@m.Name (@m.ProviderType / @m.ModuleType)</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Orden</label>
                <input type="number" @bind="_stepOrder" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Nombre del paso</label>
                <input type="text" @bind="_stepName" placeholder="Ej: Generar texto, Traducir, Crear imagen..." />
            </div>
            <div class="form-group">
                <label>Entrada de datos</label>
                <select @bind="_inputMapping">
                    <option value='{"source":"user"}'>Entrada del usuario</option>
                    <option value='{"source":"previous","field":"text"}'>Paso anterior (texto)</option>
                    <option value='{"source":"previous","field":"file"}'>Paso anterior (archivo)</option>
                </select>
            </div>
        </div>

        @{ var selectedModule = _modules.FirstOrDefault(m => m.Id.ToString() == _stepModuleId); }
        @if (selectedModule?.ModuleType == "Interaction")
        {
            <div class="form-group">
                <label>Mensaje de interaccion <span class="text-sm text-muted">(usa {previous_output} para incluir salida anterior, {step_number} para el numero de paso)</span></label>
                <textarea @bind="_interactionTemplate" rows="3"
                    placeholder="Resultado del paso anterior: {previous_output}. Te parece correcto? Responde SI para continuar o escribe tu feedback."></textarea>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Tipo de mensaje</label>
                    <select @bind="_interactionMessageType">
                        <option value="combined">Texto + Imagenes</option>
                        <option value="text">Solo texto</option>
                        <option value="image">Solo imagenes</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Esperar respuesta del usuario</label>
                    <select @bind="_interactionWaitForResponse">
                        <option value="true">Si - pausar pipeline hasta recibir respuesta</option>
                        <option value="false">No - enviar y continuar (fire & forget)</option>
                    </select>
                </div>
            </div>
            @if (_interactionWaitForResponse == "true")
            {
                <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                    El usuario recibira botones automaticos en Telegram:
                    <strong>▶️ Continuar</strong> (con descripcion del siguiente paso),
                    <strong>❌ Abortar</strong>, y
                    <strong>🔄 Reiniciar</strong> (con aclaracion opcional).
                </p>
            }
        }

        @if (selectedModule?.ModuleType == "Text")
        {
            <div class="form-group" style="margin-top: 0.5rem;">
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                    <input type="checkbox" @bind="_isImagePrompt" />
                    Este paso genera prompts para imagenes
                </label>
            </div>
            @if (_isImagePrompt)
            {
                <div class="form-group">
                    <label>Numero de imagenes a generar</label>
                    <input type="number" @bind="_imageCount" min="1" max="20" style="max-width: 100px;" />
                    <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                        Se forzara al modelo a devolver exactamente @_imageCount item(s) en la respuesta,
                        cada uno sera un prompt para el paso de generacion de imagenes.
                    </p>
                </div>
            }
        }

        @if (selectedModule?.ModuleType == "Video")
        {
            <div class="form-group" style="margin-top: 0.5rem;">
                <label>Prompt del video <span style="color: var(--danger);">*</span></label>
                <textarea @bind="_videoPrompt" rows="3"
                    placeholder="Describe lo que quieres que muestre el video..."></textarea>
                <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                    Este prompt se enviara siempre al modelo de video. Es obligatorio.
                </p>
            </div>
            <div class="form-group" style="margin-top: 0.5rem;">
                <label>Usar imagen del paso anterior</label>
                <select @bind="_videoSource">
                    <option value="prompt">No, solo texto</option>
                    @if (selectedModule?.ModelName?.Contains("veo-3.1") == true)
                    {
                        <option value="both">Si, usar imagen + prompt</option>
                    }
                </select>
                <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                    @if (_videoSource == "prompt")
                    {
                        <span>El video se generara unicamente a partir del prompt de texto.</span>
                    }
                    else
                    {
                        <span>Se usara la imagen generada en el paso anterior como primer fotograma junto con el prompt. Solo disponible con Veo 3.1.</span>
                    }
                </p>
                @if (selectedModule?.ModelName?.Contains("veo-3.1") != true)
                {
                    <p class="text-sm" style="color: var(--warning); margin-top: 0.2rem;">
                        Image-to-video solo esta disponible con modelos Veo 3.1. Este modelo solo soporta texto.
                    </p>
                }
            </div>
        }

        @if (selectedModule?.ModuleType == "Design")
        {
            <div class="form-group">
                <label>Formato de exportacion</label>
                <select @bind="_canvaExportFormat">
                    <option value="png">PNG (imagen)</option>
                    <option value="jpg">JPG (imagen)</option>
                    <option value="pdf">PDF (documento)</option>
                    <option value="pptx">PPTX (presentacion)</option>
                </select>
            </div>
            <div class="form-group">
                <label>Titulo del diseno <span class="text-sm text-muted">(usa {previous_output} para incluir salida anterior)</span></label>
                <input type="text" @bind="_canvaDesignTitle" placeholder="PixelAgents Design" />
            </div>
            <div class="form-group">
                <label>Brand Template ID <span class="text-sm text-muted">(opcional, sobreescribe el del proyecto y del modulo)</span></label>
                <input type="text" @bind="_canvaStepBrandTemplateId" placeholder="Ej: DAVZr1z5464... (dejar vacio para usar el del modulo/proyecto)" />
            </div>
            <div class="form-group">
                <label>Tipo de diseno <span class="text-sm text-muted">(si no usa template)</span></label>
                <select @bind="_canvaDesignType">
                    <option value="doc">Documento</option>
                    <option value="presentation">Presentacion</option>
                    <option value="whiteboard">Pizarra</option>
                </select>
            </div>
            <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                Si se configura un Brand Template ID (aqui, en el modulo o en la config del proyecto), se usara autofill
                con los datos del paso anterior. Si no, se creara un diseno en blanco del tipo seleccionado.
                Las imagenes del paso anterior se suben automaticamente como assets.
            </p>
        }

        @if (selectedModule?.ModuleType == "Publish")
        {
            <div class="form-group">
                <label>Tipo de publicacion</label>
                <select @bind="_publishType">
                    <option value="post">Post</option>
                    <option value="reel">Reel</option>
                    <option value="story">Story</option>
                </select>
            </div>
            <div class="form-group">
                <label>Caption <span class="text-sm text-muted">(usa {previous_output} para incluir salida anterior)</span></label>
                <textarea @bind="_publishCaption" rows="3"
                    placeholder="{previous_output}"></textarea>
            </div>
            <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                Las imagenes/videos del paso anterior se adjuntan automaticamente.
                Buffer publica en el canal configurado (Instagram, Twitter, LinkedIn, etc.).
                Programacion automatica (Buffer elige la mejor hora). Plan gratuito: 10 posts por canal.
            </p>
        }

        <button class="btn btn-primary mt-1" @onclick="AddStep" disabled="@_loading">Agregar</button>
    </div>

    <!-- Execute -->
    <div class="card">
        <h3>Ejecutar Pipeline</h3>
        @if (_execError is not null)
        {
            <div class="alert alert-error">@_execError</div>
        }
        <div class="form-group">
            <label>Entrada del usuario</label>
            <textarea @bind="_userInput" rows="3" placeholder="Escribe tu prompt aqui..."></textarea>
        </div>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
            <button class="btn btn-success" @onclick="Execute" disabled="@_executing">
                @if (_executing)
                {
                    <span class="spinner"></span>
                    <span>Ejecutando...</span>
                }
                else
                {
                    <span>Ejecutar</span>
                }
            </button>
            @if (_executing)
            {
                <button class="btn btn-danger" @onclick="CancelExecution">Cancelar</button>
            }
        </div>
    </div>

    <!-- Execution Result + Log Panel -->
    @if (_executing || _result is not null || _logEntries.Count > 0)
    {
        <div class="execution-layout">
            <!-- Left: Results -->
            <div class="execution-results">
                @if (_result is not null)
                {
                    <h3>
                        Resultado - <span class="badge @StatusBadge(_result.Status)">@_result.Status</span>
                        @if (_result.TotalEstimatedCost > 0)
                        {
                            <span class="badge" style="background: var(--surface); color: var(--text); margin-left: 0.5rem; font-weight: normal; font-size: 0.75rem;">
                                ~$@_result.TotalEstimatedCost.ToString("F4") USD
                            </span>
                        }
                    </h3>

                    @if (!string.IsNullOrWhiteSpace(_result.UserInput))
                    {
                        <div class="card" style="margin-bottom: 0.8rem; padding: 0.6rem 0.8rem;">
                            <label class="text-sm text-muted" style="margin-bottom: 0.2rem;">Prompt inicial</label>
                            <div class="output-block" style="white-space: pre-wrap;">@_result.UserInput</div>
                        </div>
                    }

                    @foreach (var step in _result.Steps.OrderBy(s => s.StepOrder))
                    {
                        <div class="step-card">
                            <div class="step-header">
                                <strong>Paso @step.StepOrder: @step.ModuleName</strong>
                                <span class="badge @StatusBadge(step.Status)">@step.Status</span>
                                @if (step.EstimatedCost > 0)
                                {
                                    <span class="text-sm text-muted" style="margin-left: 0.4rem;">~$@step.EstimatedCost.ToString("F4")</span>
                                }
                                @if (!_executing && (_result.Status == "Completed" || _result.Status == "Failed")
                                    && (step.Status == "Completed" || step.Status == "Failed"))
                                {
                                    <button class="btn btn-sm" style="margin-left: auto; padding: 0.15rem 0.5rem; font-size: 0.75rem;"
                                            @onclick="() => ToggleRetryPanel(step.StepOrder)">
                                        @(_retryStepOrder == step.StepOrder ? "Cancelar" : "Reintentar desde aqui")
                                    </button>
                                }
                            </div>

                            @if (_retryStepOrder == step.StepOrder)
                            {
                                <div class="retry-panel" style="background: var(--surface); border: 1px solid var(--border); border-radius: 0.4rem; padding: 0.6rem; margin: 0.4rem 0;">
                                    <div class="form-group" style="margin-bottom: 0.4rem;">
                                        <label class="text-sm">Feedback / comentario (opcional)</label>
                                        <textarea @bind="_retryComment" rows="2"
                                                  placeholder="Ej: Hazlo mas corto, cambia el tono, añade mas detalles sobre..."
                                                  style="font-size: 0.85rem;"></textarea>
                                    </div>
                                    @if (_retryError is not null)
                                    {
                                        <div class="alert alert-error" style="font-size: 0.8rem; padding: 0.3rem 0.5rem;">@_retryError</div>
                                    }
                                    <button class="btn btn-sm btn-success" @onclick="() => RetryFromStep(step.StepOrder)" disabled="@_executing">
                                        Reintentar paso @step.StepOrder y siguientes
                                    </button>
                                </div>
                            }

                            @if (step.ErrorMessage is not null)
                            {
                                <div class="alert alert-error">@step.ErrorMessage</div>
                            }

                            @if (step.OutputData is not null)
                            {
                                var parsed = TryParseOutput(step.OutputData);
                                if (parsed?.Type == "text")
                                {
                                    @if (parsed.Summary is not null)
                                    {
                                        <p class="text-sm" style="color: var(--accent); margin-bottom: 0.3rem;">@parsed.Summary</p>
                                    }

                                    @if (parsed.Content is not null)
                                    {
                                        <div class="output-block">@parsed.Content</div>
                                    }

                                    @if (parsed.Items is not null && parsed.Items.Count > 0)
                                    {
                                        <details class="mt-1">
                                            <summary class="text-sm" style="cursor:pointer; color: var(--accent);">
                                                @parsed.Items.Count elementos generados para el siguiente paso
                                            </summary>
                                            <div style="margin-top: 0.3rem;">
                                                @foreach (var item in parsed.Items)
                                                {
                                                    <div class="output-block" style="margin-bottom: 0.3rem; padding: 0.4rem 0.6rem; font-size: 0.8rem;">
                                                        @if (item.Label is not null) { <strong>@item.Label:</strong> }
                                                        @item.Content
                                                    </div>
                                                }
                                            </div>
                                        </details>
                                    }

                                    @if (parsed.Metadata is not null)
                                    {
                                        <div class="step-meta mt-1">
                                            @if (parsed.Metadata.TryGetValue("publishType", out var pubType))
                                            {
                                                <span class="badge badge-info">@pubType.ToString().ToUpper()</span>
                                            }
                                            @if (parsed.Metadata.TryGetValue("caption", out var caption))
                                            {
                                                <span class="badge badge-info">Caption: @caption</span>
                                            }
                                            @if (parsed.Metadata.ContainsKey("bufferRequest"))
                                            {
                                                <button class="btn btn-sm" style="padding: 0.1rem 0.4rem; font-size: 0.7rem; margin-left: 0.3rem;"
                                                        @onclick="() => ShowBufferDebug(parsed)">Ver API</button>
                                            }
                                            @if (parsed.Metadata.TryGetValue("model", out var model))
                                            {
                                                <span class="badge badge-warning">@model</span>
                                            }
                                            @if (parsed.Metadata.TryGetValue("inputTokens", out var inTok))
                                            {
                                                <span class="text-sm text-muted">In: @inTok</span>
                                            }
                                            @if (parsed.Metadata.TryGetValue("outputTokens", out var outTok))
                                            {
                                                <span class="text-sm text-muted">Out: @outTok</span>
                                            }
                                        </div>
                                    }
                                }
                                else if (parsed?.Type == "video")
                                {
                                    @if (parsed.Metadata is not null && parsed.Metadata.TryGetValue("model", out var vidModel))
                                    {
                                        <span class="badge badge-warning">@vidModel</span>
                                        @if (parsed.Metadata.TryGetValue("duration", out var vidDur))
                                        {
                                            <span class="text-sm text-muted ml-1">@vidDur s</span>
                                        }
                                        @if (parsed.Metadata.TryGetValue("resolution", out var vidRes))
                                        {
                                            <span class="text-sm text-muted ml-1">@vidRes</span>
                                        }
                                    }

                                    @if (parsed.Files is not null && parsed.Files.Count > 0)
                                    {
                                        @foreach (var f in parsed.Files)
                                        {
                                            var fileUrl = $"{_apiBase}/api/executions/{_result!.Id}/files/{f.FileId}";
                                            <div style="margin-top: 0.5rem;">
                                                <video controls style="max-width: 100%; border-radius: 8px;" crossorigin="use-credentials">
                                                    <source src="@fileUrl" type="@f.ContentType" />
                                                    Tu navegador no soporta video HTML5.
                                                </video>
                                                <div class="file-info" style="margin-top: 0.3rem;">
                                                    <a href="@fileUrl" target="_blank" download="@f.FileName" class="btn btn-sm btn-primary">
                                                        Descargar @f.FileName
                                                    </a>
                                                    <span class="text-sm text-muted">(@(f.FileSize / 1024) KB)</span>
                                                </div>
                                            </div>
                                        }
                                    }
                                }
                                else if (parsed?.Type == "image")
                                {
                                    @if (parsed.Metadata is not null && parsed.Metadata.TryGetValue("model", out var imgModel))
                                    {
                                        <span class="badge badge-warning">@imgModel</span>
                                        <span class="text-sm text-muted ml-1">@(parsed.Files?.Count ?? 0) imagen(es)</span>
                                    }

                                    @if (parsed.Files is not null && parsed.Files.Count > 0)
                                    {
                                        <div class="image-grid mt-1">
                                            @foreach (var f in parsed.Files)
                                            {
                                                var fileUrl = $"{_apiBase}/api/executions/{_result!.Id}/files/{f.FileId}";
                                                <div class="image-grid-item">
                                                    <img src="@fileUrl" alt="@f.FileName" class="file-preview" crossorigin="use-credentials" />
                                                    @if (f.RevisedPrompt is not null)
                                                    {
                                                        <p class="text-sm text-muted" style="font-style: italic; margin: 0.2rem 0;">@f.RevisedPrompt</p>
                                                    }
                                                    <div class="file-info">
                                                        <a href="@fileUrl" target="_blank" download="@f.FileName" class="btn btn-sm btn-primary">
                                                            Descargar @f.FileName
                                                        </a>
                                                        <span class="text-sm text-muted">(@(f.FileSize / 1024) KB)</span>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <!-- Fallback: raw output for old executions or unknown types -->
                                    <div class="output-block">@step.OutputData</div>

                                    @if (step.Files.Count > 0)
                                    {
                                        @foreach (var f in step.Files)
                                        {
                                            var fileUrl = $"{_apiBase}/api/executions/{_result!.Id}/files/{f.Id}";
                                            <div class="file-item">
                                                @if (f.ContentType.StartsWith("image/"))
                                                {
                                                    <img src="@fileUrl" alt="@f.FileName" class="file-preview" crossorigin="use-credentials" />
                                                }
                                                <div class="file-info">
                                                    <a href="@fileUrl" target="_blank" download="@f.FileName" class="btn btn-sm btn-primary">
                                                        Descargar @f.FileName
                                                    </a>
                                                    <span class="text-sm text-muted">(@f.ContentType, @(f.FileSize / 1024) KB)</span>
                                                </div>
                                            </div>
                                        }
                                    }
                                }
                            }
                        </div>
                    }
                }
                else if (_executing)
                {
                    <div class="card" style="text-align: center; padding: 2rem;">
                        <span class="spinner"></span>
                        <p class="text-muted mt-1">Ejecutando pipeline...</p>
                    </div>
                }
            </div>

            <!-- Right: Execution Log -->
            <div class="execution-log">
                <div class="log-header">
                    <strong>Log de Ejecucion</strong>
                    @if (_logEntries.Count > 0)
                    {
                        <button class="btn btn-sm" style="padding: 0.1rem 0.4rem; font-size: 0.7rem;" @onclick="ClearLog">Limpiar</button>
                    }
                </div>
                <div class="log-entries" @ref="_logContainer">
                    @if (_logEntries.Count == 0 && _executing)
                    {
                        <div class="log-entry log-info">
                            <span class="log-time">--:--:--</span>
                            <span>Esperando logs...</span>
                        </div>
                    }
                    @foreach (var entry in _logEntries)
                    {
                        <div class="log-entry log-@entry.Level">
                            <span class="log-time">@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                            @if (entry.StepOrder.HasValue)
                            {
                                <span class="log-step">P@(entry.StepOrder)</span>
                            }
                            <span class="log-message">@entry.Message</span>
                            @if (entry.StepOrder.HasValue && entry.Level == "error" && !_executing && _result is not null)
                            {
                                <button class="btn btn-sm btn-warning log-retry-btn"
                                        @onclick="() => RetryFromLog(entry.StepOrder!.Value)">
                                    Reintentar desde P@(entry.StepOrder)
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Execution History -->
    <h3>Historial de Ejecuciones</h3>
    @if (_executions.Count > 0)
    {
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Prompt</th>
                    <th>Status</th>
                    <th>Fecha</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in _executions)
                {
                    <tr>
                        <td class="text-sm">@e.Id.ToString()[..8]...</td>
                        <td class="text-sm" style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                            @(e.UserInput is not null ? (e.UserInput.Length > 80 ? e.UserInput[..80] + "..." : e.UserInput) : "-")
                        </td>
                        <td><span class="badge @StatusBadge(e.Status)">@e.Status</span></td>
                        <td class="text-sm text-muted">@e.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td><button class="btn btn-sm btn-primary" @onclick="() => LoadExecution(e.Id)">Ver</button></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">Sin ejecuciones aun.</p>
    }
}

@if (_showBufferDebug)
{
    <div class="modal-overlay" @onclick="() => _showBufferDebug = false">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <strong>Buffer API Debug</strong>
                <span class="badge @(_bufferDebugStatus == 200 ? "badge-success" : "badge-danger")">@_bufferDebugStatus</span>
                <button class="btn btn-sm" style="margin-left: auto; padding: 0.1rem 0.4rem;" @onclick="() => _showBufferDebug = false">X</button>
            </div>
            <div class="modal-body">
                <h4>Request</h4>
                <pre class="debug-pre">@_bufferDebugRequest</pre>
                <h4>Response</h4>
                <pre class="debug-pre">@_bufferDebugResponse</pre>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ProjectId { get; set; }

    private ProjectDetailResponse? _project;
    private List<AiModuleResponse> _modules = [];
    private List<ExecutionResponse> _executions = [];
    private ExecutionDetailResponse? _result;

    private bool _loading;
    private bool _executing;

    // Add step
    private string _stepModuleId = "";
    private int _stepOrder = 1;
    private string _stepName = "";
    private string _inputMapping = "{\"source\":\"user\"}";
    private string? _stepError;

    // Interaction step
    private string _interactionTemplate = "";
    private string _interactionMessageType = "combined";
    private string _interactionWaitForResponse = "true";

    // Publish step (Buffer)
    private bool _isImagePrompt = false;
    private int _imageCount = 1;

    private string _publishCaption = "";
    private string _publishType = "post";

    // Publish step (Canva)
    private string _canvaExportFormat = "png";
    private string _canvaDesignTitle = "";
    private string _canvaStepBrandTemplateId = "";
    private string _canvaDesignType = "doc";

    // Video step
    private string _videoSource = "prompt";
    private string _videoPrompt = "";

    // Edit step
    private Guid? _editingPmId;
    private string _editStepName = "";
    private string _editInputMapping = "";
    private string? _editError;

    // Execute
    private string _userInput = "";
    private string? _execError;

    // Retry from step
    private int? _retryStepOrder;
    private string _retryComment = "";
    private string? _retryError;

    // Telegram config
    private string _tgBotToken = "";
    private string _tgChatId = "";
    private string? _tgError;
    private bool _tgSuccess;
    private bool _tgSaving;

    // Buffer config
    private string _igApiKey = "";
    private string _igChannelId = "";
    private string? _igError;
    private bool _igSuccess;
    private bool _igSaving;

    // Canva config
    private string _canvaAccessToken = "";
    private string _canvaBrandTemplateId = "";
    private string? _canvaError;
    private bool _canvaSuccess;
    private bool _canvaSaving;

    // Buffer API debug modal
    private bool _showBufferDebug;
    private string? _bufferDebugRequest;
    private string? _bufferDebugResponse;
    private int? _bufferDebugStatus;

    // WhatsApp config
    private string _waPhoneNumberId = "";
    private string _waAccessToken = "";
    private string _waRecipientNumber = "";
    private string _waVerifyToken = "";
    private string? _waError;
    private bool _waSuccess;
    private bool _waSaving;

    // Execution log
    private List<LogEntry> _logEntries = [];
    private HubConnection? _hubConnection;
    private ElementReference _logContainer;

    // API base URL for file downloads (images, etc.)
    private string _apiBase = "";

    private record LogEntry(string Level, string Message, int? StepOrder, string? StepName, DateTime Timestamp);

    protected override async Task OnInitializedAsync()
    {
        _apiBase = (Config["ApiBaseUrl"] ?? "http://localhost:5000").TrimEnd('/');
        await LoadAll();
        await InitializeSignalR();
    }

    private async Task InitializeSignalR()
    {
        var apiBase = (Config["ApiBaseUrl"] ?? "http://localhost:5000").TrimEnd('/');
        var hubUrl = apiBase + "/hubs/execution";

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<LogEntry>("ExecutionLog", entry =>
        {
            _logEntries.Add(entry);
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinProject", ProjectId.ToString());
        }
        catch
        {
            // SignalR connection failed — logs won't show but execution still works
        }
    }

    private async Task LoadAll()
    {
        _loading = true;
        try
        {
            _project = await Api.GetProjectDetailAsync(ProjectId);
            _modules = await Api.GetModulesAsync();
            _executions = await Api.GetExecutionsAsync(ProjectId);
            if (_project is not null)
                _stepOrder = _project.Modules.Count + 1;

            // Load Telegram config
            var tgConfig = await Api.GetTelegramConfigAsync(ProjectId);
            if (tgConfig is not null)
            {
                _tgBotToken = tgConfig.BotToken;
                _tgChatId = tgConfig.ChatId;
            }

            // Load Buffer config
            var igConfig = await Api.GetInstagramConfigAsync(ProjectId);
            if (igConfig is not null)
            {
                _igApiKey = igConfig.ApiKey;
                _igChannelId = igConfig.ChannelId;
            }

            // Load Canva config
            var canvaConfig = await Api.GetCanvaConfigAsync(ProjectId);
            if (canvaConfig is not null)
            {
                _canvaAccessToken = canvaConfig.AccessToken;
                _canvaBrandTemplateId = canvaConfig.BrandTemplateId ?? "";
            }

            // Load WhatsApp config
            var waConfig = await Api.GetWhatsAppConfigAsync(ProjectId);
            if (waConfig is not null)
            {
                _waPhoneNumberId = waConfig.PhoneNumberId;
                _waAccessToken = waConfig.AccessToken;
                _waRecipientNumber = waConfig.RecipientNumber;
                _waVerifyToken = waConfig.WebhookVerifyToken;
            }
        }
        catch { }
        _loading = false;
    }

    private async Task SaveTelegramConfig()
    {
        _tgError = null;
        _tgSuccess = false;
        _tgSaving = true;
        try
        {
            var dto = new TelegramConfigDto(_tgBotToken, _tgChatId);
            var (ok, error) = await Api.SaveTelegramConfigAsync(ProjectId, dto);
            if (ok)
            {
                _tgSuccess = true;
                _modules = await Api.GetModulesAsync();
            }
            else
                _tgError = error;
        }
        catch (Exception ex) { _tgError = ex.Message; }
        _tgSaving = false;
    }

    private async Task SaveInstagramConfig()
    {
        _igError = null;
        _igSuccess = false;
        _igSaving = true;
        try
        {
            var dto = new BufferConfigDto(_igApiKey, _igChannelId);
            var (ok, error) = await Api.SaveInstagramConfigAsync(ProjectId, dto);
            if (ok)
            {
                _igSuccess = true;
                _modules = await Api.GetModulesAsync();
            }
            else
                _igError = error;
        }
        catch (Exception ex) { _igError = ex.Message; }
        _igSaving = false;
    }

    private async Task SaveCanvaConfig()
    {
        _canvaError = null;
        _canvaSuccess = false;
        _canvaSaving = true;
        try
        {
            var dto = new CanvaConfigDto(_canvaAccessToken,
                string.IsNullOrWhiteSpace(_canvaBrandTemplateId) ? null : _canvaBrandTemplateId);
            var (ok, error) = await Api.SaveCanvaConfigAsync(ProjectId, dto);
            if (ok)
            {
                _canvaSuccess = true;
                _modules = await Api.GetModulesAsync();
            }
            else
                _canvaError = error;
        }
        catch (Exception ex) { _canvaError = ex.Message; }
        _canvaSaving = false;
    }

    private async Task SaveWhatsAppConfig()
    {
        _waError = null;
        _waSuccess = false;
        _waSaving = true;
        try
        {
            var dto = new WhatsAppConfigDto(_waPhoneNumberId, _waAccessToken, _waRecipientNumber, _waVerifyToken);
            var (ok, error) = await Api.SaveWhatsAppConfigAsync(ProjectId, dto);
            if (ok)
            {
                _waSuccess = true;
                _modules = await Api.GetModulesAsync(); // Refresh to pick up sentinel module
            }
            else
                _waError = error;
        }
        catch (Exception ex) { _waError = ex.Message; }
        _waSaving = false;
    }

    private static string FormatInputMapping(string? mapping)
    {
        if (string.IsNullOrEmpty(mapping)) return "usuario";
        if (mapping.Contains("\"user\"")) return "usuario";
        if (mapping.Contains("\"previous\"") && mapping.Contains("\"file\"")) return "paso anterior (archivo)";
        if (mapping.Contains("\"previous\"")) return "paso anterior (texto)";
        if (mapping.Contains("\"step\"")) return "paso especifico";
        return mapping;
    }

    private static int GetMaxPromptLength(string modelName) => modelName.ToLowerInvariant() switch
    {
        "dall-e-2" => 1000,
        "dall-e-3" => 4000,
        var m when m.StartsWith("gpt-image") => 4000,
        var m when m.StartsWith("leonardo-") => 1500,
        var m when m.StartsWith("imagen-") => 4000,
        _ => 4000
    };

    private async Task AddStep()
    {
        _stepError = null;
        if (!Guid.TryParse(_stepModuleId, out var moduleId))
        {
            _stepError = "Selecciona un modulo";
            return;
        }
        _loading = true;
        try
        {
            // Build config for interaction steps
            string? stepConfig = null;
            var mod = _modules.FirstOrDefault(m => m.Id == moduleId);
            if (mod?.ModuleType == "Interaction")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    messageTemplate = string.IsNullOrWhiteSpace(_interactionTemplate) ? "{previous_output}" : _interactionTemplate,
                    messageType = _interactionMessageType,
                    waitForResponse = _interactionWaitForResponse == "true"
                });
            }
            if (mod?.ModuleType == "Text" && _isImagePrompt)
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    isImagePrompt = true,
                    imageCount = _imageCount
                });
            }
            if (mod?.ModuleType == "Design")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    exportFormat = _canvaExportFormat,
                    designTitle = string.IsNullOrWhiteSpace(_canvaDesignTitle) ? "PixelAgents Design" : _canvaDesignTitle,
                    brandTemplateId = string.IsNullOrWhiteSpace(_canvaStepBrandTemplateId) ? (string?)null : _canvaStepBrandTemplateId,
                    designType = _canvaDesignType
                });
            }
            if (mod?.ModuleType == "Publish")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    caption = string.IsNullOrWhiteSpace(_publishCaption) ? "{previous_output}" : _publishCaption,
                    publishType = _publishType
                });
            }
            if (mod?.ModuleType == "Video")
            {
                if (string.IsNullOrWhiteSpace(_videoPrompt))
                {
                    _stepError = "El prompt del video es obligatorio.";
                    _loading = false;
                    return;
                }
                stepConfig = JsonSerializer.Serialize(new
                {
                    videoSource = _videoSource,
                    videoPrompt = _videoPrompt.Trim()
                });
            }
            var req = new AddProjectModuleRequest(moduleId, _stepOrder, _stepName, _inputMapping, stepConfig);
            var (ok, error) = await Api.AddProjectModuleAsync(ProjectId, req);
            if (ok) { _stepName = ""; _stepModuleId = ""; _interactionTemplate = ""; _interactionMessageType = "combined"; _interactionWaitForResponse = "true"; _isImagePrompt = false; _imageCount = 1; _publishCaption = ""; _publishType = "post"; _canvaExportFormat = "png"; _canvaDesignTitle = ""; _canvaStepBrandTemplateId = ""; _canvaDesignType = "doc"; _videoSource = "prompt"; _videoPrompt = ""; await LoadAll(); }
            else _stepError = error;
        }
        catch (Exception ex) { _stepError = $"Error de conexion: {ex.Message}"; }
        _loading = false;
    }

    private void StartEdit(ProjectModuleResponse pm)
    {
        _editingPmId = pm.Id;
        _editStepName = pm.StepName ?? "";
        _editInputMapping = pm.InputMapping ?? "{\"source\":\"user\"}";
        _editError = null;
    }

    private void CancelEdit()
    {
        _editingPmId = null;
        _editError = null;
    }

    private async Task SaveEdit()
    {
        if (_editingPmId is null || _project is null) return;
        _editError = null;

        var pm = _project.Modules.FirstOrDefault(m => m.Id == _editingPmId);
        if (pm is null) return;

        try
        {
            var req = new UpdateProjectModuleRequest(
                pm.StepOrder,
                string.IsNullOrWhiteSpace(_editStepName) ? null : _editStepName,
                _editInputMapping,
                pm.Configuration,
                pm.IsActive);
            var (ok, error) = await Api.UpdateProjectModuleAsync(ProjectId, pm.Id, req);
            if (ok) { _editingPmId = null; await LoadAll(); }
            else _editError = error;
        }
        catch (Exception ex) { _editError = $"Error: {ex.Message}"; }
    }

    private async Task MoveStep(ProjectModuleResponse target, int direction)
    {
        if (_project is null) return;
        _editError = null;

        var sorted = _project.Modules.OrderBy(m => m.StepOrder).ToList();
        var idx = sorted.FindIndex(m => m.Id == target.Id);
        var swapIdx = idx + direction;
        if (swapIdx < 0 || swapIdx >= sorted.Count) return;

        var other = sorted[swapIdx];

        try
        {
            var (ok, error) = await Api.SwapStepOrderAsync(ProjectId, target.Id, other.Id);
            if (!ok) _editError = error;
            await LoadAll();
        }
        catch (Exception ex) { _editError = $"Error: {ex.Message}"; }
    }

    private async Task RemoveStep(Guid pmId)
    {
        _editError = null;
        try
        {
            var (ok, error) = await Api.DeleteProjectModuleAsync(ProjectId, pmId);
            if (ok) await LoadAll();
            else _editError = error;
        }
        catch (Exception ex) { _editError = $"Error: {ex.Message}"; }
    }

    private async Task Execute()
    {
        _execError = null; _executing = true; _result = null;
        _logEntries.Clear();

        try
        {
            var (ok, result, error) = await Api.ExecuteProjectAsync(ProjectId, string.IsNullOrWhiteSpace(_userInput) ? null : _userInput);
            if (ok) { _result = result; _executions = await Api.GetExecutionsAsync(ProjectId); }
            else _execError = error;
        }
        catch (Exception ex) { _execError = $"Error de conexion: {ex.Message}"; }
        _executing = false;
    }

    private async Task CancelExecution()
    {
        await Api.CancelExecutionAsync(ProjectId);
    }

    private async Task LoadExecution(Guid id)
    {
        _logEntries.Clear();
        try
        {
            _result = await Api.GetExecutionDetailAsync(id);
            // Load persisted logs
            var logs = await Api.GetExecutionLogsAsync(id);
            if (logs is not null)
            {
                _logEntries = logs.Select(l => new LogEntry(l.Level, l.Message, l.StepOrder, l.StepName, l.Timestamp)).ToList();
            }
        }
        catch { }
    }

    private void ToggleRetryPanel(int stepOrder)
    {
        if (_retryStepOrder == stepOrder)
        {
            _retryStepOrder = null;
            _retryComment = "";
            _retryError = null;
        }
        else
        {
            _retryStepOrder = stepOrder;
            _retryComment = "";
            _retryError = null;
        }
    }

    private async Task RetryFromStep(int stepOrder)
    {
        if (_result is null) return;
        _retryError = null;
        _executing = true;
        _logEntries.Clear();

        try
        {
            var commentToSend = string.IsNullOrWhiteSpace(_retryComment) ? null : _retryComment;
            var (ok, result, error) = await Api.RetryFromStepAsync(_result.Id, stepOrder, commentToSend);
            if (ok)
            {
                _result = result;
                _retryStepOrder = null;
                _retryComment = "";
            }
            else
            {
                _retryError = error;
            }
        }
        catch (Exception ex) { _retryError = $"Error de conexion: {ex.Message}"; }
        _executing = false;
    }

    private async Task RetryFromLog(int stepOrder)
    {
        if (_result is null) return;
        _retryError = null;
        _executing = true;
        _logEntries.Clear();

        try
        {
            var (ok, result, error) = await Api.RetryFromStepAsync(_result.Id, stepOrder, null);
            if (ok) _result = result;
            else _execError = error;
        }
        catch (Exception ex) { _execError = $"Error de conexion: {ex.Message}"; }
        _executing = false;
    }

    private void ClearLog()
    {
        _logEntries.Clear();
    }

    private void ShowBufferDebug(StepOutputDto parsed)
    {
        _bufferDebugRequest = null;
        _bufferDebugResponse = null;
        _bufferDebugStatus = null;

        if (parsed.Metadata is not null)
        {
            if (parsed.Metadata.TryGetValue("bufferRequest", out var req))
                _bufferDebugRequest = FormatJson(req?.ToString());
            if (parsed.Metadata.TryGetValue("bufferResponse", out var resp))
                _bufferDebugResponse = FormatJson(resp?.ToString());
            if (parsed.Metadata.TryGetValue("bufferStatusCode", out var sc))
            {
                if (sc is JsonElement je && je.TryGetInt32(out var code))
                    _bufferDebugStatus = code;
            }
        }

        _showBufferDebug = true;
    }

    private static string? FormatJson(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return raw;
        try
        {
            using var doc = JsonDocument.Parse(raw);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions { WriteIndented = true });
        }
        catch { return raw; }
    }

    private static StepOutputDto? TryParseOutput(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return null;
        try
        {
            var parsed = JsonSerializer.Deserialize<StepOutputDto>(json, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });
            return parsed?.Type is not null ? parsed : null;
        }
        catch { return null; }
    }

    private static string StatusBadge(string status) => status switch
    {
        "Completed" => "badge-success",
        "Failed" => "badge-danger",
        "Running" => "badge-warning",
        "WaitingForInput" => "badge-info",
        "Cancelled" => "badge-warning",
        _ => "badge-info"
    };

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            try { await _hubConnection.InvokeAsync("LeaveProject", ProjectId.ToString()); } catch { }
            await _hubConnection.DisposeAsync();
        }
    }
}
