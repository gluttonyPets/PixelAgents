    private record ParsedInputData(string? SystemPrompt, string? MandatoryRules, string? ProjectContext, List<string> Prompts, string RawJson);

    private record CheckpointEntry(string Label, string Value);

    private static List<CheckpointEntry> ParseCheckpointEntries(string json)
    {
        var entries = new List<CheckpointEntry>();
        try
        {
            using var doc = JsonDocument.Parse(json);
            foreach (var prop in doc.RootElement.EnumerateObject())
            {
                var label = prop.Name.Replace("_", " ");
                // Capitalize first letter
                if (label.Length > 0) label = char.ToUpper(label[0]) + label[1..];

                string value;
                if (prop.Value.ValueKind == JsonValueKind.String)
                    value = prop.Value.GetString() ?? "";
                else
                    value = prop.Value.GetRawText();

                // Trim very long values for the formal view
                if (value.Length > 2000) value = value[..2000] + "\n... (truncado)";
                entries.Add(new CheckpointEntry(label, value));
            }
        }
        catch
        {
            entries.Add(new CheckpointEntry("Datos", json));
        }
        return entries;
    }

    private static string? GetSystemPromptFromConfig(string? configuration)
    {
        if (string.IsNullOrWhiteSpace(configuration)) return null;
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(configuration);
            if (doc.RootElement.TryGetProperty("systemPrompt", out var sp))
                return sp.GetString();
        }
        catch { }
        return null;
    }

    private static ParsedInputData? ParseInputData(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return null;
        try
        {
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            string? systemPrompt = null;
            string? projectContext = null;
            var prompts = new List<string>();

            if (root.TryGetProperty("systemPrompt", out var spEl) && spEl.ValueKind == JsonValueKind.String)
                systemPrompt = spEl.GetString();

            if (root.TryGetProperty("projectContext", out var pcEl) && pcEl.ValueKind == JsonValueKind.String)
                projectContext = pcEl.GetString();

            string? mandatoryRules = null;
            if (root.TryGetProperty("mandatoryRules", out var mrEl) && mrEl.ValueKind == JsonValueKind.String)
                mandatoryRules = mrEl.GetString();

            // Single prompt
            if (root.TryGetProperty("prompt", out var promptEl) && promptEl.ValueKind == JsonValueKind.String)
            {
                var val = promptEl.GetString();
                if (!string.IsNullOrWhiteSpace(val)) prompts.Add(val);
            }

            // Multiple prompts
            if (root.TryGetProperty("prompts", out var promptsEl) && promptsEl.ValueKind == JsonValueKind.Array)
            {
                prompts = promptsEl.EnumerateArray()
                    .Where(e => e.ValueKind == JsonValueKind.String)
                    .Select(e => e.GetString()!)
                    .Where(s => !string.IsNullOrWhiteSpace(s))
                    .ToList();
            }

            // Pretty-print the raw JSON for fallback/non-AI steps
            var rawJson = JsonSerializer.Serialize(doc.RootElement, PrettyJsonOptions);

            return new ParsedInputData(systemPrompt, mandatoryRules, projectContext, prompts, rawJson);
        }
        catch { return null; }
    }

    private static StepOutputDto? TryParseOutput(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return null;
        try
        {
            var parsed = JsonSerializer.Deserialize<StepOutputDto>(json, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });
            return parsed?.Type is not null ? parsed : null;
        }
        catch { return null; }
    }

    private List<StepExecutionStatus>? GetStepStatuses()
    {
        // During execution, use real-time step statuses from SignalR
        if (_executing && _realtimeStepStatuses.Count > 0)
        {
            return _realtimeStepStatuses
                .Select(kv => new StepExecutionStatus(kv.Key, kv.Value))
                .ToList();
        }
        if (_result?.Steps is null || _result.Steps.Count == 0) return null;
        return _result.Steps.Select(s => new StepExecutionStatus(s.ProjectModuleId, s.Status)).ToList();
    }

    private List<ExecutionLogEntry>? GetExecutionLogs()
    {
        if (_logEntries.Count == 0) return null;
        return _logEntries.Select(l => new ExecutionLogEntry(l.Level, l.Message, l.ProjectModuleId, l.ModuleName, l.Timestamp)).ToList();
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private static string StatusBadge(string status) => status switch
    {
        "Completed" => "badge-success",
        "Failed" => "badge-danger",
        "Running" => "badge-warning",
        "WaitingForInput" => "badge-info",
        "WaitingForReview" => "badge-info",
        "WaitingForCheckpoint" => "badge-warning",
        "Rejected" => "badge-danger",
        "Cancelled" => "badge-warning",
        _ => "badge-info"
    };

    // ── Planner execution mode ─────────────────────────────────────────────

    private async Task SetExecutionMode(string mode)
    {
        _executionMode = mode;
        if (mode == "planner" && _project is not null)
        {
            if (_plannerModels.Count == 0)
                _plannerModels = await Api.GetPlannerModelsAsync();
            _plannedPrompts = await Api.GetPlannedPromptsAsync(_project.Id);
        }
        StateHasChanged();
    }

    private async Task GeneratePlannedPrompts()
    {
        _plannerError = null;
        if (_project is null) return;
        if (string.IsNullOrWhiteSpace(_plannerModelName))
        {
            _plannerError = "Elige un modelo generador";
            return;
        }
        if (string.IsNullOrWhiteSpace(_plannerInstructions))
        {
            _plannerError = "Escribe las instrucciones";
            return;
        }
        if (_plannerCount < 1 || _plannerCount > 50)
        {
            _plannerError = "Cantidad debe estar entre 1 y 50";
            return;
        }

        _plannerBusy = true;
        try
        {
            var (ok, _, error) = await Api.GeneratePlannedPromptsAsync(
                _project.Id,
                new GeneratePlannedPromptsRequest(_plannerModelName!, _plannerCount, _plannerInstructions!, _plannerReplace));
            if (!ok) { _plannerError = error ?? "Error al generar"; return; }
            _plannedPrompts = await Api.GetPlannedPromptsAsync(_project.Id);
        }
        finally { _plannerBusy = false; }
    }

    private async Task AddManualPrompt()
    {
        if (_project is null) return;
        var (ok, item, _) = await Api.CreatePlannedPromptAsync(_project.Id, "Nuevo prompt");
        if (ok && item is not null) _plannedPrompts.Add(item);
    }

    private async Task DeletePrompt(Guid promptId)
    {
        if (_project is null) return;
        var (ok, _) = await Api.DeletePlannedPromptAsync(_project.Id, promptId);
        if (ok) _plannedPrompts = _plannedPrompts.Where(p => p.Id != promptId).ToList();
    }

    private async Task OnPromptContentChanged(Guid promptId, string newContent)
    {
        if (_project is null) return;
        var (ok, item, _) = await Api.UpdatePlannedPromptAsync(_project.Id, promptId, newContent);
        if (ok && item is not null)
        {
            var idx = _plannedPrompts.FindIndex(p => p.Id == promptId);
            if (idx >= 0) _plannedPrompts[idx] = item;
        }
    }

    private async Task ExecutePlannedPrompt(Guid promptId)
    {
        if (_project is null) return;
        _plannerError = null;
        _execError = null;
        _result = null;
        _logEntries.Clear();
        _realtimeStepStatuses.Clear();
        _executing = true;
        _executingPromptId = promptId;
        _activeTab = "pipeline";
        StateHasChanged();
        try
        {
            var (ok, item, error) = await Api.ExecutePlannedPromptAsync(_project.Id, promptId);
            if (!ok)
            {
                _plannerError = error ?? "Error al ejecutar el prompt";
                _executing = false;
                return;
            }
            if (item is not null)
            {
                var idx = _plannedPrompts.FindIndex(p => p.Id == promptId);
                if (idx >= 0) _plannedPrompts[idx] = item;
            }
            StartPolling();
        }
        catch (Exception ex)
        {
            _plannerError = $"Error de conexion: {ex.Message}";
            _executing = false;
        }
        finally
        {
            _executingPromptId = null;
        }
    }

    private async Task MovePrompt(int index, int delta)
    {
        if (_project is null) return;
        var newIndex = index + delta;
        if (newIndex < 0 || newIndex >= _plannedPrompts.Count) return;
        var item = _plannedPrompts[index];
        _plannedPrompts.RemoveAt(index);
        _plannedPrompts.Insert(newIndex, item);
        var ids = _plannedPrompts.Select(p => p.Id).ToList();
        var (ok, list, _) = await Api.ReorderPlannedPromptsAsync(_project.Id, ids);
        if (ok && list is not null) _plannedPrompts = list;
    }

    public async ValueTask DisposeAsync()
    {
        StopPolling();
        _execDetailRefreshTimer?.Dispose();
        if (_hubConnection is not null)
        {
            try { await _hubConnection.InvokeAsync("LeaveProject", ProjectId.ToString()); } catch { }
            await _hubConnection.DisposeAsync();
        }
    }
}
