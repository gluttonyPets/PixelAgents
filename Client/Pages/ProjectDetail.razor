    }

    <!-- Execute tab removed — UI is now in the pipeline inspector panel -->
    <!-- ═══════════ TAB: HISTORIAL ═══════════ -->
    @if (_activeTab == "history")
    {
        <div class="tab-content tab-content-scroll">
            @if (_executions.Count > 0)
            {
                @* ── Date filter bar ── *@
                <div class="history-date-bar">
                    <button class="hd-arrow" @onclick="() => HistoryDateNav(-1)" title="Dia anterior">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"/></svg>
                    </button>
                    <div class="hd-chips">
                        <button class="hd-chip @(_historyShowAll ? "hd-chip-active" : "")"
                                @onclick="() => { _historyShowAll = true; }">
                            Todas <span class="hd-badge">@_executions.Count</span>
                        </button>
                        @foreach (var day in _executions.Select(e => e.CreatedAt.Date).Distinct().OrderByDescending(d => d).Take(14))
                        {
                            var d = day;
                            var isToday = d == DateTime.Today;
                            var label = isToday ? "Hoy" : d == DateTime.Today.AddDays(-1) ? "Ayer" : d.ToString("dd MMM");
                            var count = _executions.Count(e => e.CreatedAt.Date == d);
                            <button class="hd-chip @(!_historyShowAll && _historyDateFilter.Date == d ? "hd-chip-active" : "")"
                                    @onclick="() => { _historyShowAll = false; _historyDateFilter = d; }">
                                @label <span class="hd-badge">@count</span>
                            </button>
                        }
                    </div>
                    <button class="hd-arrow" @onclick="() => HistoryDateNav(1)" title="Dia siguiente">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/></svg>
                    </button>
                </div>

                @if (_filteredExecutions.Count > 0)
                {
                    @foreach (var e in _filteredExecutions)
                    {
                        var isExpanded = _expandedExecId == e.Id;
                        <div class="history-card" @key="e.Id">
                            <div class="history-card-header" @onclick="() => ToggleHistoryCard(e.Id)">
                                <div class="history-card-info">
                                    <span class="badge @StatusBadge(e.Status)">@e.Status</span>
                                    <span class="text-sm text-muted">@e.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                                    @if (e.TotalEstimatedCost > 0)
                                    {
                                        <span class="text-sm text-muted">~$@e.TotalEstimatedCost.ToString("F4")</span>
                                    }
                                </div>
                                <div class="history-card-prompt">
                                    @if (e.UserInput is not null)
                                    {
                                        <span class="text-sm">@(e.UserInput.Length > 120 ? e.UserInput[..120] + "..." : e.UserInput)</span>
                                    }
                                    else
                                    {
                                        <span class="text-sm text-muted">Sin prompt</span>
                                    }
                                </div>
                                <div class="history-card-actions">
                                    <button class="btn btn-sm btn-primary" @onclick="() => ViewExecution(e.Id)" @onclick:stopPropagation="true">
                                        Abrir
                                    </button>
                                    <span class="history-expand-icon">@(isExpanded ? "&#x25B2;" : "&#x25BC;")</span>
                                </div>
                            </div>

                            @if (isExpanded && _expandedExecDetail is not null && _expandedExecDetail.Id == e.Id)
                            {
                                <div class="history-card-body">
                                    @foreach (var step in _expandedExecDetail.Steps.OrderBy(s => s.StepOrder))
                                    {
                                        @if (step.Status == "WaitingForCheckpoint")
                                        {
                                            <div class="history-step-preview" style="border-left: 3px solid #ff9800; padding-left: 0.5rem;">
                                                <div style="display: flex; align-items: center; gap: 0.4rem;">
                                                    <span class="text-sm" style="color: #ff9800; font-weight: 600;">Checkpoint esperando revision</span>
                                                    @if (e.Status == "WaitingForCheckpoint")
                                                    {
                                                        <button class="btn btn-success btn-xs" style="font-size: 0.65rem; padding: 0.1rem 0.35rem;"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="@(() => { _checkpointExecutionId = e.Id; _checkpointPreviewJson = step.InputData; _showCheckpointModal = true; StateHasChanged(); })">
                                                            Revisar
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        else if (step.OutputData is not null)
                                        {
                                            var parsed = TryParseOutput(step.OutputData);
                                            @if (parsed?.Type == "image" && parsed.Files is not null && parsed.Files.Count > 0)
                                            {
                                                <div class="history-step-preview">
                                                    <span class="text-sm text-muted">Paso @GetStepLabelFromOrder(step.StepOrder): @step.ModuleName</span>
                                                    <div class="history-image-grid">
                                                        @foreach (var f in parsed.Files)
                                                        {
                                                            var fileUrl = $"{_apiBase}/api/executions/{_expandedExecDetail.Id}/files/{f.FileId}";
                                                            <div class="history-image-item">
                                                                <img src="@fileUrl" alt="@f.FileName" class="history-image-thumb" crossorigin="use-credentials" />
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            else if (parsed?.Type == "video" && parsed.Files is not null && parsed.Files.Count > 0)
                                            {
                                                <div class="history-step-preview">
                                                    <span class="text-sm text-muted">Paso @GetStepLabelFromOrder(step.StepOrder): @step.ModuleName</span>
                                                    @foreach (var f in parsed.Files)
                                                    {
                                                        var fileUrl = $"{_apiBase}/api/executions/{_expandedExecDetail.Id}/files/{f.FileId}";
                                                        <video controls style="max-width: 200px; border-radius: 6px; margin-top: 0.3rem;" crossorigin="use-credentials">
                                                            <source src="@fileUrl" type="@f.ContentType" />
                                                        </video>
                                                    }
                                                </div>
                                            }
                                            else if (parsed?.Type == "text" && parsed.Content is not null)
                                            {
                                                <div class="history-step-preview">
                                                    <span class="text-sm text-muted">Paso @GetStepLabelFromOrder(step.StepOrder): @step.ModuleName</span>
                                                    <div class="output-block" style="font-size: 0.8rem; max-height: 80px; overflow: hidden;">
                                                        @(parsed.Content.Length > 200 ? parsed.Content[..200] + "..." : parsed.Content)
                                                    </div>
                                                </div>
                                            }
                                        }
                                    }
                                </div>
                            }
                            else if (isExpanded && _expandedExecDetail is null)
                            {
                                <div class="history-card-body">
                                    <p class="text-sm text-muted">Cargando...</p>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state" style="padding: 2rem 1rem;">
                        <p class="text-sm text-muted">Sin ejecuciones en este dia</p>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <span class="empty-state-icon">&#x1F4CB;</span>
                    <p>Sin ejecuciones aun</p>
                    <p class="text-sm text-muted">Ejecuta el pipeline para ver resultados aqui</p>
                </div>
            }
        </div>
    }

</div> @* end project-page-layout *@

    <!-- ═══════════ EXECUTION DETAIL MODAL ═══════════ -->
    @if (_showExecDetailModal)
    {
        <div class="modal-overlay" @onclick="() => _showExecDetailModal = false">
            <div class="settings-modal" @onclick:stopPropagation="true" style="max-width: 1100px; width: 95vw;">
                <div class="settings-modal-header">
                    <h3 style="margin: 0;">Detalle de ejecucion</h3>
                    @if (_execDetailModal is not null && (_execDetailModal.Status == "Running" || _execDetailModal.Status == "WaitingForInput"))
                    {
                        <button class="btn btn-sm" style="margin-left: 0.5rem; font-size: 0.7rem;" @onclick="() => RefreshExecDetail(_execDetailModal.Id)">
                            &#x21BB; Actualizar
                        </button>
                    }
                    <button class="btn-icon" @onclick="() => { _showExecDetailModal = false; _execDetailRefreshTimer?.Dispose(); }">&#x2715;</button>
                </div>
                <div class="settings-modal-body" style="max-height: 75vh; overflow: hidden; padding: 0;">
                    @if (_execDetailModal is null)
                    {
                        <p class="text-muted" style="padding: 1rem;">Cargando...</p>
                    }
                    else
                    {
                        <div style="padding: 0.5rem 0.8rem;">
                            <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem; flex-wrap: wrap;">
                                <span class="badge @StatusBadge(_execDetailModal.Status)">@_execDetailModal.Status</span>
                                <span class="text-sm text-muted">@_execDetailModal.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                                @if (_execDetailModal.CompletedAt.HasValue)
                                {
                                    <span class="text-sm text-muted">- @_execDetailModal.CompletedAt.Value.ToString("HH:mm")</span>
                                }
                                @if (_execDetailModal.TotalEstimatedCost > 0)
                                {
                                    <span class="text-sm text-muted">~$@_execDetailModal.TotalEstimatedCost.ToString("F4")</span>
                                }
                            </div>
                            @if (_execDetailModal.UserInput is not null)
                            {
                                <div class="output-block" style="font-size: 0.8rem; margin-bottom: 0.5rem; max-height: 60px; overflow-y: auto;">
                                    <strong>Prompt:</strong> @_execDetailModal.UserInput
                                </div>
                            }
                        </div>

                        <div style="display: flex; gap: 0; height: calc(75vh - 130px); overflow: hidden;">
                            <!-- Left: Steps -->
                            <div style="flex: 1; overflow-y: auto; padding: 0 0.8rem 0.8rem; border-right: 1px solid var(--border);">
                                @{ var visibleSteps = _execDetailModal.Steps
                                    .Where(s => !PassThroughModuleTypes.Contains(s.ModuleType))
                                    .OrderBy(s => s.StepOrder).ToList();
                                   var stepIdx = 0; }
                                @foreach (var step in visibleSteps)
                                {
                                    stepIdx++;
                                    var isExpanded = _expandedSteps.Contains(step.StepOrder);
                                    var capturedOrder = step.StepOrder;
                                    var duration = step.CompletedAt.HasValue ? (step.CompletedAt.Value - step.CreatedAt).TotalSeconds : 0;

                                    <div class="exec-step-card @(step.Status == "Failed" ? "exec-step-failed" : step.Status == "Running" ? "exec-step-running" : "")">
                                        @* ── Compact header (always visible) ── *@
                                        <div class="exec-step-header" @onclick="() => ToggleStepExpanded(capturedOrder)">
                                            <span class="exec-step-badge">@stepIdx</span>
                                            <span class="exec-step-name">@step.ModuleName</span>
                                            <span class="badge @StatusBadge(step.Status)" style="font-size: 0.58rem;">@step.Status</span>
                                            @if (step.EstimatedCost > 0)
                                            {
                                                <span class="text-sm text-muted">$@step.EstimatedCost.ToString("F4")</span>
                                            }
                                            @if (duration > 0)
                                            {
                                                <span class="text-sm text-muted">@(duration < 1 ? "<1s" : $"{duration:F0}s")</span>
                                            }
                                            @if (step.Status == "WaitingForCheckpoint" && _execDetailModal.Status == "WaitingForCheckpoint")
                                            {
                                                <button class="btn btn-success btn-xs" style="font-size: 0.6rem; margin-left: auto; padding: 0.1rem 0.35rem;"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="@(() => { _checkpointExecutionId = _execDetailModal.Id; _checkpointPreviewJson = step.InputData; _showCheckpointModal = true; StateHasChanged(); })">
                                                    Revisar
                                                </button>
                                            }
                                            <span class="exec-step-chevron @(isExpanded ? "expanded" : "")">&#x25B6;</span>
                                        </div>

                                        @if (step.ErrorMessage is not null)
                                        {
                                            <div class="alert alert-error" style="font-size: 0.72rem; padding: 0.25rem 0.5rem; margin: 0.3rem 0 0;">@step.ErrorMessage</div>
                                        }

                                        @* ── Summary line (compact view): show a brief output preview ── *@
                                        @if (!isExpanded && step.OutputData is not null)
                                        {
                                            var preview = TryParseOutput(step.OutputData);
                                            @if (preview?.Type == "text" && preview.Content is not null)
                                            {
                                                <div class="exec-step-preview">@(preview.Content.Length > 120 ? preview.Content[..120] + "..." : preview.Content)</div>
                                            }
                                            else if (preview?.Type == "scene" && preview.Content is not null)
                                            {
                                                var scenePreview = FormatJson(preview.Content) ?? preview.Content;
                                                <div class="exec-step-preview">@(scenePreview.Length > 120 ? scenePreview[..120] + "..." : scenePreview)</div>
                                            }
                                            else if (preview?.Files is { Count: > 0 })
                                            {
                                                <div class="exec-step-preview">@preview.Files.Count archivo(s): @string.Join(", ", preview.Files.Select(f => f.FileName))</div>
                                            }
                                        }

                                        @* ── Expanded detail ── *@
                                        @if (isExpanded)
                                        {
                                            <div class="exec-step-detail">
                                                @* ── INPUTS ── *@
                                                @if (step.InputData is not null)
                                                {
                                                    @if (step.Status == "WaitingForCheckpoint" || step.ModuleName?.Contains("Checkpoint", StringComparison.OrdinalIgnoreCase) == true)
                                                    {
                                                        <div class="exec-io-section">
                                                            <div class="exec-io-title exec-io-in">Datos del Checkpoint</div>
                                                            <pre class="exec-io-block">@step.InputData</pre>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        var inputParsed = ParseInputData(step.InputData);
                                                        @if (inputParsed is not null)
                                                        {
                                                            @if (inputParsed.SystemPrompt is not null)
                                                            {
                                                                <div class="exec-io-section">
                                                                    <div class="exec-io-title exec-io-in">System Prompt</div>
                                                                    <div class="exec-io-block">@inputParsed.SystemPrompt</div>
                                                                </div>
                                                            }
                                                            @if (inputParsed.Prompts.Count > 0)
                                                            {
                                                                @foreach (var (prompt, pi) in inputParsed.Prompts.Select((p, i) => (p, i)))
                                                                {
                                                                    <div class="exec-io-section">
                                                                        <div class="exec-io-title exec-io-in">@(inputParsed.Prompts.Count > 1 ? $"Input {pi + 1}" : "Input")</div>
                                                                        <div class="exec-io-block">@prompt</div>
                                                                    </div>
                                                                }
                                                            }
                                                            @if (inputParsed.SystemPrompt is null && inputParsed.Prompts.Count == 0)
                                                            {
                                                                <div class="exec-io-section">
                                                                    <div class="exec-io-title exec-io-in">Input</div>
                                                                    <pre class="exec-io-block">@inputParsed.RawJson</pre>
                                                                </div>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <div class="exec-io-section">
                                                                <div class="exec-io-title exec-io-in">Input</div>
                                                                <pre class="exec-io-block">@step.InputData</pre>
                                                            </div>
                                                        }
                                                    }
                                                }

                                                @* ── OUTPUTS ── *@
                                                @if (step.OutputData is not null)
                                                {
                                                    var parsed = TryParseOutput(step.OutputData);
                                                    @if (parsed?.Type == "text")
                                                    {
                                                        @if (parsed.Items is { Count: > 0 })
                                                        {
                                                            @foreach (var (item, oi) in parsed.Items.Select((it, i) => (it, i)))
                                                            {
                                                                <div class="exec-io-section">
                                                                    <div class="exec-io-title exec-io-out">@(parsed.Items.Count > 1 ? $"Output {oi + 1}" : "Output") @(item.Label is not null ? $"({item.Label})" : "")</div>
                                                                    <div class="exec-io-block">@item.Content</div>
                                                                </div>
                                                            }
                                                        }
                                                        @if (parsed.Content is not null)
                                                        {
                                                            <div class="exec-io-section">
                                                                <div class="exec-io-title exec-io-out">@(parsed.Items is { Count: > 0 } ? "Content" : "Output")</div>
                                                                <div class="exec-io-block">@parsed.Content</div>
                                                            </div>
                                                        }
                                                    }
                                                    else if (parsed?.Files is { Count: > 0 })
                                                    {
                                                        <div class="exec-io-section">
                                                            <div class="exec-io-title exec-io-out">Output (@parsed.Files.Count archivo/s)</div>
                                                            @if (parsed.Type == "image")
                                                            {
                                                                <div class="history-image-grid" style="margin-top: 0.2rem;">
                                                                    @foreach (var f in parsed.Files)
                                                                    {
                                                                        var fileUrl = $"{_apiBase}/api/executions/{_execDetailModal.Id}/files/{f.FileId}";
                                                                        <div class="history-image-item">
                                                                            <img src="@fileUrl" alt="@f.FileName" class="history-image-thumb" crossorigin="use-credentials" style="max-width: 200px;" />
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                @foreach (var f in parsed.Files)
                                                                {
                                                                    var fileUrl = $"{_apiBase}/api/executions/{_execDetailModal.Id}/files/{f.FileId}";
                                                                    @if (parsed.Type == "video")
                                                                    {
                                                                        <video controls style="max-width: 300px; border-radius: 6px; margin-top: 0.3rem;" crossorigin="use-credentials">
                                                                            <source src="@fileUrl" type="@f.ContentType" />
                                                                        </video>
                                                                    }
                                                                }
                                                            }
                                                        </div>
                                                    }
                                                    else if (parsed?.Type == "scene" && parsed.Content is not null)
                                                    {
                                                        <div class="exec-io-section">
                                                            <div class="exec-io-title exec-io-out">Output escena</div>
                                                            <pre class="exec-io-block">@(FormatJson(parsed.Content) ?? parsed.Content)</pre>
                                                        </div>
                                                    }
                                                    else if (parsed?.Content is not null)
                                                    {
                                                        <div class="exec-io-section">
                                                            <div class="exec-io-title exec-io-out">Output</div>
                                                            <div class="exec-io-block">@parsed.Content</div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="exec-io-section">
                                                            <div class="exec-io-title exec-io-out">Output</div>
                                                            <pre class="exec-io-block">@(FormatJson(step.OutputData) ?? step.OutputData)</pre>
                                                        </div>
                                                    }
                                                }

                                                @* ── FILES ── *@
                                                @if (step.Files is { Count: > 0 })
                                                {
                                                    <div class="exec-io-section">
                                                        <div class="exec-io-title" style="color: var(--text-muted);">Archivos</div>
                                                        <div style="display: flex; flex-wrap: wrap; gap: 0.3rem;">
                                                            @foreach (var file in step.Files.Where(f => f.Direction == "Output"))
                                                            {
                                                                var capturedFile = file;
                                                                var capturedExecId = _execDetailModal.Id;
                                                                <button class="btn btn-sm" style="font-size: 0.7rem; padding: 0.12rem 0.35rem;"
                                                                        @onclick="() => DownloadFile(capturedExecId, capturedFile.Id, capturedFile.FileName)">
                                                                    &#x2B73; @file.FileName <span class="text-muted">(@FormatFileSize(file.FileSize))</span>
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                }

                                                @* ── RETRY ── *@
                                                @if ((step.Status == "Completed" || step.Status == "Failed") && !_executing)
                                                {
                                                    var capturedStepOrder = step.StepOrder;
                                                    <div style="margin-top: 0.4rem; display: flex; align-items: center; gap: 0.3rem; flex-wrap: wrap;">
                                                        <button class="btn btn-sm btn-outline" style="font-size: 0.68rem; padding: 0.12rem 0.4rem;"
                                                                @onclick="() => ToggleRetryPanel(capturedStepOrder)">
                                                            &#x21BB; Reiniciar desde aqui
                                                        </button>
                                                        @if (_retryStepOrder == capturedStepOrder)
                                                        {
                                                            <input type="text" @bind="_retryComment" placeholder="Comentario..."
                                                                   style="font-size: 0.72rem; padding: 0.15rem 0.35rem; flex: 1; min-width: 100px;" />
                                                            <button class="btn btn-sm btn-primary" style="font-size: 0.68rem; padding: 0.12rem 0.4rem;"
                                                                    @onclick="() => RetryFromStep(capturedStepOrder)">
                                                                Ejecutar
                                                            </button>
                                                        }
                                                    </div>
                                                    @if (_retryError is not null && _retryStepOrder == capturedStepOrder)
                                                    {
                                                        <div class="alert alert-error" style="font-size: 0.68rem; padding: 0.2rem 0.4rem; margin-top: 0.2rem;">@_retryError</div>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- Right: Logs -->
                            <div style="width: 360px; min-width: 280px; overflow-y: auto; padding: 0 0.8rem 0.8rem; display: flex; flex-direction: column;">
                                <div style="font-weight: 600; font-size: 0.85rem; padding: 0.3rem 0; position: sticky; top: 0; background: var(--bg-secondary); z-index: 1;">
                                    Logs @(_execDetailLogs is { Count: > 0 } ? $"({_execDetailLogs.Count})" : "")
                                </div>
                                @if (_execDetailLogs is { Count: > 0 })
                                {
                                    <div class="inspector-log-entries" style="flex: 1;">
                                        @foreach (var log in _execDetailLogs)
                                        {
                                            @if (log.Level == "step-start")
                                            {
                                                <div class="inspector-log-step-header">
                                                    <span class="inspector-log-time">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                                    @if (log.StepOrder.HasValue)
                                                    {
                                                        var logLabel = GetStepLabelFromOrder(log.StepOrder.Value);
                                                        @if (!string.IsNullOrEmpty(logLabel))
                                                        {
                                                            <span class="inspector-log-step-badge">@logLabel</span>
                                                        }
                                                    }
                                                    <span class="inspector-log-step-name">@log.Message</span>
                                                </div>
                                            }
                                            else if (log.Level == "input")
                                            {
                                                <div class="inspector-log-io inspector-log-io-in">
                                                    <span class="inspector-log-io-label">IN</span>
                                                    <span class="inspector-log-io-text">@log.Message</span>
                                                </div>
                                            }
                                            else if (log.Level == "output")
                                            {
                                                <div class="inspector-log-io inspector-log-io-out">
                                                    <span class="inspector-log-io-label">OUT</span>
                                                    <span class="inspector-log-io-text">@log.Message</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="inspector-log-entry inspector-log-@log.Level">
                                                    <span class="inspector-log-time">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                                    @if (log.StepOrder.HasValue)
                                                    {
                                                        var logLabel = GetStepLabelFromOrder(log.StepOrder.Value);
                                                        @if (!string.IsNullOrEmpty(logLabel))
                                                        {
                                                            <span class="inspector-log-step">P@logLabel</span>
                                                        }
                                                    }
                                                    <span>@log.Message</span>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-sm text-muted">Sin logs</p>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- ═══════════ SETTINGS MODAL ═══════════ -->
    @if (_showSettings)
    {
        <div class="modal-overlay" @onclick="() => _showSettings = false">
            <div class="settings-modal" @onclick:stopPropagation="true">
                <div class="settings-modal-header">
                    <h3 style="margin: 0;">Configuracion</h3>
                    <button class="btn-icon" @onclick="() => _showSettings = false">&#x2715;</button>
                </div>

                <!-- Settings tabs -->
                <div class="settings-tab-bar">
                    <button class="settings-tab @(_settingsTab == "messaging" ? "settings-tab-active" : "")"
                            @onclick='() => _settingsTab = "messaging"'>
                        Mensajeria
                    </button>
                    <button class="settings-tab @(_settingsTab == "social" ? "settings-tab-active" : "")"
                            @onclick='() => _settingsTab = "social"'>
                        Redes sociales
                    </button>
                    <button class="settings-tab @(_settingsTab == "schedule" ? "settings-tab-active" : "")"
                            @onclick='() => _settingsTab = "schedule"'>
                        Programacion
                    </button>
                </div>

                <div class="settings-modal-body">
                    <!-- MESSAGING TAB -->
                    @if (_settingsTab == "messaging")
                    {
                        <!-- Telegram -->
                        <div class="settings-block">
                            <div class="settings-block-header">
                                <strong>Telegram</strong>
                                @if (!string.IsNullOrWhiteSpace(_tgBotToken))
                                {
                                    <span class="badge badge-success">Configurado</span>
                                }
                            </div>
                            @if (_tgError is not null)
                            {
                                <div class="alert alert-error">@_tgError</div>
                            }
                            @if (_tgSuccess)
                            {
                                <div class="alert alert-success">Guardado correctamente</div>
                            }
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Bot Token</label>
                                    <input type="password" @bind="_tgBotToken" placeholder="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11" />
                                </div>
                                <div class="form-group">
                                    <label>Chat ID</label>
                                    <input type="text" @bind="_tgChatId" placeholder="Ej: 123456789" />
                                </div>
                            </div>
                            <p class="text-sm text-muted">
                                1. Habla con <strong>@@BotFather</strong> en Telegram &#x2192; <code>/newbot</code> &#x2192; copia el token.<br/>
                                2. Envia un mensaje al bot y visita <code>https://api.telegram.org/bot&lt;TOKEN&gt;/getUpdates</code> para obtener tu Chat ID.
                            </p>
                            <button class="btn btn-primary btn-sm" @onclick="SaveTelegramConfig" disabled="@_tgSaving">
                                @(_tgSaving ? "Guardando..." : "Guardar")
                            </button>
                        </div>

                        <!-- WhatsApp -->
                        <div class="settings-block">
                            <div class="settings-block-header">
                                <strong>WhatsApp</strong>
                                @if (!string.IsNullOrWhiteSpace(_waAccessToken))
                                {
                                    <span class="badge badge-success">Configurado</span>
                                }
                            </div>
                            @if (_waError is not null)
                            {
                                <div class="alert alert-error">@_waError</div>
                            }
                            @if (_waSuccess)
                            {
                                <div class="alert alert-success">Guardado correctamente</div>
                            }
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Phone Number ID</label>
                                    <input type="text" @bind="_waPhoneNumberId" placeholder="Ej: 123456789012345" />
                                </div>
                                <div class="form-group">
                                    <label>Numero destinatario</label>
                                    <input type="text" @bind="_waRecipientNumber" placeholder="Ej: 34612345678" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Access Token</label>
                                <input type="password" @bind="_waAccessToken" placeholder="EAABx..." />
                            </div>
                            <div class="form-group">
                                <label>Webhook Verify Token</label>
                                <input type="text" @bind="_waVerifyToken" placeholder="Token de verificacion para el webhook" />
                            </div>
                            <p class="text-sm text-muted">
                                Webhook URL: <code>https://tu-servidor/api/webhooks/whatsapp</code>
                            </p>
                            <button class="btn btn-primary btn-sm" @onclick="SaveWhatsAppConfig" disabled="@_waSaving">
                                @(_waSaving ? "Guardando..." : "Guardar")
                            </button>
                        </div>
                    }

                    <!-- SOCIAL TAB -->
                    @if (_settingsTab == "social")
                    {
                        <div class="settings-block">
                            <div class="settings-block-header">
                                <strong>Buffer</strong>
                                <span class="text-sm text-muted">Instagram, Twitter, LinkedIn...</span>
                                @if (!string.IsNullOrWhiteSpace(_igApiKey))
                                {
                                    <span class="badge badge-success">Configurado</span>
                                }
                            </div>
                            @if (_igError is not null)
                            {
                                <div class="alert alert-error">@_igError</div>
                            }
                            @if (_igSuccess)
                            {
                                <div class="alert alert-success">Guardado correctamente</div>
                            }
                            <div class="form-row">
                                <div class="form-group">
                                    <label>API Key</label>
                                    <input type="password" @bind="_igApiKey" placeholder="Token de Buffer API" />
                                </div>
                                <div class="form-group">
                                    <label>Channel ID</label>
                                    <input type="text" @bind="_igChannelId" placeholder="Ej: 65a1b2c3d4e5f6..." />
                                </div>
                            </div>
                            <p class="text-sm text-muted">
                                1. Ve a <strong>buffer.com</strong> &#x2192; Cuenta &#x2192; API Settings &#x2192; genera tu API Key.<br/>
                                2. El <strong>Channel ID</strong> se obtiene consultando tus canales conectados via la API.<br/>
                                3. Plan gratuito: 3 canales, 10 posts programados por canal.
                            </p>
                            <button class="btn btn-primary btn-sm" @onclick="SaveInstagramConfig" disabled="@_igSaving">
                                @(_igSaving ? "Guardando..." : "Guardar")
                            </button>
                        </div>

                        <div class="settings-block" style="margin-top: 1rem;">
                            <div class="settings-block-header">
                                <strong>TikTok (via Buffer)</strong>
                                <span class="text-sm text-muted">Videos e imagenes en TikTok</span>
                                @if (!string.IsNullOrWhiteSpace(_tkApiKey))
                                {
                                    <span class="badge badge-success">Configurado</span>
                                }
                            </div>
                            @if (_tkError is not null)
                            {
                                <div class="alert alert-error">@_tkError</div>
                            }
                            @if (_tkSuccess)
                            {
                                <div class="alert alert-success">Guardado correctamente</div>
                            }
                            <div class="form-row">
                                <div class="form-group">
                                    <label>API Key</label>
                                    <input type="password" @bind="_tkApiKey" placeholder="Token de Buffer API" />
                                </div>
                                <div class="form-group">
                                    <label>Channel ID (TikTok)</label>
                                    <input type="text" @bind="_tkChannelId" placeholder="Ej: 65a1b2c3d4e5f6..." />
                                </div>
                            </div>
                            <p class="text-sm text-muted">
                                Usa la misma API Key de Buffer. El <strong>Channel ID</strong> debe ser el de tu canal TikTok conectado en Buffer.<br/>
                                Soporta videos e imagenes (hasta 4 por post). Formatos: PNG, JPG, GIF, WebP (max 8MB).
                            </p>
                            <button class="btn btn-primary btn-sm" @onclick="SaveTikTokConfig" disabled="@_tkSaving">
                                @(_tkSaving ? "Guardando..." : "Guardar")
                            </button>
                        </div>
                    }

                    <!-- SCHEDULE TAB -->
                    @if (_settingsTab == "schedule")
                    {
                        <div class="settings-block">
                            @if (_schedError is not null)
                            {
                                <div class="alert alert-error">@_schedError</div>
                            }
                            @if (_schedSuccess)
                            {
                                <div class="alert alert-success">Programacion guardada correctamente</div>
                            }

                            @if (_schedule is not null)
                            {
                                <div class="schedule-status">
                                    <div class="schedule-status-item">
                                        <span class="text-muted">Estado</span>
                                        @if (_schedule.IsEnabled)
                                        {
                                            <strong style="color: var(--success);">Activa</strong>
                                        }
                                        else
                                        {
                                            <strong style="color: var(--warning);">Pausada</strong>
                                        }
                                    </div>
                                    @if (_schedule.NextRunAt.HasValue)
                                    {
                                        <div class="schedule-status-item">
                                            <span class="text-muted">Proxima ejecucion</span>
                                            <strong>@_schedule.NextRunAt.Value.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</strong>
                                        </div>
                                    }
                                    @if (_schedule.LastRunAt.HasValue)
                                    {
                                        <div class="schedule-status-item">
                                            <span class="text-muted">Ultima ejecucion</span>
                                            <strong>@_schedule.LastRunAt.Value.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</strong>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="form-group">
                                <label>Frecuencia</label>
                                <select @bind="_schedPreset">
                                    <option value="">Personalizado (cron)</option>
                                    <option value="daily">Diaria (a una hora fija)</option>
                                    <option value="twice">2 veces al dia</option>
                                    <option value="weekly">Semanal</option>
                                </select>
                            </div>

                            @if (_schedPreset == "daily" || _schedPreset == "twice")
                            {
                                <div class="form-row">
                                    <div class="form-group">
                                        <label>Hora (0-23)</label>
                                        <input type="number" min="0" max="23" @bind="_schedHour1" />
                                    </div>
                                    <div class="form-group">
                                        <label>Minuto (0-59)</label>
                                        <input type="number" min="0" max="59" @bind="_schedMinute1" />
                                    </div>
                                </div>
                                @if (_schedPreset == "twice")
                                {
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>2a hora (0-23)</label>
                                            <input type="number" min="0" max="23" @bind="_schedHour2" />
                                        </div>
                                        <div class="form-group">
                                            <label>2o minuto (0-59)</label>
                                            <input type="number" min="0" max="59" @bind="_schedMinute2" />
                                        </div>
                                    </div>
                                }
                            }
                            else if (_schedPreset == "weekly")
                            {
                                <div class="form-row" style="grid-template-columns: 1fr 1fr 1fr;">
                                    <div class="form-group">
                                        <label>Dia de la semana</label>
                                        <select @bind="_schedDayOfWeek">
                                            <option value="1">Lunes</option>
                                            <option value="2">Martes</option>
                                            <option value="3">Miercoles</option>
                                            <option value="4">Jueves</option>
                                            <option value="5">Viernes</option>
                                            <option value="6">Sabado</option>
                                            <option value="0">Domingo</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label>Hora (0-23)</label>
                                        <input type="number" min="0" max="23" @bind="_schedHour1" />
                                    </div>
                                    <div class="form-group">
                                        <label>Minuto (0-59)</label>
                                        <input type="number" min="0" max="59" @bind="_schedMinute1" />
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="form-group">
                                    <label>Expresion Cron</label>
                                    <input type="text" @bind="_schedCron" placeholder="0 9 * * * (cada dia a las 9:00)" />
                                </div>
                                <p class="text-sm text-muted" style="margin-top: -0.4rem; margin-bottom: 0.8rem;">
                                    Ejemplos: <code>0 9 * * *</code> (diario 9am) &middot; <code>0 9,18 * * *</code> (9am y 6pm) &middot; <code>0 10 * * 1</code> (lunes 10am)
                                </p>
                            }

                            <div class="form-row">
                                <div class="form-group">
                                    <label>Zona horaria</label>
                                    <select @bind="_schedTimeZone">
                                        <option value="Europe/Madrid">Europe/Madrid</option>
                                        <option value="Europe/London">Europe/London</option>
                                        <option value="America/New_York">America/New_York</option>
                                        <option value="America/Chicago">America/Chicago</option>
                                        <option value="America/Denver">America/Denver</option>
                                        <option value="America/Los_Angeles">America/Los_Angeles</option>
                                        <option value="America/Mexico_City">America/Mexico_City</option>
                                        <option value="America/Bogota">America/Bogota</option>
                                        <option value="America/Buenos_Aires">America/Buenos_Aires</option>
                                        <option value="America/Sao_Paulo">America/Sao_Paulo</option>
                                        <option value="UTC">UTC</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Input automatico <span class="text-sm text-muted">(opcional)</span></label>
                                    <input type="text" @bind="_schedUserInput" placeholder="Ej: Genera un post sobre tendencias de hoy" />
                                </div>
                            </div>

                            <div style="display: flex; gap: 0.5rem; align-items: center; margin-top: 0.3rem;">
                                <button class="btn btn-primary" @onclick="SaveSchedule" disabled="@_schedSaving">
                                    @(_schedSaving ? "Guardando..." : (_schedule is null ? "Crear programacion" : "Actualizar"))
                                </button>
                                @if (_schedule is not null)
                                {
                                    <button class="btn btn-secondary" @onclick="ToggleSchedule" disabled="@_schedSaving">
                                        @(_schedule.IsEnabled ? "Pausar" : "Activar")
                                    </button>
                                    <button class="btn btn-danger" @onclick="DeleteSchedule" disabled="@_schedSaving">
                                        Eliminar
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

<!-- ═══════════ ORCHESTRATOR REVIEW MODAL ═══════════ -->
@if (_showOrchestratorModal && _result is not null)
{
    <div class="modal-overlay" @onclick="() => {}">
        <div class="orchestrator-modal" @onclick:stopPropagation="true">
            <div class="orchestrator-modal-header">
                <h3 style="margin: 0; font-size: 1rem;">Revision del plan del orquestador</h3>
                <button class="btn-icon" @onclick="CloseOrchestratorModal">&#x2715;</button>
            </div>

            <div class="orchestrator-modal-body">
                @if (!string.IsNullOrWhiteSpace(_orchestratorModalSummary))
                {
                    <div class="orchestrator-summary">
                        <strong>Resumen:</strong> @_orchestratorModalSummary
                    </div>
                }

                @if (_orchestratorModalTasks is not null)
                {
                    <div class="orchestrator-tasks-list">
                        @foreach (var task in _orchestratorModalTasks.OrderBy(t => t.Order))
                        {
                            <div class="orchestrator-task-card">
                                <div class="task-card-header">
                                    <span class="task-order">#@task.Order</span>
                                    <span class="task-desc">@task.Description</span>
                                    <span class="badge badge-info">@task.ModuleName</span>
                                    <span class="badge" style="font-size: 0.65rem; background: var(--border);">@task.ModuleType</span>
                                </div>
                                <div class="task-card-input">
                                    <span class="text-muted" style="font-size: 0.75rem;">Prompt:</span>
                                    @task.Input
                                </div>
                                @if (!string.IsNullOrWhiteSpace(task.Reason))
                                {
                                    <div class="task-card-reason text-muted">@task.Reason</div>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Chat section -->
                <div class="orchestrator-chat">
                    <div class="orchestrator-chat-messages">
                        @if (_orchestratorChat.Count == 0)
                        {
                            <div class="text-muted text-sm" style="text-align: center; padding: 1rem;">
                                Puedes aprobar el plan o dejar un comentario para ajustarlo en la proxima ejecucion.
                            </div>
                        }
                        @foreach (var msg in _orchestratorChat)
                        {
                            <div class="chat-msg @(msg.IsSystem ? "chat-msg-system" : "chat-msg-user")">
                                <span class="chat-msg-text">@msg.Text</span>
                                <span class="chat-msg-time">@msg.Time.ToString("HH:mm")</span>
                            </div>
                        }
                    </div>

                    <div class="orchestrator-chat-input">
                        <textarea @bind="_orchestratorComment" rows="2"
                                  placeholder="Escribe un comentario para ajustar el plan..."
                                  style="flex: 1; font-size: 0.85rem;"></textarea>
                    </div>
                </div>

                @if (_orchestratorError is not null)
                {
                    <div class="alert alert-error" style="font-size: 0.8rem; margin-top: 0.5rem;">@_orchestratorError</div>
                }
            </div>

            <div class="orchestrator-modal-footer">
                <button class="btn btn-danger btn-sm" @onclick="() => ReviewOrchestratorModal(false)" disabled="@_orchestratorReviewing">
                    Rechazar
                </button>
                <button class="btn btn-success btn-sm" @onclick="() => ReviewOrchestratorModal(true)" disabled="@_orchestratorReviewing">
                    @(_orchestratorReviewing ? "Aprobando..." : "Aprobar y ejecutar")
                </button>
            </div>
        </div>
    </div>
}

