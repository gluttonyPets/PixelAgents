    private async Task SaveEdit()
    {
        if (_editingPmId is null || _project is null) return;
        _editError = null;

        var pm = _project.Modules.FirstOrDefault(m => m.Id == _editingPmId);
        if (pm is null) return;

        try
        {
            // Rebuild step config based on module type
            string? stepConfig = null;
            if (pm.ModuleType == "Image")
            {
                if (!string.IsNullOrWhiteSpace(_imagePrompt))
                    stepConfig = JsonSerializer.Serialize(new { imagePrompt = _imagePrompt.Trim() });
            }
            else if (pm.ModuleType == "Publish")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    caption = string.IsNullOrWhiteSpace(_publishCaption) ? "{previous_output}" : _publishCaption,
                    publishType = _publishType
                });
            }
            else if (pm.ModuleType == "Interaction")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    messageTemplate = string.IsNullOrWhiteSpace(_interactionTemplate) ? "{previous_output}" : _interactionTemplate,
                    messageType = _interactionMessageType,
                    waitForResponse = _interactionWaitForResponse == "true"
                });
            }
            else if (pm.ModuleType == "Design")
            {
                stepConfig = JsonSerializer.Serialize(new
                {
                    exportFormat = _canvaExportFormat,
                    designTitle = _canvaDesignTitle,
                    brandTemplateId = string.IsNullOrWhiteSpace(_canvaStepBrandTemplateId) ? (string?)null : _canvaStepBrandTemplateId,
                    designType = _canvaDesignType
                });
            }
            else
            {
                stepConfig = pm.Configuration; // preserve existing for unknown types
            }

            // Preserve the "skipped" flag from existing config
            if (IsStepSkipped(pm))
            {
                if (stepConfig is null)
                {
                    stepConfig = JsonSerializer.Serialize(new { skipped = true });
                }
                else
                {
                    var merged = JsonSerializer.Deserialize<Dictionary<string, object>>(stepConfig) ?? new();
                    merged["skipped"] = true;
                    stepConfig = JsonSerializer.Serialize(merged);
                }
            }

            var req = new UpdateProjectModuleRequest(
                string.IsNullOrWhiteSpace(_editStepName) ? null : _editStepName,
                stepConfig,
                pm.IsActive);
            var (ok, error) = await Api.UpdateProjectModuleAsync(ProjectId, pm.Id, req);
            if (ok) { _editingPmId = null; await LoadAll(); }
            else _editError = error;
        }
        catch (Exception ex) { _editError = $"Error: {ex.Message}"; }
    }

