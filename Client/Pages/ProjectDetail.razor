@page "/projects/{ProjectId:guid}"
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR.Client
@inject ApiClient Api
@inject IConfiguration Config
@implements IAsyncDisposable

@if (_project is null)
{
    <p class="text-muted">Cargando...</p>
}
else
{
    <!-- ═══════════ PROJECT HEADER ═══════════ -->
    <div class="project-header">
        <div class="project-header-info">
            <h2 class="project-title">@_project.Name</h2>
            <p class="project-meta">@(_project.Description ?? "") &middot; Creado @_project.CreatedAt.ToString("dd MMM yyyy")</p>
        </div>
        <div class="project-header-actions">
            <!-- Integration status pills -->
            <div class="integration-pills">
                <span class="pill @(string.IsNullOrWhiteSpace(_tgBotToken) ? "pill-off" : "pill-on")" title="Telegram">TG</span>
                <span class="pill @(string.IsNullOrWhiteSpace(_waAccessToken) ? "pill-off" : "pill-on")" title="WhatsApp">WA</span>
                <span class="pill @(string.IsNullOrWhiteSpace(_igApiKey) ? "pill-off" : "pill-on")" title="Buffer">BF</span>
                @if (_schedule is not null && _schedule.IsEnabled)
                {
                    <span class="pill pill-on" title="Programacion activa">&#x23f0;</span>
                }
                else
                {
                    <span class="pill pill-off" title="Sin programacion">&#x23f0;</span>
                }
            </div>
            <button class="btn-icon" @onclick="() => _showSettings = true" title="Configuracion">
                &#x2699;
            </button>
        </div>
    </div>

    <!-- Project Context (editable) -->
    @if (_editingContext)
    {
        <div class="context-bar context-bar-editing">
            <span class="context-label">Contexto</span>
            @if (_contextError is not null)
            {
                <div class="alert alert-error" style="margin:0 0 4px 0;font-size:.85rem;">@_contextError</div>
            }
            <textarea class="context-edit-input" @bind="_contextDraft" rows="3" placeholder="Escribe el contexto del proyecto..."></textarea>
            <div class="context-edit-actions">
                <button class="btn btn-primary btn-sm" @onclick="SaveContext" disabled="@_contextSaving">
                    @(_contextSaving ? "Guardando..." : "Guardar")
                </button>
                <button class="btn btn-sm" @onclick="CancelContextEdit">Cancelar</button>
            </div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_project.Context))
    {
        <div class="context-bar" @onclick="StartContextEdit" style="cursor:pointer;" title="Clic para editar">
            <span class="context-label">Contexto</span>
            <span class="context-text">@_project.Context</span>
            <span class="context-edit-icon">&#x270E;</span>
        </div>
    }
    else
    {
        <button class="btn btn-sm" style="margin-bottom:8px;" @onclick="StartContextEdit">+ Agregar contexto</button>
    }

    <!-- ═══════════ TABS ═══════════ -->
    <div class="tab-bar">
        <button class="tab @(_activeTab == "pipeline" ? "tab-active" : "")" @onclick='() => _activeTab = "pipeline"'>
            Pipeline
            @if (_project.Modules.Count > 0)
            {
                <span class="tab-count">@_project.Modules.Count</span>
            }
        </button>
        <button class="tab @(_activeTab == "execute" ? "tab-active" : "")" @onclick='() => _activeTab = "execute"'>
            Ejecutar
        </button>
        <button class="tab @(_activeTab == "history" ? "tab-active" : "")" @onclick='() => _activeTab = "history"'>
            Historial
            @if (_executions.Count > 0)
            {
                <span class="tab-count">@_executions.Count</span>
            }
        </button>
    </div>

    <!-- ═══════════ TAB: PIPELINE ═══════════ -->
    @if (_activeTab == "pipeline")
    {
        <div class="tab-content">
            @if (_editError is not null)
            {
                <div class="alert alert-error">@_editError</div>
            }

            @if (_project.Modules.Count > 0)
            {
                <div class="pipeline-format-rule">
                    Regla global: Sin emojis, sin markdown (**, *, #), sin saltos de linea, sin caracteres decorativos. Solo texto plano ASCII.
                </div>

                <div class="pipeline-flow">
                    @{ var __main = GetMainSteps(); }
                    @for (var si = 0; si < __main.Count; si++)
                    {
                        var pm = __main[si];
                        var nextPm = si + 1 < __main.Count ? __main[si + 1] : null;
                        var isEditing = _editingPmId == pm.Id;
                        var stepCost = _result?.Steps?.FirstOrDefault(s => s.ProjectModuleId == pm.Id)?.EstimatedCost;

                        <!-- Step card -->
                        <div class="pipeline-step">
                            <div class="step-card-v2 @(isEditing ? "editing" : "")">
                                <div class="step-card-header">
                                    <span class="step-number">@pm.StepOrder</span>
                                    <span class="step-title">
                                        @if (isEditing)
                                        {
                                            <input type="text" class="input-inline" @bind="_editStepName" placeholder="Nombre" />
                                        }
                                        else
                                        {
                                            @(pm.StepName ?? pm.AiModuleName)
                                        }
                                    </span>
                                    <span class="badge badge-@(pm.ModuleType.ToLower())">@pm.ModuleType</span>
                                </div>
                                <div class="step-card-meta">
                                    <span>@pm.AiModuleName</span>
                                    <span class="text-muted">@FormatInputMapping(pm.InputMapping)</span>
                                    @if (stepCost.HasValue && stepCost.Value > 0)
                                    {
                                        <span class="text-muted">~$@stepCost.Value.ToString("F4")</span>
                                    }
                                </div>
                                @if (isEditing)
                                {
                                    <div class="step-card-edit">
                                        <select class="select-inline" @bind="_editInputMapping">
                                            <option value='{"source":"user"}'>Entrada del usuario</option>
                                            <option value='{"source":"previous","field":"text"}'>Paso anterior (texto)</option>
                                            <option value='{"source":"previous","field":"file"}'>Paso anterior (archivo)</option>
                                        </select>
                                        @if (pm.ModuleType == "Image")
                                        {
                                            <textarea @bind="_imagePrompt" rows="2" placeholder="Prompt de imagen (opcional)" style="width:100%; margin-top:0.3rem;"></textarea>
                                        }
                                        @if (pm.ModuleType == "Video")
                                        {
                                            <textarea @bind="_videoPrompt" rows="2" placeholder="Prompt del video (obligatorio)" style="width:100%; margin-top:0.3rem;"></textarea>
                                            <select class="select-inline" @bind="_videoSource" style="margin-top:0.3rem;">
                                                <option value="prompt">Solo texto</option>
                                                <option value="both">Imagen + prompt</option>
                                            </select>
                                        }
                                        @if (pm.ModuleType == "Publish")
                                        {
                                            <textarea @bind="_publishCaption" rows="2" placeholder="Caption ({previous_output})" style="width:100%; margin-top:0.3rem;"></textarea>
                                            <select class="select-inline" @bind="_publishType" style="margin-top:0.3rem;">
                                                <option value="post">Post</option>
                                                <option value="reel">Reel</option>
                                                <option value="story">Story</option>
                                            </select>
                                        }
                                        @if (pm.ModuleType == "Interaction")
                                        {
                                            <textarea @bind="_interactionTemplate" rows="2" placeholder="Mensaje ({previous_output})" style="width:100%; margin-top:0.3rem;"></textarea>
                                            <select class="select-inline" @bind="_interactionMessageType" style="margin-top:0.3rem;">
                                                <option value="combined">Texto + Imagenes</option>
                                                <option value="text">Solo texto</option>
                                                <option value="image">Solo imagenes</option>
                                            </select>
                                            <select class="select-inline" @bind="_interactionWaitForResponse" style="margin-top:0.3rem;">
                                                <option value="true">Esperar respuesta</option>
                                                <option value="false">Enviar y continuar</option>
                                            </select>
                                        }
                                        @if (pm.ModuleType == "Design")
                                        {
                                            <input type="text" class="input-inline" @bind="_canvaDesignTitle" placeholder="Titulo del diseno" style="margin-top:0.3rem;" />
                                            <select class="select-inline" @bind="_canvaExportFormat" style="margin-top:0.3rem;">
                                                <option value="png">PNG</option>
                                                <option value="jpg">JPG</option>
                                                <option value="pdf">PDF</option>
                                                <option value="pptx">PPTX</option>
                                            </select>
                                        }
                                    </div>
                                }
                                @if (!isEditing && pm.ModuleType == "Text" && nextPm is not null)
                                {
                                    var maxLen = GetMaxPromptLength(nextPm.ModelName);
                                    <div class="step-rule-hint">Limite: @maxLen chars (siguiente: @nextPm.ModelName)</div>
                                }
                                <div class="step-card-actions">
                                    @if (isEditing)
                                    {
                                        <button class="btn btn-xs btn-success" @onclick="SaveEdit">Guardar</button>
                                        <button class="btn btn-xs" @onclick="CancelEdit">Cancelar</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-xs" @onclick="() => MoveStep(pm, -1)" disabled="@(pm.StepOrder <= 1)" title="Subir">&#x25B2;</button>
                                        <button class="btn btn-xs" @onclick="() => MoveStep(pm, 1)" disabled="@(pm.StepOrder >= __main.Count)" title="Bajar">&#x25BC;</button>
                                        <button class="btn btn-xs btn-primary" @onclick="() => StartEdit(pm)">Editar</button>
                                        <button class="btn btn-xs btn-danger" @onclick="() => RemoveStep(pm.Id)">Quitar</button>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Fork branches from this step -->
                        var forksHere = GetBranchesFromStep(pm.StepOrder);
                        if (forksHere.Count > 0)
                        {
                            var remainingMain = __main.Skip(si + 1).ToList();
                            <div class="step-connector"></div>
                            <div class="pipeline-fork">
                                <div class="fork-junction"></div>
                                <div class="fork-lines" style="--branch-count: @(forksHere.Count + (remainingMain.Count > 0 ? 1 : 0));"></div>
                                <div class="pipeline-branches">
                                    <!-- Main continuation column -->
                                    @if (remainingMain.Count > 0)
                                    {
                                        <div class="pipeline-branch branch-main" style="order: 0">
                                            <div class="branch-header branch-header-main">
                                                <span class="branch-name">Principal</span>
                                            </div>
                                            @for (var rmi = 0; rmi < remainingMain.Count; rmi++)
                                            {
                                                var rpm = remainingMain[rmi];
                                                var rIsEditing = _editingPmId == rpm.Id;
                                                var rNextPm = rmi + 1 < remainingMain.Count ? remainingMain[rmi + 1] : null;
                                                var rCost = _result?.Steps?.FirstOrDefault(s => s.ProjectModuleId == rpm.Id)?.EstimatedCost;

                                                @if (rmi > 0)
                                                {
                                                    <div class="branch-connector"></div>
                                                }
                                                <div class="step-card-v2 branch-step @(rIsEditing ? "editing" : "")">
                                                    <div class="step-card-header">
                                                        <span class="step-number">@rpm.StepOrder</span>
                                                        <span class="step-title">
                                                            @if (rIsEditing)
                                                            {
                                                                <input type="text" class="input-inline" @bind="_editStepName" placeholder="Nombre" />
                                                            }
                                                            else
                                                            {
                                                                @(rpm.StepName ?? rpm.AiModuleName)
                                                            }
                                                        </span>
                                                        <span class="badge badge-@(rpm.ModuleType.ToLower())">@rpm.ModuleType</span>
                                                    </div>
                                                    <div class="step-card-meta">
                                                        <span>@rpm.AiModuleName</span>
                                                        <span class="text-muted">@FormatInputMapping(rpm.InputMapping)</span>
                                                        @if (rCost.HasValue && rCost.Value > 0)
                                                        {
                                                            <span class="text-muted">~$@rCost.Value.ToString("F4")</span>
                                                        }
                                                    </div>
                                                    @if (rIsEditing)
                                                    {
                                                        <div class="step-card-edit">
                                                            <select class="select-inline" @bind="_editInputMapping">
                                                                <option value='{"source":"user"}'>Entrada del usuario</option>
                                                                <option value='{"source":"previous","field":"text"}'>Paso anterior (texto)</option>
                                                                <option value='{"source":"previous","field":"file"}'>Paso anterior (archivo)</option>
                                                            </select>
                                                            @if (rpm.ModuleType == "Image")
                                                            {
                                                                <textarea @bind="_imagePrompt" rows="2" placeholder="Prompt de imagen (opcional)" style="width:100%; margin-top:0.3rem;"></textarea>
                                                            }
                                                            @if (rpm.ModuleType == "Video")
                                                            {
                                                                <textarea @bind="_videoPrompt" rows="2" placeholder="Prompt del video (obligatorio)" style="width:100%; margin-top:0.3rem;"></textarea>
                                                                <select class="select-inline" @bind="_videoSource" style="margin-top:0.3rem;">
                                                                    <option value="prompt">Solo texto</option>
                                                                    <option value="both">Imagen + prompt</option>
                                                                </select>
                                                            }
                                                            @if (rpm.ModuleType == "Publish")
                                                            {
                                                                <textarea @bind="_publishCaption" rows="2" placeholder="Caption ({previous_output})" style="width:100%; margin-top:0.3rem;"></textarea>
                                                                <select class="select-inline" @bind="_publishType" style="margin-top:0.3rem;">
                                                                    <option value="post">Post</option>
                                                                    <option value="reel">Reel</option>
                                                                    <option value="story">Story</option>
                                                                </select>
                                                            }
                                                            @if (rpm.ModuleType == "Interaction")
                                                            {
                                                                <textarea @bind="_interactionTemplate" rows="2" placeholder="Mensaje ({previous_output})" style="width:100%; margin-top:0.3rem;"></textarea>
                                                                <select class="select-inline" @bind="_interactionMessageType" style="margin-top:0.3rem;">
                                                                    <option value="combined">Texto + Imagenes</option>
                                                                    <option value="text">Solo texto</option>
                                                                    <option value="image">Solo imagenes</option>
                                                                </select>
                                                                <select class="select-inline" @bind="_interactionWaitForResponse" style="margin-top:0.3rem;">
                                                                    <option value="true">Esperar respuesta</option>
                                                                    <option value="false">Enviar y continuar</option>
                                                                </select>
                                                            }
                                                            @if (rpm.ModuleType == "Design")
                                                            {
                                                                <input type="text" class="input-inline" @bind="_canvaDesignTitle" placeholder="Titulo del diseno" style="margin-top:0.3rem;" />
                                                                <select class="select-inline" @bind="_canvaExportFormat" style="margin-top:0.3rem;">
                                                                    <option value="png">PNG</option>
                                                                    <option value="jpg">JPG</option>
                                                                    <option value="pdf">PDF</option>
                                                                    <option value="pptx">PPTX</option>
                                                                </select>
                                                            }
                                                        </div>
                                                    }
                                                    @if (!rIsEditing && rpm.ModuleType == "Text" && rNextPm is not null)
                                                    {
                                                        var rMaxLen = GetMaxPromptLength(rNextPm.ModelName);
                                                        <div class="step-rule-hint">Limite: @rMaxLen chars (siguiente: @rNextPm.ModelName)</div>
                                                    }
                                                    <div class="step-card-actions">
                                                        @if (rIsEditing)
                                                        {
                                                            <button class="btn btn-xs btn-success" @onclick="SaveEdit">Guardar</button>
                                                            <button class="btn btn-xs" @onclick="CancelEdit">Cancelar</button>
                                                        }
                                                        else
                                                        {
                                                            <button class="btn btn-xs" @onclick="() => MoveStep(rpm, -1)" disabled="@(rpm.StepOrder <= 1)" title="Subir">&#x25B2;</button>
                                                            <button class="btn btn-xs" @onclick="() => MoveStep(rpm, 1)" disabled="@(rpm.StepOrder >= __main.Count)" title="Bajar">&#x25BC;</button>
                                                            <button class="btn btn-xs btn-primary" @onclick="() => StartEdit(rpm)">Editar</button>
                                                            <button class="btn btn-xs btn-danger" @onclick="() => RemoveStep(rpm.Id)">Quitar</button>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }

                                    <!-- Branch columns -->
                                    @for (var bi = 0; bi < forksHere.Count; bi++)
                                    {
                                        var (branchId, branchSteps) = forksHere[bi];
                                        <div class="pipeline-branch branch-fork" style="order: @(bi + 1)">
                                            <div class="branch-header">
                                                <span class="branch-name">@branchId</span>
                                                <button class="btn btn-xs btn-danger" @onclick="() => DeleteBranch(branchId)" title="Eliminar rama">&#x2715;</button>
                                            </div>
                                            @for (var bsi = 0; bsi < branchSteps.Count; bsi++)
                                            {
                                                var bpm = branchSteps[bsi];
                                                var bIsEditing = _editingPmId == bpm.Id;
                                                var bCost = _result?.Steps?.FirstOrDefault(s => s.ProjectModuleId == bpm.Id)?.EstimatedCost;

                                                @if (bsi > 0)
                                                {
                                                    <div class="branch-connector"></div>
                                                }
                                                <div class="step-card-v2 branch-step @(bIsEditing ? "editing" : "")">
                                                    <div class="step-card-header">
                                                        <span class="step-number">@bpm.StepOrder</span>
                                                        <span class="step-title">
                                                            @if (bIsEditing)
                                                            {
                                                                <input type="text" class="input-inline" @bind="_editStepName" placeholder="Nombre" />
                                                            }
                                                            else
                                                            {
                                                                @(bpm.StepName ?? bpm.AiModuleName)
                                                            }
                                                        </span>
                                                        <span class="badge badge-@(bpm.ModuleType.ToLower())">@bpm.ModuleType</span>
                                                    </div>
                                                    <div class="step-card-meta">
                                                        <span>@bpm.AiModuleName</span>
                                                        @if (bCost.HasValue && bCost.Value > 0)
                                                        {
                                                            <span class="text-muted">~$@bCost.Value.ToString("F4")</span>
                                                        }
                                                    </div>
                                                    @if (bIsEditing)
                                                    {
                                                        <div class="step-card-edit">
                                                            <select class="select-inline" @bind="_editInputMapping">
                                                                <option value='{"source":"user"}'>Entrada del usuario</option>
                                                                <option value='{"source":"previous","field":"text"}'>Paso anterior (texto)</option>
                                                                <option value='{"source":"previous","field":"file"}'>Paso anterior (archivo)</option>
                                                            </select>
                                                            @if (bpm.ModuleType == "Image")
                                                            {
                                                                <textarea @bind="_imagePrompt" rows="2" placeholder="Prompt de imagen (opcional)" style="width:100%; margin-top:0.3rem;"></textarea>
                                                            }
                                                            @if (bpm.ModuleType == "Video")
                                                            {
                                                                <textarea @bind="_videoPrompt" rows="2" placeholder="Prompt del video (obligatorio)" style="width:100%; margin-top:0.3rem;"></textarea>
                                                                <select class="select-inline" @bind="_videoSource" style="margin-top:0.3rem;">
                                                                    <option value="prompt">Solo texto</option>
                                                                    <option value="both">Imagen + prompt</option>
                                                                </select>
                                                            }
                                                            @if (bpm.ModuleType == "Publish")
                                                            {
                                                                <textarea @bind="_publishCaption" rows="2" placeholder="Caption ({previous_output})" style="width:100%; margin-top:0.3rem;"></textarea>
                                                                <select class="select-inline" @bind="_publishType" style="margin-top:0.3rem;">
                                                                    <option value="post">Post</option>
                                                                    <option value="reel">Reel</option>
                                                                    <option value="story">Story</option>
                                                                </select>
                                                            }
                                                            @if (bpm.ModuleType == "Interaction")
                                                            {
                                                                <textarea @bind="_interactionTemplate" rows="2" placeholder="Mensaje ({previous_output})" style="width:100%; margin-top:0.3rem;"></textarea>
                                                                <select class="select-inline" @bind="_interactionMessageType" style="margin-top:0.3rem;">
                                                                    <option value="combined">Texto + Imagenes</option>
                                                                    <option value="text">Solo texto</option>
                                                                    <option value="image">Solo imagenes</option>
                                                                </select>
                                                                <select class="select-inline" @bind="_interactionWaitForResponse" style="margin-top:0.3rem;">
                                                                    <option value="true">Esperar respuesta</option>
                                                                    <option value="false">Enviar y continuar</option>
                                                                </select>
                                                            }
                                                            @if (bpm.ModuleType == "Design")
                                                            {
                                                                <input type="text" class="input-inline" @bind="_canvaDesignTitle" placeholder="Titulo del diseno" style="margin-top:0.3rem;" />
                                                                <select class="select-inline" @bind="_canvaExportFormat" style="margin-top:0.3rem;">
                                                                    <option value="png">PNG</option>
                                                                    <option value="jpg">JPG</option>
                                                                    <option value="pdf">PDF</option>
                                                                    <option value="pptx">PPTX</option>
                                                                </select>
                                                            }
                                                        </div>
                                                    }
                                                    <div class="step-card-actions">
                                                        @if (bIsEditing)
                                                        {
                                                            <button class="btn btn-xs btn-success" @onclick="SaveEdit">Guardar</button>
                                                            <button class="btn btn-xs" @onclick="CancelEdit">Cancelar</button>
                                                        }
                                                        else
                                                        {
                                                            var bSorted = branchSteps;
                                                            <button class="btn btn-xs" @onclick="() => MoveStep(bpm, -1)" disabled="@(bpm.StepOrder <= 1)" title="Subir">&#x25B2;</button>
                                                            <button class="btn btn-xs" @onclick="() => MoveStep(bpm, 1)" disabled="@(bpm.StepOrder >= bSorted.Count)" title="Bajar">&#x25BC;</button>
                                                            <button class="btn btn-xs btn-primary" @onclick="() => StartEdit(bpm)">Editar</button>
                                                            <button class="btn btn-xs btn-danger" @onclick="() => RemoveStep(bpm.Id)">Quitar</button>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            <!-- Add step to branch -->
                                            <button class="btn btn-xs btn-outline branch-add-step"
                                                @onclick="() => StartAddStepToBranch(branchId, branchSteps.First().BranchFromStep, branchSteps.Count + 1)">
                                                + Paso
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                            break; // Remaining main steps already rendered inside the fork
                        }

                        <!-- Connector + add branch button (only when no fork) -->
                        @if (si < __main.Count - 1)
                        {
                            <div class="step-connector">
                                <button class="btn btn-xs btn-outline fork-btn" @onclick="() => StartAddBranch(pm.StepOrder)" title="Crear rama desde este paso">
                                    &#x2442;
                                </button>
                            </div>
                        }
                    }
                </div>

                <!-- Add branch dialog -->
                @if (_showAddBranch)
                {
                    <div class="card" style="margin-top: 0.5rem; border-color: var(--accent);">
                        <h4 style="margin-top:0;">Nueva rama desde paso @_addBranchFromStep</h4>
                        <div class="form-group">
                            <label>Nombre de la rama</label>
                            <input type="text" @bind="_newBranchName" placeholder="Ej: instagram, tiktok, twitter..." />
                        </div>
                        <div style="display:flex; gap:0.5rem;">
                            <button class="btn btn-sm btn-primary" @onclick="ConfirmAddBranch">Crear rama</button>
                            <button class="btn btn-sm" @onclick="() => _showAddBranch = false">Cancelar</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <span class="empty-state-icon">&#x1F9E9;</span>
                    <p>Pipeline vacio</p>
                    <p class="text-sm text-muted">Agrega pasos para construir tu flujo de trabajo</p>
                </div>
            }

            <!-- Add Step -->
            <div class="card" style="margin-top: 1rem;">
                <h3 style="margin-top:0;">Agregar Paso</h3>
                @if (_stepError is not null)
                {
                    <div class="alert alert-error">@_stepError</div>
                }
                <div class="form-row">
                    <div class="form-group">
                        <label>Rama</label>
                        <select value="@_stepBranchId" @onchange="OnBranchSelectChanged">
                            <option value="main">Principal (main)</option>
                            @{
                                var existingBranches = (_project?.Modules ?? new())
                                    .Where(m => m.BranchId != "main")
                                    .Select(m => m.BranchId)
                                    .Distinct()
                                    .OrderBy(b => b)
                                    .ToList();
                            }
                            @foreach (var b in existingBranches)
                            {
                                <option value="@b">@b</option>
                            }
                            @foreach (var pb in _pendingBranches.Where(pb => !existingBranches.Contains(pb.BranchId)))
                            {
                                <option value="@pb.BranchId">@pb.BranchId (nueva)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Modulo</label>
                        <select @bind="_stepModuleId">
                            <option value="">-- Seleccionar --</option>
                            @foreach (var m in _modules)
                            {
                                <option value="@m.Id">@m.Name (@m.ProviderType / @m.ModuleType)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Orden</label>
                        <input type="number" @bind="_stepOrder" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Nombre del paso</label>
                        <input type="text" @bind="_stepName" placeholder="Ej: Generar texto, Traducir, Crear imagen..." />
                    </div>
                    <div class="form-group">
                        <label>Entrada de datos</label>
                        <select @bind="_inputMapping">
                            <option value='{"source":"user"}'>Entrada del usuario</option>
                            <option value='{"source":"previous","field":"text"}'>Paso anterior (texto)</option>
                            <option value='{"source":"previous","field":"file"}'>Paso anterior (archivo)</option>
                        </select>
                    </div>
                </div>

                @{ var selectedModule = _modules.FirstOrDefault(m => m.Id.ToString() == _stepModuleId); }
                @if (selectedModule?.ModuleType == "Interaction")
                {
                    <div class="form-group">
                        <label>Mensaje de interaccion <span class="text-sm text-muted">(usa {previous_output} para incluir salida anterior, {step_number} para el numero de paso)</span></label>
                        <textarea @bind="_interactionTemplate" rows="3"
                            placeholder="Resultado del paso anterior: {previous_output}. Te parece correcto? Responde SI para continuar o escribe tu feedback."></textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Tipo de mensaje</label>
                            <select @bind="_interactionMessageType">
                                <option value="combined">Texto + Imagenes</option>
                                <option value="text">Solo texto</option>
                                <option value="image">Solo imagenes</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Esperar respuesta del usuario</label>
                            <select @bind="_interactionWaitForResponse">
                                <option value="true">Si - pausar pipeline hasta recibir respuesta</option>
                                <option value="false">No - enviar y continuar (fire & forget)</option>
                            </select>
                        </div>
                    </div>
                    @if (_interactionWaitForResponse == "true")
                    {
                        <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                            El usuario recibira botones automaticos en Telegram:
                            <strong>Continuar</strong> (con descripcion del siguiente paso),
                            <strong>Abortar</strong>, y
                            <strong>Reiniciar</strong> (con aclaracion opcional).
                        </p>
                    }
                }

                @if (selectedModule?.ModuleType == "Text")
                {
                    <div class="form-group" style="margin-top: 0.5rem;">
                        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                            <input type="checkbox" @bind="_isImagePrompt" />
                            Este paso genera prompts para imagenes
                        </label>
                    </div>
                    @if (_isImagePrompt)
                    {
                        <div class="form-group">
                            <label>Numero de imagenes a generar</label>
                            <input type="number" @bind="_imageCount" min="1" max="20" style="max-width: 100px;" />
                            <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                                Se forzara al modelo a devolver exactamente @_imageCount item(s) en la respuesta,
                                cada uno sera un prompt para el paso de generacion de imagenes.
                            </p>
                        </div>
                    }
                }

                @if (selectedModule?.ModuleType == "Image")
                {
                    <div class="form-group" style="margin-top: 0.5rem;">
                        <label>Prompt de la imagen <span class="text-sm text-muted">(opcional)</span></label>
                        <textarea @bind="_imagePrompt" rows="3"
                            placeholder="Describe la imagen que quieres generar..."></textarea>
                        <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                            Si se proporciona, este prompt se usara directamente. Si se deja vacio, se usara la entrada de datos configurada arriba.
                        </p>
                    </div>
                }

                @if (selectedModule?.ModuleType == "Video")
                {
                    <div class="form-group" style="margin-top: 0.5rem;">
                        <label>Prompt del video <span style="color: var(--danger);">*</span></label>
                        <textarea @bind="_videoPrompt" rows="3"
                            placeholder="Describe lo que quieres que muestre el video..."></textarea>
                        <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                            Este prompt se enviara siempre al modelo de video. Es obligatorio.
                        </p>
                    </div>
                    <div class="form-group" style="margin-top: 0.5rem;">
                        <label>Usar imagen del paso anterior</label>
                        <select @bind="_videoSource">
                            <option value="prompt">No, solo texto</option>
                            @if (selectedModule?.ModelName?.Contains("veo-3.1") == true)
                            {
                                <option value="both">Si, usar imagen + prompt</option>
                            }
                        </select>
                        <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                            @if (_videoSource == "prompt")
                            {
                                <span>El video se generara unicamente a partir del prompt de texto.</span>
                            }
                            else
                            {
                                <span>Se usara la imagen generada en el paso anterior como primer fotograma junto con el prompt. Solo disponible con Veo 3.1.</span>
                            }
                        </p>
                        @if (selectedModule?.ModelName?.Contains("veo-3.1") != true)
                        {
                            <p class="text-sm" style="color: var(--warning); margin-top: 0.2rem;">
                                Image-to-video solo esta disponible con modelos Veo 3.1. Este modelo solo soporta texto.
                            </p>
                        }
                    </div>
                }

                @if (selectedModule?.ModuleType == "Design")
                {
                    <div class="form-group">
                        <label>Formato de exportacion</label>
                        <select @bind="_canvaExportFormat">
                            <option value="png">PNG (imagen)</option>
                            <option value="jpg">JPG (imagen)</option>
                            <option value="pdf">PDF (documento)</option>
                            <option value="pptx">PPTX (presentacion)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Titulo del diseno <span class="text-sm text-muted">(usa {previous_output} para incluir salida anterior)</span></label>
                        <input type="text" @bind="_canvaDesignTitle" placeholder="PixelAgents Design" />
                    </div>
                    <div class="form-group">
                        <label>Brand Template ID <span class="text-sm text-muted">(opcional, sobreescribe el del modulo)</span></label>
                        <input type="text" @bind="_canvaStepBrandTemplateId" placeholder="Ej: DAVZr1z5464... (dejar vacio para usar el del modulo)" />
                    </div>
                    <div class="form-group">
                        <label>Tipo de diseno <span class="text-sm text-muted">(si no usa template)</span></label>
                        <select @bind="_canvaDesignType">
                            <option value="doc">Documento</option>
                            <option value="presentation">Presentacion</option>
                            <option value="whiteboard">Pizarra</option>
                        </select>
                    </div>
                    <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                        Si se configura un Brand Template ID (aqui o en el modulo), se usara autofill
                        con los datos del paso anterior. Si no, se creara un diseno en blanco del tipo seleccionado.
                        Las imagenes del paso anterior se suben automaticamente como assets.
                    </p>
                }

                @if (selectedModule?.ModuleType == "Publish")
                {
                    <div class="form-group">
                        <label>Tipo de publicacion</label>
                        <select @bind="_publishType">
                            <option value="post">Post</option>
                            <option value="reel">Reel</option>
                            <option value="story">Story</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Caption <span class="text-sm text-muted">(usa {previous_output} para incluir salida anterior)</span></label>
                        <textarea @bind="_publishCaption" rows="3"
                            placeholder="{previous_output}"></textarea>
                    </div>
                    <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                        Las imagenes/videos del paso anterior se adjuntan automaticamente.
                        Buffer publica en el canal configurado (Instagram, Twitter, LinkedIn, etc.).
                        Programacion automatica (Buffer elige la mejor hora). Plan gratuito: 10 posts por canal.
                    </p>
                }

                <button class="btn btn-primary mt-1" @onclick="AddStep" disabled="@_loading">Agregar</button>
            </div>
        </div>
    }

    <!-- ═══════════ TAB: EJECUTAR ═══════════ -->
    @if (_activeTab == "execute")
    {
        <div class="tab-content">
            <!-- Execute Input -->
            <div class="execute-card">
                @if (_execError is not null)
                {
                    <div class="alert alert-error">@_execError</div>
                }
                <div class="form-group">
                    <label>Entrada del usuario</label>
                    <textarea @bind="_userInput" rows="3" placeholder="Escribe tu prompt aqui..."></textarea>
                </div>
                <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <button class="btn btn-success" @onclick="Execute" disabled="@_executing">
                        @if (_executing)
                        {
                            <span class="spinner"></span>
                            <span>Ejecutando...</span>
                        }
                        else
                        {
                            <span>Ejecutar</span>
                        }
                    </button>
                    @if (_executing)
                    {
                        <button class="btn btn-danger" @onclick="CancelExecution">Cancelar</button>
                    }
                </div>
            </div>

            <!-- Execution Result + Log Panel -->
            @if (_executing || _result is not null || _logEntries.Count > 0)
            {
                <div class="execution-layout">
                    <!-- Left: Results -->
                    <div class="execution-results">
                        @if (_result is not null)
                        {
                            <h3>
                                Resultado - <span class="badge @StatusBadge(_result.Status)">@_result.Status</span>
                                @if (_result.TotalEstimatedCost > 0)
                                {
                                    <span class="badge" style="background: var(--surface); color: var(--text); margin-left: 0.5rem; font-weight: normal; font-size: 0.75rem;">
                                        ~$@_result.TotalEstimatedCost.ToString("F4") USD
                                    </span>
                                }
                            </h3>

                            @if (!string.IsNullOrWhiteSpace(_result.UserInput))
                            {
                                <div class="card" style="margin-bottom: 0.8rem; padding: 0.6rem 0.8rem;">
                                    <label class="text-sm text-muted" style="margin-bottom: 0.2rem;">Prompt inicial</label>
                                    <div class="output-block" style="white-space: pre-wrap;">@_result.UserInput</div>
                                </div>
                            }

                            @foreach (var step in _result.Steps.OrderBy(s => s.StepOrder))
                            {
                                <div class="step-card">
                                    <div class="step-header">
                                        <strong>Paso @step.StepOrder: @step.ModuleName</strong>
                                        <span class="badge @StatusBadge(step.Status)">@step.Status</span>
                                        @if (step.EstimatedCost > 0)
                                        {
                                            <span class="text-sm text-muted" style="margin-left: 0.4rem;">~$@step.EstimatedCost.ToString("F4")</span>
                                        }
                                        @if (!_executing && (_result.Status == "Completed" || _result.Status == "Failed")
                                            && (step.Status == "Completed" || step.Status == "Failed"))
                                        {
                                            <button class="btn btn-sm" style="margin-left: auto; padding: 0.15rem 0.5rem; font-size: 0.75rem;"
                                                    @onclick="() => ToggleRetryPanel(step.StepOrder)">
                                                @(_retryStepOrder == step.StepOrder ? "Cancelar" : "Reintentar desde aqui")
                                            </button>
                                        }
                                    </div>

                                    @if (_retryStepOrder == step.StepOrder)
                                    {
                                        <div class="retry-panel" style="background: var(--surface); border: 1px solid var(--border); border-radius: 0.4rem; padding: 0.6rem; margin: 0.4rem 0;">
                                            <div class="form-group" style="margin-bottom: 0.4rem;">
                                                <label class="text-sm">Feedback / comentario (opcional)</label>
                                                <textarea @bind="_retryComment" rows="2"
                                                          placeholder="Ej: Hazlo mas corto, cambia el tono, anade mas detalles sobre..."
                                                          style="font-size: 0.85rem;"></textarea>
                                            </div>
                                            @if (_retryError is not null)
                                            {
                                                <div class="alert alert-error" style="font-size: 0.8rem; padding: 0.3rem 0.5rem;">@_retryError</div>
                                            }
                                            <button class="btn btn-sm btn-success" @onclick="() => RetryFromStep(step.StepOrder)" disabled="@_executing">
                                                Reintentar paso @step.StepOrder y siguientes
                                            </button>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(step.InputData))
                                    {
                                        var inputData = ParseInputData(step.InputData);
                                        if (inputData is not null)
                                        {
                                            <details class="step-input-details">
                                                <summary class="step-input-summary">
                                                    Input enviado al modelo
                                                </summary>
                                                <div class="step-input-content">
                                                    @if (!string.IsNullOrWhiteSpace(inputData.SystemPrompt))
                                                    {
                                                        <label class="step-input-label">System Prompt</label>
                                                        <div class="output-block step-input-block">@inputData.SystemPrompt</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(inputData.ProjectContext))
                                                    {
                                                        <label class="step-input-label">Contexto del proyecto</label>
                                                        <div class="output-block step-input-block">@inputData.ProjectContext</div>
                                                    }
                                                    @if (inputData.Prompts.Count > 0)
                                                    {
                                                        @foreach (var (prompt, idx) in inputData.Prompts.Select((p, i) => (p, i)))
                                                        {
                                                            <label class="step-input-label">@(inputData.Prompts.Count > 1 ? $"Prompt {idx + 1}" : "Prompt")</label>
                                                            <div class="output-block step-input-block">@prompt</div>
                                                        }
                                                    }
                                                    else if (string.IsNullOrWhiteSpace(inputData.SystemPrompt))
                                                    {
                                                        @* Non-AI steps (publish, canva, etc): show raw JSON *@
                                                        <label class="step-input-label">Datos de entrada</label>
                                                        <div class="output-block step-input-block">@inputData.RawJson</div>
                                                    }
                                                </div>
                                            </details>
                                        }
                                    }

                                    @if (step.ErrorMessage is not null)
                                    {
                                        <div class="alert alert-error">@step.ErrorMessage</div>
                                    }

                                    @if (step.OutputData is not null)
                                    {
                                        var parsed = TryParseOutput(step.OutputData);
                                        if (parsed?.Type == "text")
                                        {
                                            @if (parsed.Summary is not null)
                                            {
                                                <p class="text-sm" style="color: var(--accent); margin-bottom: 0.3rem;">@parsed.Summary</p>
                                            }

                                            @if (parsed.Content is not null)
                                            {
                                                <div class="output-block">@parsed.Content</div>
                                            }

                                            @if (parsed.Items is not null && parsed.Items.Count > 0)
                                            {
                                                <details class="mt-1">
                                                    <summary class="text-sm" style="cursor:pointer; color: var(--accent);">
                                                        @parsed.Items.Count elementos generados para el siguiente paso
                                                    </summary>
                                                    <div style="margin-top: 0.3rem;">
                                                        @foreach (var item in parsed.Items)
                                                        {
                                                            <div class="output-block" style="margin-bottom: 0.3rem; padding: 0.4rem 0.6rem; font-size: 0.8rem;">
                                                                @if (item.Label is not null) { <strong>@item.Label:</strong> }
                                                                @item.Content
                                                            </div>
                                                        }
                                                    </div>
                                                </details>
                                            }

                                            @if (parsed.Metadata is not null)
                                            {
                                                <div class="step-meta mt-1">
                                                    @if (parsed.Metadata.TryGetValue("publishType", out var pubType))
                                                    {
                                                        <span class="badge badge-info">@pubType.ToString().ToUpper()</span>
                                                    }
                                                    @if (parsed.Metadata.TryGetValue("caption", out var caption))
                                                    {
                                                        <span class="badge badge-info">Caption: @caption</span>
                                                    }
                                                    @if (parsed.Metadata.ContainsKey("bufferRequest"))
                                                    {
                                                        <button class="btn btn-sm" style="padding: 0.1rem 0.4rem; font-size: 0.7rem; margin-left: 0.3rem;"
                                                                @onclick="() => ShowBufferDebug(parsed)">Ver API</button>
                                                    }
                                                    @if (parsed.Metadata.TryGetValue("model", out var model))
                                                    {
                                                        <span class="badge badge-warning">@model</span>
                                                    }
                                                    @if (parsed.Metadata.TryGetValue("inputTokens", out var inTok))
                                                    {
                                                        <span class="text-sm text-muted">In: @inTok</span>
                                                    }
                                                    @if (parsed.Metadata.TryGetValue("outputTokens", out var outTok))
                                                    {
                                                        <span class="text-sm text-muted">Out: @outTok</span>
                                                    }
                                                </div>
                                            }
                                        }
                                        else if (parsed?.Type == "video")
                                        {
                                            @if (parsed.Metadata is not null && parsed.Metadata.TryGetValue("model", out var vidModel))
                                            {
                                                <span class="badge badge-warning">@vidModel</span>
                                                @if (parsed.Metadata.TryGetValue("duration", out var vidDur))
                                                {
                                                    <span class="text-sm text-muted ml-1">@vidDur s</span>
                                                }
                                                @if (parsed.Metadata.TryGetValue("resolution", out var vidRes))
                                                {
                                                    <span class="text-sm text-muted ml-1">@vidRes</span>
                                                }
                                            }

                                            @if (parsed.Files is not null && parsed.Files.Count > 0)
                                            {
                                                @foreach (var f in parsed.Files)
                                                {
                                                    var fileUrl = $"{_apiBase}/api/executions/{_result!.Id}/files/{f.FileId}";
                                                    <div style="margin-top: 0.5rem;">
                                                        <video controls style="max-width: 100%; border-radius: 8px;" crossorigin="use-credentials">
                                                            <source src="@fileUrl" type="@f.ContentType" />
                                                            Tu navegador no soporta video HTML5.
                                                        </video>
                                                        <div class="file-info" style="margin-top: 0.3rem;">
                                                            <a href="@fileUrl" target="_blank" download="@f.FileName" class="btn btn-sm btn-primary">
                                                                Descargar @f.FileName
                                                            </a>
                                                            <span class="text-sm text-muted">(@(f.FileSize / 1024) KB)</span>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        }
                                        else if (parsed?.Type == "image")
                                        {
                                            @if (parsed.Metadata is not null && parsed.Metadata.TryGetValue("model", out var imgModel))
                                            {
                                                <span class="badge badge-warning">@imgModel</span>
                                                <span class="text-sm text-muted ml-1">@(parsed.Files?.Count ?? 0) imagen(es)</span>
                                            }

                                            @if (parsed.Files is not null && parsed.Files.Count > 0)
                                            {
                                                <div class="image-grid mt-1">
                                                    @foreach (var f in parsed.Files)
                                                    {
                                                        var fileUrl = $"{_apiBase}/api/executions/{_result!.Id}/files/{f.FileId}";
                                                        <div class="image-grid-item">
                                                            <img src="@fileUrl" alt="@f.FileName" class="file-preview" crossorigin="use-credentials" />
                                                            @if (f.RevisedPrompt is not null)
                                                            {
                                                                <p class="text-sm text-muted" style="font-style: italic; margin: 0.2rem 0;">@f.RevisedPrompt</p>
                                                            }
                                                            <div class="file-info">
                                                                <a href="@fileUrl" target="_blank" download="@f.FileName" class="btn btn-sm btn-primary">
                                                                    Descargar @f.FileName
                                                                </a>
                                                                <span class="text-sm text-muted">(@(f.FileSize / 1024) KB)</span>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                        else if (parsed?.Type == "orchestrator")
                                        {
                                            <div class="orchestrator-plan">
                                                <p class="text-sm" style="color: var(--accent); margin-bottom: 0.5rem; font-weight: 600;">
                                                    Plan del orquestador: @parsed.Summary
                                                </p>
                                                @if (parsed.Items is not null && parsed.Items.Count > 0)
                                                {
                                                    <div class="orchestrator-tasks">
                                                        @foreach (var item in parsed.Items)
                                                        {
                                                            var isError = item.Content?.StartsWith("ERROR:") == true;
                                                            <div class="orchestrator-task-item @(isError ? "task-error" : "task-ok")">
                                                                <span class="task-label">@(item.Label ?? "Tarea")</span>
                                                                <span class="task-content">@item.Content</span>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                @if (parsed.Files is not null && parsed.Files.Count > 0)
                                                {
                                                    <div class="orchestrator-files mt-1">
                                                        @foreach (var f in parsed.Files)
                                                        {
                                                            var fileUrl = $"{_apiBase}/api/executions/{_result!.Id}/files/{f.FileId}";
                                                            <div style="margin: 0.3rem 0;">
                                                                @if (f.ContentType.StartsWith("image/"))
                                                                {
                                                                    <img src="@fileUrl" alt="@f.FileName" style="max-width: 200px; border-radius: 6px;" crossorigin="use-credentials" />
                                                                }
                                                                else if (f.ContentType.StartsWith("video/"))
                                                                {
                                                                    <video controls style="max-width: 300px; border-radius: 6px;" crossorigin="use-credentials">
                                                                        <source src="@fileUrl" type="@f.ContentType" />
                                                                    </video>
                                                                }
                                                                <div class="file-info">
                                                                    <a href="@fileUrl" target="_blank" download="@f.FileName" class="btn btn-sm btn-primary">
                                                                        @f.FileName
                                                                    </a>
                                                                    <span class="text-sm text-muted">(@(f.FileSize / 1024) KB)</span>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>

                                            @* Show review panel if waiting for review *@
                                            @if (step.Status == "WaitingForReview")
                                            {
                                                <div class="orchestrator-review">
                                                    <h4 style="margin: 0 0 0.5rem 0; font-size: 0.9rem;">Revision del plan</h4>

                                                    @* Parse plan JSON to show tasks *@
                                                    @{
                                                        var planTasks = TryParseOrchestratorPlan(step.OutputData);
                                                    }
                                                    @if (planTasks is not null)
                                                    {
                                                        <table class="orchestrator-plan-table">
                                                            <thead>
                                                                <tr>
                                                                    <th>#</th>
                                                                    <th>Tarea</th>
                                                                    <th>Modulo</th>
                                                                    <th>Input</th>
                                                                    <th>Razon</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var t in planTasks)
                                                                {
                                                                    <tr>
                                                                        <td>@t.Order</td>
                                                                        <td>@t.Description</td>
                                                                        <td><span class="badge badge-info">@t.ModuleName</span></td>
                                                                        <td class="text-sm">@(t.Input.Length > 120 ? t.Input[..120] + "..." : t.Input)</td>
                                                                        <td class="text-sm text-muted">@t.Reason</td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }

                                                    <div class="form-group" style="margin-top: 0.5rem;">
                                                        <label class="text-sm">Comentario (se aplicara en futuras ejecuciones)</label>
                                                        <textarea @bind="_orchestratorComment" rows="2"
                                                                  placeholder="Ej: No uses generacion de video, prioriza Pexels. Anade mas escenas de producto..."
                                                                  style="font-size: 0.85rem;"></textarea>
                                                    </div>
                                                    @if (_orchestratorError is not null)
                                                    {
                                                        <div class="alert alert-error" style="font-size: 0.8rem;">@_orchestratorError</div>
                                                    }
                                                    <div style="display: flex; gap: 0.5rem; margin-top: 0.4rem;">
                                                        <button class="btn btn-success btn-sm" @onclick="() => ReviewOrchestrator(true)" disabled="@_orchestratorReviewing">
                                                            @(_orchestratorReviewing ? "Aprobando..." : "Aprobar y ejecutar")
                                                        </button>
                                                        <button class="btn btn-danger btn-sm" @onclick="() => ReviewOrchestrator(false)" disabled="@_orchestratorReviewing">
                                                            Rechazar
                                                        </button>
                                                    </div>
                                                    <p class="text-sm text-muted" style="margin-top: 0.3rem;">
                                                        Al aprobar, las futuras ejecuciones seran autonomas. Si rechazas, tu comentario se guardara para la proxima ejecucion.
                                                    </p>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <!-- Fallback: raw output for old executions or unknown types -->
                                            <div class="output-block">@step.OutputData</div>

                                            @if (step.Files.Count > 0)
                                            {
                                                @foreach (var f in step.Files)
                                                {
                                                    var fileUrl = $"{_apiBase}/api/executions/{_result!.Id}/files/{f.Id}";
                                                    <div class="file-item">
                                                        @if (f.ContentType.StartsWith("image/"))
                                                        {
                                                            <img src="@fileUrl" alt="@f.FileName" class="file-preview" crossorigin="use-credentials" />
                                                        }
                                                        <div class="file-info">
                                                            <a href="@fileUrl" target="_blank" download="@f.FileName" class="btn btn-sm btn-primary">
                                                                Descargar @f.FileName
                                                            </a>
                                                            <span class="text-sm text-muted">(@f.ContentType, @(f.FileSize / 1024) KB)</span>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        }
                                    }
                                </div>
                            }
                        }
                        else if (_executing)
                        {
                            <div class="card" style="text-align: center; padding: 2rem;">
                                <span class="spinner"></span>
                                <p class="text-muted mt-1">Ejecutando pipeline...</p>
                            </div>
                        }
                    </div>

                    <!-- Right: Execution Log -->
                    <div class="execution-log">
                        <div class="log-header">
                            <strong>Log</strong>
                            @if (_logEntries.Count > 0)
                            {
                                <button class="btn btn-sm" style="padding: 0.1rem 0.4rem; font-size: 0.7rem;" @onclick="ClearLog">Limpiar</button>
                            }
                        </div>
                        <div class="log-entries" @ref="_logContainer">
                            @if (_logEntries.Count == 0 && _executing)
                            {
                                <div class="log-entry log-info">
                                    <span class="log-time">--:--:--</span>
                                    <span>Esperando logs...</span>
                                </div>
                            }
                            @foreach (var entry in _logEntries)
                            {
                                <div class="log-entry log-@entry.Level">
                                    <span class="log-time">@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                    @if (entry.StepOrder.HasValue)
                                    {
                                        <span class="log-step">P@(entry.StepOrder)</span>
                                    }
                                    <span class="log-message">@entry.Message</span>
                                    @if (entry.StepOrder.HasValue && entry.Level == "error" && !_executing && _result is not null)
                                    {
                                        <button class="btn btn-sm btn-warning log-retry-btn"
                                                @onclick="() => RetryFromLog(entry.StepOrder!.Value)">
                                            Reintentar desde P@(entry.StepOrder)
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- ═══════════ TAB: HISTORIAL ═══════════ -->
    @if (_activeTab == "history")
    {
        <div class="tab-content">
            @if (_executions.Count > 0)
            {
                @foreach (var e in _executions)
                {
                    var isExpanded = _expandedExecId == e.Id;
                    <div class="history-card" @key="e.Id">
                        <div class="history-card-header" @onclick="() => ToggleHistoryCard(e.Id)">
                            <div class="history-card-info">
                                <span class="badge @StatusBadge(e.Status)">@e.Status</span>
                                <span class="text-sm text-muted">@e.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                                @if (e.TotalEstimatedCost > 0)
                                {
                                    <span class="text-sm text-muted">~$@e.TotalEstimatedCost.ToString("F4")</span>
                                }
                            </div>
                            <div class="history-card-prompt">
                                @if (e.UserInput is not null)
                                {
                                    <span class="text-sm">@(e.UserInput.Length > 120 ? e.UserInput[..120] + "..." : e.UserInput)</span>
                                }
                                else
                                {
                                    <span class="text-sm text-muted">Sin prompt</span>
                                }
                            </div>
                            <div class="history-card-actions">
                                <button class="btn btn-sm btn-primary" @onclick="() => ViewExecution(e.Id)" @onclick:stopPropagation="true">
                                    Abrir
                                </button>
                                <span class="history-expand-icon">@(isExpanded ? "&#x25B2;" : "&#x25BC;")</span>
                            </div>
                        </div>

                        @if (isExpanded && _expandedExecDetail is not null && _expandedExecDetail.Id == e.Id)
                        {
                            <div class="history-card-body">
                                @foreach (var step in _expandedExecDetail.Steps.OrderBy(s => s.StepOrder))
                                {
                                    @if (step.OutputData is not null)
                                    {
                                        var parsed = TryParseOutput(step.OutputData);
                                        @if (parsed?.Type == "image" && parsed.Files is not null && parsed.Files.Count > 0)
                                        {
                                            <div class="history-step-preview">
                                                <span class="text-sm text-muted">Paso @step.StepOrder: @step.ModuleName</span>
                                                <div class="history-image-grid">
                                                    @foreach (var f in parsed.Files)
                                                    {
                                                        var fileUrl = $"{_apiBase}/api/executions/{_expandedExecDetail.Id}/files/{f.FileId}";
                                                        <div class="history-image-item">
                                                            <img src="@fileUrl" alt="@f.FileName" class="history-image-thumb" crossorigin="use-credentials" />
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        else if (parsed?.Type == "video" && parsed.Files is not null && parsed.Files.Count > 0)
                                        {
                                            <div class="history-step-preview">
                                                <span class="text-sm text-muted">Paso @step.StepOrder: @step.ModuleName</span>
                                                @foreach (var f in parsed.Files)
                                                {
                                                    var fileUrl = $"{_apiBase}/api/executions/{_expandedExecDetail.Id}/files/{f.FileId}";
                                                    <video controls style="max-width: 200px; border-radius: 6px; margin-top: 0.3rem;" crossorigin="use-credentials">
                                                        <source src="@fileUrl" type="@f.ContentType" />
                                                    </video>
                                                }
                                            </div>
                                        }
                                        else if (parsed?.Type == "text" && parsed.Content is not null)
                                        {
                                            <div class="history-step-preview">
                                                <span class="text-sm text-muted">Paso @step.StepOrder: @step.ModuleName</span>
                                                <div class="output-block" style="font-size: 0.8rem; max-height: 80px; overflow: hidden;">
                                                    @(parsed.Content.Length > 200 ? parsed.Content[..200] + "..." : parsed.Content)
                                                </div>
                                            </div>
                                        }
                                    }
                                }
                            </div>
                        }
                        else if (isExpanded && _expandedExecDetail is null)
                        {
                            <div class="history-card-body">
                                <p class="text-sm text-muted">Cargando...</p>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <span class="empty-state-icon">&#x1F4CB;</span>
                    <p>Sin ejecuciones aun</p>
                    <p class="text-sm text-muted">Ejecuta el pipeline para ver resultados aqui</p>
                </div>
            }
        </div>
    }

    <!-- ═══════════ SETTINGS MODAL ═══════════ -->
    @if (_showSettings)
    {
        <div class="modal-overlay" @onclick="() => _showSettings = false">
            <div class="settings-modal" @onclick:stopPropagation="true">
                <div class="settings-modal-header">
                    <h3 style="margin: 0;">Configuracion</h3>
                    <button class="btn-icon" @onclick="() => _showSettings = false">&#x2715;</button>
                </div>

                <!-- Settings tabs -->
                <div class="settings-tab-bar">
                    <button class="settings-tab @(_settingsTab == "messaging" ? "settings-tab-active" : "")"
                            @onclick='() => _settingsTab = "messaging"'>
                        Mensajeria
                    </button>
                    <button class="settings-tab @(_settingsTab == "social" ? "settings-tab-active" : "")"
                            @onclick='() => _settingsTab = "social"'>
                        Redes sociales
                    </button>
                    <button class="settings-tab @(_settingsTab == "schedule" ? "settings-tab-active" : "")"
                            @onclick='() => _settingsTab = "schedule"'>
                        Programacion
                    </button>
                </div>

                <div class="settings-modal-body">
                    <!-- MESSAGING TAB -->
                    @if (_settingsTab == "messaging")
                    {
                        <!-- Telegram -->
                        <div class="settings-block">
                            <div class="settings-block-header">
                                <strong>Telegram</strong>
                                @if (!string.IsNullOrWhiteSpace(_tgBotToken))
                                {
                                    <span class="badge badge-success">Configurado</span>
                                }
                            </div>
                            @if (_tgError is not null)
                            {
                                <div class="alert alert-error">@_tgError</div>
                            }
                            @if (_tgSuccess)
                            {
                                <div class="alert alert-success">Guardado correctamente</div>
                            }
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Bot Token</label>
                                    <input type="password" @bind="_tgBotToken" placeholder="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11" />
                                </div>
                                <div class="form-group">
                                    <label>Chat ID</label>
                                    <input type="text" @bind="_tgChatId" placeholder="Ej: 123456789" />
                                </div>
                            </div>
                            <p class="text-sm text-muted">
                                1. Habla con <strong>@@BotFather</strong> en Telegram &#x2192; <code>/newbot</code> &#x2192; copia el token.<br/>
                                2. Envia un mensaje al bot y visita <code>https://api.telegram.org/bot&lt;TOKEN&gt;/getUpdates</code> para obtener tu Chat ID.
                            </p>
                            <button class="btn btn-primary btn-sm" @onclick="SaveTelegramConfig" disabled="@_tgSaving">
                                @(_tgSaving ? "Guardando..." : "Guardar")
                            </button>
                        </div>

                        <!-- WhatsApp -->
                        <div class="settings-block">
                            <div class="settings-block-header">
                                <strong>WhatsApp</strong>
                                @if (!string.IsNullOrWhiteSpace(_waAccessToken))
                                {
                                    <span class="badge badge-success">Configurado</span>
                                }
                            </div>
                            @if (_waError is not null)
                            {
                                <div class="alert alert-error">@_waError</div>
                            }
                            @if (_waSuccess)
                            {
                                <div class="alert alert-success">Guardado correctamente</div>
                            }
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Phone Number ID</label>
                                    <input type="text" @bind="_waPhoneNumberId" placeholder="Ej: 123456789012345" />
                                </div>
                                <div class="form-group">
                                    <label>Numero destinatario</label>
                                    <input type="text" @bind="_waRecipientNumber" placeholder="Ej: 34612345678" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Access Token</label>
                                <input type="password" @bind="_waAccessToken" placeholder="EAABx..." />
                            </div>
                            <div class="form-group">
                                <label>Webhook Verify Token</label>
                                <input type="text" @bind="_waVerifyToken" placeholder="Token de verificacion para el webhook" />
                            </div>
                            <p class="text-sm text-muted">
                                Webhook URL: <code>https://tu-servidor/api/webhooks/whatsapp</code>
                            </p>
                            <button class="btn btn-primary btn-sm" @onclick="SaveWhatsAppConfig" disabled="@_waSaving">
                                @(_waSaving ? "Guardando..." : "Guardar")
                            </button>
                        </div>
                    }

                    <!-- SOCIAL TAB -->
                    @if (_settingsTab == "social")
                    {
                        <div class="settings-block">
                            <div class="settings-block-header">
                                <strong>Buffer</strong>
                                <span class="text-sm text-muted">Instagram, Twitter, LinkedIn...</span>
                                @if (!string.IsNullOrWhiteSpace(_igApiKey))
                                {
                                    <span class="badge badge-success">Configurado</span>
                                }
                            </div>
                            @if (_igError is not null)
                            {
                                <div class="alert alert-error">@_igError</div>
                            }
                            @if (_igSuccess)
                            {
                                <div class="alert alert-success">Guardado correctamente</div>
                            }
                            <div class="form-row">
                                <div class="form-group">
                                    <label>API Key</label>
                                    <input type="password" @bind="_igApiKey" placeholder="Token de Buffer API" />
                                </div>
                                <div class="form-group">
                                    <label>Channel ID</label>
                                    <input type="text" @bind="_igChannelId" placeholder="Ej: 65a1b2c3d4e5f6..." />
                                </div>
                            </div>
                            <p class="text-sm text-muted">
                                1. Ve a <strong>buffer.com</strong> &#x2192; Cuenta &#x2192; API Settings &#x2192; genera tu API Key.<br/>
                                2. El <strong>Channel ID</strong> se obtiene consultando tus canales conectados via la API.<br/>
                                3. Plan gratuito: 3 canales, 10 posts programados por canal.
                            </p>
                            <button class="btn btn-primary btn-sm" @onclick="SaveInstagramConfig" disabled="@_igSaving">
                                @(_igSaving ? "Guardando..." : "Guardar")
                            </button>
                        </div>
                    }

                    <!-- SCHEDULE TAB -->
                    @if (_settingsTab == "schedule")
                    {
                        <div class="settings-block">
                            @if (_schedError is not null)
                            {
                                <div class="alert alert-error">@_schedError</div>
                            }
                            @if (_schedSuccess)
                            {
                                <div class="alert alert-success">Programacion guardada correctamente</div>
                            }

                            @if (_schedule is not null)
                            {
                                <div class="schedule-status">
                                    <div class="schedule-status-item">
                                        <span class="text-muted">Estado</span>
                                        @if (_schedule.IsEnabled)
                                        {
                                            <strong style="color: var(--success);">Activa</strong>
                                        }
                                        else
                                        {
                                            <strong style="color: var(--warning);">Pausada</strong>
                                        }
                                    </div>
                                    @if (_schedule.NextRunAt.HasValue)
                                    {
                                        <div class="schedule-status-item">
                                            <span class="text-muted">Proxima ejecucion</span>
                                            <strong>@_schedule.NextRunAt.Value.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</strong>
                                        </div>
                                    }
                                    @if (_schedule.LastRunAt.HasValue)
                                    {
                                        <div class="schedule-status-item">
                                            <span class="text-muted">Ultima ejecucion</span>
                                            <strong>@_schedule.LastRunAt.Value.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</strong>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="form-group">
                                <label>Frecuencia</label>
                                <select @bind="_schedPreset">
                                    <option value="">Personalizado (cron)</option>
                                    <option value="daily">Diaria (a una hora fija)</option>
                                    <option value="twice">2 veces al dia</option>
                                    <option value="weekly">Semanal</option>
                                </select>
                            </div>

                            @if (_schedPreset == "daily" || _schedPreset == "twice")
                            {
                                <div class="form-row">
                                    <div class="form-group">
                                        <label>Hora (0-23)</label>
                                        <input type="number" min="0" max="23" @bind="_schedHour1" />
                                    </div>
                                    <div class="form-group">
                                        <label>Minuto (0-59)</label>
                                        <input type="number" min="0" max="59" @bind="_schedMinute1" />
                                    </div>
                                </div>
                                @if (_schedPreset == "twice")
                                {
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>2a hora (0-23)</label>
                                            <input type="number" min="0" max="23" @bind="_schedHour2" />
                                        </div>
                                        <div class="form-group">
                                            <label>2o minuto (0-59)</label>
                                            <input type="number" min="0" max="59" @bind="_schedMinute2" />
                                        </div>
                                    </div>
                                }
                            }
                            else if (_schedPreset == "weekly")
                            {
                                <div class="form-row" style="grid-template-columns: 1fr 1fr 1fr;">
                                    <div class="form-group">
                                        <label>Dia de la semana</label>
                                        <select @bind="_schedDayOfWeek">
                                            <option value="1">Lunes</option>
                                            <option value="2">Martes</option>
                                            <option value="3">Miercoles</option>
                                            <option value="4">Jueves</option>
                                            <option value="5">Viernes</option>
                                            <option value="6">Sabado</option>
                                            <option value="0">Domingo</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label>Hora (0-23)</label>
                                        <input type="number" min="0" max="23" @bind="_schedHour1" />
                                    </div>
                                    <div class="form-group">
                                        <label>Minuto (0-59)</label>
                                        <input type="number" min="0" max="59" @bind="_schedMinute1" />
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="form-group">
                                    <label>Expresion Cron</label>
                                    <input type="text" @bind="_schedCron" placeholder="0 9 * * * (cada dia a las 9:00)" />
                                </div>
                                <p class="text-sm text-muted" style="margin-top: -0.4rem; margin-bottom: 0.8rem;">
                                    Ejemplos: <code>0 9 * * *</code> (diario 9am) &middot; <code>0 9,18 * * *</code> (9am y 6pm) &middot; <code>0 10 * * 1</code> (lunes 10am)
                                </p>
                            }

                            <div class="form-row">
                                <div class="form-group">
                                    <label>Zona horaria</label>
                                    <select @bind="_schedTimeZone">
                                        <option value="Europe/Madrid">Europe/Madrid</option>
                                        <option value="Europe/London">Europe/London</option>
                                        <option value="America/New_York">America/New_York</option>
                                        <option value="America/Chicago">America/Chicago</option>
                                        <option value="America/Denver">America/Denver</option>
                                        <option value="America/Los_Angeles">America/Los_Angeles</option>
                                        <option value="America/Mexico_City">America/Mexico_City</option>
                                        <option value="America/Bogota">America/Bogota</option>
                                        <option value="America/Buenos_Aires">America/Buenos_Aires</option>
                                        <option value="America/Sao_Paulo">America/Sao_Paulo</option>
                                        <option value="UTC">UTC</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Input automatico <span class="text-sm text-muted">(opcional)</span></label>
                                    <input type="text" @bind="_schedUserInput" placeholder="Ej: Genera un post sobre tendencias de hoy" />
                                </div>
                            </div>

                            <div style="display: flex; gap: 0.5rem; align-items: center; margin-top: 0.3rem;">
                                <button class="btn btn-primary" @onclick="SaveSchedule" disabled="@_schedSaving">
                                    @(_schedSaving ? "Guardando..." : (_schedule is null ? "Crear programacion" : "Actualizar"))
                                </button>
                                @if (_schedule is not null)
                                {
                                    <button class="btn btn-secondary" @onclick="ToggleSchedule" disabled="@_schedSaving">
                                        @(_schedule.IsEnabled ? "Pausar" : "Activar")
                                    </button>
                                    <button class="btn btn-danger" @onclick="DeleteSchedule" disabled="@_schedSaving">
                                        Eliminar
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

<!-- ═══════════ ORCHESTRATOR REVIEW MODAL ═══════════ -->
@if (_showOrchestratorModal && _result is not null)
{
    <div class="modal-overlay" @onclick="() => {}">
        <div class="orchestrator-modal" @onclick:stopPropagation="true">
            <div class="orchestrator-modal-header">
                <h3 style="margin: 0; font-size: 1rem;">Revision del plan del orquestador</h3>
                <button class="btn-icon" @onclick="CloseOrchestratorModal">&#x2715;</button>
            </div>

            <div class="orchestrator-modal-body">
                @if (!string.IsNullOrWhiteSpace(_orchestratorModalSummary))
                {
                    <div class="orchestrator-summary">
                        <strong>Resumen:</strong> @_orchestratorModalSummary
                    </div>
                }

                @if (_orchestratorModalTasks is not null)
                {
                    <div class="orchestrator-tasks-list">
                        @foreach (var task in _orchestratorModalTasks.OrderBy(t => t.Order))
                        {
                            <div class="orchestrator-task-card">
                                <div class="task-card-header">
                                    <span class="task-order">#@task.Order</span>
                                    <span class="task-desc">@task.Description</span>
                                    <span class="badge badge-info">@task.ModuleName</span>
                                    <span class="badge" style="font-size: 0.65rem; background: var(--border);">@task.ModuleType</span>
                                </div>
                                <div class="task-card-input">
                                    <span class="text-muted" style="font-size: 0.75rem;">Prompt:</span>
                                    @task.Input
                                </div>
                                @if (!string.IsNullOrWhiteSpace(task.Reason))
                                {
                                    <div class="task-card-reason text-muted">@task.Reason</div>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Chat section -->
                <div class="orchestrator-chat">
                    <div class="orchestrator-chat-messages">
                        @if (_orchestratorChat.Count == 0)
                        {
                            <div class="text-muted text-sm" style="text-align: center; padding: 1rem;">
                                Puedes aprobar el plan o dejar un comentario para ajustarlo en la proxima ejecucion.
                            </div>
                        }
                        @foreach (var msg in _orchestratorChat)
                        {
                            <div class="chat-msg @(msg.IsSystem ? "chat-msg-system" : "chat-msg-user")">
                                <span class="chat-msg-text">@msg.Text</span>
                                <span class="chat-msg-time">@msg.Time.ToString("HH:mm")</span>
                            </div>
                        }
                    </div>

                    <div class="orchestrator-chat-input">
                        <textarea @bind="_orchestratorComment" rows="2"
                                  placeholder="Escribe un comentario para ajustar el plan..."
                                  style="flex: 1; font-size: 0.85rem;"></textarea>
                    </div>
                </div>

                @if (_orchestratorError is not null)
                {
                    <div class="alert alert-error" style="font-size: 0.8rem; margin-top: 0.5rem;">@_orchestratorError</div>
                }
            </div>

            <div class="orchestrator-modal-footer">
                <button class="btn btn-danger btn-sm" @onclick="() => ReviewOrchestratorModal(false)" disabled="@_orchestratorReviewing">
                    Rechazar
                </button>
                <button class="btn btn-success btn-sm" @onclick="() => ReviewOrchestratorModal(true)" disabled="@_orchestratorReviewing">
                    @(_orchestratorReviewing ? "Aprobando..." : "Aprobar y ejecutar")
                </button>
            </div>
        </div>
    </div>
}

<!-- Buffer API Debug Modal -->
@if (_showBufferDebug)
{
    <div class="modal-overlay" @onclick="() => _showBufferDebug = false">
