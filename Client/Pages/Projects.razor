@page "/projects"
@inject ApiClient Api
@inject NavigationManager Nav

<div class="projects-page-header">
    <h2>Proyectos</h2>
    <button class="btn btn-primary" @onclick="OpenCreateModal">+ Crear nuevo</button>
</div>

@if (_projects.Count > 0)
{
    <div class="project-grid">
        @foreach (var p in _projects)
        {
            var isEditing = _editingId == p.Id;
            <div class="project-card">
                @if (isEditing)
                {
                    <div class="project-card-edit">
                        <div class="form-group">
                            <label>Nombre</label>
                            <input type="text" @bind="_editName" />
                        </div>
                        <div class="form-group">
                            <label>Descripcion</label>
                            <input type="text" @bind="_editDesc" />
                        </div>
                        <div class="form-group">
                            <label>Contexto</label>
                            <textarea @bind="_editContext" rows="2"></textarea>
                        </div>
                        <div class="project-card-edit-actions">
                            <button class="btn btn-xs btn-success" @onclick="SaveEdit">Guardar</button>
                            <button class="btn btn-xs" @onclick="CancelEdit">Cancelar</button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="project-card-body" @onclick="() => GoTo(p.Id)">
                        <div class="project-card-avatar">@(p.Name.Length > 0 ? p.Name[0].ToString().ToUpper() : "P")</div>
                        <div class="project-card-title">@p.Name</div>
                        <div class="project-card-desc">@(p.Description ?? "Sin descripción")</div>
                        @if (!string.IsNullOrEmpty(p.Context))
                        {
                            <div class="project-card-context">@Truncate(p.Context, 90)</div>
                        }
                        <div class="project-card-meta">
                            <span title="Creado el @p.CreatedAt.ToString("dd MMM yyyy")">
                                &#x1F4C5; @p.CreatedAt.ToString("dd MMM yyyy")
                            </span>
                            <span title="Última actualización">
                                &#x1F504; @RelativeTime(p.UpdatedAt)
                            </span>
                        </div>
                    </div>
                    <div class="project-card-actions">
                        <button class="project-action-btn action-edit" @onclick="() => StartEdit(p)" title="Editar">&#x270E;</button>
                        <button class="project-action-btn action-duplicate" @onclick="() => Duplicate(p.Id)" title="Duplicar">&#x2398;</button>
                        <button class="project-action-btn action-delete" @onclick="() => Delete(p.Id)" title="Eliminar">&#x2715;</button>
                    </div>
                }
            </div>
        }
    </div>
}
else if (!_loading)
{
    <div class="projects-empty">
        <div class="projects-empty-icon">&#x1F4C1;</div>
        <p>No hay proyectos creados todavía.</p>
        <button class="btn btn-primary" @onclick="OpenCreateModal">+ Crear tu primer proyecto</button>
    </div>
}

@if (_showCreateModal)
{
    <div class="modal-overlay" @onclick="CloseCreateModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span style="font-size:1.1rem; font-weight:600;">Nuevo Proyecto</span>
                <button class="modal-close-btn" @onclick="CloseCreateModal" title="Cerrar">&#x2715;</button>
            </div>
            <div class="modal-body">
                @if (_error is not null)
                {
                    <div class="alert alert-error">@_error</div>
                }
                <div class="form-row">
                    <div class="form-group">
                        <label>Nombre</label>
                        <input type="text" @bind="_name" placeholder="Mi pipeline de IA" />
                    </div>
                    <div class="form-group">
                        <label>Descripción</label>
                        <input type="text" @bind="_desc" placeholder="Pipeline que genera texto e imagen" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Contexto del proyecto</label>
                    <textarea @bind="_context" rows="4" placeholder="Ej: Este proyecto genera contenido para una marca de mascotas llamada 'PetWorld'. El tono debe ser amigable, cercano y dirigido a dueños de perros y gatos. Las imágenes deben incluir mascotas felices."></textarea>
                    <span class="text-sm text-muted">Este contexto se inyecta automáticamente en todos los módulos del proyecto.</span>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn" @onclick="CloseCreateModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="Create" disabled="@_loading">
                    @(_loading ? "Creando..." : "Crear Proyecto")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ProjectResponse> _projects = [];
    private bool _loading;
    private string? _error;

    private bool _showCreateModal;
    private string _name = "";
    private string _desc = "";
    private string _context = "";

    // Edit state
    private Guid? _editingId;
    private string _editName = "";
    private string _editDesc = "";
    private string _editContext = "";

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        try { _projects = await Api.GetProjectsAsync(); } catch { }
        _loading = false;
    }

    private void OpenCreateModal()
    {
        _error = null;
        _name = "";
        _desc = "";
        _context = "";
        _showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        _showCreateModal = false;
        _error = null;
        _name = ""; _desc = ""; _context = "";
    }

    private async Task Create()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_name))
        {
            _error = "El nombre del proyecto es obligatorio.";
            return;
        }
        _loading = true;
        try
        {
            var (ok, error) = await Api.CreateProjectAsync(new CreateProjectRequest(
                _name.Trim(),
                string.IsNullOrWhiteSpace(_desc) ? null : _desc.Trim(),
                string.IsNullOrWhiteSpace(_context) ? null : _context.Trim()));
            if (ok)
            {
                _showCreateModal = false;
                _name = ""; _desc = ""; _context = "";
                await Load();
            }
            else _error = error;
        }
        catch (Exception ex) { _error = $"Error de conexión: {ex.Message}"; }
        _loading = false;
    }

    private void GoTo(Guid id) => Nav.NavigateTo($"/projects/{id}");

    private void StartEdit(ProjectResponse p)
    {
        _editingId = p.Id;
        _editName = p.Name;
        _editDesc = p.Description ?? "";
        _editContext = p.Context ?? "";
    }

    private void CancelEdit() => _editingId = null;

    private async Task SaveEdit()
    {
        if (_editingId is null) return;
        try
        {
            var req = new UpdateProjectRequest(
                _editName,
                string.IsNullOrWhiteSpace(_editDesc) ? null : _editDesc,
                string.IsNullOrWhiteSpace(_editContext) ? null : _editContext);
            var (ok, _) = await Api.UpdateProjectAsync(_editingId.Value, req);
            if (ok) { _editingId = null; await Load(); }
        }
        catch { }
    }

    private async Task Delete(Guid id)
    {
        try { await Api.DeleteProjectAsync(id); await Load(); }
        catch { }
    }

    private async Task Duplicate(Guid id)
    {
        try { await Api.DuplicateProjectAsync(id); await Load(); }
        catch { }
    }

    private static string Truncate(string? text, int max)
    {
        if (string.IsNullOrEmpty(text)) return "-";
        return text.Length <= max ? text : text[..max] + "...";
    }

    private static string RelativeTime(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalSeconds < 0) return "ahora mismo";   // fecha futura / desfase de reloj
        if (diff.TotalMinutes < 1) return "ahora mismo";
        if (diff.TotalMinutes < 60) return $"hace {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24) return $"hace {(int)diff.TotalHours}h";
        if (diff.TotalDays < 7) return $"hace {(int)diff.TotalDays}d";
        if (diff.TotalDays < 30) return $"hace {(int)(diff.TotalDays / 7)} sem";
        return dt.ToString("dd MMM yyyy");
    }
}
