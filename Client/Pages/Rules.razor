@page "/rules"
@inject ApiClient Api

<div class="apikeys-page-header">
    <div>
        <h2>Reglas obligatorias</h2>
        <p class="text-muted" style="font-size:0.85rem; margin:0;">
            Cada regla activa se inyecta automaticamente en el system prompt de TODAS las llamadas a IA del pipeline
            (texto, imagen, coordinador, orquestador, diseno). Usalas para imponer formato, idioma, restricciones de marca, etc.
        </p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreate" style="flex-shrink:0;">+ Nueva Regla</button>
</div>

@if (_rules.Count > 0)
{
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:4rem;">Orden</th>
                    <th>Titulo</th>
                    <th>Contenido</th>
                    <th style="width:5rem;">Estado</th>
                    <th style="width:10rem;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _rules)
                {
                    <tr class="@(!r.IsActive ? "row-inactive" : string.Empty)">
                        <td>@r.SortOrder</td>
                        <td>@r.Title</td>
                        <td class="cell-mono" style="max-width:30rem; white-space:pre-wrap;">@r.Content</td>
                        <td>
                            @if (r.IsActive)
                            {
                                <span class="badge badge-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge">Inactiva</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm" @onclick="() => StartEdit(r)">Editar</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Delete(r.Id)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (!_loading)
{
    <div class="apikeys-empty">
        <div class="apikeys-empty-icon">📋</div>
        <div class="apikeys-empty-title">Sin reglas configuradas</div>
        <div class="apikeys-empty-desc">Pulsa <strong>+ Nueva Regla</strong> para añadir tu primera regla de system prompt.</div>
    </div>
}

@if (_showModal)
{
    <div class="modal-overlay" @onclick="CancelEdit">
        <div class="modal-content" @onclick:stopPropagation="true" style="max-width: 560px;">
            <div class="modal-header">
                <strong style="flex:1">@(_editingId is null ? "Nueva regla" : "Editar regla")</strong>
                <button class="modal-close-btn" @onclick="CancelEdit" aria-label="Cerrar">&#x2715;</button>
            </div>
            <div class="modal-body">
                @if (_error is not null)
                {
                    <div class="alert alert-error" style="margin-bottom:0.8rem;">@_error</div>
                }
                <div class="form-group">
                    <label>Titulo</label>
                    <input type="text" @bind="_title" placeholder="Idioma de salida" />
                </div>
                <div class="form-group">
                    <label>Contenido (instruccion enviada al modelo)</label>
                    <textarea rows="5" @bind="_content" placeholder="Toda salida debe estar en espanol..."></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Orden</label>
                        <input type="number" @bind="_sortOrder" style="width:6rem;" />
                    </div>
                    <div class="form-group" style="display:flex; align-items:end;">
                        <label style="display:flex; gap:.5rem; align-items:center;">
                            <input type="checkbox" @bind="_isActive" />
                            <span>Activa</span>
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-sm" @onclick="CancelEdit" disabled="@_loading">Cancelar</button>
                <button class="btn btn-primary btn-sm" @onclick="Save" disabled="@_loading">
                    @(_loading ? "Guardando..." : (_editingId is null ? "Crear" : "Guardar"))
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<RuleResponse> _rules = [];
    private bool _loading;
    private string? _error;

    private bool _showModal;
    private Guid? _editingId;
    private string _title = "";
    private string _content = "";
    private bool _isActive = true;
    private int _sortOrder;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        try { _rules = await Api.GetRulesAsync(); } catch { }
        _loading = false;
    }

    private void OpenCreate()
    {
        _editingId = null;
        _title = ""; _content = ""; _isActive = true; _sortOrder = 0; _error = null;
        _showModal = true;
    }

    private void StartEdit(RuleResponse r)
    {
        _editingId = r.Id;
        _title = r.Title;
        _content = r.Content;
        _isActive = r.IsActive;
        _sortOrder = r.SortOrder;
        _error = null;
        _showModal = true;
    }

    private void CancelEdit()
    {
        if (_loading) return;
        _showModal = false;
        _editingId = null;
        _title = ""; _content = ""; _isActive = true; _sortOrder = 0;
        _error = null;
    }

    private async Task Save()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_title) || string.IsNullOrWhiteSpace(_content))
        {
            _error = "Titulo y contenido son obligatorios";
            return;
        }
        _loading = true;
        try
        {
            (bool ok, string? error) result;
            if (_editingId is { } id)
                result = await Api.UpdateRuleAsync(id, new UpdateRuleRequest(_title, _content, _isActive, _sortOrder));
            else
                result = await Api.CreateRuleAsync(new CreateRuleRequest(_title, _content, _isActive, _sortOrder));

            if (result.ok) { CancelEdit(); await Load(); }
            else _error = result.error;
        }
        catch (Exception ex) { _error = $"Error de conexion: {ex.Message}"; }
        _loading = false;
    }

    private async Task Delete(Guid id)
    {
        try { await Api.DeleteRuleAsync(id); await Load(); } catch { }
    }
}
