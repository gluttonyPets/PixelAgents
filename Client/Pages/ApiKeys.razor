@page "/apikeys"
@inject ApiClient Api

<h2>API Keys</h2>

<div class="card">
    <h3>Nueva API Key</h3>
    @if (_error is not null)
    {
        <div class="alert alert-error">@_error</div>
    }
    <div class="form-row">
        <div class="form-group">
            <label>Nombre</label>
            <input type="text" @bind="_name" placeholder="Mi clave OpenAI" />
        </div>
        <div class="form-group">
            <label>Proveedor</label>
            <select @bind="_provider">
                <option value="OpenAI">OpenAI</option>
                <option value="Anthropic">Anthropic</option>
                <option value="Google">Google (Gemini)</option>
                <option value="LeonardoAI">Leonardo AI</option>
                <option value="xAI">xAI (Grok)</option>
                <option value="Pexels">Pexels</option>
                <option value="Json2Video">Json2Video</option>
            </select>
        </div>
    </div>
    <div class="form-group">
        <label>API Key</label>
        <input type="password" @bind="_key" placeholder="sk-..." />
    </div>
    <button class="btn btn-primary" @onclick="Create" disabled="@_loading">Crear</button>
</div>

@if (_loading)
{
    <p class="text-muted">Cargando...</p>
}
else if (_keys.Count > 0)
{
    var allSorted = _keys.OrderBy(k => k.ProviderType).ThenBy(k => k.Name).ToList();
    var providers = _keys.Select(k => k.ProviderType).Distinct().OrderBy(p => p).ToList();

    var filtered = allSorted
        .Where(k => string.IsNullOrEmpty(_filterProvider) || k.ProviderType == _filterProvider)
        .Where(k => string.IsNullOrEmpty(_search) || k.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .ToList();

    var providerCount = providers.Count;

    <div class="apikeys-header">
        <div class="apikeys-stats">
            <span class="apikeys-stat-total">@_keys.Count</span>
            @(_keys.Count == 1 ? "clave" : "claves")
            &nbsp;·&nbsp;
            <span class="apikeys-stat-total">@providerCount</span>
            @(providerCount == 1 ? "proveedor" : "proveedores")
        </div>
    </div>

    <div class="apikeys-toolbar">
        <div class="apikeys-search-wrap">
            <input class="apikeys-search" type="text" @bind="_search" @bind:event="oninput"
                   placeholder="🔍 Buscar por nombre…" />
        </div>
        <div class="apikeys-filters">
            <button class="filter-pill @(string.IsNullOrEmpty(_filterProvider) ? "active" : "")"
                    @onclick='() => _filterProvider = null'>
                Todos <span class="filter-count">@_keys.Count</span>
            </button>
            @foreach (var p in providers)
            {
                var (_, pClass) = GetProviderMeta(p);
                var pCount = _keys.Count(k => k.ProviderType == p);
                var isActive = _filterProvider == p;
                <button class="filter-pill @(isActive ? "active" : "") @pClass"
                        @onclick="() => _filterProvider = p">
                    <ProviderIcon Provider="@p" Size="14" />&nbsp;@p <span class="filter-count">@pCount</span>
                </button>
            }
        </div>
    </div>

    @if (filtered.Count == 0)
    {
        <div class="apikeys-empty">
            <div class="apikeys-empty-icon">🔍</div>
            <div class="apikeys-empty-title">Sin resultados</div>
            <div class="apikeys-empty-desc">No hay claves que coincidan con los filtros aplicados.</div>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table apikeys-table">
            <thead>
                <tr>
                    <th class="col-provider">Proveedor</th>
                    <th class="col-name">Nombre</th>
                    <th class="col-id">ID Corto</th>
                    <th class="col-date">Creada</th>
                    <th class="col-usage">Uso</th>
                    <th class="col-actions"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var k in filtered)
                {
                    var (_, badgeClass) = GetProviderMeta(k.ProviderType);
                    var isConfirming = _confirmDeleteId == k.Id;
                    var shortId = k.Id.ToString("N")[..8];

                    <tr class="@(isConfirming ? "row-confirming" : k.ModulesCount == 0 ? "row-unused" : "")">
                        <td>
                            <span class="badge @badgeClass">
                                <ProviderIcon Provider="@k.ProviderType" Size="14" />&nbsp;@k.ProviderType
                            </span>
                        </td>
                        <td><span class="key-name">@k.Name</span></td>
                        <td>
                            <span class="key-id" title="@k.Id">@shortId…</span>
                        </td>
                        <td>
                            <span class="key-date" title="@k.CreatedAt.ToString("yyyy-MM-dd HH:mm")">
                                @RelativeTime(k.CreatedAt)
                            </span>
                        </td>
                        <td>
                            @if (k.ModulesCount > 0)
                            {
                                <span class="key-usage-badge key-usage-active" title="@k.ModulesCount módulo(s) usando esta clave">
                                    ⚡ @k.ModulesCount módulo@(k.ModulesCount == 1 ? "" : "s")
                                </span>
                            }
                            else
                            {
                                <span class="key-usage-badge key-usage-idle" title="Ningún módulo usa esta clave">
                                    Sin uso
                                </span>
                            }
                        </td>
                        <td class="apikeys-actions">
                            @if (isConfirming)
                            {
                                <span class="text-muted" style="margin-right:0.5rem;">¿Eliminar?</span>
                                <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDelete(k.Id)">Sí</button>
                                <button class="btn btn-sm" @onclick="CancelDelete" style="margin-left:0.25rem;">No</button>
                            }
                            else
                            {
                                <button class="btn btn-danger btn-sm" @onclick="() => RequestDelete(k.Id)">Eliminar</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
            </table>
        </div><!-- /.table-wrap -->
    }
}
else
{
    <div class="apikeys-empty">
        <div class="apikeys-empty-icon">🔑</div>
        <div class="apikeys-empty-title">Sin API Keys configuradas</div>
        <div class="apikeys-empty-desc">Añade tu primera clave usando el formulario de arriba para conectar con los proveedores de IA.</div>
    </div>
}

@code {
    private List<ApiKeyResponse> _keys = [];
    private bool _loading;
    private string? _error;
    private Guid? _confirmDeleteId;

    private string _name = "";
    private string _provider = "OpenAI";
    private string _key = "";

    private string _search = "";
    private string? _filterProvider;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        try { _keys = await Api.GetApiKeysAsync(); } catch { }
        _loading = false;
    }

    private async Task Create()
    {
        _error = null; _loading = true;
        try
        {
            var (ok, error) = await Api.CreateApiKeyAsync(new CreateApiKeyRequest(_name, _provider, _key));
            if (ok) { _name = ""; _key = ""; await Load(); }
            else _error = error;
        }
        catch (Exception ex) { _error = $"Error de conexion: {ex.Message}"; }
        _loading = false;
    }

    private void RequestDelete(Guid id) => _confirmDeleteId = id;
    private void CancelDelete() => _confirmDeleteId = null;

    private async Task ConfirmDelete(Guid id)
    {
        _confirmDeleteId = null;
        try { await Api.DeleteApiKeyAsync(id); await Load(); }
        catch { }
    }

    private static (string Icon, string BadgeClass) GetProviderMeta(string provider) => provider switch
    {
        "OpenAI"     => ("", "badge-openai"),
        "Anthropic"  => ("", "badge-anthropic"),
        "Google"     => ("", "badge-google"),
        "LeonardoAI" => ("", "badge-leonardo"),
        "xAI"        => ("", "badge-xai"),
        "Pexels"     => ("", "badge-pexels"),
        "Json2Video" => ("", "badge-json2video"),
        _            => ("", "badge-info")
    };

    private static string RelativeTime(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalSeconds < 60)  return "hace unos segundos";
        if (diff.TotalMinutes < 60)  return $"hace {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24)    return $"hace {(int)diff.TotalHours}h";
        if (diff.TotalDays < 30)     return $"hace {(int)diff.TotalDays} días";
        if (diff.TotalDays < 365)    return $"hace {(int)(diff.TotalDays / 30)} meses";
        return $"hace {(int)(diff.TotalDays / 365)} años";
    }
}
