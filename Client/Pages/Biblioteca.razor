@page "/biblioteca"
@inject ApiClient Api
@inject NavigationManager Nav

<h2>Biblioteca de Archivos</h2>

@if (_loading)
{
    <p class="text-muted">Cargando...</p>
}
else if (_files.Count == 0)
{
    <p class="text-muted">No hay archivos subidos. Sube archivos desde la configuracion de un modulo IA.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Archivo</th>
                <th>Tipo</th>
                <th>Tamano</th>
                <th>Modulo asignado</th>
                <th>Fecha</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in _files)
            {
                <tr>
                    <td>
                        <span title="@f.FileName">@TruncateName(f.FileName, 40)</span>
                    </td>
                    <td><span class="badge badge-info">@GetFileTypeLabel(f.ContentType)</span></td>
                    <td>@FormatFileSize(f.FileSize)</td>
                    <td>
                        <a href="/modules" class="link">@f.ModuleName</a>
                    </td>
                    <td>@f.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                    <td style="display: flex; gap: 0.25rem;">
                        <a href="/api/module-files/@f.Id/download" target="_blank" class="btn btn-sm">Descargar</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => Delete(f.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ModuleFileResponse> _files = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _files = await Api.GetAllModuleFilesAsync();
        }
        catch { }
        _loading = false;
    }

    private async Task Delete(Guid fileId)
    {
        try
        {
            await Api.DeleteModuleFileAsync(fileId);
            _files.RemoveAll(f => f.Id == fileId);
        }
        catch { }
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private static string TruncateName(string name, int max)
    {
        if (name.Length <= max) return name;
        var ext = Path.GetExtension(name);
        return name[..(max - ext.Length - 3)] + "..." + ext;
    }

    private static string GetFileTypeLabel(string contentType) => contentType switch
    {
        var t when t.StartsWith("image/") => "Imagen",
        "application/pdf" => "PDF",
        var t when t.Contains("spreadsheet") || t.Contains("excel") => "Excel",
        var t when t.Contains("word") || t.Contains("document") => "Word",
        "text/plain" => "Texto",
        "text/csv" => "CSV",
        "application/json" => "JSON",
        "text/markdown" => "Markdown",
        _ => contentType
    };
}
