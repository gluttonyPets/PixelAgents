@* Componente que muestra el logotipo oficial de cada proveedor de IA como SVG inline.
   Uso: <ProviderIcon Provider="OpenAI" Size="16" />
   Proveedores soportados: OpenAI, Anthropic, Google, xAI, LeonardoAI, Pexels, Json2Video, System *@

@switch (Provider)
{
    case "OpenAI":
        @* Logo oficial de OpenAI (rosette/flor de 4 petalos) *@
        <svg class="provider-logo" width="@Size" height="@Size" viewBox="0 0 41 41" fill="none"
             xmlns="http://www.w3.org/2000/svg" aria-label="OpenAI">
            <path d="M37.532 16.87a9.963 9.963 0 0 0-.856-8.184 10.078 10.078 0 0 0-10.855-4.835 9.964 9.964 0 0 0-6.396-3.506 10.079 10.079 0 0 0-10.855 4.835 9.965 9.965 0 0 0-6.167 4.818 10.079 10.079 0 0 0 1.24 11.817 9.965 9.965 0 0 0 .856 8.185 10.079 10.079 0 0 0 10.855 4.835 9.965 9.965 0 0 0 6.396 3.506 10.079 10.079 0 0 0 10.855-4.835 9.965 9.965 0 0 0 6.167-4.818 10.079 10.079 0 0 0-1.24-11.817zm-14.233 20.61a7.477 7.477 0 0 1-4.793-1.72l.236-.134 7.964-4.6a1.328 1.328 0 0 0 .655-1.134V19.054l3.366 1.944a.12.12 0 0 1 .066.092v9.299a7.505 7.505 0 0 1-7.494 7.091zm-16.106-6.892a7.474 7.474 0 0 1-.894-5.023l.236.142 7.964 4.6a1.328 1.328 0 0 0 1.308 0l9.724-5.614v3.888a.12.12 0 0 1-.048.103l-8.051 4.649a7.504 7.504 0 0 1-10.24-2.745zm-2.09-17.41a7.474 7.474 0 0 1 3.897-3.284V19.61a1.328 1.328 0 0 0 .654 1.132l9.723 5.614-3.366 1.944a.12.12 0 0 1-.114.012L7.589 23.86a7.504 7.504 0 0 1-2.485-10.682zm27.658 6.437l-9.724-5.615 3.367-1.943a.121.121 0 0 1 .114-.012l8.048 4.648a7.498 7.498 0 0 1-1.158 13.528v-9.476a1.328 1.328 0 0 0-.647-1.13zm3.35-5.043l-.236-.141-7.965-4.6a1.328 1.328 0 0 0-1.308 0l-9.723 5.614v-3.888a.12.12 0 0 1 .048-.103l8.05-4.645a7.497 7.497 0 0 1 11.135 7.763zm-21.063 6.929l-3.367-1.944a.12.12 0 0 1-.065-.092v-9.299a7.497 7.497 0 0 1 12.293-5.756l-.236.134-7.965 4.6a1.328 1.328 0 0 0-.654 1.132l-.006 11.225zm1.829-3.943l4.33-2.501 4.332 2.5v4.998l-4.331 2.5-4.331-2.5V18.558z"
                  fill="currentColor"/>
        </svg>
        break;

    case "Anthropic":
        @* Logo oficial de Anthropic (triangulo con la A) *@
        <svg class="provider-logo" width="@Size" height="@Size" viewBox="0 0 92 66" fill="none"
             xmlns="http://www.w3.org/2000/svg" aria-label="Anthropic">
            <path d="M53.925 0h-16.04L64.214 66h16.04L53.925 0z" fill="currentColor"/>
            <path d="M27.746 0H11.747L0 33l11.747 33h15.999L15.999 33 27.746 0z" fill="currentColor"/>
        </svg>
        break;

    case "Google":
        @* Logo G de Google con colores oficiales *@
        <svg class="provider-logo" width="@Size" height="@Size" viewBox="0 0 48 48" fill="none"
             xmlns="http://www.w3.org/2000/svg" aria-label="Google">
            <path d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z" fill="#FFC107"/>
            <path d="M6.306 14.691l6.571 4.819C14.655 15.108 19.002 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z" fill="#FF3D00"/>
            <path d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z" fill="#4CAF50"/>
            <path d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z" fill="#1976D2"/>
        </svg>
        break;

    case "xAI":
        @* Logo X de xAI/Grok *@
        <svg class="provider-logo" width="@Size" height="@Size" viewBox="0 0 300 300" fill="none"
             xmlns="http://www.w3.org/2000/svg" aria-label="xAI">
            <path d="M178.57 127.15L290.27 0h-26.46l-97.03 110.38L89.34 0H0l117.13 166.93L0 300.25h26.46l102.4-116.59 81.8 116.59h89.34M36.01 19.54H76.66l187.13 262.13h-40.66" fill="currentColor"/>
        </svg>
        break;

    case "LeonardoAI":
        @* Icono simplificado de Leonardo AI (L estilizada con degradado) *@
        <svg class="provider-logo" width="@Size" height="@Size" viewBox="0 0 32 32" fill="none"
             xmlns="http://www.w3.org/2000/svg" aria-label="Leonardo AI">
            <circle cx="16" cy="16" r="16" fill="url(#leo-grad)"/>
            <text x="16" y="22" text-anchor="middle" font-size="18" font-weight="bold" font-family="Georgia,serif" fill="white">L</text>
            <defs>
                <linearGradient id="leo-grad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                    <stop offset="0%" stop-color="#7C3AED"/>
                    <stop offset="100%" stop-color="#A78BFA"/>
                </linearGradient>
            </defs>
        </svg>
        break;

    case "Pexels":
        @* Logo de Pexels (P sobre fondo verde) *@
        <svg class="provider-logo" width="@Size" height="@Size" viewBox="0 0 32 32" fill="none"
             xmlns="http://www.w3.org/2000/svg" aria-label="Pexels">
            <rect width="32" height="32" rx="6" fill="#05A081"/>
            <path d="M12 8h5.5a4.5 4.5 0 0 1 0 9H15v7h-3V8zm3 6.5h2.5a1.5 1.5 0 0 0 0-3H15v3z" fill="white"/>
        </svg>
        break;

    case "Json2Video":
        @* Icono de Json2Video (camara de video) *@
        <svg class="provider-logo" width="@Size" height="@Size" viewBox="0 0 32 32" fill="none"
             xmlns="http://www.w3.org/2000/svg" aria-label="Json2Video">
            <rect width="32" height="32" rx="6" fill="#FF7043"/>
            <path d="M5 11a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V11zm16 2.5l4-2.5v10l-4-2.5V13.5z" fill="white"/>
        </svg>
        break;

    case "Canva":
        @* Icono de Canva (C estilizada) *@
        <svg class="provider-logo" width="@Size" height="@Size" viewBox="0 0 32 32" fill="none"
             xmlns="http://www.w3.org/2000/svg" aria-label="Canva">
            <circle cx="16" cy="16" r="16" fill="url(#canva-grad)"/>
            <text x="16" y="22" text-anchor="middle" font-size="18" font-weight="bold" font-family="Arial,sans-serif" fill="white">C</text>
            <defs>
                <linearGradient id="canva-grad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                    <stop offset="0%" stop-color="#00C4CC"/>
                    <stop offset="100%" stop-color="#7D2AE7"/>
                </linearGradient>
            </defs>
        </svg>
        break;

    default:
        @* Icono generico para proveedores desconocidos o System *@
        <svg class="provider-logo" width="@Size" height="@Size" viewBox="0 0 24 24" fill="none"
             xmlns="http://www.w3.org/2000/svg" aria-label="@Provider">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
            <path d="M12 8v4l3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        break;
}

@code {
    /// <summary>Nombre del proveedor: OpenAI, Anthropic, Google, xAI, LeonardoAI, Pexels, Json2Video, Canva</summary>
    [Parameter] public string Provider { get; set; } = "";

    /// <summary>Tamanio del icono en pixeles (ancho y alto). Por defecto 16.</summary>
    [Parameter] public int Size { get; set; } = 16;
}
