@* Asistente "Anadir con IA": toma el prompt actual como base, integra lo que el
   usuario pide y muestra el cambio (diff antes/despues) para aceptar o rechazar.
   Al aceptar, invoca OnAccept con el prompt completo actualizado. *@

@inject ApiClient Api

<div class="modal-overlay pb-overlay" @onclick="Close">
    <div class="modal-content pb-modal pb-modal-wide" @onclick:stopPropagation="true" role="dialog" aria-modal="true"
         aria-label="Anadir al prompt con IA">
        <div class="modal-header">
            <h3 style="margin:0; font-size:1.05rem; flex:1;">
                <i class="bi bi-plus-circle" style="margin-right:0.35rem;"></i>Anadir al prompt con IA
            </h3>
            <button class="node-btn" @onclick="Close" title="Cerrar" aria-label="Cerrar">&#x2715;</button>
        </div>

        <div class="modal-body">
            @if (_error is not null)
            {
                <div class="pb-alert pb-alert-error" role="alert">@_error</div>
            }

            @if (_step == 1)
            {
                @if (_modelsLoaded && _models.Count == 0)
                {
                    <div class="pb-alert pb-alert-warn">
                        No hay ninguna API Key configurada. Anade una en
                        <strong>Configuracion &gt; API Keys</strong> y vuelve a intentarlo.
                    </div>
                }

                <div class="form-group">
                    <label for="pa-model">Modelo que te ayudara</label>
                    <select id="pa-model" @bind="_modelName" disabled="@(_models.Count == 0)">
                        @if (_models.Count == 0)
                        {
                            <option value="">-- sin modelos disponibles --</option>
                        }
                        @foreach (var m in _models)
                        {
                            <option value="@m.ModelName">@m.DisplayName (@m.Provider)</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label for="pa-add">¿Que quieres anadir al prompt?</label>
                    <textarea id="pa-add" rows="4" @bind="_addition" @bind:event="oninput"
                              placeholder="Ej: anade una seccion de restricciones que prohiba usar emojis y limite el texto a 3 frases..."></textarea>
                    <p class="text-sm text-muted" style="margin-top:0.15rem;">
                        La IA interpretara y mejorara tu peticion, la integrara en el prompt actual y comprobara si
                        rompe alguna regla ya aplicada o genera incoherencias. Despues veras el cambio y los avisos antes de aplicarlo.
                    </p>
                </div>
            }
            else if (_step == 2)
            {
                @if (_warnings.Count > 0)
                {
                    <div class="pa-warnings" role="alert">
                        <div class="pa-warnings-title">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            Se detectaron @_warnings.Count posible@(_warnings.Count == 1 ? "" : "s") conflicto@(_warnings.Count == 1 ? "" : "s") o incoherencia@(_warnings.Count == 1 ? "" : "s")
                        </div>
                        <ul class="pa-warnings-list">
                            @foreach (var w in _warnings)
                            {
                                <li>@w</li>
                            }
                        </ul>
                    </div>
                }
                else
                {
                    <div class="pa-warnings pa-warnings-ok" role="status">
                        <i class="bi bi-check-circle-fill"></i>
                        Sin conflictos con las reglas ni incoherencias detectadas.
                    </div>
                }
                <p class="text-sm text-muted" style="margin-top:0;">
                    Revisa el cambio propuesto. En verde lo anadido, en rojo lo eliminado.
                </p>
                <div class="pa-diff" role="region" aria-label="Cambios propuestos">
                    @foreach (var d in _diff)
                    {
                        <div class="pa-diff-line @DiffClass(d.Kind)"><span class="pa-diff-sign">@DiffSign(d.Kind)</span><span class="pa-diff-text">@d.Text</span></div>
                    }
                </div>
            }
        </div>

        <div class="modal-footer">
            @if (_step == 1)
            {
                <button class="btn btn-sm" @onclick="Close" disabled="@_busy">Cancelar</button>
                <div style="flex:1;"></div>
                <button class="btn btn-primary btn-sm" @onclick="Generate"
                        disabled="@(_busy || _models.Count == 0 || string.IsNullOrWhiteSpace(_addition) || string.IsNullOrWhiteSpace(_modelName))">
                    @if (_busy) { <span class="spinner" style="width:0.7rem;height:0.7rem;"></span><span> Generando...</span> }
                    else { <span>Generar cambio</span> }
                </button>
            }
            else if (_step == 2)
            {
                <button class="btn btn-sm" @onclick="Reject" disabled="@_busy">Rechazar</button>
                <div style="flex:1;"></div>
                <button class="btn btn-sm" @onclick="Generate" disabled="@_busy" title="Volver a generar la propuesta">
                    @if (_busy) { <span class="spinner" style="width:0.7rem;height:0.7rem;"></span><span> Regenerando...</span> }
                    else { <span><i class="bi bi-arrow-repeat"></i> Regenerar</span> }
                </button>
                <button class="btn btn-primary btn-sm" @onclick="Accept" disabled="@_busy">Aceptar cambio</button>
            }
        </div>
    </div>
</div>

@code {
    /// <summary>"text" o "image": ajusta la generacion.</summary>
    [Parameter] public string TargetKind { get; set; } = "text";
    /// <summary>Prompt actual que sirve de base para la adicion.</summary>
    [Parameter] public string? CurrentPrompt { get; set; }
    /// <summary>Se invoca con el prompt completo actualizado cuando el usuario acepta.</summary>
    [Parameter] public EventCallback<string> OnAccept { get; set; }
    /// <summary>Se invoca al cerrar sin aplicar nada.</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    private int _step = 1;
    private bool _busy;
    private string? _error;

    private List<PromptBuilderModelOption> _models = new();
    private bool _modelsLoaded;
    private string _modelName = "";
    private string _addition = "";

    private string _proposedPrompt = "";
    private List<DiffLine> _diff = new();
    private List<string> _warnings = new();

    protected override async Task OnInitializedAsync()
    {
        _models = await Api.GetPromptBuilderModelsAsync();
        _modelsLoaded = true;
        if (_models.Count > 0)
            _modelName = _models[0].ModelName;
    }

    private async Task Generate()
    {
        if (string.IsNullOrWhiteSpace(_addition) || string.IsNullOrWhiteSpace(_modelName)) return;
        _busy = true;
        _error = null;
        try
        {
            var (ok, prompt, warnings, error) = await Api.AddPromptBuilderAsync(
                new PromptBuilderAddRequest(_modelName, TargetKind, CurrentPrompt ?? "", _addition));
            if (!ok)
            {
                _error = error ?? "No se pudo generar el cambio.";
                return;
            }
            _proposedPrompt = prompt ?? "";
            _warnings = warnings ?? new();
            _diff = ComputeDiff(CurrentPrompt ?? "", _proposedPrompt);
            _step = 2;
        }
        finally { _busy = false; }
    }

    private void Reject()
    {
        // Volver al paso 1 conservando lo escrito para reintentar.
        _step = 1;
        _error = null;
    }

    private async Task Accept()
    {
        if (string.IsNullOrWhiteSpace(_proposedPrompt)) return;
        await OnAccept.InvokeAsync(_proposedPrompt);
    }

    private async Task Close() => await OnClose.InvokeAsync();

    // ── Diff por lineas (LCS) ──

    private record DiffLine(string Kind, string Text); // Kind: "same" | "add" | "del"

    private static string DiffClass(string kind) => kind switch
    {
        "add" => "pa-diff-add",
        "del" => "pa-diff-del",
        _ => "pa-diff-same",
    };

    private static string DiffSign(string kind) => kind switch
    {
        "add" => "+",
        "del" => "−",
        _ => " ",
    };

    private static List<DiffLine> ComputeDiff(string oldText, string newText)
    {
        var a = string.IsNullOrEmpty(oldText) ? Array.Empty<string>() : SplitLines(oldText);
        var b = string.IsNullOrEmpty(newText) ? Array.Empty<string>() : SplitLines(newText);
        int n = a.Length, m = b.Length;

        // Tabla LCS.
        var dp = new int[n + 1, m + 1];
        for (int i = n - 1; i >= 0; i--)
            for (int j = m - 1; j >= 0; j--)
                dp[i, j] = a[i] == b[j] ? dp[i + 1, j + 1] + 1 : Math.Max(dp[i + 1, j], dp[i, j + 1]);

        var res = new List<DiffLine>();
        int x = 0, y = 0;
        while (x < n && y < m)
        {
            if (a[x] == b[y]) { res.Add(new DiffLine("same", a[x])); x++; y++; }
            else if (dp[x + 1, y] >= dp[x, y + 1]) { res.Add(new DiffLine("del", a[x])); x++; }
            else { res.Add(new DiffLine("add", b[y])); y++; }
        }
        while (x < n) { res.Add(new DiffLine("del", a[x])); x++; }
        while (y < m) { res.Add(new DiffLine("add", b[y])); y++; }
        return res;
    }

    private static string[] SplitLines(string text) =>
        (text ?? "").Replace("\r\n", "\n").Replace("\r", "\n").Split('\n');
}
