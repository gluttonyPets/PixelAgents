@inject ApiClient Api
@inject AuthStateService AuthState
@implements IDisposable

@if (_visible)
{
    <div class="modal-overlay" @onclick="CloseOnBackdrop">
        <div class="modal-content login-popup" @onclick:stopPropagation="true">
            <div class="login-popup-tabs">
                <button class="tab-btn @(_tab == "login" ? "active" : "")" @onclick='() => _tab = "login"'>Iniciar sesión</button>
                <button class="tab-btn @(_tab == "register" ? "active" : "")" @onclick='() => _tab = "register"'>Registrarse</button>
            </div>

            @if (_tab == "login")
            {
                <div class="login-popup-form">
                    @if (_loginError is not null)
                    {
                        <div class="alert alert-error">@_loginError</div>
                    }
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" @bind="_loginEmail" @bind:event="oninput" @onkeydown="OnLoginKeyDown" />
                    </div>
                    <div class="form-group">
                        <label>Contraseña</label>
                        <input type="password" @bind="_loginPassword" @bind:event="oninput" @onkeydown="OnLoginKeyDown" />
                    </div>
                    <button class="btn btn-primary" @onclick="Login" disabled="@_loading">
                        @(_loading ? "Entrando..." : "Entrar")
                    </button>
                </div>
            }
            else
            {
                <div class="login-popup-form">
                    @if (_regError is not null)
                    {
                        <div class="alert alert-error">@_regError</div>
                    }
                    @if (_regSuccess)
                    {
                        <div class="alert alert-success">Cuenta creada. Ahora inicia sesión.</div>
                    }
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" @bind="_regEmail" @bind:event="oninput" />
                    </div>
                    <div class="form-group">
                        <label>Contraseña</label>
                        <input type="password" @bind="_regPassword" @bind:event="oninput" />
                    </div>
                    <button class="btn btn-primary" @onclick="Register" disabled="@_loading">
                        @(_loading ? "Registrando..." : "Crear cuenta")
                    </button>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _visible;
    private string _tab = "login";
    private bool _loading;

    private string _loginEmail = "";
    private string _loginPassword = "";
    private string? _loginError;

    private string _regEmail = "";
    private string _regPassword = "";
    private string? _regError;
    private bool _regSuccess;

    protected override void OnInitialized()
    {
        AuthState.OnLoginRequired += Show;
    }

    public void Show()
    {
        _visible = true;
        _tab = "login";
        _loginError = null;
        _regError = null;
        _regSuccess = false;
        InvokeAsync(StateHasChanged);
    }

    private void CloseOnBackdrop() => _visible = false;

    private async Task OnLoginKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Login();
    }

    private async Task Login()
    {
        _loginError = null; _loading = true;
        try
        {
            var (ok, user, error) = await Api.LoginAsync(_loginEmail, _loginPassword);
            if (ok)
            {
                AuthState.SetUser(user);
                _visible = false;
                _loginEmail = "";
                _loginPassword = "";
            }
            else _loginError = error;
        }
        catch (Exception ex) { _loginError = $"Error de conexión: {ex.Message}"; }
        _loading = false;
    }

    private async Task Register()
    {
        _regError = null; _regSuccess = false; _loading = true;
        try
        {
            var (ok, error) = await Api.RegisterAsync(_regEmail, _regPassword);
            if (ok)
            {
                _regSuccess = true;
                _loginEmail = _regEmail;
                _regEmail = "";
                _regPassword = "";
                await Task.Delay(1500);
                _tab = "login";
            }
            else _regError = error;
        }
        catch (Exception ex) { _regError = $"Error de conexión: {ex.Message}"; }
        _loading = false;
    }

    public void Dispose()
    {
        AuthState.OnLoginRequired -= Show;
    }
}
