@using Client.Models
@using Client.Services
@using System.Text.Json
@inject IJSRuntime JS
@inject ApiClient Api

<div class="pipeline-editor-container">
    <!-- ── Center: Drawflow canvas (now full width) ── -->
    <div class="pipeline-canvas-wrapper">
        <div id="drawflow-@_canvasId" class="drawflow-container"></div>

        <!-- Toolbar -->
        <div class="canvas-toolbar">
            <button class="toolbar-btn toolbar-btn-primary" @onclick="ToggleModulePanel" title="Agregar modulo">
                <span class="toolbar-btn-icon">&#x2795;</span> Modulo
            </button>
        </div>

        <!-- Floating module selector panel -->
        @if (_showModulePanel)
        {
            <div class="module-panel-backdrop" @onclick="CloseModulePanel"></div>
            <div class="module-panel">
                <div class="module-panel-header">
                    <span>Agregar modulo</span>
                    <button class="node-btn" @onclick="CloseModulePanel">&#x2715;</button>
                </div>
                <div class="module-panel-search">
                    <input type="text" placeholder="Buscar modulo..." @bind="_searchFilter" @bind:event="oninput" />
                </div>
                <div class="module-panel-body">
                    @if (string.IsNullOrWhiteSpace(_searchFilter))
                    {
                        @foreach (var category in _moduleCategories)
                        {
                            var modulesInCategory = AvailableModules.Where(m => category.Types.Contains(m.ModuleType)).ToList();
                            if (modulesInCategory.Count == 0) continue;

                            <div class="module-category">
                                <button class="module-category-header" @onclick="() => ToggleCategory(category.Key)">
                                    <span class="module-category-icon"><i class="bi @category.Icon"></i></span>
                                    <span class="module-category-label">@category.Label</span>
                                    <span class="module-category-count">@modulesInCategory.Count</span>
                                    <span class="module-category-chevron @(_expandedCategories.Contains(category.Key) ? "expanded" : "")">&#x25B6;</span>
                                </button>
                                @if (_expandedCategories.Contains(category.Key))
                                {
                                    <div class="module-category-items">
                                        @foreach (var m in modulesInCategory)
                                        {
                                            <div class="palette-item" @onclick="() => AddNodeFromPalette(m)">
                                                <div class="palette-item-icon" style="background: @ModulePortRegistry.GetModuleColor(m.ModuleType);">
                                                    <i class="bi @ModulePortRegistry.GetModuleIcon(m.ModuleType)"></i>
                                                </div>
                                                <div class="palette-item-info">
                                                    <div class="palette-item-name">@m.Name</div>
                                                    <div class="palette-item-type">@m.ProviderType</div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="module-category-items">
                            @foreach (var m in FilteredModules)
                            {
                                <div class="palette-item" @onclick="() => AddNodeFromPalette(m)">
                                    <div class="palette-item-icon" style="background: @ModulePortRegistry.GetModuleColor(m.ModuleType);">
                                        @ModulePortRegistry.GetModuleIcon(m.ModuleType)
                                    </div>
                                    <div class="palette-item-info">
                                        <div class="palette-item-name">@m.Name</div>
                                        <div class="palette-item-type">@m.ProviderType / @m.ModuleType</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @if (Modules.Count == 0 && _jsInitialized)
        {
            <div class="canvas-empty-overlay">
                <span class="canvas-empty-state-icon">&#x1F9E9;</span>
                <p>Pipeline vacio</p>
                <p class="text-sm">Pulsa <strong>+ Modulo</strong> para empezar a construir tu pipeline</p>
            </div>
        }
    </div>

    <!-- ── Right: Execute + Inspector ── -->
    <div class="pipeline-inspector">
        @if (TopPanel is not null)
        {
            <div class="inspector-top-panel">
                @TopPanel
            </div>
        }
        @if (_selectedModuleId.HasValue)
        {
            var sel = Modules.FirstOrDefault(m => m.Id == _selectedModuleId);
            if (sel is not null)
            {
                <div class="inspector-header">
                    <span>@(sel.StepName ?? sel.AiModuleName)</span>
                    <button class="node-btn" @onclick="DeselectNode">&#x2715;</button>
                </div>
                <div class="inspector-body">
                    <div class="inspector-section">
                        <div class="inspector-section-title">Informacion</div>
                        <div class="inspector-field">
                            <label>Modulo</label>
                            <input type="text" value="@sel.AiModuleName" readonly />
                        </div>
                        <div class="inspector-field">
                            <label>Tipo</label>
                            <input type="text" value="@sel.ModuleType" readonly />
                        </div>
                        <div class="inspector-field">
                            <label>Modelo</label>
                            @if (sel.ModuleType == "Orchestrator")
                            {
                                <select value="@GetOrchestratorModel(sel)"
                                        @onchange="@(e => SetModuleConfig(sel.Id, "modelName", e.Value?.ToString() ?? ""))">
                                    <option value="">@sel.ModelName (por defecto)</option>
                                    @foreach (var m in _orchestratorModels.Where(m => m != sel.ModelName))
                                    {
                                        <option value="@m">@m</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="text" value="@sel.ModelName" readonly />
                            }
                        </div>
                    </div>

                    <div class="inspector-section">
                        <div class="inspector-section-title">Conexiones</div>
                        @{
                            var ports = ModulePortRegistry.GetPorts(sel.ModuleType, "", GetSceneCount(sel.Id), sel.InputMapping, sel.OrchestratorOutputs);
                            var inputPorts = ports.Where(p => p.IsInput).ToList();
                            var outputPorts = ports.Where(p => !p.IsInput).ToList();
                        }
                        @if (inputPorts.Any())
                        {
                            <div class="inspector-port-section">
                                <div class="inspector-port-section-label">
                                    <i class="bi bi-arrow-right-circle"></i> Entradas
                                </div>
                                @foreach (var port in inputPorts)
                                {
                                    var portConns = _connections.Where(c => c.ToModuleId == sel.Id && c.ToPort == port.Id).ToList();
                                    <div class="inspector-port-item">
                                        <div class="inspector-port-header">
                                            <span class="inspector-port-dot" style="background: @PortDataType.GetColor(port.DataType);"></span>
                                            <span class="inspector-port-name">@port.Label</span>
                                            <span class="inspector-port-type-badge" style="background: @(PortDataType.GetColor(port.DataType))22; color: @PortDataType.GetColor(port.DataType); border: 1px solid @(PortDataType.GetColor(port.DataType))44;">@PortDataType.GetLabel(port.DataType)</span>
                                            @if (port.AllowMultiple)
                                            {
                                                <span class="inspector-port-multi-badge" title="Acepta multiples conexiones">N</span>
                                            }
                                            @if (port.IsRequired)
                                            {
                                                <span style="color: var(--danger); font-size: 0.6rem; font-weight: 700;">*</span>
                                            }
                                        </div>
                                        @if (portConns.Count > 0)
                                        {
                                            @foreach (var conn in portConns)
                                            {
                                                var capturedInputConn = conn;
                                                var fromModule = Modules.FirstOrDefault(m => m.Id == conn.FromModuleId);
                                                var fromPortsList = fromModule is not null ? ModulePortRegistry.GetPorts(fromModule.ModuleType, "", GetSceneCount(fromModule.Id), fromModule.InputMapping, fromModule.OrchestratorOutputs) : new();
                                                var fromPort = fromPortsList.FirstOrDefault(p => p.Id == conn.FromPort);
                                                <div class="inspector-port-connection">
                                                    <span class="inspector-port-conn-arrow">&#x2190;</span>
                                                    <span class="inspector-port-conn-source">@(fromModule?.StepName ?? fromModule?.AiModuleName ?? "?")</span>
                                                    @if (fromPort is not null)
                                                    {
                                                        <span class="inspector-port-type-badge" style="background: @(PortDataType.GetColor(fromPort.DataType))22; color: @PortDataType.GetColor(fromPort.DataType); border: 1px solid @(PortDataType.GetColor(fromPort.DataType))44;">@fromPort.Label</span>
                                                    }
                                                    <button class="inspector-port-remove-btn" @onclick="() => RemoveConnection(capturedInputConn)" title="Quitar conexion">&#x2715;</button>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="inspector-port-empty">sin conectar</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        @if (outputPorts.Any())
                        {
                            <div class="inspector-port-section" style="margin-top: 0.4rem;">
                                <div class="inspector-port-section-label">
                                    <i class="bi bi-arrow-left-circle"></i> Salidas
                                </div>
                                @foreach (var port in outputPorts)
                                {
                                    var outConns = _connections.Where(c => c.FromModuleId == sel.Id && c.FromPort == port.Id).ToList();
                                    <div class="inspector-port-item">
                                        <div class="inspector-port-header">
                                            <span class="inspector-port-dot" style="background: @PortDataType.GetColor(port.DataType);"></span>
                                            <span class="inspector-port-name">@port.Label</span>
                                            <span class="inspector-port-type-badge" style="background: @(PortDataType.GetColor(port.DataType))22; color: @PortDataType.GetColor(port.DataType); border: 1px solid @(PortDataType.GetColor(port.DataType))44;">@PortDataType.GetLabel(port.DataType)</span>
                                            @if (outConns.Count > 0)
                                            {
                                                <span class="inspector-port-count-badge">@outConns.Count</span>
                                            }
                                        </div>
                                        @if (outConns.Count > 0)
                                        {
                                            @foreach (var c in outConns)
                                            {
                                                var capturedOutputConn = c;
                                                var toModule = Modules.FirstOrDefault(m => m.Id == c.ToModuleId);
                                                var toPortsList = toModule is not null ? ModulePortRegistry.GetPorts(toModule.ModuleType, "", GetSceneCount(toModule.Id), toModule.InputMapping, toModule.OrchestratorOutputs) : new();
                                                var toPort = toPortsList.FirstOrDefault(p => p.Id == c.ToPort);
                                                <div class="inspector-port-connection">
                                                    <span class="inspector-port-conn-arrow">&#x2192;</span>
                                                    <span class="inspector-port-conn-source">@(toModule?.StepName ?? toModule?.AiModuleName ?? "?")</span>
                                                    @if (toPort is not null)
                                                    {
                                                        <span class="inspector-port-type-badge" style="background: @(PortDataType.GetColor(toPort.DataType))22; color: @PortDataType.GetColor(toPort.DataType); border: 1px solid @(PortDataType.GetColor(toPort.DataType))44;">@toPort.Label</span>
                                                    }
                                                    <button class="inspector-port-remove-btn" @onclick="() => RemoveConnection(capturedOutputConn)" title="Quitar conexion">&#x2715;</button>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="inspector-port-empty">sin conectar</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Input mapping editor -->
                    <div class="inspector-section">
                        <div class="inspector-section-title">Entrada de datos</div>
                        <div class="inspector-field">
                            <label>Fuente de datos</label>
                            <select value="@(sel.InputMapping ?? "{\"source\":\"user\"}")"
                                    @onchange="e => HandleInputMappingChange(sel.Id, e.Value?.ToString())">
                                <option value='{"source":"user"}'>Entrada del usuario</option>
                                <option value='{"source":"previous","field":"text"}'>Paso anterior (texto)</option>
                                <option value='{"source":"previous","field":"file"}'>Paso anterior (archivo)</option>
                            </select>
                            <p class="text-sm text-muted" style="margin-top: 0.2rem;">
                                Tipo actual: <strong>@FormatInputMapping(sel.InputMapping)</strong>
                            </p>
                        </div>
                    </div>

                    @if (sel.ModuleType == "Image")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Generacion</div>
                            <div class="inspector-field">
                                <label>Numero de imagenes</label>
                                <input type="number" min="1" max="20"
                                       value="@GetSceneCount(sel.Id)"
                                       @onchange="@(e => OnImageCountChange(sel.Id, e))" />
                                <p class="text-sm text-muted" style="margin-top: 0.15rem;">Cada imagen tendra su propia salida.</p>
                            </div>
                        </div>
                    }

                    @if (sel.ModuleType == "VideoEdit")
                    {
                        @* ── General ── *@
                        <div class="inspector-section">
                            <div class="inspector-section-title">General</div>
                            <div class="inspector-field">
                                <label>Numero de escenas</label>
                                <input type="number" min="1" max="10" value="@GetSceneCount(sel.Id)"
                                       @onchange="e => UpdateSceneCount(sel.Id, int.TryParse(e.Value?.ToString(), out var v) ? v : 1)" />
                                <p class="text-sm text-muted" style="margin-top: 0.15rem;">Cada escena acepta video o imagen.</p>
                            </div>
                            <div class="inspector-field">
                                <label>Duracion de escenas con imagen (seg)</label>
                                <input type="number" min="1" max="30" step="0.5"
                                       value="@GetModuleConfig(sel.Id, "imageDuration", "5")"
                                       @onchange="@(e => SetModuleConfig(sel.Id, "imageDuration", e.Value?.ToString() ?? "5"))" />
                            </div>
                            <div class="inspector-field">
                                <label>Animacion de imagenes</label>
                                <select value="@GetModuleConfig(sel.Id, "imageAnimation", "zoom-in")"
                                        @onchange="@(e => SetModuleConfig(sel.Id, "imageAnimation", e.Value?.ToString() ?? "zoom-in"))">
                                    <option value="none">Sin animacion</option>
                                    <option value="zoom-in">Zoom in</option>
                                    <option value="zoom-out">Zoom out</option>
                                    <option value="pan-left">Pan izquierda</option>
                                    <option value="pan-right">Pan derecha</option>
                                    <option value="random">Aleatorio</option>
                                </select>
                            </div>
                            <div class="inspector-field">
                                <label>Resolucion</label>
                                <select value="@GetModuleConfig(sel.Id, "resolution", "full-hd")"
                                        @onchange="@(e => SetModuleConfig(sel.Id, "resolution", e.Value?.ToString() ?? "full-hd"))">
                                    <option value="sd">SD (640x480)</option>
                                    <option value="hd">HD (1280x720)</option>
                                    <option value="full-hd">Full HD (1920x1080)</option>
                                    <option value="squared">Cuadrado (1080x1080)</option>
                                    <option value="instagram-story">Instagram Story (1080x1920)</option>
                                    <option value="instagram-feed">Instagram Feed (1080x1350)</option>
                                    <option value="twitter-landscape">Twitter Landscape</option>
                                    <option value="twitter-portrait">Twitter Portrait</option>
                                </select>
                            </div>
                            <div class="inspector-field">
                                <label>Calidad</label>
                                <select value="@GetModuleConfig(sel.Id, "quality", "high")"
                                        @onchange="@(e => SetModuleConfig(sel.Id, "quality", e.Value?.ToString() ?? "high"))">
                                    <option value="low">Baja</option>
                                    <option value="medium">Media</option>
                                    <option value="high">Alta</option>
                                </select>
                            </div>
                            <div class="inspector-field">
                                <label style="display: flex; align-items: center; gap: 0.4rem; cursor: pointer;">
                                    <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "cache", true)"
                                           @onchange="@(e => SetModuleConfig(sel.Id, "cache", ((bool)(e.Value ?? true)).ToString().ToLower()))" />
                                    Cache
                                </label>
                                <p class="text-sm text-muted" style="margin-top: 0.15rem;">Reutiliza escenas sin cambios para renderizar mas rapido.</p>
                            </div>
                        </div>

                        @* ── Transiciones ── *@
                        <div class="inspector-section">
                            <div class="inspector-section-title">Transiciones entre escenas</div>
                            <div class="inspector-field">
                                <label>Estilo</label>
                                <select value="@GetModuleConfig(sel.Id, "transitionStyle", "none")"
                                        @onchange="@(e => SetModuleConfig(sel.Id, "transitionStyle", e.Value?.ToString() ?? "none"))">
                                    <option value="none">Ninguna</option>
                                    <option value="fade">Fade</option>
                                    <option value="circleopen">Circle Open</option>
                                    <option value="circleclose">Circle Close</option>
                                    <option value="wipeup">Wipe Up</option>
                                    <option value="wipedown">Wipe Down</option>
                                    <option value="wipeleft">Wipe Left</option>
                                    <option value="wiperight">Wipe Right</option>
                                </select>
                            </div>
                            @if (GetModuleConfig(sel.Id, "transitionStyle", "none") != "none")
                            {
                                <div class="inspector-field">
                                    <label>Duracion (s)</label>
                                    <input type="number" min="0.1" max="1" step="0.1"
                                           value="@GetModuleConfig(sel.Id, "transitionDuration", "0.5")"
                                           @onchange="@(e => SetModuleConfig(sel.Id, "transitionDuration", e.Value?.ToString() ?? "0.5"))" />
                                    <p class="text-sm text-muted" style="margin-top: 0.1rem;">Max 1s para evitar solapamiento de audio.</p>
                                </div>
                            }
                        </div>

                        @* ── Voz ── *@
                        <div class="inspector-section">
                            <div class="inspector-section-title">Voz (TTS)</div>
                            <div class="inspector-field">
                                <label style="display: flex; align-items: center; gap: 0.4rem; cursor: pointer;">
                                    <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "enableVoice", true)"
                                           @onchange="@(e => SetModuleConfig(sel.Id, "enableVoice", ((bool)(e.Value ?? true)).ToString().ToLower()))" />
                                    Habilitar voz
                                </label>
                            </div>
                            @if (GetModuleConfigBool(sel.Id, "enableVoice", true))
                            {
                                <div class="inspector-field">
                                    <label>Proveedor</label>
                                    <select value="@GetModuleConfig(sel.Id, "voiceModel", "azure")"
                                            @onchange="@(e => SetModuleConfig(sel.Id, "voiceModel", e.Value?.ToString() ?? "azure"))">
                                        <option value="azure">Azure (gratis)</option>
                                        <option value="elevenlabs">ElevenLabs (60 cred/min)</option>
                                        <option value="elevenlabs-flash-v2-5">ElevenLabs Flash v2.5</option>
                                    </select>
                                </div>
                                <div class="inspector-field">
                                    <label>Nombre de voz</label>
                                    @if (GetModuleConfig(sel.Id, "voiceModel", "azure") == "azure")
                                    {
                                        <select value="@GetModuleConfig(sel.Id, "voiceName", "es-ES-AlvaroNeural")"
                                                @onchange="@(e => SetModuleConfig(sel.Id, "voiceName", e.Value?.ToString() ?? "es-ES-AlvaroNeural"))">
                                            <optgroup label="Espanol (Espana)">
                                                <option value="es-ES-AlvaroNeural">Alvaro (hombre)</option>
                                                <option value="es-ES-ElviraNeural">Elvira (mujer)</option>
                                                <option value="es-ES-IsidoraMultilingualNeural">Isidora (mujer, multilingue)</option>
                                                <option value="es-ES-XimenaMultilingualNeural">Ximena (mujer, multilingue)</option>
                                                <option value="es-ES-AbrilNeural">Abril (mujer)</option>
                                                <option value="es-ES-ArnauNeural">Arnau (hombre)</option>
                                                <option value="es-ES-DarioNeural">Dario (hombre)</option>
                                                <option value="es-ES-EliasNeural">Elias (hombre)</option>
                                                <option value="es-ES-EstrellaNeural">Estrella (mujer)</option>
                                                <option value="es-ES-IreneNeural">Irene (mujer)</option>
                                                <option value="es-ES-LaiaNeural">Laia (mujer)</option>
                                                <option value="es-ES-NilNeural">Nil (hombre)</option>
                                                <option value="es-ES-SaulNeural">Saul (hombre)</option>
                                                <option value="es-ES-TeoNeural">Teo (hombre)</option>
                                                <option value="es-ES-TrianaNeural">Triana (mujer)</option>
                                                <option value="es-ES-VeraNeural">Vera (mujer)</option>
                                            </optgroup>
                                            <optgroup label="Espanol (Mexico)">
                                                <option value="es-MX-JorgeNeural">Jorge (hombre)</option>
                                                <option value="es-MX-DaliaNeural">Dalia (mujer)</option>
                                                <option value="es-MX-BeatrizNeural">Beatriz (mujer)</option>
                                                <option value="es-MX-MarinaNeural">Marina (mujer)</option>
                                            </optgroup>
                                            <optgroup label="Espanol (Argentina)">
                                                <option value="es-AR-TomasNeural">Tomas (hombre)</option>
                                                <option value="es-AR-ElenaNeural">Elena (mujer)</option>
                                            </optgroup>
                                            <optgroup label="Espanol (Colombia)">
                                                <option value="es-CO-GonzaloNeural">Gonzalo (hombre)</option>
                                                <option value="es-CO-SalomeNeural">Salome (mujer)</option>
                                            </optgroup>
                                            <optgroup label="Ingles (US)">
                                                <option value="en-US-EmmaMultilingualNeural">Emma (mujer, multilingue)</option>
                                                <option value="en-US-AndrewMultilingualNeural">Andrew (hombre, multilingue)</option>
                                                <option value="en-US-AriaNeural">Aria (mujer)</option>
                                                <option value="en-US-GuyNeural">Guy (hombre)</option>
                                                <option value="en-US-JennyNeural">Jenny (mujer)</option>
                                            </optgroup>
                                            <optgroup label="Ingles (UK)">
                                                <option value="en-GB-SoniaNeural">Sonia (mujer)</option>
                                                <option value="en-GB-RyanNeural">Ryan (hombre)</option>
                                            </optgroup>
                                        </select>
                                        <a href="https://json2video.com/ai-voices/azure/voices/@(GetModuleConfig(sel.Id, "voiceName", "es-ES-AlvaroNeural").ToLower())/"
                                           target="_blank" rel="noopener"
                                           style="display: inline-block; margin-top: 0.25rem; font-size: 0.75rem; color: var(--accent);">
                                            Escuchar muestra de @GetModuleConfig(sel.Id, "voiceName", "es-ES-AlvaroNeural")
                                        </a>
                                    }
                                    else
                                    {
                                        <select value="@GetModuleConfig(sel.Id, "voiceName", "Brian")"
                                                @onchange="@(e => SetModuleConfig(sel.Id, "voiceName", e.Value?.ToString() ?? "Brian"))">
                                            <optgroup label="Multilingue (hablan espanol)">
                                                <option value="Brian">Brian (hombre, narrador)</option>
                                                <option value="Aria">Aria (mujer, expresiva)</option>
                                                <option value="Chris">Chris (hombre, casual)</option>
                                                <option value="Jessica">Jessica (mujer, juvenil)</option>
                                                <option value="George">George (hombre, calido)</option>
                                                <option value="Laura">Laura (mujer, entusiasta)</option>
                                                <option value="Daniel">Daniel (hombre, autoritario)</option>
                                                <option value="Alice">Alice (mujer, segura)</option>
                                                <option value="Bill">Bill (hombre, confiable)</option>
                                                <option value="Rachel">Rachel (mujer, natural)</option>
                                            </optgroup>
                                            <optgroup label="Hombres">
                                                <option value="Adam">Adam (profundo)</option>
                                                <option value="Charlie">Charlie (australiano)</option>
                                                <option value="Antoni">Antoni (joven)</option>
                                                <option value="Arnold">Arnold (serio)</option>
                                                <option value="Callum">Callum (intenso)</option>
                                                <option value="Jackson">Jackson (seguro)</option>
                                            </optgroup>
                                            <optgroup label="Mujeres">
                                                <option value="Emily">Emily (calmada)</option>
                                                <option value="Charlotte">Charlotte (suave)</option>
                                                <option value="Dorothy">Dorothy (britanica)</option>
                                                <option value="Grace">Grace (surena)</option>
                                                <option value="Freya">Freya (expresiva)</option>
                                            </optgroup>
                                        </select>
                                        <p class="text-sm text-muted" style="margin-top: 0.15rem;">
                                            Todas las voces hablan espanol. O pega un voice ID de
                                            <a href="https://json2video.com/ai-voices/elevenlabs/" target="_blank" rel="noopener"
                                               style="color: var(--accent);">la galeria</a>:
                                        </p>
                                        <input value="@GetModuleConfig(sel.Id, "voiceNameCustom", "")"
                                               placeholder="Pegar voice ID personalizado..."
                                               style="margin-top: 0.2rem;"
                                               @onchange="@(e => { var v = e.Value?.ToString() ?? ""; if (!string.IsNullOrWhiteSpace(v)) SetModuleConfig(sel.Id, "voiceName", v); SetModuleConfig(sel.Id, "voiceNameCustom", v); })" />
                                    }
                                </div>
                                @if (GetModuleConfig(sel.Id, "voiceModel", "azure").StartsWith("elevenlabs"))
                                {
                                    <div class="inspector-field">
                                        <label>Velocidad (0.7 - 1.2)</label>
                                        <input type="number" min="0.7" max="1.2" step="0.05"
                                               value="@GetModuleConfig(sel.Id, "voiceSpeed", "1.0")"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "voiceSpeed", e.Value?.ToString() ?? "1.0"))" />
                                    </div>
                                }
                            }
                        </div>

                        @* ── Subtitulos ── *@
                        <div class="inspector-section">
                            <div class="inspector-section-title">Subtitulos</div>
                            <div class="inspector-field">
                                <label style="display: flex; align-items: center; gap: 0.4rem; cursor: pointer;">
                                    <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "enableSubtitles", true)"
                                           @onchange="@(e => SetModuleConfig(sel.Id, "enableSubtitles", ((bool)(e.Value ?? true)).ToString().ToLower()))" />
                                    Habilitar subtitulos
                                </label>
                            </div>
                            @if (GetModuleConfigBool(sel.Id, "enableSubtitles", true))
                            {
                                <div class="inspector-field">
                                    <label>Idioma</label>
                                    <select value="@GetModuleConfig(sel.Id, "subtitleLanguage", "es")"
                                            @onchange="@(e => SetModuleConfig(sel.Id, "subtitleLanguage", e.Value?.ToString() ?? "es"))">
                                        <option value="es">Espanol</option>
                                        <option value="en">Ingles</option>
                                        <option value="pt">Portugues</option>
                                        <option value="fr">Frances</option>
                                        <option value="de">Aleman</option>
                                        <option value="it">Italiano</option>
                                        <option value="auto">Auto-detectar</option>
                                    </select>
                                </div>
                                <div class="inspector-field">
                                    <label>Modelo de transcripcion</label>
                                    <select value="@GetModuleConfig(sel.Id, "subtitleModel", "default")"
                                            @onchange="@(e => SetModuleConfig(sel.Id, "subtitleModel", e.Value?.ToString() ?? "default"))">
                                        <option value="default">Default (mas preciso)</option>
                                        <option value="whisper">Whisper (mas idiomas)</option>
                                    </select>
                                </div>
                                <div class="inspector-field">
                                    <label>Estilo</label>
                                    <select value="@GetModuleConfig(sel.Id, "subtitleStyle", "boxed-word")"
                                            @onchange="@(e => SetModuleConfig(sel.Id, "subtitleStyle", e.Value?.ToString() ?? "boxed-word"))">
                                        <option value="classic">Classic</option>
                                        <option value="classic-progressive">Classic Progressive</option>
                                        <option value="boxed-line">Boxed Line</option>
                                        <option value="boxed-word">Boxed Word</option>
                                    </select>
                                </div>
                                <div class="inspector-field">
                                    <label>Fuente</label>
                                    <select value="@GetModuleConfig(sel.Id, "subtitleFontFamily", "Montserrat")"
                                            @onchange="@(e => SetModuleConfig(sel.Id, "subtitleFontFamily", e.Value?.ToString() ?? "Montserrat"))">
                                        <optgroup label="Sans Serif">
                                            <option value="Montserrat">Montserrat</option>
                                            <option value="Roboto">Roboto</option>
                                            <option value="Roboto Condensed">Roboto Condensed</option>
                                            <option value="Inter">Inter</option>
                                            <option value="Poppins">Poppins</option>
                                            <option value="Oswald">Oswald</option>
                                            <option value="Bebas Neue">Bebas Neue</option>
                                            <option value="Nunito">Nunito</option>
                                            <option value="Open Sans">Open Sans</option>
                                            <option value="Lato">Lato</option>
                                            <option value="Raleway">Raleway</option>
                                            <option value="Arial">Arial</option>
                                        </optgroup>
                                        <optgroup label="Display / Impacto">
                                            <option value="Luckiest Guy">Luckiest Guy</option>
                                            <option value="Bungee">Bungee</option>
                                            <option value="Permanent Marker">Permanent Marker</option>
                                            <option value="Bangers">Bangers</option>
                                            <option value="Passion One">Passion One</option>
                                            <option value="Anton">Anton</option>
                                            <option value="Black Ops One">Black Ops One</option>
                                        </optgroup>
                                        <optgroup label="Serif / Elegante">
                                            <option value="Playfair Display">Playfair Display</option>
                                            <option value="Libre Baskerville">Libre Baskerville</option>
                                            <option value="Merriweather">Merriweather</option>
                                            <option value="Lora">Lora</option>
                                        </optgroup>
                                        <optgroup label="Handwriting">
                                            <option value="Dancing Script">Dancing Script</option>
                                            <option value="Caveat">Caveat</option>
                                            <option value="Nanum Pen Script">Nanum Pen Script</option>
                                        </optgroup>
                                    </select>
                                    <link href="https://fonts.googleapis.com/css2?family=@(Uri.EscapeDataString(GetModuleConfig(sel.Id, "subtitleFontFamily", "Montserrat"))):wght@@@(GetModuleConfig(sel.Id, "subtitleFontWeight", "700"))&display=swap" rel="stylesheet" />
                                    <div style="font-family: '@(GetModuleConfig(sel.Id, "subtitleFontFamily", "Montserrat"))', sans-serif; font-size: 1.1rem; font-weight: @GetModuleConfig(sel.Id, "subtitleFontWeight", "700");
                                                background: #000; color: @GetModuleConfig(sel.Id, "subtitleWordColor", "#FFFF00");
                                                padding: 0.4rem 0.6rem; border-radius: 4px; margin-top: 0.3rem; text-align: center;">
                                        Subtitulo de ejemplo
                                    </div>
                                </div>
                                <div class="inspector-field">
                                    <label>Tamano de fuente</label>
                                    <input type="number" min="20" max="300" step="10"
                                           value="@GetModuleConfig(sel.Id, "subtitleFontSize", "120")"
                                           @onchange="@(e => SetModuleConfig(sel.Id, "subtitleFontSize", e.Value?.ToString() ?? "120"))" />
                                </div>
                                <div class="inspector-field">
                                    <label>Grosor de fuente</label>
                                    <select value="@GetModuleConfig(sel.Id, "subtitleFontWeight", "700")"
                                            @onchange="@(e => SetModuleConfig(sel.Id, "subtitleFontWeight", e.Value?.ToString() ?? "700"))">
                                        <option value="100">100 - Thin</option>
                                        <option value="200">200 - Extra Light</option>
                                        <option value="300">300 - Light</option>
                                        <option value="400">400 - Regular</option>
                                        <option value="500">500 - Medium</option>
                                        <option value="600">600 - Semi Bold</option>
                                        <option value="700">700 - Bold</option>
                                        <option value="800">800 - Extra Bold</option>
                                        <option value="900">900 - Black</option>
                                    </select>
                                    <p class="text-sm text-muted" style="margin-top: 0.1rem;">100 (mas fino) a 900 (mas grueso). Depende de la fuente elegida.</p>
                                </div>
                                <div class="inspector-field">
                                    <label>Posicion</label>
                                    <select value="@GetModuleConfig(sel.Id, "subtitlePosition", "bottom-center")"
                                            @onchange="@(e => SetModuleConfig(sel.Id, "subtitlePosition", e.Value?.ToString() ?? "bottom-center"))">
                                        <option value="top-center">Arriba centro</option>
                                        <option value="center">Centro</option>
                                        <option value="bottom-center">Abajo centro</option>
                                    </select>
                                </div>
                                <div class="inspector-field">
                                    <label>Palabras por linea</label>
                                    <input type="number" min="1" max="20" step="1"
                                           value="@GetModuleConfig(sel.Id, "subtitleMaxWordsPerLine", "4")"
                                           @onchange="@(e => SetModuleConfig(sel.Id, "subtitleMaxWordsPerLine", e.Value?.ToString() ?? "4"))" />
                                    <p class="text-sm text-muted" style="margin-top: 0.1rem;">1 = efecto karaoke (palabra por palabra)</p>
                                </div>
                                <div class="ve-color-row">
                                    <div class="inspector-field" style="flex: 1;">
                                        <label>Color linea</label>
                                        <input type="color" value="@GetModuleConfig(sel.Id, "subtitleLineColor", "#FFFFFF")"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "subtitleLineColor", e.Value?.ToString() ?? "#FFFFFF"))" />
                                    </div>
                                    <div class="inspector-field" style="flex: 1;">
                                        <label>Color palabra</label>
                                        <input type="color" value="@GetModuleConfig(sel.Id, "subtitleWordColor", "#FFFF00")"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "subtitleWordColor", e.Value?.ToString() ?? "#FFFF00"))" />
                                    </div>
                                    <div class="inspector-field" style="flex: 1;">
                                        <label>Color fondo</label>
                                        <input type="color" value="@(GetModuleConfig(sel.Id, "subtitleBoxColor", "#000000CC").Length > 7 ? GetModuleConfig(sel.Id, "subtitleBoxColor", "#000000CC")[..7] : GetModuleConfig(sel.Id, "subtitleBoxColor", "#000000"))"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "subtitleBoxColor", (e.Value?.ToString() ?? "#000000") + "CC"))" />
                                    </div>
                                </div>
                                <div class="ve-color-row">
                                    <div class="inspector-field" style="flex: 1;">
                                        <label>Color borde</label>
                                        <input type="color" value="@(GetModuleConfig(sel.Id, "subtitleOutlineColor", "#000000"))"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "subtitleOutlineColor", e.Value?.ToString() ?? "#000000"))" />
                                    </div>
                                    <div class="inspector-field" style="flex: 1;">
                                        <label>Grosor borde</label>
                                        <input type="number" min="0" max="10" step="1"
                                               value="@GetModuleConfig(sel.Id, "subtitleOutlineWidth", "0")"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "subtitleOutlineWidth", e.Value?.ToString() ?? "0"))" />
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @if (sel.ModuleType == "Checkpoint")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Configuracion del Checkpoint</div>
                            <div class="inspector-field">
                                <label>Numero de entradas/salidas</label>
                                <input type="number" min="1" max="10" value="@GetSceneCount(sel.Id)"
                                       @onchange="e => UpdateSceneCount(sel.Id, int.TryParse(e.Value?.ToString(), out var v) ? v : 1)" />
                                <p class="text-sm text-muted" style="margin-top: 0.15rem;">Cada entrada se empareja con una salida del mismo numero. Los datos pasan directamente al continuar.</p>
                            </div>
                        </div>
                    }

                    @if (sel.ModuleType == "Coordinator")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Configuracion del Coordinator</div>
                            <div class="inspector-field">
                                <label>Numero de entradas</label>
                                <input type="number" min="1" max="20" value="@GetSceneCount(sel.Id)"
                                       @onchange="e => UpdateSceneCount(sel.Id, int.TryParse(e.Value?.ToString(), out var v) ? v : 1)" />
                                <p class="text-sm text-muted" style="margin-top: 0.15rem;">Conecta imagenes, textos, audio u otros modulos a cada entrada.</p>
                            </div>
                        </div>
                    }

                    @if (sel.ModuleType == "Publish")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Configuracion de publicacion</div>

                            @if (sel.ModelName != "tiktok")
                            {
                                <div class="inspector-field">
                                    <label>Tipo de publicacion</label>
                                    <select value="@GetModuleConfig(sel.Id, "publishType", "post")"
                                            @onchange="@(e => SetModuleConfig(sel.Id, "publishType", e.Value?.ToString() ?? "post"))">
                                        <option value="post">Post</option>
                                        <option value="reel">Reel</option>
                                        <option value="story">Story</option>
                                    </select>
                                </div>
                            }

                            <div class="inspector-field">
                                <label>Caption <span class="text-sm text-muted">(usa {previous_output} para incluir salida anterior)</span></label>
                                <textarea rows="3" placeholder="{previous_output}"
                                          value="@GetModuleConfig(sel.Id, "caption", "")"
                                          @onchange="@(e => SetModuleConfig(sel.Id, "caption", e.Value?.ToString() ?? ""))"></textarea>
                            </div>

                            @if (sel.ModelName == "tiktok")
                            {
                                <div class="inspector-field">
                                    <label>Privacidad</label>
                                    <select value="@GetModuleConfig(sel.Id, "privacyLevel", "PUBLIC_TO_EVERYONE")"
                                            @onchange="@(e => SetModuleConfig(sel.Id, "privacyLevel", e.Value?.ToString() ?? "PUBLIC_TO_EVERYONE"))">
                                        <option value="PUBLIC_TO_EVERYONE">Publico</option>
                                        <option value="FOLLOWER_OF_CREATOR">Solo seguidores</option>
                                        <option value="MUTUAL_FOLLOW_FRIENDS">Amigos mutuos</option>
                                        <option value="SELF_ONLY">Solo yo</option>
                                    </select>
                                </div>
                                <div class="inspector-field">
                                    <label class="inspector-checkbox">
                                        <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "allowComments", true)"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "allowComments", ((bool)(e.Value ?? true)).ToString().ToLower()))" />
                                        <span>Permitir comentarios</span>
                                    </label>
                                </div>
                                <div class="inspector-field">
                                    <label class="inspector-checkbox">
                                        <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "allowDuet", true)"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "allowDuet", ((bool)(e.Value ?? true)).ToString().ToLower()))" />
                                        <span>Permitir Duet</span>
                                    </label>
                                </div>
                                <div class="inspector-field">
                                    <label class="inspector-checkbox">
                                        <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "allowStitch", true)"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "allowStitch", ((bool)(e.Value ?? true)).ToString().ToLower()))" />
                                        <span>Permitir Stitch</span>
                                    </label>
                                </div>
                                <div class="inspector-field">
                                    <label class="inspector-checkbox">
                                        <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "brandedContent", false)"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "brandedContent", ((bool)(e.Value ?? false)).ToString().ToLower()))" />
                                        <span>Contenido de marca</span>
                                    </label>
                                </div>
                                <div class="inspector-field">
                                    <label class="inspector-checkbox">
                                        <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "brandPartnership", false)"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "brandPartnership", ((bool)(e.Value ?? false)).ToString().ToLower()))" />
                                        <span>Asociacion de marca</span>
                                    </label>
                                </div>
                            }

                            <p class="text-sm text-muted" style="margin-top: 0.15rem;">
                                Las imagenes/videos del paso anterior se adjuntan automaticamente.
                                Buffer publica en el canal configurado. Programacion automatica.
                                @if (sel.ModelName == "tiktok")
                                {
                                    <br/><text>TikTok: soporta videos e imagenes (hasta 4 por post).</text>
                                }
                            </p>
                        </div>
                    }

                    @if (sel.ModuleType == "Orchestrator")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Salidas del orquestador</div>
                            @if (sel.OrchestratorOutputs is { Count: > 0 })
                            {
                                @foreach (var output in sel.OrchestratorOutputs.OrderBy(o => o.SortOrder))
                                {
                                    var oid = output.Id;
                                    var isEditing = _editingOutputId == oid;

                                    @if (isEditing)
                                    {
                                        <div class="orch-output-card orch-output-editing">
                                            <div class="inspector-field" style="margin-bottom: 0.25rem;">
                                                <label>Label</label>
                                                <input @bind="_editLabel" placeholder="Label" />
                                            </div>
                                            <div class="inspector-field" style="margin-bottom: 0.25rem;">
                                                <label>Prompt</label>
                                                <textarea @bind="_editPrompt" rows="3" placeholder="Prompt de esta salida..." style="font-size: 0.75rem;"></textarea>
                                            </div>
                                            <div class="inspector-field" style="margin-bottom: 0.35rem;">
                                                <label>Tipo</label>
                                                <select @bind="_editDataType">
                                                    <option value="text">Texto</option>
                                                    <option value="image">Imagen</option>
                                                    <option value="video">Video</option>
                                                    <option value="audio">Audio</option>
                                                    <option value="file">Archivo</option>
                                                </select>
                                            </div>
                                            <div style="display: flex; gap: 0.3rem;">
                                                <button class="btn btn-xs btn-primary" style="flex: 1;" @onclick="() => SaveOrchestratorOutput(sel, output)">Guardar</button>
                                                <button class="btn btn-xs" style="flex: 1; border: 1px solid var(--border-color);" @onclick="() => _editingOutputId = null">Cancelar</button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="orch-output-card" @onclick="() => StartEditingOutput(output)">
                                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
                                                <strong>@output.Label</strong>
                                                <div style="display: flex; gap: 0.2rem; align-items: center;">
                                                    <span class="orch-type-badge" style="color: @PortDataType.GetColor(output.DataType); border-color: @PortDataType.GetColor(output.DataType);">@PortDataType.GetLabel(output.DataType)</span>
                                                    <button class="btn btn-xs btn-danger" style="padding: 0.1rem 0.3rem; font-size: 0.6rem;" @onclick="() => DeleteOrchestratorOutput(sel, output.Id)" @onclick:stopPropagation="true">X</button>
                                                </div>
                                            </div>
                                            <div class="text-muted orch-prompt-preview">@(string.IsNullOrWhiteSpace(output.Prompt) ? "Sin prompt — click para editar" : output.Prompt)</div>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <p class="text-sm text-muted">No hay salidas configuradas.</p>
                            }
                            <div style="margin-top: 0.3rem;">
                                <div class="inspector-field" style="margin-bottom: 0.2rem;">
                                    <label>Label</label>
                                    <input @bind="_newOutputLabel" placeholder="Ej: Video perro" />
                                </div>
                                <div class="inspector-field" style="margin-bottom: 0.2rem;">
                                    <label>Prompt</label>
                                    <textarea @bind="_newOutputPrompt" rows="2" placeholder="Ej: Busca un video de un perro paseando" style="font-size: 0.75rem;"></textarea>
                                </div>
                                <div class="inspector-field" style="margin-bottom: 0.2rem;">
                                    <label>Tipo de salida</label>
                                    <select @bind="_newOutputDataType">
                                        <option value="text">Texto</option>
                                        <option value="image">Imagen</option>
                                        <option value="video">Video</option>
                                        <option value="audio">Audio</option>
                                        <option value="file">Archivo</option>
                                    </select>
                                </div>
                                <button class="btn btn-xs btn-primary" style="width: 100%;" @onclick="() => AddOrchestratorOutput(sel)">Agregar salida</button>
                            </div>
                        </div>
                    }

                    <div class="inspector-section">
                        <button class="btn btn-xs btn-danger" style="width:100%;" @onclick="() => RequestDeleteNode(sel.Id)">Eliminar nodo</button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="inspector-header"><span>Inspector</span></div>
            <div class="inspector-empty">Selecciona un nodo para ver sus propiedades</div>
        }

        @if (Executing || (ExecutionLogs is { Count: > 0 }))
        {
            <div class="inspector-log">
                <div class="inspector-log-header">
                    <span>Log</span>
                    @if (Executing) { <span class="spinner" style="width: 0.6rem; height: 0.6rem;"></span> }
                </div>
                <div class="inspector-log-entries">
                    @if (ExecutionLogs is not null)
                    {
                        @foreach (var entry in ExecutionLogs.TakeLast(50))
                        {
                            <div class="inspector-log-entry inspector-log-@entry.Level">
                                <span class="inspector-log-time">@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                @if (entry.StepOrder.HasValue)
                                {
                                    var logPm = Modules.FirstOrDefault(m => m.StepOrder == entry.StepOrder.Value);
                                    var logLabel = logPm is not null ? GetStepLabel(logPm) : entry.StepOrder.Value.ToString();
                                    <span class="inspector-log-step">P@(logLabel)</span>
                                }
                                <span>@entry.Message</span>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-error" style="margin-top: 0.5rem;">@_error</div>
}

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public List<ProjectModuleResponse> Modules { get; set; } = [];
    [Parameter] public List<AiModuleResponse> AvailableModules { get; set; } = [];
    [Parameter] public List<ModuleConnectionResponse> Connections { get; set; } = [];
    [Parameter] public RenderFragment? TopPanel { get; set; }
    [Parameter] public EventCallback<Guid> OnAddModule { get; set; }
    [Parameter] public EventCallback<Guid> OnRemoveModule { get; set; }
    [Parameter] public EventCallback<SaveGraphRequest> OnSaveGraph { get; set; }
    [Parameter] public EventCallback<(Guid ModuleId, string InputMapping)> OnInputMappingChanged { get; set; }

    // Execution state from parent
    [Parameter] public bool Executing { get; set; }
    [Parameter] public List<StepExecutionStatus>? StepStatuses { get; set; }
    [Parameter] public List<ExecutionLogEntry>? ExecutionLogs { get; set; }

    // Local mutable copy of connections (modified by JS callbacks)
    private List<ConnectionEntry> _connections = new();
    // Local mutable positions (modified by JS callbacks)
    private Dictionary<Guid, (double X, double Y)> _positions = new();

    private string _canvasId = Guid.NewGuid().ToString("N")[..8];
    private string _searchFilter = "";
    private Guid? _selectedModuleId;
    private string? _error;
    private bool _jsInitialized;
    private CancellationTokenSource? _saveDebounce;
    private DotNetObjectReference<PipelineCanvas>? _dotNetRef;
    private int _lastModuleCount;
    private int _lastConnectionCount;
    private string _lastInputMappingsHash = "";
    private Dictionary<Guid, int> _sceneCountOverrides = new();
    private static readonly string[] _orchestratorModels = [
        "gpt-4o", "gpt-4o-mini", "gpt-4.1", "gpt-4.1-mini", "gpt-4.1-nano",
        "claude-sonnet-4-20250514", "claude-opus-4-20250514", "claude-3-5-haiku-20241022",
        "gemini-2.0-flash", "gemini-2.5-flash", "gemini-2.5-pro",
    ];
    private Dictionary<Guid, Dictionary<string, string>> _moduleConfigs = new();
    private bool _lastExecuting;
    private int _lastLogCount;
    private string? _pendingAutoSelectModuleType;

    // Module panel state
    private bool _showModulePanel;
    private HashSet<string> _expandedCategories = new() { "ai" };

    private record ModuleCategory(string Key, string Icon, string Label, string[] Types);
    private static readonly ModuleCategory[] _moduleCategories =
    [
        new("ai", "bi-cpu", "IA y Texto", ["Text", "Interaction", "Orchestrator"]),
        new("media", "bi-brush", "Generacion", ["Image", "Video", "Audio", "Design"]),
        new("search", "bi-search", "Busqueda y Analisis", ["VideoSearch", "Transcription", "Embeddings"]),
        new("control", "bi-sliders", "Control y Salida", ["VideoEdit", "Checkpoint", "Publish", "Coordinator"]),
    ];

    private void ToggleModulePanel() => _showModulePanel = !_showModulePanel;
    private void CloseModulePanel()
    {
        _showModulePanel = false;
        _searchFilter = "";
    }
    private void ToggleCategory(string key)
    {
        if (!_expandedCategories.Add(key))
            _expandedCategories.Remove(key);
    }

    // Orchestrator output form state
    private string _newOutputLabel = "";
    private string _newOutputPrompt = "";
    private string _newOutputDataType = "text";

    // Orchestrator output editing state
    private Guid? _editingOutputId;
    private string _editLabel = "";
    private string _editPrompt = "";
    private string _editDataType = "text";

    private IEnumerable<AiModuleResponse> FilteredModules => string.IsNullOrWhiteSpace(_searchFilter)
        ? AvailableModules
        : AvailableModules.Where(m =>
            m.Name.Contains(_searchFilter, StringComparison.OrdinalIgnoreCase) ||
            m.ModuleType.Contains(_searchFilter, StringComparison.OrdinalIgnoreCase) ||
            m.ProviderType.Contains(_searchFilter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("pipelineEditor.init", _dotNetRef, $"drawflow-{_canvasId}");
            _jsInitialized = true;
            LoadFromParameters();
            await RebuildDrawflow();
            _lastModuleCount = Modules.Count;
            _lastConnectionCount = Connections.Count;
            _lastInputMappingsHash = string.Join("|", Modules.Select(m => $"{m.Id}:{m.InputMapping}"));
        }
        else if (_jsInitialized)
        {
            var mappingsHash = string.Join("|", Modules.Select(m => $"{m.Id}:{m.InputMapping}"));
            if (Modules.Count != _lastModuleCount || Connections.Count != _lastConnectionCount || mappingsHash != _lastInputMappingsHash)
            {
                Console.WriteLine($"[PipelineCanvas] Rebuild triggered: modules {_lastModuleCount}→{Modules.Count}, conns {_lastConnectionCount}→{Connections.Count}, hashChanged={mappingsHash != _lastInputMappingsHash}");
                // Auto-select newly added module so inspector shows immediately
                // (needed for Orchestrator to configure outputs, VideoEdit to set scene count, etc.)
                if (_pendingAutoSelectModuleType is not null && Modules.Count > _lastModuleCount)
                {
                    var newModule = Modules.OrderByDescending(m => m.StepOrder).FirstOrDefault(m => m.ModuleType == _pendingAutoSelectModuleType);
                    if (newModule is not null)
                        _selectedModuleId = newModule.Id;
                }
                _pendingAutoSelectModuleType = null;

                _lastModuleCount = Modules.Count;
                _lastConnectionCount = Connections.Count;
                _lastInputMappingsHash = mappingsHash;
                LoadFromParameters();
                await RebuildDrawflow();
            }
        }

        // Update execution visualization without full rebuild
        if (_jsInitialized)
        {
            var logCount = ExecutionLogs?.Count ?? 0;
            if (Executing != _lastExecuting || logCount != _lastLogCount)
            {
                _lastExecuting = Executing;
                _lastLogCount = logCount;
                await UpdateExecutionVisualization();
            }
        }
    }

    /// <summary>Load local mutable state from parent parameters.</summary>
    private void LoadFromParameters()
    {
        _positions = Modules.ToDictionary(m => m.Id, m => (m.PosX, m.PosY));
        _connections = Connections.Select(c => new ConnectionEntry(c.FromModuleId,
            MigratePortId(c.FromPort), c.ToModuleId, MigratePortId(c.ToPort))).ToList();
        Console.WriteLine($"[PipelineCanvas] LoadFromParameters: {Modules.Count} modules, {Connections.Count} connections from parent, {_connections.Count} local connections");
    }

    /// <summary>Migrate legacy port IDs to current names.</summary>
    private static string MigratePortId(string portId)
    {
        // input_scene_X_video → input_scene_X_media (renamed in scene port refactor)
        if (portId.StartsWith("input_scene_") && portId.EndsWith("_video"))
            return portId[..^"_video".Length] + "_media";
        return portId;
    }

    private async Task RebuildDrawflow()
    {
        await JS.InvokeVoidAsync("pipelineEditor.setSuppressEvents", true);
        await JS.InvokeVoidAsync("pipelineEditor.clear");

        var execOrder = ComputeExecutionOrder();

        // Add all nodes using positions from DB
        int idx = 0;
        foreach (var pm in Modules)
        {
            var sceneCount = GetSceneCount(pm.Id);
            var ports = ModulePortRegistry.GetPorts(pm.ModuleType, "", sceneCount, pm.InputMapping, pm.OrchestratorOutputs);
            var inputs = ports.Where(p => p.IsInput).Select(p => new {
                id = p.Id, label = p.Label, color = PortDataType.GetColor(p.DataType), required = p.IsRequired, allowMultiple = p.AllowMultiple
            }).ToList();
            var outputs = ports.Where(p => !p.IsInput).Select(p => new {
                id = p.Id, label = p.Label, color = PortDataType.GetColor(p.DataType), required = false
            }).ToList();

            var pos = _positions.GetValueOrDefault(pm.Id, (60 + (idx % 4) * 280, 60 + (idx / 4) * 200));
            var order = execOrder.GetValueOrDefault(pm.Id, 0);
            var stepLabel = order > 0 ? GetStepLabel(pm) : "";

            var warning = pm.ModuleType == "Orchestrator"
                && (pm.OrchestratorOutputs is null || pm.OrchestratorOutputs.Count == 0)
                ? "Sin salidas configuradas"
                : null;

            await JS.InvokeVoidAsync("pipelineEditor.addNode",
                pm.Id.ToString(),
                pm.StepName ?? pm.AiModuleName,
                pm.ModuleType,
                ModulePortRegistry.GetModuleColor(pm.ModuleType),
                ModulePortRegistry.GetModuleIcon(pm.ModuleType),
                JsonSerializer.Serialize(inputs),
                JsonSerializer.Serialize(outputs),
                pos.X, pos.Y,
                stepLabel,
                pm.ModelName,
                warning);
            idx++;
        }

        // Add all connections from DB
        Console.WriteLine($"[PipelineCanvas] RebuildDrawflow: adding {_connections.Count} connections");
        foreach (var conn in _connections)
        {
            Console.WriteLine($"[PipelineCanvas]   conn: {conn.FromPort} → {conn.ToPort}");
            await JS.InvokeVoidAsync("pipelineEditor.addConnection",
                conn.FromModuleId.ToString(), conn.FromPort,
                conn.ToModuleId.ToString(), conn.ToPort);
        }

        await JS.InvokeVoidAsync("pipelineEditor.setSuppressEvents", false);

        await Task.Delay(100);
        await JS.InvokeVoidAsync("pipelineEditor.refreshConnections");

        // Apply execution states if currently executing
        if (Executing || StepStatuses is { Count: > 0 })
            await UpdateExecutionVisualization();
    }

    /// <summary>Compute topological execution order from connections (1-based).</summary>
    private Dictionary<Guid, int> ComputeExecutionOrder()
    {
        var moduleIds = Modules.Select(m => m.Id).ToHashSet();
        var inDegree = moduleIds.ToDictionary(id => id, _ => 0);
        var adj = moduleIds.ToDictionary(id => id, _ => new List<Guid>());

        foreach (var conn in _connections)
        {
            if (moduleIds.Contains(conn.FromModuleId) && moduleIds.Contains(conn.ToModuleId))
            {
                adj[conn.FromModuleId].Add(conn.ToModuleId);
                inDegree[conn.ToModuleId]++;
            }
        }

        // Kahn's algorithm (topological sort)
        var queue = new Queue<Guid>(inDegree.Where(kv => kv.Value == 0).Select(kv => kv.Key));
        var order = new Dictionary<Guid, int>();
        int step = 1;

        while (queue.Count > 0)
        {
            var node = queue.Dequeue();
            order[node] = step++;
            foreach (var next in adj[node])
            {
                inDegree[next]--;
                if (inDegree[next] == 0) queue.Enqueue(next);
            }
        }

        // Nodes in cycles or disconnected get 0
        return order;
    }

    /// <summary>Update node/connection visual states based on execution progress.</summary>
    private async Task UpdateExecutionVisualization()
    {
        if (!_jsInitialized) return;

        if (!Executing && (StepStatuses is null || StepStatuses.Count == 0))
        {
            await JS.InvokeVoidAsync("pipelineEditor.clearAllStates");
            return;
        }

        if (StepStatuses is null) return;

        // Map projectModuleId → status
        var statusMap = StepStatuses.ToDictionary(s => s.ProjectModuleId, s => s.Status);
        Guid? runningModuleId = null;

        foreach (var pm in Modules)
        {
            var status = statusMap.GetValueOrDefault(pm.Id, "idle");
            var state = status switch
            {
                "Running" => "running",
                "Completed" => "completed",
                "Failed" => "failed",
                "WaitingForCheckpoint" => "waiting",
                "WaitingForReview" => "waiting",
                _ => "idle"
            };
            await JS.InvokeVoidAsync("pipelineEditor.setNodeState", pm.Id.ToString(), state);
            if (state == "running") runningModuleId = pm.Id;
        }

        // Animate the connection FROM the running node to the next
        // First clear all connection states, then set the active one
        foreach (var conn in _connections)
        {
            var isActive = runningModuleId.HasValue && conn.FromModuleId == runningModuleId.Value;
            if (isActive)
                await JS.InvokeVoidAsync("pipelineEditor.setConnectionState", conn.FromModuleId.ToString(), conn.ToModuleId.ToString(), "active");
        }
    }

    // ── Helpers ──

    private int GetSceneCount(Guid moduleId)
    {
        if (_sceneCountOverrides.TryGetValue(moduleId, out var count))
            return Math.Max(1, count);

        // Load from persisted Configuration if not overridden
        var module = Modules.FirstOrDefault(m => m.Id == moduleId);
        if (module?.Configuration is not null)
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(module.Configuration);
                // VideoEdit: sceneCount; Image: n or numberOfImages
                foreach (var key in new[] { "sceneCount", "n", "numberOfImages" })
                {
                    if (doc.RootElement.TryGetProperty(key, out var sc) && sc.ValueKind == System.Text.Json.JsonValueKind.Number)
                    {
                        var persisted = sc.GetInt32();
                        _sceneCountOverrides[moduleId] = persisted;
                        return Math.Max(1, persisted);
                    }
                }
            }
            catch { /* ignore */ }
        }

        return 1;
    }

    // ── Generic module config helpers ──

    private string GetModuleConfig(Guid moduleId, string key, string fallback = "")
    {
        if (_moduleConfigs.TryGetValue(moduleId, out var dict) && dict.TryGetValue(key, out var val))
            return val;

        // Load from persisted Configuration JSON
        var module = Modules.FirstOrDefault(m => m.Id == moduleId);
        if (module?.Configuration is not null)
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(module.Configuration);
                if (doc.RootElement.TryGetProperty(key, out var prop))
                {
                    var persisted = prop.ValueKind switch
                    {
                        System.Text.Json.JsonValueKind.True => "true",
                        System.Text.Json.JsonValueKind.False => "false",
                        System.Text.Json.JsonValueKind.Number => prop.GetRawText(),
                        _ => prop.GetString() ?? fallback
                    };
                    if (!_moduleConfigs.ContainsKey(moduleId))
                        _moduleConfigs[moduleId] = new();
                    _moduleConfigs[moduleId][key] = persisted;
                    return persisted;
                }
            }
            catch { /* ignore */ }
        }

        return fallback;
    }

    private string GetOrchestratorModel(ProjectModuleResponse sel)
    {
        var val = GetModuleConfig(sel.Id, "modelName", "");
        return string.IsNullOrEmpty(val) ? "" : val;
    }

    private bool GetModuleConfigBool(Guid moduleId, string key, bool fallback = false)
    {
        var val = GetModuleConfig(moduleId, key, "");
        if (string.IsNullOrEmpty(val)) return fallback;
        return val.Equals("true", StringComparison.OrdinalIgnoreCase);
    }

    private async Task SetModuleConfig(Guid moduleId, string key, string value)
    {
        if (!_moduleConfigs.ContainsKey(moduleId))
            _moduleConfigs[moduleId] = new();
        _moduleConfigs[moduleId][key] = value;
        await AutoSaveGraph();
    }

