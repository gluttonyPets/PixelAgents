    private void PrettyPrintFormat()
    {
        if (_formatEditor is null || !_formatEditor.IsValid) return;
        var draft = (_formatEditor.Draft ?? "").Trim();
        if (string.IsNullOrEmpty(draft)) return;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(draft);
            _formatEditor.Draft = System.Text.Json.JsonSerializer.Serialize(doc.RootElement,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            ValidateFormatDraft();
        }
        catch { /* validator already reported the error */ }
    }

