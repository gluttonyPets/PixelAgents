    /// <summary>
    /// Recompute IsValid / Error / ShapeSummary from the current Draft. Empty
    /// draft is considered valid (it means "remove the contract on save").
    /// </summary>
    private void ValidateFormatDraft()
    {
        if (_formatEditor is null) return;
        var draft = (_formatEditor.Draft ?? "").Trim();
        if (string.IsNullOrEmpty(draft))
        {
            _formatEditor.IsValid = true;
            _formatEditor.Error = null;
            _formatEditor.ShapeSummary = null;
            return;
        }
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(draft);
            _formatEditor.IsValid = true;
            _formatEditor.Error = null;
            _formatEditor.ShapeSummary = BuildShapeSummary(doc.RootElement, depth: 0);
        }
        catch (System.Text.Json.JsonException jex)
        {
            _formatEditor.IsValid = false;
            _formatEditor.ShapeSummary = null;
            // BytePositionInLine is 0-based, surface 1-based for the user.
            var col = jex.BytePositionInLine.HasValue ? jex.BytePositionInLine.Value + 1 : (long?)null;
            var line = jex.LineNumber.HasValue ? jex.LineNumber.Value + 1 : (long?)null;
            var loc = (line, col) switch
            {
                (long l, long c) => $"linea {l}, columna {c}",
                (long l, null)   => $"linea {l}",
                _ => "posicion desconocida",
            };
            _formatEditor.Error = $"JSON invalido en {loc}: {jex.Message}";
        }
        catch (Exception ex)
        {
            _formatEditor.IsValid = false;
            _formatEditor.ShapeSummary = null;
            _formatEditor.Error = $"JSON invalido: {ex.Message}";
        }
    }

    /// <summary>
    /// Recursive structural description: enumerates keys/types up to depth 3
    /// so the user can see the shape of the contract at a glance without
    /// needing to read the full JSON.
    /// </summary>
    private static string BuildShapeSummary(System.Text.Json.JsonElement el, int depth)
    {
        switch (el.ValueKind)
        {
            case System.Text.Json.JsonValueKind.Object:
                var props = el.EnumerateObject().ToList();
                if (depth >= 3 || props.Count == 0)
                    return $"objeto({props.Count})";
                var fields = props.Take(6).Select(p =>
                    $"{p.Name}: {BuildShapeSummary(p.Value, depth + 1)}");
                var tail = props.Count > 6 ? ", ..." : "";
                return $"objeto · {string.Join(", ", fields)}{tail}";

            case System.Text.Json.JsonValueKind.Array:
                var arr = el.EnumerateArray().ToList();
                if (arr.Count == 0) return "array(0)";
                if (depth >= 3) return $"array({arr.Count})";
                var firstKind = arr[0].ValueKind;
                var allSame = arr.All(x => x.ValueKind == firstKind);
                if (!allSame) return $"array({arr.Count}) mixto";
                var inner = BuildShapeSummary(arr[0], depth + 1);
                return $"array({arr.Count}) de {inner}";

            case System.Text.Json.JsonValueKind.String: return "string";
            case System.Text.Json.JsonValueKind.Number: return "number";
            case System.Text.Json.JsonValueKind.True:
            case System.Text.Json.JsonValueKind.False: return "boolean";
            case System.Text.Json.JsonValueKind.Null:  return "null";
            default: return "valor";
        }
    }

    private async Task ApplyFormatEdit(string? newFormat)
    {
        if (_formatEditor is null) return;

        var fromId = _formatEditor.FromModuleId;
        var fromPort = _formatEditor.FromPort;
        var toId = _formatEditor.ToModuleId;
        var toPort = _formatEditor.ToPort;

        for (int i = 0; i < _connections.Count; i++)
        {
            var c = _connections[i];
            if (c.FromModuleId == fromId && c.FromPort == fromPort &&
                c.ToModuleId == toId && c.ToPort == toPort)
            {
                _connections[i] = c with { Format = newFormat };
                break;
            }
        }

        _formatEditor = null;
        await AutoSaveGraph();
        await RefreshConnectionFormatBadges();
        StateHasChanged();
    }

