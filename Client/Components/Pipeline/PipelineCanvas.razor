@using Client.Models
@using Client.Services
@using System.Text.Json
@inject IJSRuntime JS
@inject ApiClient Api

<div class="pipeline-editor-container">
    <!-- ── Left: Module palette ── -->
    <div class="pipeline-palette">
        <div class="palette-header">Modulos</div>
        <div class="palette-search">
            <input type="text" placeholder="Buscar modulo..." @bind="_searchFilter" @bind:event="oninput" />
        </div>
        <div class="palette-list">
            @foreach (var m in FilteredModules)
            {
                <div class="palette-item" @onclick="() => AddNodeFromPalette(m)">
                    <div class="palette-item-icon" style="background: @ModulePortRegistry.GetModuleColor(m.ModuleType);">
                        @ModulePortRegistry.GetModuleIcon(m.ModuleType)
                    </div>
                    <div class="palette-item-info">
                        <div class="palette-item-name">@m.Name</div>
                        <div class="palette-item-type">@m.ProviderType / @m.ModuleType</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ── Center: Drawflow canvas ── -->
    <div class="pipeline-canvas-wrapper">
        <div id="drawflow-@_canvasId" class="drawflow-container"></div>

        <!-- Toolbar -->
        <div class="canvas-toolbar">
            <button @onclick="AutoLayout" title="Organizar automaticamente">&#x2B50; Auto-layout</button>
        </div>

        @if (Modules.Count == 0 && _jsInitialized)
        {
            <div class="canvas-empty-overlay">
                <span class="canvas-empty-state-icon">&#x1F9E9;</span>
                <p>Pipeline vacio</p>
                <p class="text-sm">Haz clic en un modulo del panel izquierdo para agregarlo</p>
            </div>
        }
    </div>

    <!-- ── Right: Execute + Inspector ── -->
    <div class="pipeline-inspector">
        @if (TopPanel is not null)
        {
            <div class="inspector-top-panel">
                @TopPanel
            </div>
        }
        @if (_selectedModuleId.HasValue)
        {
            var sel = Modules.FirstOrDefault(m => m.Id == _selectedModuleId);
            if (sel is not null)
            {
                <div class="inspector-header">
                    <span>@(sel.StepName ?? sel.AiModuleName)</span>
                    <button class="node-btn" @onclick="DeselectNode">&#x2715;</button>
                </div>
                <div class="inspector-body">
                    <div class="inspector-section">
                        <div class="inspector-section-title">Informacion</div>
                        <div class="inspector-field">
                            <label>Modulo</label>
                            <input type="text" value="@sel.AiModuleName" readonly />
                        </div>
                        <div class="inspector-field">
                            <label>Tipo</label>
                            <input type="text" value="@sel.ModuleType" readonly />
                        </div>
                        <div class="inspector-field">
                            <label>Modelo</label>
                            <input type="text" value="@sel.ModelName" readonly />
                        </div>
                    </div>

                    <div class="inspector-section">
                        <div class="inspector-section-title">Conexiones</div>
                        @{
                            var ports = ModulePortRegistry.GetPorts(sel.ModuleType, "", GetSceneCount(sel.Id), sel.InputMapping, sel.OrchestratorOutputs);
                            var inputPorts = ports.Where(p => p.IsInput).ToList();
                            var outputPorts = ports.Where(p => !p.IsInput).ToList();
                        }
                        @if (inputPorts.Any())
                        {
                            <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.2rem;">Entradas:</p>
                            @foreach (var port in inputPorts)
                            {
                                var conn = _connections.FirstOrDefault(c => c.ToModuleId == sel.Id && c.ToPort == port.Id);
                                <div style="font-size: 0.75rem; padding: 0.15rem 0; display: flex; align-items: center; gap: 0.3rem; flex-wrap: wrap;">
                                    <span style="color: @PortDataType.GetColor(port.DataType);">&#x25CF;</span>
                                    <span>@port.Label</span>
                                    <span class="port-type-badge" style="background: @PortDataType.GetColor(port.DataType); color: #fff; padding: 0 0.3rem; border-radius: 3px; font-size: 0.65rem;">@PortDataType.GetLabel(port.DataType)</span>
                                    @if (conn is not null)
                                    {
                                        var capturedInputConn = conn;
                                        var fromModule = Modules.FirstOrDefault(m => m.Id == conn.FromModuleId);
                                        var fromPorts = fromModule is not null ? ModulePortRegistry.GetPorts(fromModule.ModuleType, "", GetSceneCount(fromModule.Id), fromModule.InputMapping, fromModule.OrchestratorOutputs) : new();
                                        var fromPort = fromPorts.FirstOrDefault(p => p.Id == conn.FromPort);
                                        <span class="text-muted">&#x2190; @(fromModule?.StepName ?? fromModule?.AiModuleName ?? "?")</span>
                                        @if (fromPort is not null)
                                        {
                                            <span class="port-type-badge" style="background: @PortDataType.GetColor(fromPort.DataType); color: #fff; padding: 0 0.3rem; border-radius: 3px; font-size: 0.65rem;">@PortDataType.GetLabel(fromPort.DataType)</span>
                                        }
                                        <button style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:0.7rem;padding:0 0.2rem;line-height:1;opacity:0.6;" @onclick="() => RemoveConnection(capturedInputConn)" title="Quitar conexion">&#x2715;</button>
                                    }
                                    else
                                    {
                                        <span class="text-muted" style="font-style:italic;">sin conectar</span>
                                    }
                                </div>
                            }
                        }
                        @if (outputPorts.Any())
                        {
                            <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.3rem; margin-bottom: 0.2rem;">Salidas:</p>
                            @foreach (var port in outputPorts)
                            {
                                var conns = _connections.Where(c => c.FromModuleId == sel.Id && c.FromPort == port.Id).ToList();
                                <div style="font-size: 0.75rem; padding: 0.15rem 0; display: flex; align-items: center; gap: 0.3rem; flex-wrap: wrap;">
                                    <span style="color: @PortDataType.GetColor(port.DataType);">&#x25CF;</span>
                                    <span>@port.Label</span>
                                    <span class="port-type-badge" style="background: @PortDataType.GetColor(port.DataType); color: #fff; padding: 0 0.3rem; border-radius: 3px; font-size: 0.65rem;">@PortDataType.GetLabel(port.DataType)</span>
                                    @if (conns.Any())
                                    {
                                        @foreach (var c in conns)
                                        {
                                            var capturedOutputConn = c;
                                            var toModule = Modules.FirstOrDefault(m => m.Id == c.ToModuleId);
                                            var toPorts = toModule is not null ? ModulePortRegistry.GetPorts(toModule.ModuleType, "", GetSceneCount(toModule.Id), toModule.InputMapping, toModule.OrchestratorOutputs) : new();
                                            var toPort = toPorts.FirstOrDefault(p => p.Id == c.ToPort);
                                            <span class="text-muted">&#x2192; @(toModule?.StepName ?? toModule?.AiModuleName ?? "?")</span>
                                            @if (toPort is not null)
                                            {
                                                <span class="port-type-badge" style="background: @PortDataType.GetColor(toPort.DataType); color: #fff; padding: 0 0.3rem; border-radius: 3px; font-size: 0.65rem;">@PortDataType.GetLabel(toPort.DataType)</span>
                                            }
                                            <button style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:0.7rem;padding:0 0.2rem;line-height:1;opacity:0.6;" @onclick="() => RemoveConnection(capturedOutputConn)" title="Quitar conexion">&#x2715;</button>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted" style="font-style:italic;">sin conectar</span>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <!-- Input mapping editor -->
                    <div class="inspector-section">
                        <div class="inspector-section-title">Entrada de datos</div>
                        <div class="inspector-field">
                            <label>Fuente de datos</label>
                            <select value="@(sel.InputMapping ?? "{\"source\":\"user\"}")"
                                    @onchange="e => HandleInputMappingChange(sel.Id, e.Value?.ToString())">
                                <option value='{"source":"user"}'>Entrada del usuario</option>
                                <option value='{"source":"previous","field":"text"}'>Paso anterior (texto)</option>
                                <option value='{"source":"previous","field":"file"}'>Paso anterior (archivo)</option>
                            </select>
                            <p class="text-sm text-muted" style="margin-top: 0.2rem;">
                                Tipo actual: <strong>@FormatInputMapping(sel.InputMapping)</strong>
                            </p>
                        </div>
                    </div>

                    @if (sel.ModuleType == "VideoEdit")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Escenas Json2Video</div>
                            <div class="inspector-field">
                                <label>Numero de escenas</label>
                                <input type="number" min="1" max="10" value="@GetSceneCount(sel.Id)"
                                       @onchange="e => UpdateSceneCount(sel.Id, int.TryParse(e.Value?.ToString(), out var v) ? v : 1)" />
                            </div>
                            <p class="text-sm text-muted">Cada escena crea puertos de video y guion que puedes conectar a otros modulos.</p>
                        </div>
                    }

                    @if (sel.ModuleType == "Orchestrator")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Salidas del orquestador</div>
                            @if (sel.OrchestratorOutputs is { Count: > 0 })
                            {
                                @foreach (var output in sel.OrchestratorOutputs.OrderBy(o => o.SortOrder))
                                {
                                    <div class="orchestrator-output-card" style="border: 1px solid var(--border-color); border-radius: 0.3rem; padding: 0.4rem; margin-bottom: 0.4rem; font-size: 0.75rem;">
                                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.3rem;">
                                            <strong>@output.Label</strong>
                                            <button class="btn btn-xs btn-danger" style="padding: 0.1rem 0.3rem; font-size: 0.65rem;" @onclick="() => DeleteOrchestratorOutput(sel, output.Id)">X</button>
                                        </div>
                                        <div class="text-muted" style="font-size: 0.7rem; margin-bottom: 0.2rem;">@output.Prompt</div>
                                        @if (output.TargetModuleName is not null)
                                        {
                                            <div style="font-size: 0.7rem;">Modulo: <strong>@output.TargetModuleName</strong> (@output.TargetModuleType)</div>
                                        }
                                        else
                                        {
                                            <div style="font-size: 0.7rem; color: var(--text-muted);">Sin modulo destino</div>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-sm text-muted">No hay salidas configuradas.</p>
                            }
                            <div style="margin-top: 0.3rem;">
                                <div class="inspector-field" style="margin-bottom: 0.2rem;">
                                    <label>Label</label>
                                    <input @bind="_newOutputLabel" placeholder="Ej: Video perro" />
                                </div>
                                <div class="inspector-field" style="margin-bottom: 0.2rem;">
                                    <label>Prompt</label>
                                    <textarea @bind="_newOutputPrompt" rows="2" placeholder="Ej: Busca un video de un perro paseando" style="font-size: 0.75rem;"></textarea>
                                </div>
                                <div class="inspector-field" style="margin-bottom: 0.2rem;">
                                    <label>Modulo destino</label>
                                    <select @bind="_newOutputTargetModuleId">
                                        <option value="">-- Ninguno --</option>
                                        @foreach (var m in AvailableModules.Where(m => m.ModuleType != "Orchestrator" && m.ModuleType != "Interaction" && m.ModuleType != "Publish"))
                                        {
                                            <option value="@m.Id">@m.Name (@m.ModuleType)</option>
                                        }
                                    </select>
                                </div>
                                <button class="btn btn-xs btn-primary" style="width: 100%;" @onclick="() => AddOrchestratorOutput(sel)">Agregar salida</button>
                            </div>
                        </div>
                    }

                    <div class="inspector-section">
                        <button class="btn btn-xs btn-danger" style="width:100%;" @onclick="() => RequestDeleteNode(sel.Id)">Eliminar nodo</button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="inspector-header"><span>Inspector</span></div>
            <div class="inspector-empty">Selecciona un nodo para ver sus propiedades</div>
        }

        @if (Executing || (ExecutionLogs is { Count: > 0 }))
        {
            <div class="inspector-log">
                <div class="inspector-log-header">
                    <span>Log</span>
                    @if (Executing) { <span class="spinner" style="width: 0.6rem; height: 0.6rem;"></span> }
                </div>
                <div class="inspector-log-entries">
                    @if (ExecutionLogs is not null)
                    {
                        @foreach (var entry in ExecutionLogs.TakeLast(50))
                        {
                            <div class="inspector-log-entry inspector-log-@entry.Level">
                                <span class="inspector-log-time">@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                @if (entry.StepOrder.HasValue)
                                {
                                    var logPm = Modules.FirstOrDefault(m => m.StepOrder == entry.StepOrder.Value);
                                    var logLabel = logPm is not null ? GetStepLabel(logPm) : entry.StepOrder.Value.ToString();
                                    <span class="inspector-log-step">P@(logLabel)</span>
                                }
                                <span>@entry.Message</span>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-error" style="margin-top: 0.5rem;">@_error</div>
}

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public List<ProjectModuleResponse> Modules { get; set; } = [];
    [Parameter] public List<AiModuleResponse> AvailableModules { get; set; } = [];
    [Parameter] public List<ModuleConnectionResponse> Connections { get; set; } = [];
    [Parameter] public RenderFragment? TopPanel { get; set; }
    [Parameter] public EventCallback<Guid> OnAddModule { get; set; }
    [Parameter] public EventCallback<Guid> OnRemoveModule { get; set; }
    [Parameter] public EventCallback<SaveGraphRequest> OnSaveGraph { get; set; }
    [Parameter] public EventCallback<(Guid ModuleId, string InputMapping)> OnInputMappingChanged { get; set; }

    // Execution state from parent
    [Parameter] public bool Executing { get; set; }
    [Parameter] public List<StepExecutionStatus>? StepStatuses { get; set; }
    [Parameter] public List<ExecutionLogEntry>? ExecutionLogs { get; set; }

    // Local mutable copy of connections (modified by JS callbacks)
    private List<ConnectionEntry> _connections = new();
    // Local mutable positions (modified by JS callbacks)
    private Dictionary<Guid, (double X, double Y)> _positions = new();

    private string _canvasId = Guid.NewGuid().ToString("N")[..8];
    private string _searchFilter = "";
    private Guid? _selectedModuleId;
    private string? _error;
    private bool _jsInitialized;
    private CancellationTokenSource? _saveDebounce;
    private DotNetObjectReference<PipelineCanvas>? _dotNetRef;
    private int _lastModuleCount;
    private int _lastConnectionCount;
    private string _lastInputMappingsHash = "";
    private Dictionary<Guid, int> _sceneCountOverrides = new();
    private bool _lastExecuting;
    private int _lastLogCount;

    // Orchestrator output form state
    private string _newOutputLabel = "";
    private string _newOutputPrompt = "";
    private string _newOutputTargetModuleId = "";

    private IEnumerable<AiModuleResponse> FilteredModules => string.IsNullOrWhiteSpace(_searchFilter)
        ? AvailableModules
        : AvailableModules.Where(m =>
            m.Name.Contains(_searchFilter, StringComparison.OrdinalIgnoreCase) ||
            m.ModuleType.Contains(_searchFilter, StringComparison.OrdinalIgnoreCase) ||
            m.ProviderType.Contains(_searchFilter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("pipelineEditor.init", _dotNetRef, $"drawflow-{_canvasId}");
            _jsInitialized = true;
            LoadFromParameters();
            await RebuildDrawflow();
            _lastModuleCount = Modules.Count;
            _lastConnectionCount = Connections.Count;
        }
        else if (_jsInitialized)
        {
            var mappingsHash = string.Join("|", Modules.Select(m => $"{m.Id}:{m.InputMapping}"));
            if (Modules.Count != _lastModuleCount || Connections.Count != _lastConnectionCount || mappingsHash != _lastInputMappingsHash)
            {
                _lastModuleCount = Modules.Count;
                _lastConnectionCount = Connections.Count;
                _lastInputMappingsHash = mappingsHash;
                LoadFromParameters();
                await RebuildDrawflow();
            }
        }

        // Update execution visualization without full rebuild
        if (_jsInitialized)
        {
            var logCount = ExecutionLogs?.Count ?? 0;
            if (Executing != _lastExecuting || logCount != _lastLogCount)
            {
                _lastExecuting = Executing;
                _lastLogCount = logCount;
                await UpdateExecutionVisualization();
            }
        }
    }

    /// <summary>Load local mutable state from parent parameters.</summary>
    private void LoadFromParameters()
    {
        _positions = Modules.ToDictionary(m => m.Id, m => (m.PosX, m.PosY));
        _connections = Connections.Select(c => new ConnectionEntry(c.FromModuleId, c.FromPort, c.ToModuleId, c.ToPort)).ToList();
        Console.WriteLine($"[PipelineCanvas] LoadFromParameters: {Modules.Count} modules, {Connections.Count} connections from parent, {_connections.Count} local connections");
    }

    private async Task RebuildDrawflow()
    {
        await JS.InvokeVoidAsync("pipelineEditor.setSuppressEvents", true);
        await JS.InvokeVoidAsync("pipelineEditor.clear");

        var execOrder = ComputeExecutionOrder();

        // Add all nodes using positions from DB
        int idx = 0;
        foreach (var pm in Modules)
        {
            var sceneCount = GetSceneCount(pm.Id);
            var ports = ModulePortRegistry.GetPorts(pm.ModuleType, "", sceneCount, pm.InputMapping, pm.OrchestratorOutputs);
            var inputs = ports.Where(p => p.IsInput).Select(p => new {
                id = p.Id, label = p.Label, color = PortDataType.GetColor(p.DataType), required = p.IsRequired
            }).ToList();
            var outputs = ports.Where(p => !p.IsInput).Select(p => new {
                id = p.Id, label = p.Label, color = PortDataType.GetColor(p.DataType), required = false
            }).ToList();

            var pos = _positions.GetValueOrDefault(pm.Id, (60 + (idx % 4) * 280, 60 + (idx / 4) * 200));
            var order = execOrder.GetValueOrDefault(pm.Id, 0);
            var stepLabel = order > 0 ? GetStepLabel(pm) : "";

            await JS.InvokeVoidAsync("pipelineEditor.addNode",
                pm.Id.ToString(),
                pm.StepName ?? pm.AiModuleName,
                pm.ModuleType,
                ModulePortRegistry.GetModuleColor(pm.ModuleType),
                ModulePortRegistry.GetModuleIcon(pm.ModuleType),
                JsonSerializer.Serialize(inputs),
                JsonSerializer.Serialize(outputs),
                pos.X, pos.Y,
                stepLabel,
                pm.ModelName);
            idx++;
        }

        // Add all connections from DB
        foreach (var conn in _connections)
        {
            await JS.InvokeVoidAsync("pipelineEditor.addConnection",
                conn.FromModuleId.ToString(), conn.FromPort,
                conn.ToModuleId.ToString(), conn.ToPort);
        }

        await JS.InvokeVoidAsync("pipelineEditor.setSuppressEvents", false);

        await Task.Delay(100);
        await JS.InvokeVoidAsync("pipelineEditor.refreshConnections");

        // Apply execution states if currently executing
        if (Executing || StepStatuses is { Count: > 0 })
            await UpdateExecutionVisualization();
    }

    /// <summary>Compute topological execution order from connections (1-based).</summary>
    private Dictionary<Guid, int> ComputeExecutionOrder()
    {
        var moduleIds = Modules.Select(m => m.Id).ToHashSet();
        var inDegree = moduleIds.ToDictionary(id => id, _ => 0);
        var adj = moduleIds.ToDictionary(id => id, _ => new List<Guid>());

        foreach (var conn in _connections)
        {
            if (moduleIds.Contains(conn.FromModuleId) && moduleIds.Contains(conn.ToModuleId))
            {
                adj[conn.FromModuleId].Add(conn.ToModuleId);
                inDegree[conn.ToModuleId]++;
            }
        }

        // Kahn's algorithm (topological sort)
        var queue = new Queue<Guid>(inDegree.Where(kv => kv.Value == 0).Select(kv => kv.Key));
        var order = new Dictionary<Guid, int>();
        int step = 1;

        while (queue.Count > 0)
        {
            var node = queue.Dequeue();
            order[node] = step++;
            foreach (var next in adj[node])
            {
                inDegree[next]--;
                if (inDegree[next] == 0) queue.Enqueue(next);
            }
        }

        // Nodes in cycles or disconnected get 0
        return order;
    }

    /// <summary>Update node/connection visual states based on execution progress.</summary>
    private async Task UpdateExecutionVisualization()
    {
        if (!_jsInitialized) return;

        if (!Executing && (StepStatuses is null || StepStatuses.Count == 0))
        {
            await JS.InvokeVoidAsync("pipelineEditor.clearAllStates");
            return;
        }

        if (StepStatuses is null) return;

        // Map projectModuleId → status
        var statusMap = StepStatuses.ToDictionary(s => s.ProjectModuleId, s => s.Status);
        Guid? runningModuleId = null;

        foreach (var pm in Modules)
        {
            var status = statusMap.GetValueOrDefault(pm.Id, "idle");
            var state = status switch
            {
                "Running" => "running",
                "Completed" => "completed",
                "Failed" => "failed",
                _ => "idle"
            };
            await JS.InvokeVoidAsync("pipelineEditor.setNodeState", pm.Id.ToString(), state);
            if (state == "running") runningModuleId = pm.Id;
        }

        // Animate the connection FROM the running node to the next
        // First clear all connection states, then set the active one
        foreach (var conn in _connections)
        {
            var isActive = runningModuleId.HasValue && conn.FromModuleId == runningModuleId.Value;
            if (isActive)
                await JS.InvokeVoidAsync("pipelineEditor.setConnectionState", conn.FromModuleId.ToString(), conn.ToModuleId.ToString(), "active");
        }
    }

    // ── Helpers ──

    private int GetSceneCount(Guid moduleId)
    {
        if (_sceneCountOverrides.TryGetValue(moduleId, out var count))
            return Math.Max(1, count);
        return 1;
    }

    // ── Actions ──

    private async Task AddNodeFromPalette(AiModuleResponse module)
    {
        await OnAddModule.InvokeAsync(module.Id);
    }

    private void DeselectNode()
    {
        _selectedModuleId = null;
    }

    private async Task RequestDeleteNode(Guid id)
    {
        _connections.RemoveAll(c => c.FromModuleId == id || c.ToModuleId == id);
        _positions.Remove(id);
        if (_selectedModuleId == id) _selectedModuleId = null;
        await JS.InvokeVoidAsync("pipelineEditor.removeNodeByModuleId", id.ToString());
        await OnRemoveModule.InvokeAsync(id);
        await NotifyGraphChanged();
    }

    private async Task AddOrchestratorOutput(ProjectModuleResponse module)
    {
        if (string.IsNullOrWhiteSpace(_newOutputLabel)) return;

        Guid? targetId = Guid.TryParse(_newOutputTargetModuleId, out var tid) ? tid : null;
        var sortOrder = (module.OrchestratorOutputs?.Count ?? 0) + 1;

        var (output, error) = await Api.CreateOrchestratorOutputAsync(
            ProjectId, module.Id,
            new OrchestratorOutputRequest(_newOutputLabel, _newOutputPrompt, sortOrder, targetId));

        if (output is not null)
        {
            // Update local state
            var outputs = module.OrchestratorOutputs?.ToList() ?? new();
            outputs.Add(output);
            // Replace module in the list with updated outputs (records are immutable)
            var idx = Modules.FindIndex(m => m.Id == module.Id);
            if (idx >= 0)
            {
                Modules[idx] = module with { OrchestratorOutputs = outputs };
            }

            _newOutputLabel = "";
            _newOutputPrompt = "";
            _newOutputTargetModuleId = "";

            // Rebuild node to show new ports
            await RebuildDrawflow();
        }
        else
        {
            _error = error ?? "Error al crear salida";
        }
        StateHasChanged();
    }

    private async Task DeleteOrchestratorOutput(ProjectModuleResponse module, Guid outputId)
    {
        var (ok, error) = await Api.DeleteOrchestratorOutputAsync(ProjectId, module.Id, outputId);
        if (ok)
        {
            var outputs = module.OrchestratorOutputs?.Where(o => o.Id != outputId).ToList() ?? new();
            var idx = Modules.FindIndex(m => m.Id == module.Id);
            if (idx >= 0)
            {
                Modules[idx] = module with { OrchestratorOutputs = outputs };
            }
            await RebuildDrawflow();
        }
        else
        {
            _error = error ?? "Error al eliminar salida";
        }
        StateHasChanged();
    }

    private async Task UpdateSceneCount(Guid moduleId, int count)
    {
        _sceneCountOverrides[moduleId] = count;

        var module = Modules.FirstOrDefault(m => m.Id == moduleId);
        if (module is not null)
        {
            var validPorts = ModulePortRegistry.GetPorts(module.ModuleType, "", count, module.InputMapping, module.OrchestratorOutputs).Select(p => p.Id).ToHashSet();
            _connections.RemoveAll(c =>
                (c.FromModuleId == moduleId && !validPorts.Contains(c.FromPort)) ||
                (c.ToModuleId == moduleId && !validPorts.Contains(c.ToPort)));
        }

        await NotifyGraphChanged();
        await RebuildDrawflow();
    }

    private async Task AutoLayout()
    {
        var moduleIds = Modules.Select(m => m.Id).ToList();
        var depths = new Dictionary<Guid, int>();
        foreach (var id in moduleIds) depths[id] = 0;

        bool changed = true;
        while (changed)
        {
            changed = false;
            foreach (var conn in _connections)
            {
                if (depths.ContainsKey(conn.FromModuleId) && depths.ContainsKey(conn.ToModuleId))
                {
                    var newDepth = depths[conn.FromModuleId] + 1;
                    if (newDepth > depths[conn.ToModuleId])
                    {
                        depths[conn.ToModuleId] = newDepth;
                        changed = true;
                    }
                }
            }
        }

        var groups = moduleIds.GroupBy(id => depths.GetValueOrDefault(id, 0)).OrderBy(g => g.Key).ToList();
        for (int col = 0; col < groups.Count; col++)
        {
            var group = groups[col].ToList();
            for (int row = 0; row < group.Count; row++)
            {
                var x = 60 + col * 300;
                var y = 60 + row * 200;
                _positions[group[row]] = (x, y);
                await JS.InvokeVoidAsync("pipelineEditor.updateNodePosition", group[row].ToString(), (double)x, (double)y);
            }
        }

        await NotifyGraphChanged();
        StateHasChanged();
    }

    private async Task AutoSaveGraph()
    {
        _error = null;
        var positions = _positions.Select(p => new NodePositionEntry(p.Key, p.Value.X, p.Value.Y)).ToList();
        var req = new SaveGraphRequest(positions, _connections);
        await OnSaveGraph.InvokeAsync(req);
    }

    // ── JS Callbacks ──

    [JSInvokable]
    public async Task OnNodeMoved(string moduleId, double x, double y)
    {
        if (!Guid.TryParse(moduleId, out var id)) return;
        _positions[id] = (x, y);
        await NotifyGraphChanged();
    }

    [JSInvokable]
    public async Task OnConnectionMade(string fromModuleId, string fromPort, string toModuleId, string toPort)
    {
        if (!Guid.TryParse(fromModuleId, out var fromId) || !Guid.TryParse(toModuleId, out var toId))
            return;

        // Validate compatibility
        var fromModule = Modules.FirstOrDefault(m => m.Id == fromId);
        var toModule = Modules.FirstOrDefault(m => m.Id == toId);
        if (fromModule is null || toModule is null) return;

        var fromPorts = ModulePortRegistry.GetPorts(fromModule.ModuleType, "", GetSceneCount(fromId), fromModule.InputMapping);
        var toPorts = ModulePortRegistry.GetPorts(toModule.ModuleType, "", GetSceneCount(toId), toModule.InputMapping);
        var fromPortDef = fromPorts.FirstOrDefault(p => p.Id == fromPort && !p.IsInput);
        var toPortDef = toPorts.FirstOrDefault(p => p.Id == toPort && p.IsInput);
        if (fromPortDef is null || toPortDef is null) return;

        if (!PortDataType.AreCompatible(fromPortDef.DataType, toPortDef.DataType))
        {
            _error = $"Tipos incompatibles: {PortDataType.GetLabel(fromPortDef.DataType)} -> {PortDataType.GetLabel(toPortDef.DataType)}";
            await InvokeAsync(StateHasChanged);
            _ = ClearErrorAfterDelay();
            await JS.InvokeVoidAsync("pipelineEditor.removeConnection",
                fromModuleId, fromPort, toModuleId, toPort);
            return;
        }

        // Remove existing connection to same input port
        _connections.RemoveAll(c => c.ToModuleId == toId && c.ToPort == toPort);

        if (!_connections.Any(c => c.FromModuleId == fromId && c.FromPort == fromPort && c.ToModuleId == toId && c.ToPort == toPort))
        {
            _connections.Add(new ConnectionEntry(fromId, fromPort, toId, toPort));
        }

        await NotifyGraphChanged();
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnConnectionRemoved(string fromModuleId, string fromPort, string toModuleId, string toPort)
    {
        if (!Guid.TryParse(fromModuleId, out var fromId) || !Guid.TryParse(toModuleId, out var toId))
            return;

        _connections.RemoveAll(c =>
            c.FromModuleId == fromId && c.FromPort == fromPort &&
            c.ToModuleId == toId && c.ToPort == toPort);

        await NotifyGraphChanged();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RemoveConnection(ConnectionEntry conn)
    {
        _connections.RemoveAll(c =>
            c.FromModuleId == conn.FromModuleId && c.FromPort == conn.FromPort &&
            c.ToModuleId == conn.ToModuleId && c.ToPort == conn.ToPort);

        await JS.InvokeVoidAsync("pipelineEditor.removeConnection",
            conn.FromModuleId.ToString(), conn.FromPort,
            conn.ToModuleId.ToString(), conn.ToPort);

        await NotifyGraphChanged();
        StateHasChanged();
    }

