@using Client.Models
@using Client.Services
@using System.Text.Json
@inject IJSRuntime JS
@inject ApiClient Api

<div class="pipeline-editor-container">
    <!-- ── Center: Drawflow canvas (now full width) ── -->
    <div class="pipeline-canvas-wrapper">
        <div id="drawflow-@_canvasId" class="drawflow-container"></div>

        <!-- Toolbar -->
        <div class="canvas-toolbar">
            <button class="toolbar-btn toolbar-btn-primary" @onclick="ToggleModulePanel" title="Agregar modulo">
                <span class="toolbar-btn-icon">&#x2795;</span> Modulo
            </button>
        </div>

        <!-- Floating module selector panel -->
        @if (_showModulePanel)
        {
            <div class="module-panel-backdrop" @onclick="CloseModulePanel"></div>
            <div class="module-panel">
                <div class="module-panel-header">
                    <span>Agregar modulo</span>
                    <button class="node-btn" @onclick="CloseModulePanel">&#x2715;</button>
                </div>
                <div class="module-panel-search">
                    <input type="text" placeholder="Buscar modulo..." @bind="_searchFilter" @bind:event="oninput" />
                </div>
                <div class="module-panel-body">
                    @if (string.IsNullOrWhiteSpace(_searchFilter))
                    {
                        @foreach (var category in _moduleCategories)
                        {
                            var modulesInCategory = AvailableModules.Where(m => category.Types.Contains(m.ModuleType)).ToList();
                            if (modulesInCategory.Count == 0) continue;

                            <div class="module-category">
                                <button class="module-category-header" @onclick="() => ToggleCategory(category.Key)">
                                    <span class="module-category-icon"><i class="bi @category.Icon"></i></span>
                                    <span class="module-category-label">@category.Label</span>
                                    <span class="module-category-count">@modulesInCategory.Count</span>
                                    <span class="module-category-chevron @(_expandedCategories.Contains(category.Key) ? "expanded" : "")">&#x25B6;</span>
                                </button>
                                @if (_expandedCategories.Contains(category.Key))
                                {
                                    <div class="module-category-items">
                                        @foreach (var m in modulesInCategory)
                                        {
                                            <div class="palette-item" @onclick="() => AddNodeFromPalette(m)">
                                                <div class="palette-item-icon" style="background: @ModulePortRegistry.GetModuleColor(m.ModuleType);">
                                                    <i class="bi @ModulePortRegistry.GetModuleIcon(m.ModuleType)"></i>
                                                </div>
                                                <div class="palette-item-info">
                                                    <div class="palette-item-name">@m.Name</div>
                                                    <div class="palette-item-type">
                                                        <ProviderIcon Provider="@m.ProviderType" Size="12" />&nbsp;@m.ProviderType
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }


                    }
                    else
                    {
                        <div class="module-category-items">
                            @foreach (var m in FilteredModules)
                            {
                                <div class="palette-item" @onclick="() => AddNodeFromPalette(m)">
                                    <div class="palette-item-icon" style="background: @ModulePortRegistry.GetModuleColor(m.ModuleType);">
                                        @ModulePortRegistry.GetModuleIcon(m.ModuleType)
                                    </div>
                                    <div class="palette-item-info">
                                        <div class="palette-item-name">@m.Name</div>
                                        <div class="palette-item-type">
                                            <ProviderIcon Provider="@m.ProviderType" Size="12" />&nbsp;@m.ProviderType / @m.ModuleType
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @if (Modules.Count == 0 && _jsInitialized)
        {
            <div class="canvas-empty-overlay">
                <span class="canvas-empty-state-icon">&#x1F9E9;</span>
                <p>Pipeline vacio</p>
                <p class="text-sm">Pulsa <strong>+ Modulo</strong> para empezar a construir tu pipeline</p>
            </div>
        }
    </div>


    <!-- ── Right: Execute + Inspector ── -->
    <div class="pipeline-inspector">
        @if (TopPanel is not null)
        {
            <div class="inspector-top-panel">
                @TopPanel
            </div>
        }
        @if (_selectedModuleId.HasValue)
        {
            var sel = Modules.FirstOrDefault(m => m.Id == _selectedModuleId);
            if (sel is not null)
            {
                <div class="inspector-header">
                    <span>@(sel.StepName ?? sel.AiModuleName)</span>
                    <button class="node-btn" @onclick="DeselectNode">&#x2715;</button>
                </div>
                <div class="inspector-body">
                    <div class="inspector-section">
                        <div class="inspector-section-title">Informacion</div>
                        <div class="inspector-field">
                            <label>Modulo</label>
                            <input type="text" value="@sel.AiModuleName" readonly />
                        </div>
                        <div class="inspector-field">
                            <label>Tipo</label>
                            <input type="text" value="@sel.ModuleType" readonly />
                        </div>
                        <div class="inspector-field">
                            <label>Modelo</label>
                            @if (sel.ModuleType == "Orchestrator")
                            {
                                <select value="@GetOrchestratorModel(sel)"
                                        @onchange="@(e => SetModuleConfig(sel.Id, "modelName", e.Value?.ToString() ?? ""))">
                                    <option value="">@sel.ModelName (por defecto)</option>
                                    @foreach (var m in _orchestratorModels.Where(m => m != sel.ModelName))
                                    {
                                        <option value="@m">@m</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="text" value="@sel.ModelName" readonly />
                            }
                        </div>
                    </div>

                    <div class="inspector-section">
                        <div class="inspector-field">
                            <label style="display: flex; align-items: center; gap: 0.4rem; cursor: pointer;">
                                <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "skipped", false)"
                                       @onchange="@(e => ToggleSkipped(sel.Id, (bool)(e.Value ?? false)))" />
                                Saltar este paso
                            </label>
                            <p class="text-sm text-muted" style="margin-top: 0.15rem;">Si se activa, este paso se omitira durante la ejecucion del pipeline.</p>
                        </div>
                    </div>

                    <div class="inspector-section">
                        <div class="inspector-section-title">Conexiones</div>
                        @{
                            var ports = ModulePortRegistry.GetPorts(sel.ModuleType, "", GetSceneCount(sel.Id), sel.OrchestratorOutputs, GetTemplateVars(sel.Id), sel.ModelName);
                            var inputPorts = ports.Where(p => p.IsInput).ToList();
                            var outputPorts = ports.Where(p => !p.IsInput).ToList();
                        }
                        @if (inputPorts.Any())
                        {
                            <div class="inspector-port-section">
                                <div class="inspector-port-section-label">
                                    <i class="bi bi-arrow-right-circle"></i> Entradas
                                </div>
                                @foreach (var port in inputPorts)
                                {
                                    var portConns = _connections.Where(c => c.ToModuleId == sel.Id && c.ToPort == port.Id).ToList();
                                    <div class="inspector-port-item">
                                        <div class="inspector-port-header">
                                            <span class="inspector-port-dot" style="background: @PortDataType.GetColor(port.DataType);"></span>
                                            <span class="inspector-port-name">@port.Label</span>
                                            <span class="inspector-port-type-badge" style="background: @(PortDataType.GetColor(port.DataType))22; color: @PortDataType.GetColor(port.DataType); border: 1px solid @(PortDataType.GetColor(port.DataType))44;">@PortDataType.GetLabel(port.DataType)</span>
                                            @if (port.AllowMultiple)
                                            {
                                                <span class="inspector-port-multi-badge" title="Acepta multiples conexiones">N</span>
                                            }
                                            @if (port.IsRequired)
                                            {
                                                <span style="color: var(--danger); font-size: 0.6rem; font-weight: 700;">*</span>
                                            }
                                        </div>
                                        @if (portConns.Count > 0)
                                        {
                                            @foreach (var conn in portConns)
                                            {
                                                var capturedInputConn = conn;
                                                var fromModule = Modules.FirstOrDefault(m => m.Id == conn.FromModuleId);
                                                var fromPortsList = fromModule is not null ? ModulePortRegistry.GetPorts(fromModule.ModuleType, "", GetSceneCount(fromModule.Id), fromModule.OrchestratorOutputs, GetTemplateVars(fromModule.Id), fromModule.ModelName) : new();
                                                var fromPort = fromPortsList.FirstOrDefault(p => p.Id == conn.FromPort);
                                                <div class="inspector-port-connection">
                                                    <span class="inspector-port-conn-arrow">&#x2190;</span>
                                                    <span class="inspector-port-conn-source">@(fromModule?.StepName ?? fromModule?.AiModuleName ?? "?")</span>
                                                    @if (fromPort is not null)
                                                    {
                                                        <span class="inspector-port-type-badge" style="background: @(PortDataType.GetColor(fromPort.DataType))22; color: @PortDataType.GetColor(fromPort.DataType); border: 1px solid @(PortDataType.GetColor(fromPort.DataType))44;">@fromPort.Label</span>
                                                    }
                                                    <button class="inspector-port-remove-btn" @onclick="() => RemoveConnection(capturedInputConn)" title="Quitar conexion">&#x2715;</button>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="inspector-port-empty">sin conectar</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        @if (outputPorts.Any())
                        {
                            <div class="inspector-port-section" style="margin-top: 0.4rem;">
                                <div class="inspector-port-section-label">
                                    <i class="bi bi-arrow-left-circle"></i> Salidas
                                </div>
                                @foreach (var port in outputPorts)
                                {
                                    var outConns = _connections.Where(c => c.FromModuleId == sel.Id && c.FromPort == port.Id).ToList();
                                    <div class="inspector-port-item">
                                        <div class="inspector-port-header">
                                            <span class="inspector-port-dot" style="background: @PortDataType.GetColor(port.DataType);"></span>
                                            <span class="inspector-port-name">@port.Label</span>
                                            <span class="inspector-port-type-badge" style="background: @(PortDataType.GetColor(port.DataType))22; color: @PortDataType.GetColor(port.DataType); border: 1px solid @(PortDataType.GetColor(port.DataType))44;">@PortDataType.GetLabel(port.DataType)</span>
                                            @if (outConns.Count > 0)
                                            {
                                                <span class="inspector-port-count-badge">@outConns.Count</span>
                                            }
                                        </div>
                                        @if (outConns.Count > 0)
                                        {
                                            @foreach (var c in outConns)
                                            {
                                                var capturedOutputConn = c;
                                                var toModule = Modules.FirstOrDefault(m => m.Id == c.ToModuleId);
                                                var toPortsList = toModule is not null ? ModulePortRegistry.GetPorts(toModule.ModuleType, "", GetSceneCount(toModule.Id), toModule.OrchestratorOutputs, GetTemplateVars(toModule.Id), toModule.ModelName) : new();
                                                var toPort = toPortsList.FirstOrDefault(p => p.Id == c.ToPort);
                                                <div class="inspector-port-connection">
                                                    <span class="inspector-port-conn-arrow">&#x2192;</span>
                                                    <span class="inspector-port-conn-source">@(toModule?.StepName ?? toModule?.AiModuleName ?? "?")</span>
                                                    @if (toPort is not null)
                                                    {
                                                        <span class="inspector-port-type-badge" style="background: @(PortDataType.GetColor(toPort.DataType))22; color: @PortDataType.GetColor(toPort.DataType); border: 1px solid @(PortDataType.GetColor(toPort.DataType))44;">@toPort.Label</span>
                                                    }
                                                    <button class="inspector-port-remove-btn" @onclick="() => RemoveConnection(capturedOutputConn)" title="Quitar conexion">&#x2715;</button>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="inspector-port-empty">sin conectar</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @{
                        var activeRules = GetActiveRules(sel);
                    }
                    @if (activeRules.Count > 0)
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">
                                <i class="bi bi-shield-check" style="color: var(--success); margin-right: 0.3rem;"></i>
                                Reglas activas <span class="tab-count">@activeRules.Count</span>
                            </div>
                            <p class="text-sm text-muted" style="margin-top: -0.2rem; margin-bottom: 0.4rem;">
                                Estas reglas se inyectan automaticamente al prompt de este modulo.
                            </p>
                            @foreach (var group in activeRules.GroupBy(r => r.Category))
                            {
                                <div class="inspector-rules-group">
                                    <div class="inspector-rules-group-title">@group.Key</div>
                                    @foreach (var r in group)
                                    {
                                        <details class="inspector-rule-item">
                                            <summary>
                                                <span class="inspector-rule-title">@r.Title</span>
                                                <span class="inspector-rule-desc">@r.Description</span>
                                            </summary>
                                            @if (!string.IsNullOrWhiteSpace(r.Body))
                                            {
                                                <pre class="inspector-rule-body">@r.Body</pre>
                                            }
                                        </details>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (sel.ModuleType == "Image")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Salidas</div>
                            <div class="inspector-field">
                                <label>Numero de imagenes</label>
                                <input type="number" min="1" max="20"
                                       value="@GetSceneCount(sel.Id)"
                                       @onchange="@(e => OnImageCountChange(sel.Id, e))" />
                                <p class="text-sm text-muted" style="margin-top: 0.15rem;">Cada imagen tendra su propia salida. El resto de ajustes (instrucciones, prompt, tamaño...) estan en "Editar nodo".</p>
                            </div>
                        </div>
                    }

                    @if (sel.ModuleType == "Scene")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Campos de la escena</div>
                            <p class="text-sm text-muted" style="margin-bottom: 0.4rem;">
                                Define los campos y sus valores. Si un campo tiene un puerto conectado, el valor conectado tiene prioridad.
                            </p>
                            @{
                                var sceneFields = GetTemplateVars(sel.Id) ?? new List<TemplateVariable>();
                            }
                            @if (sceneFields.Count > 0)
                            {
                                @foreach (var f in sceneFields)
                                {
                                    var capturedFieldName = f.Name;
                                    var configKey = $"fv_{f.Name}";
                                    <div style="border: 1px solid var(--border); border-radius: 0.3rem; padding: 0.3rem 0.4rem; margin-bottom: 0.3rem;">
                                        <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.2rem;">
                                            <span style="font-family: monospace; font-size: 0.78rem; flex: 1; font-weight: 600;">@f.Name</span>
                                            <span style="background: @(f.Type == "file" ? "#607d8b" : "#6c63ff"); color: #fff; padding: 0.05rem 0.3rem; border-radius: 0.2rem; font-size: 0.65rem;">
                                                @(f.Type == "file" ? "Archivo" : "Texto")
                                            </span>
                                            <button type="button" title="Eliminar"
                                                    @onclick="async () => await RemoveTemplateVar(sel.Id, capturedFieldName)"
                                                    style="color: #f44336; background: none; border: none; cursor: pointer; font-size: 0.8rem; padding: 0;">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                        @if (f.Type == "file")
                                        {
                                            <input type="text" value="@GetModuleConfig(sel.Id, configKey, "")"
                                                   placeholder="URL del archivo..."
                                                   @onchange="@(e => SetModuleConfig(sel.Id, configKey, e.Value?.ToString() ?? ""))"
                                                   style="width: 100%; font-size: 0.78rem; padding: 0.15rem 0.3rem;" />
                                        }
                                        else
                                        {
                                            <input type="text" value="@GetModuleConfig(sel.Id, configKey, "")"
                                                   placeholder="Valor..."
                                                   @onchange="@(e => SetModuleConfig(sel.Id, configKey, e.Value?.ToString() ?? ""))"
                                                   style="width: 100%; font-size: 0.78rem; padding: 0.15rem 0.3rem;" />
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-sm text-muted" style="font-style: italic;">Sin campos. Anade campos para crear puertos de entrada.</p>
                            }
                            <div style="display: flex; align-items: flex-end; gap: 0.3rem; margin-top: 0.4rem;">
                                <div style="flex: 2;">
                                    <label style="font-size: 0.72rem;">Nombre</label>
                                    <input type="text" @bind="_sceneNewFieldName" placeholder="ej: question, voiceover..."
                                           style="font-size: 0.8rem; padding: 0.2rem 0.4rem;" />
                                </div>
                                <div style="flex: 1;">
                                    <label style="font-size: 0.72rem;">Tipo</label>
                                    <select @bind="_sceneNewFieldType" style="font-size: 0.8rem; padding: 0.2rem 0.3rem;">
                                        <option value="text">Texto</option>
                                        <option value="file">Archivo</option>
                                    </select>
                                </div>
                                <button type="button" class="btn btn-sm"
                                        style="font-size: 0.75rem; padding: 0.2rem 0.5rem; white-space: nowrap;"
                                        disabled="@string.IsNullOrWhiteSpace(_sceneNewFieldName)"
                                        @onclick="async () => await AddTemplateVar(sel.Id, _sceneNewFieldName.Trim(), _sceneNewFieldType)">
                                    <i class="bi bi-plus-lg"></i> Anadir
                                </button>
                            </div>
                        </div>
                    }

                    @if (sel.ModuleType == "Checkpoint")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Configuracion del Checkpoint</div>
                            <div class="inspector-field">
                                <label>Numero de entradas/salidas</label>
                                <input type="number" min="1" max="10" value="@GetSceneCount(sel.Id)"
                                       @onchange="e => UpdateSceneCount(sel.Id, int.TryParse(e.Value?.ToString(), out var v) ? v : 1)" />
                                <p class="text-sm text-muted" style="margin-top: 0.15rem;">Cada entrada se empareja con una salida del mismo numero. Los datos pasan directamente al continuar.</p>
                            </div>
                        </div>
                    }

                    @if (sel.ModuleType == "Coordinator")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Configuracion del Coordinator</div>
                            <div class="inspector-field">
                                <label>Numero de entradas</label>
                                <input type="number" min="1" max="20" value="@GetSceneCount(sel.Id)"
                                       @onchange="e => UpdateSceneCount(sel.Id, int.TryParse(e.Value?.ToString(), out var v) ? v : 1)" />
                                <p class="text-sm text-muted" style="margin-top: 0.15rem;">Conecta imagenes, textos, audio u otros modulos a cada entrada.</p>
                            </div>
                        </div>
                    }

                    @if (sel.ModuleType == "FileUpload")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Archivos del modulo</div>
                            <p class="text-sm text-muted" style="margin-bottom: 0.4rem;">
                                Sube archivos (imagenes, audio, video, documentos) que se proporcionaran como recurso al pipeline.
                                Gestiona los archivos desde la pagina de <a href="/modules">Modulos</a>.
                            </p>

                            @if (_fileUploadFiles.Count > 0)
                            {
                                <div style="display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 0.4rem;">
                                    @foreach (var f in _fileUploadFiles)
                                    {
                                        <div style="display: flex; align-items: center; gap: 0.4rem; background: var(--bg); border: 1px solid var(--border); border-radius: 4px; padding: 0.25rem 0.4rem; font-size: 0.75rem;">
                                            <i class="bi @GetFileIcon(f.ContentType)" style="color: var(--text-muted);"></i>
                                            <span style="flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@f.FileName">@f.FileName</span>
                                            <span class="text-muted">@FormatFileSize(f.FileSize)</span>
                                            <button class="node-btn" style="font-size: 0.7rem; color: #e53935;" title="Eliminar"
                                                    @onclick="() => DeleteFileUploadFile(f.Id)" @onclick:stopPropagation>&#x2715;</button>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div style="text-align: center; padding: 0.6rem; color: var(--text-muted); font-size: 0.78rem; border: 1px dashed var(--border); border-radius: 4px; margin-bottom: 0.4rem;">
                                    Sin archivos adjuntos
                                </div>
                            }

                            <InputFile OnChange="OnFileUploadFilesSelected" multiple accept="*/*" />

                            @if (_fileUploadUploading)
                            {
                                <p class="text-sm text-muted" style="margin-top: 0.2rem;">Subiendo archivos...</p>
                            }
                            @if (_fileUploadError is not null)
                            {
                                <div class="alert alert-error" style="font-size: 0.75rem; margin-top: 0.2rem;">@_fileUploadError</div>
                            }
                        </div>
                    }

                    @if (sel.ModuleType == "Publish")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Configuracion de publicacion</div>

                            <p class="text-sm text-muted" style="margin-bottom:0.5rem;">
                                <i class="bi bi-info-circle"></i>
                                La publicacion se realiza a traves de Buffer. Elige el canal de destino;
                                las credenciales de Buffer (API Key y Channel ID) de cada red se configuran
                                en los ajustes del proyecto.
                            </p>

                            <div class="inspector-field">
                                <label>Red social (canal de Buffer)</label>
                                <select value="@GetModuleConfig(sel.Id, "provider", "instagram")"
                                        @onchange="@(e => SetModuleConfig(sel.Id, "provider", e.Value?.ToString() ?? "instagram"))">
                                    <option value="instagram">Instagram</option>
                                    <option value="tiktok">TikTok</option>
                                    <option value="pinterest">Pinterest</option>
                                    <option value="threads">Threads</option>
                                </select>
                            </div>

                            @if (GetModuleConfig(sel.Id, "provider", "instagram") != "tiktok")
                            {
                                <div class="inspector-field">
                                    <label>Tipo de publicacion</label>
                                    <select value="@GetModuleConfig(sel.Id, "publishType", "post")"
                                            @onchange="@(e => SetModuleConfig(sel.Id, "publishType", e.Value?.ToString() ?? "post"))">
                                        <option value="post">Post</option>
                                        <option value="reel">Reel</option>
                                        <option value="story">Story</option>
                                    </select>
                                </div>
                            }

                            <div class="inspector-field">
                                <label>Caption <span class="text-sm text-muted">(usa {previous_output} para incluir salida anterior)</span></label>
                                <textarea rows="3" placeholder="{previous_output}"
                                          value="@GetModuleConfig(sel.Id, "caption", "")"
                                          @onchange="@(e => SetModuleConfig(sel.Id, "caption", e.Value?.ToString() ?? ""))"></textarea>
                            </div>

                            @if (GetModuleConfig(sel.Id, "provider", "instagram") == "tiktok")
                            {
                                <div class="inspector-field">
                                    <label>Privacidad</label>
                                    <select value="@GetModuleConfig(sel.Id, "privacyLevel", "PUBLIC_TO_EVERYONE")"
                                            @onchange="@(e => SetModuleConfig(sel.Id, "privacyLevel", e.Value?.ToString() ?? "PUBLIC_TO_EVERYONE"))">
                                        <option value="PUBLIC_TO_EVERYONE">Publico</option>
                                        <option value="FOLLOWER_OF_CREATOR">Solo seguidores</option>
                                        <option value="MUTUAL_FOLLOW_FRIENDS">Amigos mutuos</option>
                                        <option value="SELF_ONLY">Solo yo</option>
                                    </select>
                                </div>
                                <div class="inspector-field">
                                    <label class="inspector-checkbox">
                                        <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "allowComments", true)"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "allowComments", ((bool)(e.Value ?? true)).ToString().ToLower()))" />
                                        <span>Permitir comentarios</span>
                                    </label>
                                </div>
                                <div class="inspector-field">
                                    <label class="inspector-checkbox">
                                        <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "allowDuet", true)"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "allowDuet", ((bool)(e.Value ?? true)).ToString().ToLower()))" />
                                        <span>Permitir Duet</span>
                                    </label>
                                </div>
                                <div class="inspector-field">
                                    <label class="inspector-checkbox">
                                        <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "allowStitch", true)"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "allowStitch", ((bool)(e.Value ?? true)).ToString().ToLower()))" />
                                        <span>Permitir Stitch</span>
                                    </label>
                                </div>
                                <div class="inspector-field">
                                    <label class="inspector-checkbox">
                                        <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "brandedContent", false)"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "brandedContent", ((bool)(e.Value ?? false)).ToString().ToLower()))" />
                                        <span>Contenido de marca</span>
                                    </label>
                                </div>
                                <div class="inspector-field">
                                    <label class="inspector-checkbox">
                                        <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "brandPartnership", false)"
                                               @onchange="@(e => SetModuleConfig(sel.Id, "brandPartnership", ((bool)(e.Value ?? false)).ToString().ToLower()))" />
                                        <span>Asociacion de marca</span>
                                    </label>
                                </div>
                            }

                            @if (GetModuleConfig(sel.Id, "provider", "instagram") == "pinterest")
                            {
                                <div class="inspector-field">
                                    <label>Nombre del tablero <span class="text-sm text-muted">(opcional)</span></label>
                                    <input type="text"
                                           value="@GetModuleConfig(sel.Id, "boardName", "")"
                                           @onchange="@(e => SetModuleConfig(sel.Id, "boardName", e.Value?.ToString() ?? ""))"
                                           placeholder="Ej: Mi tablero de recetas" />
                                </div>
                                <div class="inspector-field">
                                    <label>Enlace destino <span class="text-sm text-muted">(opcional)</span></label>
                                    <input type="url"
                                           value="@GetModuleConfig(sel.Id, "link", "")"
                                           @onchange="@(e => SetModuleConfig(sel.Id, "link", e.Value?.ToString() ?? ""))"
                                           placeholder="https://..." />
                                </div>
                            }
                        </div>
                    }

                    @if (sel.ModuleType == "ShopifyBlog")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Articulo de blog (Shopify)</div>

                            <p class="text-sm text-muted" style="margin-bottom:0.5rem;">
                                <i class="bi bi-info-circle"></i>
                                La tienda se elige asignando una conexion de Shopify en los ajustes del proyecto.
                                El titulo y el cuerpo del articulo vienen del modulo conectado a la entrada.
                                Si ese modulo emite un JSON con el formato de la plantilla de la conexion
                                (titulo, cuerpo, extracto, slug, seo_titulo, seo_descripcion), el nodo reparte
                                cada campo automaticamente. Los valores de abajo solo hacen falta para forzar/sobreescribir.
                            </p>

                            <div class="inspector-field">
                                <label>Blog destino</label>
                                @if (_shopifyBlogs.Count > 0)
                                {
                                    <select value="@GetModuleConfig(sel.Id, "blogId", "")"
                                            @onchange="@(e => OnShopifyBlogChanged(sel.Id, e.Value?.ToString() ?? ""))">
                                        <option value="">-- Seleccionar blog --</option>
                                        @foreach (var b in _shopifyBlogs)
                                        {
                                            <option value="@b.Id">@b.Title</option>
                                        }
                                    </select>
                                }
                                else if (!string.IsNullOrEmpty(GetModuleConfig(sel.Id, "blogTitle", "")))
                                {
                                    <div class="text-muted">Actual: @GetModuleConfig(sel.Id, "blogTitle", "")</div>
                                }
                                <button class="btn btn-outline btn-sm" style="margin-top:0.4rem;"
                                        @onclick="LoadShopifyBlogs" disabled="@_loadingShopifyBlogs">
                                    @(_loadingShopifyBlogs ? "Cargando..." : "Cargar blogs")
                                </button>
                                @if (_shopifyBlogsError is not null)
                                {
                                    <div class="alert alert-error" style="margin-top:0.4rem;">@_shopifyBlogsError</div>
                                }
                            </div>

                            <div class="inspector-field">
                                <label>Autor <span class="text-sm text-muted">(opcional, por defecto "Equipo")</span></label>
                                <input type="text" value="@GetModuleConfig(sel.Id, "author", "")"
                                       @onchange="@(e => SetModuleConfig(sel.Id, "author", e.Value?.ToString() ?? ""))"
                                       placeholder="Ej: Equipo de marketing" />
                            </div>

                            <div class="inspector-field">
                                <label>Tags <span class="text-sm text-muted">(separados por comas, opcional)</span></label>
                                <input type="text" value="@GetModuleConfig(sel.Id, "tags", "")"
                                       @onchange="@(e => SetModuleConfig(sel.Id, "tags", e.Value?.ToString() ?? ""))"
                                       placeholder="novedades, recetas" />
                            </div>

                            <div class="inspector-field">
                                <label>Extracto <span class="text-sm text-muted">(opcional, si se deja vacio se genera del contenido)</span></label>
                                <textarea rows="2" value="@GetModuleConfig(sel.Id, "excerpt", "")"
                                          @onchange="@(e => SetModuleConfig(sel.Id, "excerpt", e.Value?.ToString() ?? ""))"
                                          placeholder="Resumen breve del articulo"></textarea>
                            </div>

                            <div class="inspector-field">
                                <label>Identificador URL <span class="text-sm text-muted">(slug, opcional; por defecto se genera del titulo)</span></label>
                                <input type="text" value="@GetModuleConfig(sel.Id, "handle", "")"
                                       @onchange="@(e => SetModuleConfig(sel.Id, "handle", e.Value?.ToString() ?? ""))"
                                       placeholder="mi-articulo-de-blog" />
                            </div>

                            <div class="inspector-field">
                                <label>Titulo de la pagina (SEO) <span class="text-sm text-muted">(opcional, por defecto el titulo)</span></label>
                                <input type="text" value="@GetModuleConfig(sel.Id, "seoTitle", "")"
                                       @onchange="@(e => SetModuleConfig(sel.Id, "seoTitle", e.Value?.ToString() ?? ""))"
                                       placeholder="Titulo que aparece en buscadores" />
                            </div>

                            <div class="inspector-field">
                                <label>Metadescripcion (SEO) <span class="text-sm text-muted">(opcional, ~155 caracteres; si se deja vacia se genera)</span></label>
                                <textarea rows="2" value="@GetModuleConfig(sel.Id, "metaDescription", "")"
                                          @onchange="@(e => SetModuleConfig(sel.Id, "metaDescription", e.Value?.ToString() ?? ""))"
                                          placeholder="Descripcion breve para los resultados de busqueda"></textarea>
                            </div>

                            <div class="inspector-field">
                                <label class="inspector-checkbox">
                                    <input type="checkbox" checked="@GetModuleConfigBool(sel.Id, "published", false)"
                                           @onchange="@(e => SetModuleConfig(sel.Id, "published", ((bool)(e.Value ?? false)).ToString().ToLower()))" />
                                    <span>Publicar (si no, se guarda como borrador)</span>
                                </label>
                            </div>
                        </div>
                    }

                    @if (sel.ModuleType == "Orchestrator")
                    {
                        <div class="inspector-section">
                            <div class="inspector-section-title">Salidas del orquestador</div>
                            @if (sel.OrchestratorOutputs is { Count: > 0 })
                            {
                                @foreach (var output in sel.OrchestratorOutputs.OrderBy(o => o.SortOrder))
                                {
                                    var oid = output.Id;
                                    var isEditing = _editingOutputId == oid;

                                    @if (isEditing)
                                    {
                                        <div class="orch-output-card orch-output-editing">
                                            <div class="inspector-field" style="margin-bottom: 0.25rem;">
                                                <label>Label</label>
                                                <input @bind="_editLabel" placeholder="Label" />
                                            </div>
                                            <div class="inspector-field" style="margin-bottom: 0.25rem;">
                                                <label>Prompt</label>
                                                <textarea @bind="_editPrompt" rows="3" placeholder="Prompt de esta salida..." style="font-size: 0.75rem;"></textarea>
                                            </div>
                                            <div class="inspector-field" style="margin-bottom: 0.35rem;">
                                                <label>Tipo</label>
                                                <select @bind="_editDataType">
                                                    <option value="text">Texto</option>
                                                    <option value="image">Imagen</option>
                                                    <option value="video">Video</option>
                                                    <option value="audio">Audio</option>
                                                    <option value="file">Archivo</option>
                                                </select>
                                            </div>
                                            <div style="display: flex; gap: 0.3rem;">
                                                <button class="btn btn-xs btn-primary" style="flex: 1;" @onclick="() => SaveOrchestratorOutput(sel, output)">Guardar</button>
                                                <button class="btn btn-xs" style="flex: 1; border: 1px solid var(--border-color);" @onclick="() => _editingOutputId = null">Cancelar</button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="orch-output-card" @onclick="() => StartEditingOutput(output)">
                                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
                                                <strong>@output.Label</strong>
                                                <div style="display: flex; gap: 0.2rem; align-items: center;">
                                                    <span class="orch-type-badge" style="color: @PortDataType.GetColor(output.DataType); border-color: @PortDataType.GetColor(output.DataType);">@PortDataType.GetLabel(output.DataType)</span>
                                                    <button class="btn btn-xs btn-danger" style="padding: 0.1rem 0.3rem; font-size: 0.6rem;" @onclick="() => DeleteOrchestratorOutput(sel, output.Id)" @onclick:stopPropagation="true">X</button>
                                                </div>
                                            </div>
                                            <div class="text-muted orch-prompt-preview">@(string.IsNullOrWhiteSpace(output.Prompt) ? "Sin prompt — click para editar" : output.Prompt)</div>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <p class="text-sm text-muted">No hay salidas configuradas.</p>
                            }
                            <div style="margin-top: 0.3rem;">
                                <div class="inspector-field" style="margin-bottom: 0.2rem;">
                                    <label>Label</label>
                                    <input @bind="_newOutputLabel" placeholder="Ej: Video perro" />
                                </div>
                                <div class="inspector-field" style="margin-bottom: 0.2rem;">
                                    <label>Prompt</label>
                                    <textarea @bind="_newOutputPrompt" rows="2" placeholder="Ej: Busca un video de un perro paseando" style="font-size: 0.75rem;"></textarea>
                                </div>
                                <div class="inspector-field" style="margin-bottom: 0.2rem;">
                                    <label>Tipo de salida</label>
                                    <select @bind="_newOutputDataType">
                                        <option value="text">Texto</option>
                                        <option value="image">Imagen</option>
                                        <option value="video">Video</option>
                                        <option value="audio">Audio</option>
                                        <option value="file">Archivo</option>
                                    </select>
                                </div>
                                <button class="btn btn-xs btn-primary" style="width: 100%;" @onclick="() => AddOrchestratorOutput(sel)">Agregar salida</button>
                            </div>
                        </div>
                    }

                    @if (sel.ModuleType != "Start")
                    {
                        <div class="inspector-section">
                            <button class="btn btn-xs btn-primary" style="width:100%; margin-bottom: 0.35rem;" @onclick="() => OpenEditNode(sel)">Editar nodo</button>
                            <button class="btn btn-xs btn-danger" style="width:100%;" @onclick="() => RequestDeleteNode(sel.Id)">Eliminar nodo</button>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="inspector-header"><span>Inspector</span></div>
            <div class="inspector-empty">Selecciona un nodo para ver sus propiedades</div>
        }

        @if (Executing || (ExecutionLogs is { Count: > 0 }))
        {
            var logCount = ExecutionLogs?.Count ?? 0;
            <div class="inspector-log">
                <div class="inspector-log-header">
                    <span class="inspector-log-title">Log de ejecución</span>
                    @if (logCount > 0)
                    {
                        <span class="inspector-log-count">@logCount</span>
                    }
                    <span class="inspector-log-header-spacer"></span>
                    @if (Executing)
                    {
                        <span class="inspector-log-live">
                            <span class="inspector-log-live-dot"></span>
                            En vivo
                        </span>
                    }
                </div>
                <div class="inspector-log-entries" id="inspector-log-body-@_canvasId">
                    @if (logCount == 0)
                    {
                        <div class="inspector-log-waiting">
                            <span class="spinner" style="width: 0.7rem; height: 0.7rem;"></span>
                            <span>Esperando eventos de ejecución&hellip;</span>
                        </div>
                    }
                    else if (ExecutionLogs is not null)
                    {
                        @foreach (var entry in ExecutionLogs.TakeLast(80))
                        {
                            @if (entry.Level == "step-start")
                            {
                                <div class="inspector-log-step-header">
                                    <span class="inspector-log-time">@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                    @if (entry.ProjectModuleId.HasValue)
                                    {
                                        var logPm = Modules.FirstOrDefault(m => m.Id == entry.ProjectModuleId.Value);
                                        var logName = logPm?.StepName ?? logPm?.AiModuleName ?? entry.ModuleName;
                                        <span class="inspector-log-step-badge">@logName</span>
                                    }
                                    <span class="inspector-log-step-name">@entry.Message</span>
                                </div>
                            }
                            else if (entry.Level == "input")
                            {
                                <div class="inspector-log-io inspector-log-io-in">
                                    <span class="inspector-log-io-label">IN</span>
                                    <span class="inspector-log-io-text">@entry.Message</span>
                                </div>
                            }
                            else if (entry.Level == "output")
                            {
                                <div class="inspector-log-io inspector-log-io-out">
                                    <span class="inspector-log-io-label">OUT</span>
                                    <span class="inspector-log-io-text">@entry.Message</span>
                                </div>
                            }
                            else
                            {
                                <div class="inspector-log-entry inspector-log-@entry.Level">
                                    <span class="inspector-log-dot"></span>
                                    <span class="inspector-log-time">@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                    <div class="inspector-log-body">
                                        @if (entry.ProjectModuleId.HasValue)
                                        {
                                            var logPm = Modules.FirstOrDefault(m => m.Id == entry.ProjectModuleId.Value);
                                            var logName = logPm?.StepName ?? logPm?.AiModuleName ?? entry.ModuleName;
                                            <span class="inspector-log-step">@logName</span>
                                        }
                                        <span class="inspector-log-msg">@entry.Message</span>
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-error" style="margin-top: 0.5rem;">@_error</div>
}

@if (_formatEditor is not null)
{
    <div class="modal-overlay" @onclick="CloseFormatEditor">
        <div class="modal-content format-modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3 style="margin: 0; font-size: 0.95rem;">
                    <i class="bi bi-braces" style="margin-right: 0.3rem;"></i>
                    Formato de la conexion
                </h3>
                <button class="node-btn" @onclick="CloseFormatEditor" title="Cerrar">&#x2715;</button>
            </div>
            <div class="modal-body">
                <p class="text-sm text-muted" style="margin-top: 0; margin-bottom: 0.4rem;">
                    <strong>@_formatEditor.FromLabel</strong>
                    <span style="margin: 0 0.3rem;">&#x2192;</span>
                    <strong>@_formatEditor.ToLabel</strong>
                </p>
                <p class="text-sm text-muted" style="margin-bottom: 0.4rem;">
                    Define el JSON que el modulo origen debe emitir para que el destino pueda leer cada campo en su sitio. Se inyecta como instruccion al prompt del origen y guia al destino en la lectura.
                </p>
                <div style="display:flex; align-items:center; gap:0.4rem; margin-bottom:0.5rem;">
                    <label class="text-sm text-muted" style="white-space:nowrap; margin:0;">Plantilla:</label>
                    <select style="flex:1;" value="@_formatEditor.SelectedTemplate"
                            @onchange="OnFormatTemplateSelected">
                        <option value="">-- Personalizada --</option>
                        @foreach (var t in FormatTemplates)
                        {
                            <option value="@t.Key">@t.Label</option>
                        }
                    </select>
                </div>
                <textarea rows="14" spellcheck="false"
                          placeholder='{"images":[{"prompt":"slide 1"},{"prompt":"slide 2"},{"prompt":"slide 3"}]}'
                          style="width: 100%; font-family: var(--font-mono, monospace); font-size: 0.8rem;"
                          value="@_formatEditor.Draft"
                          @oninput="OnFormatDraftInput"></textarea>
                @if (!_formatEditor.IsValid && !string.IsNullOrWhiteSpace(_formatEditor.Error))
                {
                    <div class="alert alert-error" style="font-size: 0.75rem; margin-top: 0.4rem;">
                        <i class="bi bi-exclamation-circle" style="margin-right: 0.25rem;"></i>@_formatEditor.Error
                    </div>
                }
                else if (_formatEditor.IsValid && !string.IsNullOrWhiteSpace(_formatEditor.ShapeSummary))
                {
                    <div class="alert alert-success" style="font-size: 0.75rem; margin-top: 0.4rem;">
                        <i class="bi bi-check-circle" style="margin-right: 0.25rem;"></i>
                        <strong>Estructura:</strong> @_formatEditor.ShapeSummary
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-sm" @onclick="ClearFormatEditor" title="Quitar el formato de esta conexion">Quitar</button>
                <button class="btn btn-sm" @onclick="PrettyPrintFormat"
                        disabled="@(!_formatEditor.IsValid || string.IsNullOrWhiteSpace(_formatEditor.Draft))"
                        title="Reformatear el JSON con indentacion">
                    <i class="bi bi-code-square" style="margin-right: 0.2rem;"></i>Pretty-print
                </button>
                <div style="flex: 1;"></div>
                <button class="btn btn-sm" @onclick="CloseFormatEditor">Cancelar</button>
                <button class="btn btn-success btn-sm" @onclick="SaveFormatEditor" disabled="@(!_formatEditor.IsValid)">Guardar</button>
            </div>
        </div>
    </div>
}

@* ── Popup "Editar nodo": edita la configuracion del modulo de catalogo del nodo,
     igual que el boton "Configurar" de la pagina Modulos. ── *@
@if (_editNodeModule is not null)
{
    <div class="modal-overlay" @onclick="CloseEditNode">
        <div class="modal-content" style="max-width:760px; width:95vw;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 style="margin:0; font-size:1.05rem; flex:1;">Editar nodo &mdash; @_editNodeModule.Name</h3>
                <button class="node-btn" @onclick="CloseEditNode" title="Cerrar">&#x2715;</button>
            </div>
            <div class="modal-body">
                @if (_editNodeError is not null)
                {
                    <div class="alert alert-error">@_editNodeError</div>
                }
                @if (_editNodeSuccess)
                {
                    <div class="alert alert-success">Cambios guardados</div>
                }

                @if (_editNodeUsageOtherProjects > 0)
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle" style="margin-right: 0.3rem;"></i>
                        Este modulo tambien se usa en <strong>@_editNodeUsageOtherProjects</strong>
                        @(_editNodeUsageOtherProjects == 1 ? " proyecto" : " proyectos") mas
                        @if (_editNodeUsageNames.Count > 0)
                        {
                            <text>(@string.Join(", ", _editNodeUsageNames))</text>
                        }
                        . Si guardas los cambios, afectaran a todos. Usa <strong>Duplicar con cambios</strong>
                        para crear una copia independiente solo para este proyecto.
                    </div>
                }

                <div class="form-group">
                    <label>Nombre del modulo</label>
                    <input type="text" @bind="_editNodeName" placeholder="Nombre del modulo" />
                </div>
                <div class="form-group">
                    <label>Descripcion</label>
                    <input type="text" @bind="_editNodeDesc" placeholder="Descripcion opcional" />
                </div>

                <fieldset class="config-fieldset">
                    <legend>Configuracion</legend>
                    <ModuleConfigEditor @ref="_nodeConfigEditor" Module="_editNodeModule" />
                </fieldset>
            </div>
            <div class="modal-footer">
                <button class="btn btn-sm" @onclick="CloseEditNode" disabled="@_editNodeSaving">Cancelar</button>
                <div style="flex: 1;"></div>
                <button class="btn btn-sm" @onclick="DuplicateNodeModule" disabled="@_editNodeSaving"
                        title="Crea una copia del modulo con estos cambios y la asigna solo a este nodo">
                    <i class="bi bi-files" style="margin-right: 0.2rem;"></i>Duplicar con cambios
                </button>
                <button class="btn btn-primary btn-sm" @onclick="SaveNodeModule" disabled="@_editNodeSaving">
                    @(_editNodeSaving ? "Guardando..." : "Guardar cambios")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public List<ProjectModuleResponse> Modules { get; set; } = [];
    [Parameter] public List<AiModuleResponse> AvailableModules { get; set; } = [];
    [Parameter] public List<ModuleConnectionResponse> Connections { get; set; } = [];
    [Parameter] public List<RuleResponse> TenantRules { get; set; } = [];
    [Parameter] public RenderFragment? TopPanel { get; set; }
    [Parameter] public EventCallback<Guid> OnAddModule { get; set; }
    [Parameter] public EventCallback<Guid> OnRemoveModule { get; set; }
    [Parameter] public EventCallback<SaveGraphRequest> OnSaveGraph { get; set; }
    // Avisa al padre de que la lista de modulos o el modulo de algun nodo cambio,
    // para que recargue los datos (catalogo + proyecto).
    [Parameter] public EventCallback OnModulesChanged { get; set; }

    // Execution state from parent
    [Parameter] public bool Executing { get; set; }
    [Parameter] public List<StepExecutionStatus>? StepStatuses { get; set; }
    [Parameter] public List<ExecutionLogEntry>? ExecutionLogs { get; set; }

    // Local mutable copy of connections (modified by JS callbacks)
    private List<ConnectionEntry> _connections = new();
    // Local mutable positions (modified by JS callbacks)
    private Dictionary<Guid, (double X, double Y)> _positions = new();

    private string _canvasId = Guid.NewGuid().ToString("N")[..8];
    private string _searchFilter = "";
    private Guid? _selectedModuleId;
    private string? _error;
    private bool _jsInitialized;
    private CancellationTokenSource? _saveDebounce;
    private DotNetObjectReference<PipelineCanvas>? _dotNetRef;
    private int _lastModuleCount;
    private int _lastConnectionCount;
    private Dictionary<Guid, int> _sceneCountOverrides = new();

    // ── Estado del popup "Editar nodo" ──
    private ProjectModuleResponse? _editNodeProjectModule; // nodo (instancia) en edicion
    private AiModuleResponse? _editNodeModule;             // modulo de catalogo del nodo
    private ModuleConfigEditor? _nodeConfigEditor;
    private string _editNodeName = "";
    private string? _editNodeDesc;
    private bool _editNodeSaving;
    private bool _editNodeSuccess;
    private string? _editNodeError;
    private int _editNodeUsageOtherProjects;
    private List<string> _editNodeUsageNames = [];
    private static readonly string[] _orchestratorModels = [
        "gpt-4o", "gpt-4o-mini", "gpt-4.1", "gpt-4.1-mini", "gpt-4.1-nano",
        "claude-sonnet-4-20250514", "claude-opus-4-20250514", "claude-3-5-haiku-20241022",
        "gemini-2.0-flash", "gemini-2.5-flash", "gemini-2.5-pro",
    ];
    private Dictionary<Guid, Dictionary<string, string>> _moduleConfigs = new();
    private bool _lastExecuting;

    // Shopify blog picker (config del nodo ShopifyBlog)
    private List<ShopifyBlogDto> _shopifyBlogs = new();
    private bool _loadingShopifyBlogs;
    private string? _shopifyBlogsError;

    private FormatEditorState? _formatEditor;

    private sealed class FormatEditorState
    {
        public Guid FromModuleId { get; set; }
        public string FromPort { get; set; } = "";
        public Guid ToModuleId { get; set; }
