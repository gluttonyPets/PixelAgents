    private bool GetModuleConfigBool(Guid moduleId, string key, bool fallback = false)
    {
        var val = GetModuleConfig(moduleId, key, "");
        if (string.IsNullOrEmpty(val)) return fallback;
        return val.Equals("true", StringComparison.OrdinalIgnoreCase);
    }

    private List<TemplateVariable>? GetTemplateVars(Guid moduleId)
    {
        var json = GetModuleConfig(moduleId, "templateVars", "");
        if (string.IsNullOrEmpty(json)) return null;
        try
        {
            var vars = System.Text.Json.JsonSerializer.Deserialize<List<TemplateVariable>>(json);
            return vars is { Count: > 0 } ? vars : null;
        }
        catch { return null; }
    }

    private async Task AddTemplateVar(Guid moduleId, string name, string type)
    {
        var vars = GetTemplateVars(moduleId) ?? new List<TemplateVariable>();
        if (vars.Any(v => v.Name == name)) return;
        vars.Add(new TemplateVariable { Name = name, Type = type });
        await SetModuleConfig(moduleId, "templateVars", System.Text.Json.JsonSerializer.Serialize(vars));
        _sceneNewFieldName = "";
        await RebuildDrawflow();
    }

    private async Task RemoveTemplateVar(Guid moduleId, string name)
    {
        var vars = GetTemplateVars(moduleId) ?? new List<TemplateVariable>();
        vars.RemoveAll(v => v.Name == name);
        var json = vars.Count > 0 ? System.Text.Json.JsonSerializer.Serialize(vars) : "";
        await SetModuleConfig(moduleId, "templateVars", json);
        // Remove connections to the deleted port
        var portId = $"input_tpl_{name}";
        _connections.RemoveAll(c => (c.ToModuleId == moduleId && c.ToPort == portId) || (c.FromModuleId == moduleId && c.FromPort == portId));
        await RebuildDrawflow();
    }

    private async Task SetModuleConfig(Guid moduleId, string key, string value)
    {
        if (!_moduleConfigs.ContainsKey(moduleId))
            _moduleConfigs[moduleId] = new();
        _moduleConfigs[moduleId][key] = value;
        await AutoSaveGraph();
    }

