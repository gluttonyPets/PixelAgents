    // ── FileUpload inspector helpers ──

    private async Task LoadFileUploadFiles(Guid projectModuleId)
    {
        try { _fileUploadFiles = await Api.GetModuleFilesAsync(projectModuleId); }
        catch { _fileUploadFiles = []; }
    }

    private async Task OnFileUploadFilesSelected(InputFileChangeEventArgs e)
    {
        var sel = _selectedModuleId.HasValue ? Modules.FirstOrDefault(m => m.Id == _selectedModuleId) : null;
        if (sel is null) return;

        _fileUploadError = null;
        _fileUploadUploading = true;
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            foreach (var file in e.GetMultipleFiles(20))
            {
                content.Add(CreateBrowserFileContent(file), "files", file.Name);
            }
            await Api.UploadModuleFilesAsync(sel.Id, content);
            await LoadFileUploadFiles(sel.Id);
        }
        catch (Exception ex)
        {
            _fileUploadError = $"Error al subir: {ex.Message}";
        }
        finally
        {
            _fileUploadUploading = false;
            StateHasChanged();
        }
    }

    private async Task DeleteFileUploadFile(Guid fileId)
    {
        var sel = _selectedModuleId.HasValue ? Modules.FirstOrDefault(m => m.Id == _selectedModuleId) : null;
        if (sel is null) return;

        try
        {
            await Api.DeleteModuleFileAsync(fileId);
            await LoadFileUploadFiles(sel.Id);
            StateHasChanged();
        }
        catch { }
    }

    private static string GetFileIcon(string contentType) => contentType switch
    {
        var t when t.StartsWith("image/") => "bi-file-image",
        var t when t.StartsWith("video/") => "bi-file-play",
        var t when t.StartsWith("audio/") => "bi-file-music",
        var t when t.Contains("pdf") => "bi-file-pdf",
        var t when t.Contains("json") || t.Contains("xml") || t.Contains("csv") => "bi-file-code",
        var t when t.Contains("text") || t.Contains("document") => "bi-file-text",
        _ => "bi-file-earmark"
    };

    private static StreamContent CreateBrowserFileContent(IBrowserFile file)
    {
        var stream = file.OpenReadStream(maxAllowedSize: MaxUploadFileSize);
        var content = new StreamContent(stream);
        var contentType = string.IsNullOrWhiteSpace(file.ContentType)
            ? "application/octet-stream"
            : file.ContentType;
        content.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(contentType);
        return content;
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private async Task NotifyGraphChanged()
    {
        await ClearNodeBadges();
        await RefreshConnectionFormatBadges();

        // Debounce auto-save: wait 500ms after last change
        _saveDebounce?.Cancel();
        _saveDebounce = new CancellationTokenSource();
        var token = _saveDebounce.Token;
        try
        {
            await Task.Delay(500, token);
            if (!token.IsCancellationRequested)
                await AutoSaveGraph();
        }
        catch (TaskCanceledException) { }
    }

    private async Task ClearNodeBadges()
    {
        if (!_jsInitialized) return;
        foreach (var pm in Modules)
        {
            await JS.InvokeVoidAsync("pipelineEditor.updateNodeBadge", pm.Id.ToString(), "");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsInitialized)
        {
            try { await JS.InvokeVoidAsync("pipelineEditor.dispose"); } catch { }
        }
        _dotNetRef?.Dispose();
    }
