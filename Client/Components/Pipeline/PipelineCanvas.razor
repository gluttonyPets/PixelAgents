    private static string FormatInputMapping(string? mapping)
    {
        if (string.IsNullOrEmpty(mapping)) return "Usuario";
        try
        {
            var el = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(mapping);
            var source = el.TryGetProperty("source", out var s) ? s.GetString() : "user";
            if (source == "user") return "Usuario";
            var field = el.TryGetProperty("field", out var f) ? f.GetString() : "text";
            return field == "file" ? "Paso anterior (archivo)" : "Paso anterior (texto)";
        }
        catch { return "Usuario"; }
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsInitialized)
        {
            try { await JS.InvokeVoidAsync("pipelineEditor.dispose"); } catch { }
        }
        _dotNetRef?.Dispose();
    }
}
