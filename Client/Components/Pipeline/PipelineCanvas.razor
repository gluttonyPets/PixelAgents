    [JSInvokable]
    public void OpenConnectionFormat(string fromModuleId, string fromPort, string toModuleId, string toPort)
    {
        if (!Guid.TryParse(fromModuleId, out var fromId)) return;
        if (!Guid.TryParse(toModuleId, out var toId)) return;

        var conn = _connections.FirstOrDefault(c =>
            c.FromModuleId == fromId && c.FromPort == fromPort &&
            c.ToModuleId == toId && c.ToPort == toPort);
        if (conn is null) return;

        var fromModule = Modules.FirstOrDefault(m => m.Id == fromId);
        var toModule = Modules.FirstOrDefault(m => m.Id == toId);
        var fromPorts = fromModule is not null ? ModulePortRegistry.GetPorts(fromModule.ModuleType, "", GetSceneCount(fromModule.Id), fromModule.OrchestratorOutputs, GetTemplateVars(fromModule.Id), fromModule.ModelName) : new();
        var toPorts = toModule is not null ? ModulePortRegistry.GetPorts(toModule.ModuleType, "", GetSceneCount(toModule.Id), toModule.OrchestratorOutputs, GetTemplateVars(toModule.Id), toModule.ModelName) : new();
        var fromLabel = $"{fromModule?.StepName ?? fromModule?.AiModuleName ?? "?"} · {fromPorts.FirstOrDefault(p => p.Id == fromPort)?.Label ?? fromPort}";
        var toLabel = $"{toModule?.StepName ?? toModule?.AiModuleName ?? "?"} · {toPorts.FirstOrDefault(p => p.Id == toPort)?.Label ?? toPort}";

        _formatEditor = new FormatEditorState
        {
            FromModuleId = fromId,
            FromPort = fromPort,
            ToModuleId = toId,
            ToPort = toPort,
            FromLabel = fromLabel,
            ToLabel = toLabel,
            Draft = conn.Format ?? "",
        };

        // Si el destino es ShopifyBlog y la conexion aun no tiene formato, sugerimos
        // la plantilla de Shopify ya cargada (el usuario puede cambiarla o vaciarla).
        if (string.IsNullOrWhiteSpace(_formatEditor.Draft) && toModule?.ModuleType == "ShopifyBlog")
        {
            var shopifyTpl = FormatTemplates.FirstOrDefault(t => t.Key == "shopify");
            if (shopifyTpl is not null)
            {
                _formatEditor.Draft = shopifyTpl.Json;
                _formatEditor.SelectedTemplate = shopifyTpl.Key;
            }
        }

        ValidateFormatDraft();
        InvokeAsync(StateHasChanged);
    }

