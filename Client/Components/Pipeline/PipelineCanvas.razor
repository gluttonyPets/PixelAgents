    private async Task OpenEditNode(ProjectModuleResponse node)
    {
        _editNodeError = null;
        _editNodeSuccess = false;
        _editNodeSaving = false;
        _editNodeProjectModule = node;

        // Resolver el modulo de catalogo asociado al nodo.
        var catalog = AvailableModules.FirstOrDefault(m => m.Id == node.AiModuleId);
        if (catalog is null)
        {
            // Fallback: pedirlo al servidor por si no esta en la lista local.
            catalog = await Api.GetModuleAsync(node.AiModuleId);
        }
        if (catalog is null)
        {
            _editNodeError = "No se pudo cargar la configuracion del modulo.";
            _editNodeModule = null;
            return;
        }

        _editNodeModule = catalog;
        _editNodeName = catalog.Name;
        _editNodeDesc = catalog.Description;

        // Comprobar uso en otros proyectos (excluyendo el actual) para advertir.
        var usage = await Api.GetModuleUsageAsync(catalog.Id, ProjectId);
        _editNodeUsageOtherProjects = usage.ProjectCount;
        _editNodeUsageNames = usage.ProjectNames ?? [];

        StateHasChanged();
    }

    private void CloseEditNode()
    {
        _editNodeModule = null;
        _editNodeProjectModule = null;
        _editNodeError = null;
        _editNodeSuccess = false;
        _editNodeUsageOtherProjects = 0;
        _editNodeUsageNames = [];
    }

    // Guarda los cambios sobre el modulo de catalogo (afecta a todos los proyectos que lo usan).
    private async Task SaveNodeModule()
    {
        if (_editNodeModule is null) return;
        _editNodeError = null;
        _editNodeSuccess = false;
        _editNodeSaving = true;
        try
        {
            var config = _nodeConfigEditor?.BuildConfig();
            // UpdateModuleConfigAsync envia Name/Description desde 'current', asi que pasamos
            // el modulo con el nombre/descripcion ya actualizados para persistirlo todo.
            var updated = _editNodeModule with { Name = _editNodeName, Description = _editNodeDesc, Configuration = config };
            var (ok, error) = await Api.UpdateModuleConfigAsync(_editNodeModule.Id, updated, config);
            if (ok)
            {
                _editNodeSuccess = true;
                await OnModulesChanged.InvokeAsync();
                CloseEditNode();
            }
            else
            {
                _editNodeError = error ?? "Error al guardar.";
            }
        }
        catch (Exception ex) { _editNodeError = $"Error: {ex.Message}"; }
        _editNodeSaving = false;
    }

    // Crea una copia del modulo con los cambios y la asigna solo a este nodo.
    private async Task DuplicateNodeModule()
    {
        if (_editNodeModule is null || _editNodeProjectModule is null) return;
        _editNodeError = null;
        _editNodeSuccess = false;
        _editNodeSaving = true;
        try
        {
            var config = _nodeConfigEditor?.BuildConfig();
            var dupName = string.IsNullOrWhiteSpace(_editNodeName) ? _editNodeModule.Name : _editNodeName;
            var req = new CreateAiModuleRequest(
                dupName + " (copia)", _editNodeDesc, _editNodeModule.ProviderType,
                _editNodeModule.ModuleType, _editNodeModule.ModelName, _editNodeModule.ApiKeyId, config);

            var (ok, error, newId) = await Api.CreateModuleAsync(req);
            if (!ok || newId is null)
            {
                _editNodeError = error ?? "No se pudo duplicar el modulo.";
                _editNodeSaving = false;
                return;
            }

            var (rok, rerror) = await Api.ReassignProjectModuleAsync(ProjectId, _editNodeProjectModule.Id, newId.Value);
            if (!rok)
            {
                _editNodeError = rerror ?? "Se creo la copia pero no se pudo asignar al nodo.";
                _editNodeSaving = false;
                return;
            }

            _editNodeSuccess = true;
            await OnModulesChanged.InvokeAsync();
            CloseEditNode();
        }
        catch (Exception ex) { _editNodeError = $"Error: {ex.Message}"; }
        _editNodeSaving = false;
    }

    private async Task AddOrchestratorOutput(ProjectModuleResponse module)
    {
        if (string.IsNullOrWhiteSpace(_newOutputLabel)) return;

        var sortOrder = (module.OrchestratorOutputs?.Count ?? 0) + 1;

        var (output, error) = await Api.CreateOrchestratorOutputAsync(
            ProjectId, module.Id,
            new OrchestratorOutputRequest(_newOutputLabel, _newOutputPrompt, _newOutputDataType, sortOrder));

        if (output is not null)
        {
            var outputs = module.OrchestratorOutputs?.ToList() ?? new();
            outputs.Add(output);
            var idx = Modules.FindIndex(m => m.Id == module.Id);
            if (idx >= 0)
            {
                Modules[idx] = module with { OrchestratorOutputs = outputs };
            }

            _newOutputLabel = "";
            _newOutputPrompt = "";
            _newOutputDataType = "text";

            // Rebuild node to show new ports
            await RebuildDrawflow();
        }
        else
        {
            _error = error ?? "Error al crear salida";
        }
        StateHasChanged();
    }

    private void StartEditingOutput(OrchestratorOutputResponse output)
    {
        _editingOutputId = output.Id;
        _editLabel = output.Label;
        _editPrompt = output.Prompt;
        _editDataType = output.DataType;
    }

    private async Task SaveOrchestratorOutput(ProjectModuleResponse module, OrchestratorOutputResponse output)
    {
        if (string.IsNullOrWhiteSpace(_editLabel)) return;

        var req = new OrchestratorOutputRequest(_editLabel, _editPrompt, _editDataType, output.SortOrder);
        var (updated, error) = await Api.UpdateOrchestratorOutputAsync(ProjectId, module.Id, output.Id, req);

        if (updated is not null)
        {
            var outputs = module.OrchestratorOutputs?.ToList() ?? new();
            var oi = outputs.FindIndex(o => o.Id == output.Id);
            if (oi >= 0) outputs[oi] = updated;

            var idx = Modules.FindIndex(m => m.Id == module.Id);
            if (idx >= 0)
                Modules[idx] = module with { OrchestratorOutputs = outputs };

            _editingOutputId = null;
            await RebuildDrawflow();
        }
        else
        {
            _error = error ?? "Error al actualizar salida";
        }
        StateHasChanged();
    }

    private async Task DeleteOrchestratorOutput(ProjectModuleResponse module, Guid outputId)
    {
        var (ok, error) = await Api.DeleteOrchestratorOutputAsync(ProjectId, module.Id, outputId);
        if (ok)
        {
            var outputs = module.OrchestratorOutputs?.Where(o => o.Id != outputId).ToList() ?? new();
            var idx = Modules.FindIndex(m => m.Id == module.Id);
            if (idx >= 0)
            {
                Modules[idx] = module with { OrchestratorOutputs = outputs };
            }
            await RebuildDrawflow();
        }
        else
        {
            _error = error ?? "Error al eliminar salida";
        }
        StateHasChanged();
    }

    private async Task OnImageCountChange(Guid moduleId, ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var count) || count < 1) count = 1;
        if (count > 20) count = 20;
        // Persist to module config as "n" so executor and GetSceneCount can read it
        if (!_moduleConfigs.ContainsKey(moduleId))
            _moduleConfigs[moduleId] = new();
        _moduleConfigs[moduleId]["n"] = count.ToString();
        // UpdateSceneCount rebuilds drawflow with new ports and calls AutoSaveGraph
        await UpdateSceneCount(moduleId, count);
    }

    private async Task UpdateSceneCount(Guid moduleId, int count)
    {
        _sceneCountOverrides[moduleId] = count;

        var module = Modules.FirstOrDefault(m => m.Id == moduleId);
        if (module is not null)
        {
            var validPorts = ModulePortRegistry.GetPorts(module.ModuleType, "", count, module.OrchestratorOutputs, GetTemplateVars(module.Id), module.ModelName).Select(p => p.Id).ToHashSet();
            _connections.RemoveAll(c =>
                (c.FromModuleId == moduleId && !validPorts.Contains(c.FromPort)) ||
                (c.ToModuleId == moduleId && !validPorts.Contains(c.ToPort)));
        }

        await NotifyGraphChanged();
        await RebuildDrawflow();
    }

    private async Task AutoLayout()
    {
        var moduleIds = Modules.Select(m => m.Id).ToList();
        var depths = new Dictionary<Guid, int>();
        foreach (var id in moduleIds) depths[id] = 0;

        bool changed = true;
        while (changed)
        {
            changed = false;
            foreach (var conn in _connections)
            {
                if (depths.ContainsKey(conn.FromModuleId) && depths.ContainsKey(conn.ToModuleId))
                {
                    var newDepth = depths[conn.FromModuleId] + 1;
                    if (newDepth > depths[conn.ToModuleId])
                    {
                        depths[conn.ToModuleId] = newDepth;
                        changed = true;
                    }
                }
            }
        }

        var groups = moduleIds.GroupBy(id => depths.GetValueOrDefault(id, 0)).OrderBy(g => g.Key).ToList();
        for (int col = 0; col < groups.Count; col++)
        {
            var group = groups[col].ToList();
            for (int row = 0; row < group.Count; row++)
            {
                var x = 60 + col * 300;
                var y = 60 + row * 200;
                _positions[group[row]] = (x, y);
                await JS.InvokeVoidAsync("pipelineEditor.updateNodePosition", group[row].ToString(), (double)x, (double)y);
            }
        }

        await NotifyGraphChanged();
        StateHasChanged();
    }

    private async Task AutoSaveGraph()
    {
        Console.WriteLine($"[PipelineCanvas] AutoSaveGraph: saving {_connections.Count} connections");
        _error = null;
        var positions = _positions.Select(p => new NodePositionEntry(p.Key, p.Value.X, p.Value.Y)).ToList();
        var sceneCounts = _sceneCountOverrides
            .Where(kv => kv.Value > 1)
            .Select(kv => new SceneCountEntry(kv.Key, kv.Value))
            .ToList();
        var moduleConfigs = _moduleConfigs
            .SelectMany(kv => kv.Value.Select(c => new ModuleConfigEntry(kv.Key, c.Key, c.Value)))
            .ToList();
        var req = new SaveGraphRequest(positions, _connections,
            sceneCounts.Count > 0 ? sceneCounts : null,
            moduleConfigs.Count > 0 ? moduleConfigs : null);
        await OnSaveGraph.InvokeAsync(req);
    }

