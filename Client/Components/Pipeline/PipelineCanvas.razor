    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("pipelineEditor.init", _dotNetRef, $"drawflow-{_canvasId}");
            _jsInitialized = true;
            LoadFromParameters();
            await RebuildDrawflow();
            _lastModuleCount = Modules.Count;
            _lastConnectionCount = Connections.Count;
        }
        else if (_jsInitialized)
        {
            if (Modules.Count != _lastModuleCount || Connections.Count != _lastConnectionCount)
            {
                Console.WriteLine($"[PipelineCanvas] Rebuild triggered: modules {_lastModuleCount}→{Modules.Count}, conns {_lastConnectionCount}→{Connections.Count}");
                // Auto-select newly added module so inspector shows immediately
                // (needed for Orchestrator to configure outputs, etc.)
                if (_pendingAutoSelectModuleType is not null && Modules.Count > _lastModuleCount)
                {
                    var newModule = Modules.LastOrDefault(m => m.ModuleType == _pendingAutoSelectModuleType);
                    if (newModule is not null)
                    {
                        _selectedModuleId = newModule.Id;
                        if (newModule.ModuleType == "FileUpload")
                            _ = LoadFileUploadFiles(newModule.Id);
                    }
                }
                _pendingAutoSelectModuleType = null;

                _lastModuleCount = Modules.Count;
                _lastConnectionCount = Connections.Count;
                LoadFromParameters();
                await RebuildDrawflow();
            }
        }

        // Update execution visualization without full rebuild
        if (_jsInitialized)
        {
            var logCount = ExecutionLogs?.Count ?? 0;
            var logGrew = logCount != _lastLogCount;
            if (Executing != _lastExecuting || logGrew)
            {
                _lastExecuting = Executing;
                _lastLogCount = logCount;
                await UpdateExecutionVisualization();
            }

            // Keep the live log pinned to the newest entry (unless the user scrolled up).
            if (logGrew)
            {
                try { await JS.InvokeVoidAsync("pipelineEditor.scrollLogToBottom", $"inspector-log-body-{_canvasId}"); }
                catch { /* log element may not be rendered yet */ }
            }
        }
    }

    /// <summary>Load local mutable state from parent parameters.</summary>
    private void LoadFromParameters()
    {
        _positions = Modules.ToDictionary(m => m.Id, m => (m.PosX, m.PosY));
        _connections = Connections.Select(c => new ConnectionEntry(c.FromModuleId,
            MigratePortId(c.FromPort), c.ToModuleId, MigratePortId(c.ToPort), c.Format)).ToList();
        Console.WriteLine($"[PipelineCanvas] LoadFromParameters: {Modules.Count} modules, {Connections.Count} connections from parent, {_connections.Count} local connections");
    }

    /// <summary>Migrate legacy port IDs to current names.</summary>
    private static string MigratePortId(string portId)
    {
        // input_scene_X_video → input_scene_X_media (renamed in scene port refactor)
        if (portId.StartsWith("input_scene_") && portId.EndsWith("_video"))
            return portId[..^"_video".Length] + "_media";
        return portId;
    }

    private async Task RebuildDrawflow()
    {
        await JS.InvokeVoidAsync("pipelineEditor.setSuppressEvents", true);
        await JS.InvokeVoidAsync("pipelineEditor.clear");

        // Add all nodes using positions from DB
        int idx = 0;
        foreach (var pm in Modules)
        {
            var sceneCount = GetSceneCount(pm.Id);
            var ports = ModulePortRegistry.GetPorts(pm.ModuleType, "", sceneCount, pm.OrchestratorOutputs, GetTemplateVars(pm.Id), pm.ModelName);
            var inputs = ports.Where(p => p.IsInput).Select(p => new {
                id = p.Id, label = p.Label, color = PortDataType.GetColor(p.DataType), required = p.IsRequired, allowMultiple = p.AllowMultiple
            }).ToList();
            var outputs = ports.Where(p => !p.IsInput).Select(p => new {
                id = p.Id, label = p.Label, color = PortDataType.GetColor(p.DataType), required = false
            }).ToList();

            var pos = _positions.GetValueOrDefault(pm.Id, (60 + (idx % 4) * 280, 60 + (idx / 4) * 200));
            var stepLabel = "";

            var warning = pm.ModuleType == "Orchestrator"
                && (pm.OrchestratorOutputs is null || pm.OrchestratorOutputs.Count == 0)
                ? "Sin salidas configuradas"
                : null;

            var isSkipped = GetModuleConfigBool(pm.Id, "skipped", false);
            var activeRulesCount = GetActiveRules(pm).Count;

            await JS.InvokeVoidAsync("pipelineEditor.addNode",
                pm.Id.ToString(),
                pm.StepName ?? pm.AiModuleName,
                pm.ModuleType,
                ModulePortRegistry.GetModuleColor(pm.ModuleType),
                ModulePortRegistry.GetModuleIcon(pm.ModuleType),
                JsonSerializer.Serialize(inputs),
                JsonSerializer.Serialize(outputs),
                pos.X, pos.Y,
                stepLabel,
                pm.ModelName,
                warning,
                isSkipped,
                activeRulesCount);

            idx++;
        }

        // Add all connections from DB
        Console.WriteLine($"[PipelineCanvas] RebuildDrawflow: adding {_connections.Count} connections");
        foreach (var conn in _connections)
        {
            Console.WriteLine($"[PipelineCanvas]   conn: {conn.FromPort} → {conn.ToPort}");
            await JS.InvokeVoidAsync("pipelineEditor.addConnection",
                conn.FromModuleId.ToString(), conn.FromPort,
                conn.ToModuleId.ToString(), conn.ToPort);
        }

        await JS.InvokeVoidAsync("pipelineEditor.setSuppressEvents", false);

        await Task.Delay(100);
        await JS.InvokeVoidAsync("pipelineEditor.refreshConnections");
        await RefreshConnectionFormatBadges();

        // Apply execution states if currently executing
        if (Executing || StepStatuses is { Count: > 0 })
            await UpdateExecutionVisualization();
    }

    /// <summary>
    /// Tell the JS editor which connections have a Format set so it can paint
    /// the midpoint badge on the right edges. Called after every rebuild and
    /// after Format changes via the modal.
    /// </summary>
    private async Task RefreshConnectionFormatBadges()
    {
        if (!_jsInitialized) return;
        var payload = _connections.Select(c => new
        {
            fromModuleId = c.FromModuleId.ToString(),
            fromPort = c.FromPort,
            toModuleId = c.ToModuleId.ToString(),
            toPort = c.ToPort,
            hasFormat = !string.IsNullOrWhiteSpace(c.Format),
        }).ToList();
        await JS.InvokeVoidAsync("pipelineEditor.setConnectionFormats",
            System.Text.Json.JsonSerializer.Serialize(payload));
    }

    /// <summary>Update node/connection visual states based on execution progress.</summary>
    private async Task UpdateExecutionVisualization()
    {
        if (!_jsInitialized) return;

        if (!Executing && (StepStatuses is null || StepStatuses.Count == 0))
        {
            await JS.InvokeVoidAsync("pipelineEditor.clearAllStates");
            return;
        }

        if (StepStatuses is null) return;

        // Map projectModuleId → status
        var statusMap = StepStatuses.ToDictionary(s => s.ProjectModuleId, s => s.Status);
        Guid? runningModuleId = null;

        foreach (var pm in Modules)
        {
            var status = statusMap.GetValueOrDefault(pm.Id, "idle");
            var state = status switch
            {
                "Running" => "running",
                "Completed" => "completed",
                "Failed" => "failed",
                "Skipped" => "skipped",
                "WaitingForCheckpoint" => "waiting",
                "WaitingForReview" => "waiting",
                _ => "idle"
            };
            await JS.InvokeVoidAsync("pipelineEditor.setNodeState", pm.Id.ToString(), state);
            if (state == "running") runningModuleId = pm.Id;
        }

        // Animate the connection FROM the running node to the next
        // First clear all connection states, then set the active one
        foreach (var conn in _connections)
        {
            var isActive = runningModuleId.HasValue && conn.FromModuleId == runningModuleId.Value;
            if (isActive)
                await JS.InvokeVoidAsync("pipelineEditor.setConnectionState", conn.FromModuleId.ToString(), conn.ToModuleId.ToString(), "active");
        }
    }

    // ── Helpers ──

    private int GetSceneCount(Guid moduleId)
    {
        if (_sceneCountOverrides.TryGetValue(moduleId, out var count))
            return Math.Max(1, count);

        // Load from persisted Configuration if not overridden
        var module = Modules.FirstOrDefault(m => m.Id == moduleId);
        if (module?.Configuration is not null)
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(module.Configuration);
                // sceneCount (Scene/Checkpoint/Coordinator); Image: n or numberOfImages
                foreach (var key in new[] { "sceneCount", "n", "numberOfImages" })
                {
                    if (doc.RootElement.TryGetProperty(key, out var sc) && sc.ValueKind == System.Text.Json.JsonValueKind.Number)
                    {
                        var persisted = sc.GetInt32();
                        _sceneCountOverrides[moduleId] = persisted;
                        return Math.Max(1, persisted);
                    }
                }
            }
            catch { /* ignore */ }
        }

        return 1;
    }

    // ── Generic module config helpers ──

    private string GetModuleConfig(Guid moduleId, string key, string fallback = "")
    {
        if (_moduleConfigs.TryGetValue(moduleId, out var dict) && dict.TryGetValue(key, out var val))
            return val;

        // Load from persisted Configuration JSON
        var module = Modules.FirstOrDefault(m => m.Id == moduleId);
        if (module?.Configuration is not null)
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(module.Configuration);
                if (doc.RootElement.TryGetProperty(key, out var prop))
                {
                    var persisted = prop.ValueKind switch
                    {
                        System.Text.Json.JsonValueKind.True => "true",
                        System.Text.Json.JsonValueKind.False => "false",
                        System.Text.Json.JsonValueKind.Number => prop.GetRawText(),
                        System.Text.Json.JsonValueKind.Array => prop.GetRawText(),
                        System.Text.Json.JsonValueKind.Object => prop.GetRawText(),
                        _ => prop.GetString() ?? fallback
                    };
                    if (!_moduleConfigs.ContainsKey(moduleId))
                        _moduleConfigs[moduleId] = new();
                    _moduleConfigs[moduleId][key] = persisted;
                    return persisted;
                }
            }
            catch { /* ignore */ }
        }

        return fallback;
    }

