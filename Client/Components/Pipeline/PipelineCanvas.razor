    private async Task ClearErrorAfterDelay()
    {
        await Task.Delay(3000);
        _error = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task NotifyGraphChanged()
    {
        // Update step order badges in real-time
        await UpdateStepOrderBadges();

        // Debounce auto-save: wait 500ms after last change
        _saveDebounce?.Cancel();
        _saveDebounce = new CancellationTokenSource();
        var token = _saveDebounce.Token;
        try
        {
            await Task.Delay(500, token);
            if (!token.IsCancellationRequested)
                await AutoSaveGraph();
        }
        catch (TaskCanceledException) { }
    }

    private async Task UpdateStepOrderBadges()
    {
        if (!_jsInitialized) return;
        var order = ComputeExecutionOrder();
        foreach (var pm in Modules)
        {
            var step = order.GetValueOrDefault(pm.Id, 0);
            var label = step > 0 ? GetStepLabel(pm) : "";
            await JS.InvokeVoidAsync("pipelineEditor.updateNodeStepOrder", pm.Id.ToString(), label);
        }
    }

    private string GetStepLabel(ProjectModuleResponse pm)
    {
        var branches = Modules.Where(m => m.BranchId != "main")
            .Select(m => m.BranchFromStep).Where(f => f.HasValue).Select(f => f!.Value).Distinct().ToList();
        if (branches.Count == 0) return pm.StepOrder.ToString();

        var maxFork = branches.Max();
        if (pm.BranchId == "main" && pm.StepOrder <= maxFork)
            return pm.StepOrder.ToString();

        if (pm.BranchId == "main")
        {
            var mainPostFork = Modules.Where(m => m.BranchId == "main" && m.StepOrder > maxFork)
                .OrderBy(m => m.StepOrder).ToList();
            var idx = mainPostFork.FindIndex(m => m.StepOrder == pm.StepOrder);
            return $"A{maxFork + 1 + idx}";
        }

        var branchIds = Modules.Where(m => m.BranchId != "main")
            .GroupBy(m => m.BranchId).Select(g => g.Key).OrderBy(b => b).ToList();
        var branchIdx = branchIds.IndexOf(pm.BranchId);
        var letter = (char)('B' + branchIdx);
        var forkStep = pm.BranchFromStep ?? maxFork;
        var branchSteps = Modules.Where(m => m.BranchId == pm.BranchId)
            .OrderBy(m => m.StepOrder).ToList();
        var bIdx = branchSteps.FindIndex(m => m.StepOrder == pm.StepOrder);
        return $"{letter}{forkStep + 1 + bIdx}";
    }

    private async Task HandleInputMappingChange(Guid moduleId, string? mapping)
