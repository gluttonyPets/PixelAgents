        if (string.IsNullOrWhiteSpace(module.Configuration)) return;

        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(module.Configuration);
            var root = doc.RootElement;

            if (root.TryGetProperty("systemPrompt", out var sp)) _editSystemPrompt = sp.GetString() ?? "";
            if (root.TryGetProperty("temperature", out var t)) _editTemperature = t.GetDouble();
            if (root.TryGetProperty("maxTokens", out var mt)) _editMaxTokens = mt.GetInt32();
            if (root.TryGetProperty("size", out var sz)) _editImageSize = sz.GetString() ?? "1024x1024";
            if (root.TryGetProperty("quality", out var q)) _editImageQuality = q.GetString() ?? "standard";
            if (root.TryGetProperty("voice", out var v)) _editTtsVoice = v.GetString() ?? "alloy";
            if (root.TryGetProperty("speed", out var spd)) _editTtsSpeed = spd.GetDouble();
            if (root.TryGetProperty("width", out var lw)) _editLeoWidth = lw.GetInt32();
            if (root.TryGetProperty("height", out var lh)) _editLeoHeight = lh.GetInt32();
            if (root.TryGetProperty("presetStyle", out var lps)) _editLeoPresetStyle = lps.GetString() ?? "DYNAMIC";
            if (root.TryGetProperty("aspectRatio", out var ar))
            {
                _editGeminiAspectRatio = ar.GetString() ?? "1:1";
                _editVideoAspectRatio = ar.GetString() ?? "16:9";
            }
            if (root.TryGetProperty("numberOfImages", out var ni)) _editGeminiImageCount = ni.GetInt32();
            if (root.TryGetProperty("n", out var grokN)) _editGrokImageCount = grokN.GetInt32();
            if (root.TryGetProperty("duration", out var vdur))
            {
                _editVideoDuration = vdur.GetString() ?? "8";
                _editSoraDuration = vdur.GetString() ?? "8";
            }
            if (root.TryGetProperty("resolution", out var vres)) _editVideoResolution = vres.GetString() ?? "720p";
            if (root.TryGetProperty("personGeneration", out var vpg)) _editVideoPersonGeneration = vpg.GetString() ?? "allow_adult";
            if (root.TryGetProperty("size", out var soraSize) && soraSize.GetString()?.Contains("x") == true)
                _editSoraSize = soraSize.GetString() ?? "1280x720";
            if (root.TryGetProperty("accessToken", out var cat)) _editCanvaAccessToken = cat.GetString() ?? "";
            if (root.TryGetProperty("exportFormat", out var cef)) _editCanvaExportFormat = cef.GetString() ?? "png";
            if (root.TryGetProperty("brandTemplateId", out var cbt)) _editCanvaBrandTemplate = cbt.GetString() ?? "";
            if (root.TryGetProperty("designType", out var cdt)) _editCanvaDesignType = cdt.GetString() ?? "doc";
            if (root.TryGetProperty("orientation", out var por)) _editPexelsOrientation = por.GetString() ?? "landscape";
            if (root.TryGetProperty("size", out var psz2) && psz2.GetString() is "large" or "medium" or "small") _editPexelsSize = psz2.GetString()!;
            if (root.TryGetProperty("preferredQuality", out var ppq)) _editPexelsQuality = ppq.GetString() ?? "hd";
            if (root.TryGetProperty("locale", out var ploc)) _editPexelsLocale = ploc.GetString() ?? "es-ES";
            if (root.TryGetProperty("minDuration", out var pmd)) _editPexelsMinDuration = pmd.GetInt32();
            if (root.TryGetProperty("maxDuration", out var pmxd)) _editPexelsMaxDuration = pmxd.GetInt32();
            if (root.TryGetProperty("perPage", out var ppp)) _editPexelsPerPage = ppp.GetInt32();
            if (root.TryGetProperty("useTemplate", out var j2vUt)) _editJ2vUseTemplate = j2vUt.ValueKind == System.Text.Json.JsonValueKind.True;
            if (root.TryGetProperty("templateVars", out var j2vTv) && j2vTv.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                _editJ2vTemplateVars = System.Text.Json.JsonSerializer.Deserialize<List<TemplateVariable>>(j2vTv.GetRawText()) ?? [];
            }
            if (root.TryGetProperty("resolution", out var j2vRes) && j2vRes.GetString() is "full-hd" or "hd" or "4k") _editJ2vResolution = j2vRes.GetString()!;
            if (root.TryGetProperty("enableVoice", out var j2vEv)) _editJ2vEnableVoice = j2vEv.ValueKind != System.Text.Json.JsonValueKind.False;
            if (root.TryGetProperty("enableSubtitles", out var j2vEs)) _editJ2vEnableSubtitles = j2vEs.ValueKind != System.Text.Json.JsonValueKind.False;
            if (root.TryGetProperty("voiceModel", out var j2vVm)) _editJ2vVoiceModel = j2vVm.GetString() ?? "azure";
            if (root.TryGetProperty("voiceName", out var j2vVn)) _editJ2vVoiceName = j2vVn.GetString() ?? "es-ES-AlvaroNeural";
            if (root.TryGetProperty("subtitleLanguage", out var j2vSl)) _editJ2vSubtitleLanguage = j2vSl.GetString() ?? "es";
            if (root.TryGetProperty("subtitleStyle", out var j2vSs)) _editJ2vSubtitleStyle = j2vSs.GetString() ?? "boxed";
