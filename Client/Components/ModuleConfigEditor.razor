        _editJ2vVoiceName = "es-ES-AlvaroNeural";
        _editJ2vSubtitleLanguage = "es";
        _editJ2vSubtitleStyle = "boxed";
        _editJ2vSubtitleFontSize = 120;
        _editJ2vSubtitleWordColor = "#FFFF00";
        _editJ2vImageDuration = 5.0;
        _editJ2vUseTemplate = false;
        _editJ2vTemplateVars = [];
