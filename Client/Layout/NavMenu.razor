@inject ApiClient Api
@inject AuthStateService AuthState
@implements IDisposable

<nav class="sidebar">
    <div class="sidebar-brand">PixelAgents</div>

    <NavLink href="/apikeys">API Keys</NavLink>
    <NavLink href="/redes-sociales">Redes sociales</NavLink>
    <NavLink href="/mensajeria">Mensajeria</NavLink>
    <NavLink href="/shopify">Shopify</NavLink>
    <NavLink href="/rules">Reglas</NavLink>
    <NavLink href="/modules">Modulos IA</NavLink>
    <NavLink href="/biblioteca">Biblioteca</NavLink>
    <NavLink href="/projects">Proyectos</NavLink>

    <div class="auth-status">
        @if (AuthState.IsAuthenticated)
        {
            <div>@AuthState.User!.Email</div>
            <button class="btn btn-sm btn-danger mt-1" @onclick="Logout">Cerrar sesión</button>
        }
        else
        {
            <button class="btn btn-sm btn-primary" @onclick="AuthState.RequireLogin">Iniciar sesión</button>
        }
        @if (_buildInfo is not null)
        {
            <div class="build-info">@_buildInfo.BuildDate | @_buildInfo.CommitHash</div>
        }
    </div>
</nav>

@code {
    private Client.Models.BuildInfoResponse? _buildInfo;

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnChange += StateHasChanged;
        if (!AuthState.IsAuthenticated)
        {
            try
            {
                var user = await Api.GetMeAsync();
                if (user is not null) AuthState.SetUser(user);
            }
            catch { }
        }
        try { _buildInfo = await Api.GetBuildInfoAsync(); } catch { }
    }

    private async Task Logout()
    {
        await Api.LogoutAsync();
        AuthState.SetUser(null);
    }

    public void Dispose()
    {
        AuthState.OnChange -= StateHasChanged;
    }
}
