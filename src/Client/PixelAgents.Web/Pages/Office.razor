@page "/"
@page "/office"
@inject ApiClient Api
@inject AgentHubService Hub

<PageTitle>PixelAgents - Office</PageTitle>

<div class="office-container">
    <div class="office-viewport">
        <OfficeScene Agents="@_officeState.Agents" AgentVisuals="@_officeState.AgentVisuals" />
    </div>

    <div class="office-sidebar">
        <div class="panel agent-panel">
            <h3 class="panel-title">Agents</h3>
            @foreach (var agent in _officeState.Agents)
            {
                var visual = _officeState.AgentVisuals.GetValueOrDefault(agent.Id);
                <AgentCard Agent="@agent" VisualState="@visual" />
            }
        </div>

        <div class="panel activity-panel">
            <h3 class="panel-title">Activity Log</h3>
            <ActivityLog Entries="@_officeState.ActivityLog" />
        </div>

        <div class="panel action-panel">
            <h3 class="panel-title">Quick Actions</h3>
            <div class="action-buttons">
                <button class="pixel-btn" @onclick="CreateNewProject">New Content Project</button>
                @if (_officeState.CurrentWorkspace is null)
                {
                    <button class="pixel-btn primary" @onclick="InitializeWorkspace">Create Workspace</button>
                }
            </div>
        </div>
    </div>
</div>

@if (_showNewProject)
{
    <NewProjectDialog OnClose="@(() => _showNewProject = false)"
                      OnCreate="@HandleCreateProject"
                      WorkspaceId="@(_officeState.CurrentWorkspace?.Id ?? Guid.Empty)" />
}

@code {
    private readonly OfficeState _officeState = new();
    private bool _showNewProject;

    protected override async Task OnInitializedAsync()
    {
        Hub.OnAgentStatusChanged += HandleAgentStatusChanged;
        Hub.OnPipelineProgress += HandlePipelineProgress;
        Hub.OnAgentMessage += HandleAgentMessage;

        _officeState.OnStateChanged += () => InvokeAsync(StateHasChanged);

        try
        {
            await Hub.StartAsync();
        }
        catch
        {
            _officeState.AddLog("System", "Could not connect to server. Working in offline mode.", "error");
        }
    }

    private async Task InitializeWorkspace()
    {
        var workspace = await Api.CreateWorkspaceAsync(
            new CreateWorkspaceRequest("Mi Oficina", "Oficina principal de creacion de contenido", "pixel-office"));

        if (workspace is not null)
        {
            _officeState.CurrentWorkspace = workspace;
            _officeState.Agents = workspace.Agents;

            foreach (var agent in workspace.Agents)
            {
                _officeState.AgentVisuals[agent.Id] = new AgentVisualState(agent.Id);
            }

            _officeState.AddLog("System", $"Workspace '{workspace.Name}' created with {workspace.Agents.Count} agents");
            await Hub.JoinWorkspaceAsync(workspace.Id.ToString());
            _officeState.NotifyStateChanged();
        }
    }

    private void CreateNewProject()
    {
        if (_officeState.CurrentWorkspace is null)
        {
            _officeState.AddLog("System", "Create a workspace first!", "error");
            return;
        }
        _showNewProject = true;
    }

    private async Task HandleCreateProject(CreateContentProjectRequest request)
    {
        _showNewProject = false;
        var project = await Api.CreateContentProjectAsync(request);
        if (project is not null)
        {
            _officeState.AddLog("System", $"Project created: {project.Topic}");

            var pipeline = await Api.ExecutePipelineAsync(
                new ExecutePipelineRequest(project.PipelineId, new Dictionary<string, object>
                {
                    ["topic"] = project.Topic
                }));

            if (pipeline is not null)
            {
                _officeState.ActivePipeline = pipeline;
                _officeState.AddLog("System", $"Pipeline started: {pipeline.Name}");
            }
        }
        _officeState.NotifyStateChanged();
    }

    private void HandleAgentStatusChanged(Guid agentId, string name, AgentStatusDto status, string? activity)
    {
        _officeState.UpdateAgentStatus(agentId, status, activity);
    }

    private void HandlePipelineProgress(Guid pipelineId, Guid stepId, string stepName, string status, double progress, string? message)
    {
        _officeState.AddLog("Pipeline", $"[{stepName}] {progress:F0}% - {message ?? status}",
            status == "Completed" ? "success" : "work");
        _officeState.NotifyStateChanged();
    }

    private void HandleAgentMessage(Guid agentId, string agentName, string message, string type)
    {
        _officeState.AddLog(agentName, message, type);
        _officeState.NotifyStateChanged();
    }
}
