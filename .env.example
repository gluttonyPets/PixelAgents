# PixelAgents - Ejemplo de configuración de variables de entorno
# Copia este archivo a .env y configura los valores según tu entorno

# ==================== CONFIGURACIÓN OBLIGATORIA ====================

# IP pública o dominio de tu servidor (SIN http:// ni puerto)
# Ejemplos:
#   - Si tienes IP pública: 123.45.67.89
#   - Si tienes dominio: midominio.com
# Esta variable es CRÍTICA para que Buffer pueda acceder a las imágenes
PUBLIC_IP=localhost

# ==================== CONFIGURACIÓN DE BASE DE DATOS ====================

# Contraseña de PostgreSQL (cambia esto en producción)
POSTGRES_PASSWORD=changeme_secure_password

# Puerto de PostgreSQL en el host (por defecto 5433)
PG_PORT=5433

# ==================== CONFIGURACIÓN DE APLICACIÓN ====================

# Puerto de la aplicación en el host (por defecto 8080)
APP_PORT=8080

# ==================== CONFIGURACIÓN DE LOGS (DOZZLE) ====================

# Puerto de Dozzle (visualizador de logs)
DOZZLE_PORT=9999

# Credenciales de Dozzle
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=changeme_logs_password
DOZZLE_KEY=changeme_session_key

# ==================== NOTAS IMPORTANTES ====================

# IMPORTANTE PARA BUFFER/PUBLICACIÓN EN REDES SOCIALES:
# Si vas a usar Buffer para publicar en Instagram/TikTok, DEBES configurar
# PUBLIC_IP con tu IP pública o dominio accesible desde internet.
# 
# Si dejas PUBLIC_IP=localhost, Buffer no podrá descargar las imágenes
# y las publicaciones fallarán.
#
# Cómo obtener tu IP pública:
#   curl ifconfig.me
#
# Si usas un dominio, asegúrate de que apunte a tu servidor y que el
# puerto APP_PORT esté abierto en tu firewall.
