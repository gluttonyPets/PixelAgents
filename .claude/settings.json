{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./tools/git_safe_commit_push.sh:*)",
      "Bash(bash ./tools/git_safe_commit_push.sh:*)",
      "Bash(./tools/leantime.sh:*)",
      "Bash(bash ./tools/leantime.sh:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git fetch:*)",
      "Bash(git remote -v)",
      "Bash(git remote get-url:*)",
      "Bash(git checkout -b feature/*)",
      "Bash(git checkout -b fix/*)",
      "Bash(git checkout -b hotfix/*)",
      "Bash(git switch -c feature/*)",
      "Bash(git switch -c fix/*)",
      "Bash(git switch -c hotfix/*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ]
  }
}
