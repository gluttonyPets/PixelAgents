{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "ConnectionStrings": {
    "Core": "Host=postgres;Port=5432;Database=pixelagents_core;Username=postgres;Password=${POSTGRES_PASSWORD}",
    "TenantTemplate": "Host=postgres;Port=5432;Database={db};Username=postgres;Password=${POSTGRES_PASSWORD}"
  }
}
